{
  "business_profile": {
    "type": "object",
    "required": [
      "id",
      "business_name",
      "category",
      "location",
      "source"
    ],
    "properties": {
      "id": {
        "type": "string",
        "description": "唯一标识符"
      },
      "business_name": {
        "type": "string"
      },
      "category": {
        "type": "string",
        "description": "如roofing, plumbing"
      },
      "phone": {
        "type": "string"
      },
      "email": {
        "type": [
          "string",
          "null"
        ]
      },
      "website_url": {
        "type": [
          "string",
          "null"
        ]
      },
      "location": {
        "type": "object",
        "properties": {
          "address": {
            "type": "string"
          },
          "suburb": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "postcode": {
            "type": "string"
          }
        }
      },
      "gbp_data": {
        "type": "object",
        "properties": {
          "claimed": {
            "type": "boolean"
          },
          "rating": {
            "type": "number",
            "minimum": 0,
            "maximum": 5
          },
          "review_count": {
            "type": "integer"
          },
          "image_count": {
            "type": "integer"
          },
          "has_hours": {
            "type": "boolean"
          },
          "has_description": {
            "type": "boolean"
          },
          "has_service_area": {
            "type": "boolean"
          },
          "reviews_replied_pct": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          }
        }
      },
      "source": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "scraped_at": {
            "type": "string",
            "format": "date-time"
          },
          "map_rank": {
            "type": [
              "integer",
              "null"
            ]
          }
        }
      },
      "status": {
        "type": "string",
        "enum": [
          "scraped",
          "enriched",
          "audited",
          "qualified",
          "demo_built",
          "proposal_ready",
          "contacted",
          "replied",
          "negotiating",
          "paid",
          "live",
          "archived"
        ]
      },
      "created_at": {
        "type": "string",
        "format": "date-time"
      },
      "updated_at": {
        "type": "string",
        "format": "date-time"
      }
    }
  },
  "audit_result": {
    "type": "object",
    "required": [
      "business_id",
      "audit_score",
      "decision"
    ],
    "properties": {
      "business_id": {
        "type": "string"
      },
      "audit_version": {
        "type": "string",
        "description": "评分规则版本"
      },
      "audited_at": {
        "type": "string",
        "format": "date-time"
      },
      "audit_score": {
        "type": "integer",
        "minimum": 0,
        "maximum": 100
      },
      "dimension_scores": {
        "type": "object",
        "properties": {
          "gbp": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "technical": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "ux_conversion": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "content": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "seo": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "visual": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          }
        }
      },
      "decision": {
        "type": "string",
        "enum": [
          "strong_redesign",
          "moderate_candidate",
          "low_priority",
          "not_qualified"
        ]
      },
      "qualification_reason": {
        "type": "string"
      },
      "hard_triggers": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "触发强制进入候选的条件，如no_website, mobile_broken"
      },
      "issues": {
        "type": "object",
        "properties": {
          "critical": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "issue": {
                  "type": "string"
                },
                "category": {
                  "type": "string"
                },
                "evidence": {
                  "type": "string"
                },
                "impact": {
                  "type": "string"
                }
              }
            }
          },
          "major": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "minor": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "competitors": {
        "type": "object",
        "properties": {
          "avg_score": {
            "type": "number"
          },
          "avg_review_count": {
            "type": "number"
          },
          "top_3_names": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "delta_summary": {
            "type": "string"
          }
        }
      },
      "evidence": {
        "type": "object",
        "properties": {
          "screenshots": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "url": {
                  "type": "string"
                },
                "type": {
                  "type": "string",
                  "enum": [
                    "desktop_home",
                    "mobile_home",
                    "desktop_services",
                    "mobile_services"
                  ]
                },
                "timestamp": {
                  "type": "string"
                }
              }
            }
          },
          "lighthouse_report": {
            "type": "object"
          },
          "technical_metrics": {
            "type": "object"
          }
        }
      },
      "recommended_solution": {
        "type": "string",
        "enum": [
          "full_redesign",
          "mobile_optimization",
          "conversion_optimization",
          "content_refresh"
        ]
      },
      "estimated_price_band": {
        "type": "string",
        "enum": [
          "budget",
          "standard",
          "premium"
        ]
      },
      "confidence_score": {
        "type": "number",
        "minimum": 0,
        "maximum": 100
      }
    }
  },
  "visual_audit": {
    "type": "object",
    "required": [
      "visual_freshness_score",
      "trust_score",
      "conversion_readiness_score"
    ],
    "properties": {
      "visual_freshness_score": {
        "type": "integer",
        "minimum": 1,
        "maximum": 10
      },
      "trust_score": {
        "type": "integer",
        "minimum": 1,
        "maximum": 10
      },
      "conversion_readiness_score": {
        "type": "integer",
        "minimum": 1,
        "maximum": 10
      },
      "design_age_estimate": {
        "type": "string",
        "enum": [
          "modern",
          "slightly_outdated",
          "outdated",
          "severely_outdated"
        ]
      },
      "issues": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "maxItems": 5
      },
      "evidence": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "基于截图的具体观察"
      },
      "client_safe_summary": {
        "type": "string",
        "maxLength": 200
      },
      "confidence": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "needs_human_review": {
        "type": "boolean"
      },
      "version": {
        "type": "string"
      }
    }
  },
  "sales_angle": {
    "type": "object",
    "required": [
      "primary_angle"
    ],
    "properties": {
      "primary_angle": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "conversion_loss",
              "mobile_gap",
              "trust_gap",
              "competitor_gap",
              "no_website",
              "speed_issue"
            ]
          },
          "headline": {
            "type": "string",
            "maxLength": 100
          },
          "talking_point": {
            "type": "string",
            "maxLength": 250
          }
        }
      },
      "secondary_angles": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string"
            },
            "headline": {
              "type": "string"
            }
          }
        },
        "maxItems": 3
      },
      "best_channel": {
        "type": "string",
        "enum": [
          "email",
          "sms",
          "phone",
          "direct_visit",
          "dm"
        ]
      },
      "urgency_factor": {
        "type": "string",
        "enum": [
          "high",
          "medium",
          "low"
        ]
      },
      "confidence": {
        "type": "number"
      },
      "version": {
        "type": "string"
      }
    }
  },
  "outreach_content": {
    "type": "object",
    "required": [
      "email_1"
    ],
    "properties": {
      "email_1": {
        "type": "object",
        "properties": {
          "subject": {
            "type": "string",
            "maxLength": 80
          },
          "body": {
            "type": "string",
            "maxLength": 600
          },
          "angle": {
            "type": "string"
          }
        }
      },
      "email_2": {
        "type": "object"
      },
      "email_3": {
        "type": "object"
      },
      "sms_1": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "maxLength": 160
          },
          "short_url": {
            "type": "string"
          }
        }
      },
      "phone_opening": {
        "type": "object",
        "properties": {
          "opening_line": {
            "type": "string",
            "maxLength": 150
          },
          "hook": {
            "type": "string"
          },
          "transition": {
            "type": "string"
          }
        }
      },
      "followups": {
        "type": "object",
        "properties": {
          "day_3": {
            "type": "object"
          },
          "day_7": {
            "type": "object"
          },
          "day_14": {
            "type": "object"
          }
        }
      },
      "dm_version": {
        "type": "object"
      },
      "objections": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "objection": {
              "type": "string"
            },
            "response": {
              "type": "string",
              "maxLength": 300
            }
          }
        }
      },
      "generated_at": {
        "type": "string",
        "format": "date-time"
      },
      "version": {
        "type": "string"
      }
    }
  },
  "proposal_page": {
    "type": "object",
    "required": [
      "business_id",
      "hero_title",
      "problem_section",
      "improvement_cards"
    ],
    "properties": {
      "business_id": {
        "type": "string"
      },
      "page_url": {
        "type": "string"
      },
      "hero_title": {
        "type": "string",
        "maxLength": 100
      },
      "hero_subtitle": {
        "type": "string",
        "maxLength": 200
      },
      "problem_section": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "icon": {
              "type": "string"
            }
          }
        },
        "maxItems": 3
      },
      "improvement_cards": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "metric": {
              "type": "string",
              "description": "如'速度提升75%'"
            }
          }
        },
        "maxItems": 3
      },
      "demo_url": {
        "type": "string"
      },
      "before_after": {
        "type": "object",
        "properties": {
          "before_screenshot": {
            "type": "string"
          },
          "after_screenshot": {
            "type": "string"
          },
          "comparison_type": {
            "type": "string",
            "enum": [
              "slider",
              "side_by_side"
            ]
          }
        }
      },
      "roi_section": {
        "type": "object",
        "properties": {
          "headline": {
            "type": "string"
          },
          "estimated_revenue_impact": {
            "type": "string"
          },
          "calculation_basis": {
            "type": "string"
          }
        }
      },
      "faq": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "question": {
              "type": "string"
            },
            "answer": {
              "type": "string"
            }
          }
        },
        "minItems": 5,
        "maxItems": 8
      },
      "cta_primary": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "stripe_payment",
              "contact_form",
              "calendar_booking"
            ]
          }
        }
      },
      "cta_secondary": {
        "type": "object"
      },
      "price": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          },
          "display_text": {
            "type": "string"
          },
          "guarantee": {
            "type": "string"
          }
        }
      },
      "generated_at": {
        "type": "string"
      },
      "version": {
        "type": "string"
      }
    }
  },
  "demo_site": {
    "type": "object",
    "required": [
      "business_id",
      "demo_url",
      "status"
    ],
    "properties": {
      "business_id": {
        "type": "string"
      },
      "demo_url": {
        "type": "string"
      },
      "template_used": {
        "type": "string"
      },
      "pages": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "页面列表，如['home', 'services', 'contact']"
      },
      "content_sources": {
        "type": "object",
        "properties": {
          "gbp": {
            "type": "boolean"
          },
          "original_website": {
            "type": "boolean"
          },
          "ai_generated": {
            "type": "boolean"
          }
        }
      },
      "deployment": {
        "type": "object",
        "properties": {
          "platform": {
            "type": "string"
          },
          "deployed_at": {
            "type": "string"
          },
          "build_time_seconds": {
            "type": "number"
          }
        }
      },
      "metrics": {
        "type": "object",
        "properties": {
          "lighthouse_performance": {
            "type": "number"
          },
          "lighthouse_accessibility": {
            "type": "number"
          },
          "load_time": {
            "type": "number"
          }
        }
      },
      "status": {
        "type": "string",
        "enum": [
          "building",
          "ready",
          "shown_to_client",
          "paid",
          "live",
          "archived"
        ]
      },
      "created_at": {
        "type": "string"
      },
      "expires_at": {
        "type": [
          "string",
          "null"
        ]
      }
    }
  },
  "internal_sales_report": {
    "type": "object",
    "required": [
      "business_id",
      "priority_level"
    ],
    "properties": {
      "business_id": {
        "type": "string"
      },
      "generated_at": {
        "type": "string"
      },
      "priority_level": {
        "type": "string",
        "enum": [
          "high",
          "medium",
          "low"
        ]
      },
      "qualification_summary": {
        "type": "string",
        "maxLength": 300
      },
      "why_worth_doing": {
        "type": "string"
      },
      "top_3_issues": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "minItems": 1,
        "maxItems": 3
      },
      "solutions_implemented": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "recommended_price": {
        "type": "object",
        "properties": {
          "base_price": {
            "type": "number"
          },
          "rationale": {
            "type": "string"
          },
          "discount_eligible": {
            "type": "boolean"
          }
        }
      },
      "outreach_strategy": {
        "type": "object",
        "properties": {
          "best_channel": {
            "type": "string"
          },
          "channel_sequence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "timing_recommendation": {
            "type": "string"
          }
        }
      },
      "win_probability": {
        "type": "number",
        "minimum": 0,
        "maximum": 100,
        "description": "主观成交概率"
      },
      "notes": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "note": {
              "type": "string"
            },
            "added_by": {
              "type": "string"
            },
            "added_at": {
              "type": "string"
            }
          }
        }
      },
      "version": {
        "type": "string"
      }
    }
  }
}