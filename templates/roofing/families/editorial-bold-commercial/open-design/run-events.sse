id: 407
event: agent
data: {"type":"text_delta","delta":"Built the template family with `index.html`, `outreach.html`, copied local image assets under `assets/`, and added `style-guide.md`. Final checks passed for required sections, local asset references, customer-facing copy, and prohibited internal terms.\n\n<artifact identifier=\"ridge-hammer-editorial-bold-commercial\" type=\"text/html\" title=\"Ridge & Hammer Roofing Editorial Bold Commercial Template\">\n<!doctype html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Ridge & Hammer Roofing · Commercial Roofing Template</title>\n  <style>\n    :root {\n      --bg: #F7F7F4;\n      --surface: #FFFFFF;\n      --fg: #050505;\n      --muted: #6D6D6D;\n      --border: #D8D8D2;\n      --accent: #F25A1D;\n      --sky: #DDEAF0;\n      --metal: #B8B9B4;\n      --on-primary: #FFFFFF;\n      --on-tertiary: #111111;\n\n      --accent-soft: color-mix(in oklch, var(--accent) 14%, transparent);\n      --fg-soft: color-mix(in oklch, var(--fg) 6%, transparent);\n      --black-soft: color-mix(in oklch, var(--fg) 86%, var(--muted));\n\n      --font-display: Inter, Arial, Helvetica, sans-serif;\n      --font-body: Inter, Arial, Helvetica, sans-serif;\n      --font-mono: ui-monospace, \"SF Mono\", Menlo, Consolas, monospace;\n\n      --fs-h1: clamp(72px, 12.4vw, 178px);\n      --fs-h2: clamp(42px, 7vw, 104px);\n      --fs-h3: clamp(22px, 2.1vw, 34px);\n      --fs-lead: clamp(18px, 1.7vw, 24px);\n      --fs-body: 16px;\n      --fs-meta: 12px;\n\n      --gap-md: 20px;\n      --gap-lg: 32px;\n      --gap-xl: 64px;\n      --gap-2xl: 104px;\n      --container: 1320px;\n      --gutter: clamp(18px, 3vw, 44px);\n      --radius: 8px;\n      --radius-lg: 16px;\n    }\n\n    *, *::before, *::after { box-sizing: border-box; }\n    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }\n    body {\n      margin: 0;\n      background: var(--bg);\n      color: var(--fg);\n      font-family: var(--font-body);\n      font-size: var(--fs-body);\n      line-height: 1.55;\n      text-rendering: optimizeLegibility;\n      -webkit-font-smoothing: antialiased;\n    }\n    img, svg { display: block; max-width: 100%; }\n    img { width: 100%; height: 100%; object-fit: cover; }\n    a { color: inherit; text-decoration: none; }\n    button, input, textarea { font: inherit; }\n    p { text-wrap: pretty; }\n    h1, h2, h3, h4 { text-wrap: balance; }\n\n    .container { max-width: var(--container); margin-inline: auto; padding-inline: var(--gutter); }\n    .section { padding-block: clamp(56px, 9vw, var(--gap-2xl)); }\n    .section + .section { border-top: 1px solid var(--border); }\n    .stack { display: flex; flex-direction: column; }\n    .stack > * + * { margin-top: var(--gap-md); }\n    .row { display: flex; align-items: center; gap: var(--gap-md); }\n    .row-between { display: flex; align-items: center; justify-content: space-between; gap: var(--gap-md); }\n    .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--gap-lg); }\n    .grid-2-1 { display: grid; grid-template-columns: minmax(0, 2fr) minmax(280px, 1fr); gap: var(--gap-xl); align-items: start; }\n    .grid-1-2 { display: grid; grid-template-columns: minmax(280px, 1fr) minmax(0, 2fr); gap: var(--gap-xl); align-items: start; }\n\n    h1, .h1 {\n      font-family: var(--font-display);\n      font-size: var(--fs-h1);\n      line-height: .82;\n      letter-spacing: 0;\n      margin: 0;\n      font-weight: 950;\n      text-transform: uppercase;\n    }\n    h2, .h2 {\n      font-family: var(--font-display);\n      font-size: var(--fs-h2);\n      line-height: .9;\n      letter-spacing: 0;\n      margin: 0;\n      font-weight: 920;\n      text-transform: uppercase;\n    }\n    h3, .h3 {\n      font-family: var(--font-display);\n      font-size: var(--fs-h3);\n      font-weight: 880;\n      line-height: 1;\n      letter-spacing: 0;\n      margin: 0;\n      text-transform: uppercase;\n    }\n    .lead { font-size: var(--fs-lead); line-height: 1.35; color: var(--muted); max-width: 48ch; margin: 0; }\n    .eyebrow {\n      font-family: var(--font-mono);\n      font-size: var(--fs-meta);\n      letter-spacing: .12em;\n      text-transform: uppercase;\n      color: var(--accent);\n      margin: 0 0 var(--gap-md);\n      font-weight: 800;\n    }\n    .num { font-family: var(--font-mono); font-variant-numeric: tabular-nums; }\n\n    .topnav {\n      position: sticky;\n      top: 0;\n      z-index: 20;\n      background: color-mix(in oklch, var(--fg) 92%, transparent);\n      color: var(--on-primary);\n      backdrop-filter: blur(12px);\n      border-bottom: 1px solid color-mix(in oklch, var(--surface) 16%, transparent);\n    }\n    .topnav-inner { display: flex; align-items: center; justify-content: space-between; gap: var(--gap-lg); padding-block: 14px; }\n    .brand { display: inline-flex; align-items: center; gap: 14px; min-width: max-content; }\n    .brand-mark { width: 180px; height: 48px; }\n    .brand-word { display: flex; flex-direction: column; line-height: .95; font-weight: 900; text-transform: uppercase; letter-spacing: 0; }\n    .topnav nav { display: flex; gap: clamp(16px, 2.2vw, 34px); }\n    .topnav nav a { font-size: 13px; color: color-mix(in oklch, var(--surface) 72%, transparent); font-weight: 800; text-transform: uppercase; letter-spacing: .06em; }\n    .topnav nav a:hover { color: var(--surface); }\n    .nav-cta { color: var(--accent); font-weight: 900; font-size: 14px; white-space: nowrap; }\n\n    .btn {\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n      gap: 9px;\n      min-height: 48px;\n      padding: 14px 20px;\n      border-radius: var(--radius);\n      border: 1px solid transparent;\n      font-size: 13px;\n      font-weight: 900;\n      letter-spacing: .08em;\n      text-transform: uppercase;\n      transition: transform .05s ease, background .15s ease, border-color .15s ease;\n    }\n    .btn:active { transform: translateY(1px); }\n    .btn-primary { background: var(--accent); color: var(--on-tertiary); border-color: var(--accent); }\n    .btn-primary:hover { background: color-mix(in oklch, var(--accent) 88%, var(--fg)); }\n    .btn-secondary { background: transparent; color: var(--fg); border-color: var(--fg); }\n    .btn-secondary:hover { background: var(--fg); color: var(--surface); }\n\n    .card-rule { background: transparent; border: 0; border-top: 1px solid var(--fg); padding: 24px 0 0; border-radius: 0; }\n    .stat .stat-num { font-family: var(--font-display); font-size: clamp(70px, 11vw, 168px); line-height: .78; letter-spacing: 0; color: var(--accent); font-weight: 950; }\n    .stat .stat-label { color: color-mix(in oklch, var(--surface) 70%, transparent); font-size: 15px; margin-top: 14px; max-width: 28ch; }\n    .pill { display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; background: var(--accent-soft); color: var(--accent); border-radius: 999px; font-family: var(--font-mono); font-size: 11px; letter-spacing: .06em; text-transform: uppercase; font-weight: 800; }\n\n    .field { display: flex; flex-direction: column; gap: 6px; }\n    .field label { font-size: 13px; color: var(--muted); font-weight: 800; text-transform: uppercase; letter-spacing: .06em; }\n    .input, .textarea { width: 100%; padding: 13px 14px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--surface); color: var(--fg); font: inherit; font-size: 15px; }\n    .input:focus, .textarea:focus { outline: 2px solid var(--accent-soft); border-color: var(--accent); }\n    .textarea { min-height: 112px; resize: vertical; line-height: 1.55; }\n\n    .ph-img { background: linear-gradient(135deg, var(--accent-soft), var(--fg-soft)), var(--surface); color: var(--muted); border: 1px solid var(--border); border-radius: var(--radius-lg); display: grid; place-items: center; min-height: 240px; font-family: var(--font-mono); font-size: 12px; letter-spacing: .06em; text-transform: uppercase; overflow: hidden; }\n    .portrait { aspect-ratio: 4 / 5; }\n    .wide { aspect-ratio: 16 / 9; }\n\n    .hero-poster {\n      min-height: calc(100svh - 77px);\n      display: grid;\n      grid-template-rows: auto 1fr auto;\n      background: var(--fg);\n      color: var(--surface);\n      overflow: hidden;\n    }\n    .hero-topline { padding-top: clamp(28px, 4vw, 54px); display: grid; grid-template-columns: 1fr auto; gap: var(--gap-lg); align-items: start; }\n    .hero-kicker { max-width: 30ch; color: color-mix(in oklch, var(--surface) 70%, transparent); margin: 0; font-size: 15px; }\n    .hero-title { position: relative; z-index: 2; max-width: 10ch; margin-top: clamp(28px, 5vw, 68px); }\n    .hero-title em { color: var(--accent); font-style: normal; }\n    .hero-media {\n      position: absolute;\n      inset: 90px var(--gutter) 30px auto;\n      width: min(64vw, 920px);\n      border-radius: var(--radius-lg);\n      overflow: hidden;\n      background: var(--metal);\n    }\n    .hero-media::after {\n      content: \"\";\n      position: absolute;\n      inset: 0;\n      background: linear-gradient(90deg, color-mix(in oklch, var(--fg) 78%, transparent), transparent 34%, transparent 78%, color-mix(in oklch, var(--fg) 38%, transparent));\n      pointer-events: none;\n    }\n    .hero-bottom { position: relative; z-index: 2; padding-bottom: clamp(24px, 4vw, 52px); display: grid; grid-template-columns: minmax(280px, 460px) auto; gap: var(--gap-lg); align-items: end; }\n    .hero-note { color: color-mix(in oklch, var(--surface) 72%, transparent); margin: 0; font-size: 18px; max-width: 36ch; }\n    .hero-actions { justify-self: end; display: flex; flex-wrap: wrap; gap: 12px; }\n    .hero-actions .btn-secondary { color: var(--surface); border-color: color-mix(in oklch, var(--surface) 55%, transparent); }\n    .hero-actions .btn-secondary:hover { background: var(--surface); color: var(--fg); }\n    .availability { position: absolute; right: var(--gutter); top: 24px; z-index: 3; background: var(--surface); color: var(--fg); border-radius: 999px; padding: 8px 13px; font-family: var(--font-mono); font-size: 11px; letter-spacing: .08em; text-transform: uppercase; font-weight: 800; }\n\n    .service-marquee { padding-block: 22px; background: var(--surface); border-block: 1px solid var(--fg); overflow: hidden; }\n    .marquee-track { display: flex; width: max-content; animation: marquee 26s linear infinite; }\n    .marquee-item { display: inline-flex; align-items: center; gap: 18px; margin-right: 18px; font-size: clamp(28px, 5vw, 70px); font-weight: 950; line-height: .9; text-transform: uppercase; white-space: nowrap; }\n    .marquee-item::after { content: \"\"; width: 18px; height: 18px; border-radius: 999px; background: var(--accent); }\n    @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }\n\n    .story-block { background: var(--fg); color: var(--surface); border-radius: var(--radius-lg); padding: clamp(28px, 5vw, 64px); display: grid; grid-template-columns: 1fr 1.1fr; gap: var(--gap-xl); overflow: hidden; }\n    .story-copy .lead { color: color-mix(in oklch, var(--surface) 74%, transparent); }\n    .story-photos { display: grid; grid-template-columns: 1fr 1fr; gap: var(--gap-md); align-items: end; }\n    .story-photos .portrait { min-height: 460px; }\n    .story-photos .wide { min-height: 260px; transform: translateY(32px); }\n    .proof-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap-lg); margin-top: var(--gap-xl); }\n\n    .service-row { display: grid; grid-template-columns: 90px 1.2fr 1fr auto; gap: var(--gap-lg); align-items: center; padding: 28px 0; border-top: 1px solid var(--border); }\n    .service-row:last-child { border-bottom: 1px solid var(--border); }\n    .service-row .num { font-size: 18px; color: var(--accent); font-weight: 900; }\n    .service-row p { margin: 0; color: var(--muted); max-width: 44ch; }\n    .arrow-disc { width: 42px; height: 42px; border-radius: 999px; border: 1px solid var(--fg); display: grid; place-items: center; font-weight: 900; }\n\n    .material-band { background: var(--sky); }\n    .material-card { display: grid; grid-template-columns: 1.2fr .8fr; gap: var(--gap-lg); align-items: stretch; }\n    .material-card .copy { background: var(--surface); border-radius: var(--radius-lg); border: 1px solid var(--border); padding: clamp(26px, 4vw, 48px); }\n    .material-card .image { min-height: 520px; border-radius: var(--radius-lg); overflow: hidden; }\n\n    .gallery { display: grid; grid-template-columns: 1.15fr .85fr; grid-template-rows: 320px 320px; gap: var(--gap-md); }\n    .gallery figure { margin: 0; position: relative; overflow: hidden; border-radius: var(--radius-lg); background: var(--metal); }\n    .gallery figure:first-child { grid-row: span 2; }\n    .gallery figcaption { position: absolute; left: 16px; bottom: 16px; right: 16px; background: color-mix(in oklch, var(--fg) 78%, transparent); color: var(--surface); border-radius: var(--radius); padding: 12px 14px; font-family: var(--font-mono); font-size: 11px; letter-spacing: .08em; text-transform: uppercase; }\n\n    .process-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; border: 1px solid var(--fg); }\n    .process-step { padding: 24px; min-height: 220px; border-right: 1px solid var(--fg); display: flex; flex-direction: column; justify-content: space-between; background: var(--surface); }\n    .process-step:last-child { border-right: 0; }\n    .process-step p { color: var(--muted); margin: 16px 0 0; }\n\n    .faq-list { border-top: 1px solid var(--border); }\n    details { border-bottom: 1px solid var(--border); padding: 24px 0; }\n    summary { cursor: pointer; font-family: var(--font-display); font-size: 24px; font-weight: 900; text-transform: uppercase; list-style: none; }\n    summary::-webkit-details-marker { display: none; }\n    details p { color: var(--muted); max-width: 68ch; margin: 14px 0 0; }\n\n    .contact-panel { background: var(--fg); color: var(--surface); border-radius: var(--radius-lg); padding: clamp(28px, 5vw, 64px); display: grid; grid-template-columns: 1fr 420px; gap: var(--gap-xl); }\n    .contact-panel .lead { color: color-mix(in oklch, var(--surface) 74%, transparent); }\n    .contact-form { background: var(--surface); color: var(--fg); border-radius: var(--radius-lg); padding: 24px; }\n    .contact-form .btn { width: 100%; }\n\n    .pagefoot { padding-block: var(--gap-xl); color: var(--muted); font-size: 13px; border-top: 1px solid var(--border); }\n    .pagefoot .row-between { flex-wrap: wrap; gap: var(--gap-md); }\n    .footer-links { display: flex; gap: 18px; flex-wrap: wrap; }\n\n    @media (max-width: 1060px) {\n      .topnav nav { display: none; }\n      .hero-media { position: relative; inset: auto; width: 100%; min-height: 420px; margin-top: 24px; }\n      .hero-poster { display: block; min-height: auto; }\n      .hero-title { max-width: 100%; }\n      .hero-bottom, .hero-topline, .story-block, .material-card, .contact-panel { grid-template-columns: 1fr; }\n      .hero-actions { justify-self: start; }\n      .proof-grid, .process-grid { grid-template-columns: 1fr 1fr; }\n      .process-step:nth-child(2) { border-right: 0; }\n      .process-step:nth-child(-n+2) { border-bottom: 1px solid var(--fg); }\n      .service-row { grid-template-columns: 58px 1fr auto; }\n      .service-row p { grid-column: 2 / -1; }\n      .story-photos .wide { transform: none; }\n    }\n    @media (max-width: 920px) {\n      .grid-2, .grid-2-1, .grid-1-2 { grid-template-columns: 1fr; }\n      .gallery { grid-template-columns: 1fr; grid-template-rows: auto; }\n      .gallery figure, .gallery figure:first-child { grid-row: auto; min-height: 300px; }\n    }\n    @media (max-width: 640px) {\n      :root { --fs-h1: clamp(58px, 19vw, 94px); --fs-h2: clamp(38px, 13vw, 62px); }\n      .brand-mark { width: 138px; }\n      .hero-topline { grid-template-columns: 1fr; }\n      .availability { display: none; }\n      .hero-media { min-height: 330px; }\n      .hero-bottom { padding-top: 24px; }\n      .proof-grid, .process-grid, .story-photos { grid-template-columns: 1fr; }\n      .process-step, .process-step:nth-child(2) { border-right: 0; border-bottom: 1px solid var(--fg); }\n      .process-step:last-child { border-bottom: 0; }\n      .service-row { grid-template-columns: 44px 1fr; }\n      .service-row .arrow-disc { grid-column: 2; justify-self: start; }\n      .hero-actions { width: 100%; }\n      .btn { width: 100%; }\n    }\n    @media (prefers-reduced-motion: reduce) {\n      *, *::before, *::after { animation-duration: .01ms !important; animation-iteration-count: 1 !important; scroll-behavior: auto !important; }\n    }\n  </style>\n</head>\n<body>\n  <header class=\"topnav\">\n    <div class=\"container topnav-inner\">\n      <a class=\"brand\" href=\"#top\" aria-label=\"Ridge & Hammer Roofing home\">\n        <svg class=\"brand-mark\" viewBox=\"0 0 180 48\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Ridge and Hammer Roofing\">\n          <path d=\"M8 27 30 9l22 18\" fill=\"none\" stroke=\"var(--muted)\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          <path d=\"M20 27h24v14H20z\" fill=\"var(--surface)\"/>\n          <text x=\"66\" y=\"32\" font-family=\"Inter, Arial, sans-serif\" font-size=\"24\" font-weight=\"800\" fill=\"var(--surface)\">RH</text>\n        </svg>\n        <span class=\"brand-word\"><span>Ridge & Hammer</span><span>Roofing</span></span>\n      </a>\n      <nav aria-label=\"Primary navigation\">\n        <a href=\"#services\">Services</a>\n        <a href=\"#proof\">Proof</a>\n        <a href=\"#projects\">Work</a>\n        <a href=\"#process\">Process</a>\n        <a href=\"#contact\">Contact</a>\n      </nav>\n      <a class=\"nav-cta\" href=\"tel:+15550101988\">(555) 010-1988</a>\n    </div>\n  </header>\n\n  <main id=\"top\">\n    <section class=\"hero-poster\" data-od-id=\"hero\">\n      <span class=\"availability\">Commercial roof crews · Request a walkthrough</span>\n      <div class=\"container hero-topline\">\n        <p class=\"eyebrow\">Ridge & Hammer Roofing · Metal, flat, and repair programs</p>\n        <p class=\"hero-kicker\">For property managers, facility teams, and owners who need the roof handled before it becomes the story.</p>\n      </div>\n      <div class=\"container\" style=\"position: relative;\">\n        <h1 class=\"hero-title\">Big roofs. Hard deadlines. <em>No drama.</em></h1>\n        <div class=\"hero-media wide\" aria-label=\"Roof worker standing on a wide commercial metal roof\">\n          <img src=\"assets/hero-worker-standing-metal-roof-wide.png\" alt=\"Roof worker standing on a wide metal roof with open sky\" />\n        </div>\n      </div>\n      <div class=\"container hero-bottom\">\n        <p class=\"hero-note\">Commercial-grade roof replacement, maintenance, and storm response presented with clear scopes, clean site coordination, and photo-backed updates.</p>\n        <div class=\"hero-actions\">\n          <a class=\"btn btn-primary\" href=\"#contact\">Book a roof walkthrough</a>\n          <a class=\"btn btn-secondary\" href=\"#projects\">See roof work</a>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"service-marquee\" data-od-id=\"services-marquee\" aria-label=\"Service categories\">\n      <div class=\"marquee-track\" aria-hidden=\"true\">\n        <span class=\"marquee-item\">Metal roof systems</span>\n        <span class=\"marquee-item\">Flat roof repair</span>\n        <span class=\"marquee-item\">Storm response</span>\n        <span class=\"marquee-item\">Gutter and drainage</span>\n        <span class=\"marquee-item\">Roof maintenance</span>\n        <span class=\"marquee-item\">Commercial inspections</span>\n        <span class=\"marquee-item\">Metal roof systems</span>\n        <span class=\"marquee-item\">Flat roof repair</span>\n        <span class=\"marquee-item\">Storm response</span>\n        <span class=\"marquee-item\">Gutter and drainage</span>\n        <span class=\"marquee-item\">Roof maintenance</span>\n        <span class=\"marquee-item\">Commercial inspections</span>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"proof\" data-od-id=\"proof-story\">\n      <div class=\"container\">\n        <div class=\"story-block\">\n          <div class=\"story-copy stack\">\n            <p class=\"eyebrow\">The roof is either managed or it manages you</p>\n            <h2>Built for buildings that cannot wait.</h2>\n            <p class=\"lead\">Every roof visit should end with fewer unknowns: what failed, what matters next, and which repair protects the building without turning into a guessing game.</p>\n            <div class=\"proof-grid\">\n              <div class=\"stat\">\n                <div class=\"stat-num num\">1</div>\n                <p class=\"stat-label\">clear priority list after the roof condition is documented.</p>\n              </div>\n              <div class=\"stat\">\n                <div class=\"stat-num num\">3</div>\n                <p class=\"stat-label\">decision-ready options: repair, maintain, or replace.</p>\n              </div>\n              <div class=\"stat\">\n                <div class=\"stat-num num\">0</div>\n                <p class=\"stat-label\">sales pressure in the walkthrough. Scope first, quote second.</p>\n              </div>\n            </div>\n          </div>\n          <div class=\"story-photos\">\n            <div class=\"ph-img portrait\">\n              <img src=\"assets/story-two-roofers-metal-roof-portrait.png\" alt=\"Two roofers working on a metal roof panel\" />\n            </div>\n            <div class=\"ph-img wide\">\n              <img src=\"assets/project-commercial-metal-roof-detail.png\" alt=\"Close detail of a commercial metal roof system\" />\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"services\" data-od-id=\"services\">\n      <div class=\"container stack\" style=\"gap: 56px;\">\n        <div class=\"grid-1-2\">\n          <p class=\"eyebrow\">Service list</p>\n          <h2>Roof work for real commercial schedules.</h2>\n        </div>\n        <div>\n          <article class=\"service-row\">\n            <span class=\"num\">01</span>\n            <h3>Commercial roof replacement</h3>\n            <p>Metal, flat, and low-slope replacement plans for retail, warehouse, office, and mixed-use buildings.</p>\n            <a class=\"arrow-disc\" href=\"#contact\" aria-label=\"Ask about commercial roof replacement\">-></a>\n          </article>\n          <article class=\"service-row\">\n            <span class=\"num\">02</span>\n            <h3>Leak tracing and repair</h3>\n            <p>Targeted roof repairs with photo documentation so managers can see the condition, not just the invoice.</p>\n            <a class=\"arrow-disc\" href=\"#contact\" aria-label=\"Ask about leak tracing and repair\">-></a>\n          </article>\n          <article class=\"service-row\">\n            <span class=\"num\">03</span>\n            <h3>Metal roof restoration</h3>\n            <p>Panel, seam, fastener, flashing, and coating recommendations for aging metal roof assemblies.</p>\n            <a class=\"arrow-disc\" href=\"#contact\" aria-label=\"Ask about metal roof restoration\">-></a>\n          </article>\n          <article class=\"service-row\">\n            <span class=\"num\">04</span>\n            <h3>Maintenance programs</h3>\n            <p>Seasonal inspection paths for drainage, penetrations, seams, edge details, and storm-prone areas.</p>\n            <a class=\"arrow-disc\" href=\"#contact\" aria-label=\"Ask about maintenance programs\">-></a>\n          </article>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section material-band\" data-od-id=\"materials-proof\">\n      <div class=\"container material-card\">\n        <div class=\"copy stack\">\n          <p class=\"eyebrow\">Material proof</p>\n          <h2>Show the roof. Explain the work.</h2>\n          <p class=\"lead\">The template is built around roof photos that carry the sale: metal seams, crew scale, drainage lines, and detail shots that make the contractor feel established before the form is touched.</p>\n          <div class=\"grid-2\">\n            <div class=\"card-rule\">\n              <h3>Photo-first scopes</h3>\n              <p style=\"color: var(--muted); margin-bottom: 0;\">Use image captions to turn each project into a quick proof point instead of a generic gallery.</p>\n            </div>\n            <div class=\"card-rule\">\n              <h3>Plain-English options</h3>\n              <p style=\"color: var(--muted); margin-bottom: 0;\">Separate emergency repair, planned maintenance, and replacement so visitors can self-select.</p>\n            </div>\n          </div>\n        </div>\n        <div class=\"image ph-img\">\n          <img src=\"assets/service-roofer-metal-roof-diagonal.png\" alt=\"Roofer working diagonally across a commercial metal roof\" />\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"projects\" data-od-id=\"projects-teaser\">\n      <div class=\"container stack\" style=\"gap: 46px;\">\n        <div class=\"row-between\">\n          <div style=\"max-width: 760px;\">\n            <p class=\"eyebrow\">Featured work</p>\n            <h2>Proof without the brochure voice.</h2>\n          </div>\n          <a class=\"btn btn-secondary\" href=\"#contact\">Discuss a similar roof</a>\n        </div>\n        <div class=\"gallery\">\n          <figure>\n            <img src=\"assets/project-commercial-metal-roof-detail.png\" alt=\"Commercial metal roof detail with clean panel seams\" />\n            <figcaption>Metal roof detail · seam and panel condition</figcaption>\n          </figure>\n          <figure>\n            <img src=\"assets/service-orange-accent-roof-work.png\" alt=\"Roof work with orange safety accent and commercial roof surface\" />\n            <figcaption>Active roof work · clean site movement</figcaption>\n          </figure>\n          <figure>\n            <img src=\"assets/service-roofer-metal-roof-diagonal.png\" alt=\"Roofer moving across diagonal metal roofing panels\" />\n            <figcaption>Service proof · diagonal roof plane</figcaption>\n          </figure>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"process\" data-od-id=\"process\">\n      <div class=\"container stack\" style=\"gap: 42px;\">\n        <div class=\"grid-2-1\">\n          <h2>From leak call to clear next step.</h2>\n          <p class=\"lead\">A direct path for customers who need a roof partner, not a mystery quote.</p>\n        </div>\n        <div class=\"process-grid\">\n          <div class=\"process-step\">\n            <span class=\"num\">01</span>\n            <div>\n              <h3>Walk the roof</h3>\n              <p>Inspect visible roof surfaces, drainage, penetrations, edge details, and leak clues.</p>\n            </div>\n          </div>\n          <div class=\"process-step\">\n            <span class=\"num\">02</span>\n            <div>\n              <h3>Document the findings</h3>\n              <p>Share plain-language notes and photos so the condition is easy to understand.</p>\n            </div>\n          </div>\n          <div class=\"process-step\">\n            <span class=\"num\">03</span>\n            <div>\n              <h3>Prioritize the scope</h3>\n              <p>Separate urgent repair items from maintenance and replacement planning.</p>\n            </div>\n          </div>\n          <div class=\"process-step\">\n            <span class=\"num\">04</span>\n            <div>\n              <h3>Schedule the work</h3>\n              <p>Coordinate access, staging, noise, and cleanup around how the building operates.</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" data-od-id=\"faq\">\n      <div class=\"container grid-1-2\">\n        <div>\n          <p class=\"eyebrow\">Questions</p>\n          <h2>Fast answers before the roof visit.</h2>\n        </div>\n        <div class=\"faq-list\">\n          <details open>\n            <summary>Do you handle active roof leaks?</summary>\n            <p>Yes. The contact path is set up for leak triage, temporary protection, and follow-up repair planning without promising an unverified emergency window.</p>\n          </details>\n          <details>\n            <summary>Can this template support residential work too?</summary>\n            <p>Yes. The layout leads with commercial authority but the service rows can include residential replacement, repairs, gutters, and storm damage support.</p>\n          </details>\n          <details>\n            <summary>What should we prepare before a walkthrough?</summary>\n            <p>Photos of the leak area, access notes, known roof age if available, and any maintenance history help the contractor start with context.</p>\n          </details>\n          <details>\n            <summary>Can we start without a full roof history?</summary>\n            <p>Yes. Photos, access notes, and the current concern are enough to begin. Any unknowns can be sorted during the walkthrough.</p>\n          </details>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"contact\" data-od-id=\"contact\">\n      <div class=\"container contact-panel\">\n        <div class=\"stack\">\n          <p class=\"eyebrow\">Book the walkthrough</p>\n          <h2>Send the roof. We'll send the next move.</h2>\n          <p class=\"lead\">Tell us what kind of building you manage, what is happening on the roof, and how soon someone needs to look at it.</p>\n          <div class=\"row\" style=\"flex-wrap: wrap;\">\n            <span class=\"pill\">Call (555) 010-1988</span>\n            <span class=\"pill\">Photos welcome</span>\n          </div>\n        </div>\n        <form class=\"contact-form stack\" action=\"#\" aria-label=\"Roof walkthrough request form\">\n          <div class=\"field\">\n            <label for=\"name\">Name</label>\n            <input class=\"input\" id=\"name\" name=\"name\" autocomplete=\"name\" placeholder=\"Your name\" />\n          </div>\n          <div class=\"field\">\n            <label for=\"phone\">Phone</label>\n            <input class=\"input\" id=\"phone\" name=\"phone\" autocomplete=\"tel\" placeholder=\"Best number\" />\n          </div>\n          <div class=\"field\">\n            <label for=\"roof\">What is happening?</label>\n            <textarea class=\"textarea\" id=\"roof\" name=\"roof\" placeholder=\"Leak, replacement planning, metal roof issue, storm damage...\"></textarea>\n          </div>\n          <button class=\"btn btn-primary\" type=\"submit\">Request a walkthrough</button>\n        </form>\n      </div>\n    </section>\n  </main>\n\n  <footer class=\"pagefoot\" data-od-id=\"footer\">\n    <div class=\"container row-between\">\n      <div>\n        <strong style=\"color: var(--fg); text-transform: uppercase;\">Ridge & Hammer Roofing</strong><br />\n        Commercial roofing, roof repair, metal roofing, and maintenance programs.\n      </div>\n      <div class=\"footer-links\">\n        <a href=\"#services\">Services</a>\n        <a href=\"#projects\">Work</a>\n        <a href=\"#contact\">Contact</a>\n        <a href=\"outreach.html\">Outreach page</a>\n      </div>\n    </div>\n  </footer>\n</body>\n</html>\n</artifact>"}

