data: {"type":"tool_result","toolUseId":"item_51","content":"outreach.html:115:    <section class=\"hero\" data-od-id=\"outreach-hero\">\noutreach.html:119:          <h1>Your roof needs a <span>clear next move.</span></h1>\noutreach.html:127:          <img src=\"assets/hero-worker-standing-metal-roof-wide.png\" alt=\"Commercial roof worker standing on metal roof with large sky\" />\noutreach.html:132:    <section class=\"strip\" data-od-id=\"outreach-proof-strip\">\noutreach.html:141:    <section class=\"section\" id=\"services\" data-od-id=\"outreach-services\">\noutreach.html:145:          <h2>The roof has moved from background to blocker.</h2>\noutreach.html:173:    <section class=\"section\" data-od-id=\"outreach-photo-proof\">\noutreach.html:176:          <img src=\"assets/service-roofer-metal-roof-diagonal.png\" alt=\"Roofer working across a diagonal commercial metal roof\" />\noutreach.html:180:          <h2>Less guessing from the ground.</h2>\noutreach.html:186:    <section class=\"section\" id=\"contact\" data-od-id=\"outreach-contact\">\noutreach.html:190:          <h2>Send the roof concern.</h2>\nindex.html:352:    <section class=\"hero-poster\" data-od-id=\"hero\">\nindex.html:359:        <h1 class=\"hero-title\">Big roofs. Hard deadlines. <em>No drama.</em></h1>\nindex.html:361:          <img src=\"assets/hero-worker-standing-metal-roof-wide.png\" alt=\"Roof worker standing on a wide metal roof with open sky\" />\nindex.html:373:    <section class=\"service-marquee\" data-od-id=\"services-marquee\" aria-label=\"Service categories\">\nindex.html:390:    <section class=\"section\" id=\"proof\" data-od-id=\"proof-story\">\nindex.html:395:            <h2>Built for buildings that cannot wait.</h2>\nindex.html:414:              <img src=\"assets/story-two-roofers-metal-roof-portrait.png\" alt=\"Two roofers working on a metal roof panel\" />\nindex.html:417:              <img src=\"assets/project-commercial-metal-roof-detail.png\" alt=\"Close detail of a commercial metal roof system\" />\nindex.html:424:    <section class=\"section\" id=\"services\" data-od-id=\"services\">\nindex.html:428:          <h2>Roof work for real commercial schedules.</h2>\nindex.html:459:    <section class=\"section material-band\" data-od-id=\"materials-proof\">\nindex.html:463:          <h2>Show the roof. Explain the work.</h2>\nindex.html:477:          <img src=\"assets/service-roofer-metal-roof-diagonal.png\" alt=\"Roofer working diagonally across a commercial metal roof\" />\nindex.html:482:    <section class=\"section\" id=\"projects\" data-od-id=\"projects-teaser\">\nindex.html:487:            <h2>Proof without the brochure voice.</h2>\nindex.html:493:            <img src=\"assets/project-commercial-metal-roof-detail.png\" alt=\"Commercial metal roof detail with clean panel seams\" />\nindex.html:497:            <img src=\"assets/service-orange-accent-roof-work.png\" alt=\"Roof work with orange safety accent and commercial roof surface\" />\nindex.html:501:            <img src=\"assets/service-roofer-metal-roof-diagonal.png\" alt=\"Roofer moving across diagonal metal roofing panels\" />\nindex.html:508:    <section class=\"section\" id=\"process\" data-od-id=\"process\">\nindex.html:511:          <h2>From leak call to clear next step.</h2>\nindex.html:547:    <section class=\"section\" data-od-id=\"faq\">\nindex.html:551:          <h2>Fast answers before the roof visit.</h2>\nindex.html:574:    <section class=\"section\" id=\"contact\" data-od-id=\"contact\">\nindex.html:578:          <h2>Send the roof. We'll send the next move.</h2>\nindex.html:604:  <footer class=\"pagefoot\" data-od-id=\"footer\">\n","isError":false}

