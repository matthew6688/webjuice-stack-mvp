data: {"type":"tool_result","toolUseId":"item_24","content":"64:    .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--gap-lg); }\n65:    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap-lg); }\n66:    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--gap-md); }\n67:    .grid-2-1 { display: grid; grid-template-columns: 2fr 1fr; gap: var(--gap-xl); align-items: start; }\n68:    .grid-1-2 { display: grid; grid-template-columns: 1fr 2fr; gap: var(--gap-xl); align-items: start; }\n164:    .hero-grid { display: grid; grid-template-columns: 0.88fr 1.12fr; min-height: min(760px, calc(100vh - 96px)); }\n178:      grid-template-columns: repeat(3, 1fr);\n190:      grid-template-columns: repeat(5, 1fr);\n223:    .service-wrap { display: grid; grid-template-columns: minmax(0, 1fr) minmax(320px, 0.72fr); gap: var(--gap-xl); align-items: stretch; }\n232:      grid-template-columns: 42px 1fr 24px;\n243:    .proof-card { display: grid; grid-template-columns: 1fr 1fr; gap: var(--gap-lg); align-items: center; overflow: hidden; padding: 0; }\n258:      grid-template-columns: 1.2fr 0.8fr;\n319:    .footer-grid { display: grid; grid-template-columns: 1.4fr repeat(3, 1fr); gap: var(--gap-lg); }\n334:      .hero-grid, .service-wrap, .proof-card, .project-teaser, .footer-grid { grid-template-columns: 1fr; }\n337:      .hero-stats, .logo-strip, .grid-2, .grid-3, .grid-4, .grid-2-1, .grid-1-2 { grid-template-columns: 1fr; }\n347:      .service-item summary { grid-template-columns: 34px 1fr 20px; }\n356:        <svg class=\"brand-mark\" viewBox=\"0 0 180 48\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Roofex demo logo\">\n588:            <p>Add them only when a real business provides verified details. The demo avoids claims that would need proof from a specific roofing company.</p>\n643:            <svg class=\"brand-mark\" viewBox=\"0 0 180 48\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Roofex demo logo\">\n","isError":false}

