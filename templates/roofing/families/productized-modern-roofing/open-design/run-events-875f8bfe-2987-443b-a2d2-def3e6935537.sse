id: 335
event: agent
data: {"type":"tool_result","toolUseId":"item_44","content":"<!doctype html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Roofex Roofing Systems · Modern Roofing Quotes and Materials</title>\n  <style>\n    :root {\n      --bg: #F3F4F6;\n      --surface: #FFFFFF;\n      --fg: #111827;\n      --muted: #64748B;\n      --border: #E5E7EB;\n      --accent: #2F6F5E;\n      --on-dark: #F9FAFB;\n      --accent-soft: color-mix(in oklch, var(--accent) 12%, transparent);\n      --fg-soft: color-mix(in oklch, var(--fg) 6%, transparent);\n      --font-display: \"Iowan Old Style\", \"Charter\", Georgia, serif;\n      --font-body: Inter, -apple-system, BlinkMacSystemFont, \"Segoe UI\", system-ui, sans-serif;\n      --font-mono: \"JetBrains Mono\", \"SF Mono\", ui-monospace, Menlo, monospace;\n      --fs-h1: clamp(50px, 7.2vw, 104px);\n      --fs-h2: clamp(32px, 4vw, 52px);\n      --fs-h3: 22px;\n      --fs-lead: 19px;\n      --fs-body: 16px;\n      --fs-meta: 12px;\n      --gap-xs: 8px;\n      --gap-sm: 12px;\n      --gap-md: 20px;\n      --gap-lg: 32px;\n      --gap-xl: 56px;\n      --gap-2xl: 96px;\n      --container: 1180px;\n      --gutter: 28px;\n      --radius: 8px;\n      --radius-lg: 16px;\n    }\n\n    *, *::before, *::after { box-sizing: border-box; }\n    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }\n    body {\n      margin: 0;\n      background: var(--bg);\n      color: var(--fg);\n      font-family: var(--font-body);\n      font-size: var(--fs-body);\n      line-height: 1.6;\n      text-rendering: optimizeLegibility;\n      -webkit-font-smoothing: antialiased;\n    }\n    img, svg { display: block; max-width: 100%; }\n    a { color: inherit; text-decoration: none; }\n    button, input, textarea, select { font: inherit; }\n    button { cursor: pointer; }\n    p { text-wrap: pretty; }\n    h1, h2, h3, h4 { text-wrap: balance; }\n\n    .container { max-width: var(--container); margin-inline: auto; padding-inline: var(--gutter); }\n    .section { padding-block: clamp(56px, 8vw, var(--gap-2xl)); }\n    .section + .section { border-top: 1px solid var(--border); }\n    .stack { display: flex; flex-direction: column; gap: var(--gap-md); }\n    .row { display: flex; align-items: center; gap: var(--gap-md); }\n    .row-between { display: flex; align-items: center; justify-content: space-between; gap: var(--gap-md); }\n    .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--gap-lg); }\n    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap-lg); }\n    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--gap-md); }\n    .grid-2-1 { display: grid; grid-template-columns: 2fr 1fr; gap: var(--gap-xl); align-items: start; }\n    .grid-1-2 { display: grid; grid-template-columns: 1fr 2fr; gap: var(--gap-xl); align-items: start; }\n\n    .h1, h1 {\n      font-family: var(--font-display);\n      font-size: var(--fs-h1);\n      line-height: 1;\n      letter-spacing: 0;\n      margin: 0;\n      font-weight: 700;\n    }\n    .h2, h2 {\n      font-family: var(--font-display);\n      font-size: var(--fs-h2);\n      line-height: 1.08;\n      letter-spacing: 0;\n      margin: 0;\n      font-weight: 700;\n    }\n    .h3, h3 {\n      font-family: var(--font-display);\n      font-size: var(--fs-h3);\n      font-weight: 700;\n      line-height: 1.25;\n      margin: 0;\n    }\n    .lead { font-size: var(--fs-lead); line-height: 1.55; color: var(--muted); max-width: 62ch; margin: 0; }\n    .eyebrow {\n      font-family: var(--font-mono);\n      font-size: var(--fs-meta);\n      letter-spacing: 0.08em;\n      text-transform: uppercase;\n      color: var(--accent);\n      font-weight: 700;\n      margin: 0 0 var(--gap-md);\n    }\n    .meta { font-family: var(--font-mono); font-size: var(--fs-meta); color: var(--muted); letter-spacing: 0.03em; }\n    .num { font-family: var(--font-mono); font-variant-numeric: tabular-nums; }\n\n    .topnav {\n      position: sticky;\n      top: 0;\n      z-index: 20;\n      background: color-mix(in oklch, var(--surface) 90%, transparent);\n      backdrop-filter: blur(16px);\n      border-bottom: 1px solid var(--border);\n    }\n    .topnav-inner { display: flex; align-items: center; justify-content: space-between; padding-block: 14px; }\n    .brand { display: inline-flex; align-items: center; gap: 12px; font-weight: 800; letter-spacing: -0.02em; }\n    .brand-mark { width: 45px; height: 32px; color: var(--muted); }\n    .brand-word { font-size: 16px; }\n    .topnav nav { display: flex; gap: var(--gap-lg); }\n    .topnav nav a { font-size: 14px; color: var(--muted); }\n    .topnav nav a:hover { color: var(--fg); }\n    .nav-actions { display: flex; align-items: center; gap: var(--gap-sm); }\n\n    .btn {\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n      gap: 8px;\n      min-height: 44px;\n      padding: 12px 18px;\n      border-radius: var(--radius);\n      border: 1px solid transparent;\n      font-family: var(--font-display);\n      font-size: 13px;\n      font-weight: 800;\n      letter-spacing: 0.04em;\n      text-transform: uppercase;\n      transition: transform 0.08s ease, background 0.18s ease, border-color 0.18s ease;\n    }\n    .btn:active { transform: translateY(1px); }\n    .btn-primary { background: var(--accent); color: var(--on-dark); border-color: var(--accent); }\n    .btn-primary:hover { background: color-mix(in oklch, var(--accent) 86%, var(--fg)); }\n    .btn-secondary { background: var(--surface); color: var(--fg); border-color: var(--border); }\n    .btn-secondary:hover { border-color: var(--fg); }\n    .btn-ghost { background: transparent; color: var(--fg); border-color: transparent; padding-inline: 8px; }\n    .btn-ghost:hover { color: var(--accent); }\n    .btn-arrow::after { content: \"→\"; transition: transform 0.15s ease; }\n    .btn-arrow:hover::after { transform: translateX(2px); }\n\n    .card {\n      background: var(--surface);\n      border: 1px solid var(--border);\n      border-radius: var(--radius-lg);\n      padding: 28px;\n    }\n    .surface-dark { background: var(--fg); color: var(--on-dark); border-color: color-mix(in oklch, var(--fg) 70%, var(--surface)); }\n    .surface-dark .lead, .surface-dark .meta { color: color-mix(in oklch, var(--on-dark) 72%, transparent); }\n    .hero-panel {\n      position: relative;\n      min-height: min(820px, calc(100vh - 76px));\n      border-radius: 0;\n      background: var(--fg);\n      color: var(--on-dark);\n      overflow: hidden;\n      border: 1px solid color-mix(in oklch, var(--fg) 78%, var(--surface));\n      isolation: isolate;\n    }\n    .hero-panel::before {\n      content: \"\";\n      position: absolute;\n      inset: 0;\n      z-index: -1;\n      background:\n        linear-gradient(90deg, color-mix(in oklch, var(--fg) 92%, transparent) 0%, color-mix(in oklch, var(--fg) 66%, transparent) 42%, color-mix(in oklch, var(--fg) 10%, transparent) 100%),\n        linear-gradient(0deg, color-mix(in oklch, var(--fg) 84%, transparent) 0%, color-mix(in oklch, var(--fg) 30%, transparent) 44%, color-mix(in oklch, var(--fg) 8%, transparent) 100%);\n    }\n    .hero-panel::after {\n      content: \"\";\n      position: absolute;\n      inset: 18px;\n      z-index: -1;\n      border: 1px solid color-mix(in oklch, var(--on-dark) 22%, transparent);\n      pointer-events: none;\n    }\n    .hero-grid { display: grid; min-height: inherit; }\n    .hero-media { position: absolute; inset: 0; z-index: -2; }\n    .hero-media img, .image-fill img { width: 100%; height: 100%; object-fit: cover; }\n    .hero-media img { object-position: center 58%; filter: saturate(1.06) contrast(1.04); transform: scale(1.02); }\n    .hero-copy {\n      min-height: inherit;\n      padding: clamp(34px, 5.6vw, 82px);\n      display: grid;\n      grid-template-rows: auto 1fr auto;\n      gap: var(--gap-lg);\n    }\n    .hero-kicker-row {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      flex-wrap: wrap;\n      gap: var(--gap-md);\n      color: color-mix(in oklch, var(--on-dark) 72%, transparent);\n    }\n    .hero-kicker-row .meta { color: color-mix(in oklch, var(--on-dark) 68%, transparent); }\n    .hero-content { align-self: center; max-width: 860px; }\n    .hero-content h1 {\n      max-width: 10.5ch;\n      text-shadow: 0 2px 28px color-mix(in oklch, var(--fg) 64%, transparent);\n    }\n    .hero-copy .lead { color: color-mix(in oklch, var(--on-dark) 80%, transparent); max-width: 48ch; }\n    .hero-cta { display: flex; flex-wrap: wrap; gap: var(--gap-sm); margin-top: 30px; }\n    .hero-cta .btn-secondary {\n      background: color-mix(in oklch, var(--surface) 12%, transparent);\n      color: var(--on-dark);\n      border-color: color-mix(in oklch, var(--on-dark) 24%, transparent);\n      backdrop-filter: blur(14px);\n    }\n    .hero-dock {\n      display: grid;\n      grid-template-columns: 1.05fr repeat(3, 1fr);\n      gap: 1px;\n      background: color-mix(in oklch, var(--on-dark) 18%, transparent);\n      border: 1px solid color-mix(in oklch, var(--on-dark) 18%, transparent);\n      border-radius: 0;\n      overflow: hidden;\n      backdrop-filter: blur(18px);\n    }\n    .hero-dock-intro, .hero-stat {\n      background: color-mix(in oklch, var(--fg) 50%, transparent);\n      padding: 16px;\n    }\n    .hero-dock-intro strong, .hero-stat strong { display: block; font-size: 13px; margin-bottom: 5px; }\n    .hero-dock-intro span, .hero-stat span { display: block; color: color-mix(in oklch, var(--on-dark) 64%, transparent); font-size: 12px; }\n    .hero-proof-card {\n      position: absolute;\n      right: clamp(34px, 5vw, 78px);\n      top: clamp(112px, 15vh, 178px);\n      z-index: 2;\n      width: min(280px, 24vw);\n      padding: 18px;\n      color: var(--on-dark);\n      background: color-mix(in oklch, var(--fg) 46%, transparent);\n      border: 1px solid color-mix(in oklch, var(--on-dark) 22%, transparent);\n      backdrop-filter: blur(18px);\n    }\n    .hero-proof-card img {\n      width: 100%;\n      aspect-ratio: 16 / 10;\n      object-fit: cover;\n      margin-bottom: 14px;\n      border: 1px solid color-mix(in oklch, var(--on-dark) 16%, transparent);\n    }\n    .hero-proof-card strong { display: block; font-family: var(--font-display); font-size: 21px; line-height: 1.1; margin-bottom: 8px; }\n    .hero-proof-card span { display: block; color: color-mix(in oklch, var(--on-dark) 70%, transparent); font-size: 13px; line-height: 1.45; }\n\n    .logo-strip {\n      display: grid;\n      grid-template-columns: repeat(5, 1fr);\n      gap: 1px;\n      background: var(--border);\n      border: 1px solid var(--border);\n      border-radius: var(--radius-lg);\n      overflow: hidden;\n    }\n    .logo-strip span {\n      background: var(--surface);\n      min-height: 74px;\n      display: grid;\n      place-items: center;\n      color: var(--muted);\n      font-family: var(--font-mono);\n      font-size: 12px;\n      text-transform: uppercase;\n      letter-spacing: 0.08em;\n    }\n\n    .material-card { padding: 0; overflow: hidden; }\n    .material-card img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; }\n    .material-card .card-body { padding: 24px; }\n    .material-card ul, .service-list, .check-list { list-style: none; padding: 0; margin: 18px 0 0; }\n    .material-card li, .check-list li {\n      display: flex;\n      gap: 10px;\n      padding-block: 7px;\n      color: var(--muted);\n      border-top: 1px solid var(--border);\n      font-size: 14px;\n    }\n    .material-card li::before, .check-list li::before { content: \"—\"; color: var(--fg); }\n\n    .service-wrap { display: grid; grid-template-columns: minmax(0, 1fr) minmax(320px, 0.72fr); gap: var(--gap-xl); align-items: stretch; }\n    .image-fill { min-height: 540px; border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--border); background: var(--surface); }\n    .service-item {\n      border-top: 1px solid var(--border);\n      padding: 22px 0;\n    }\n    .service-item summary {\n      list-style: none;\n      display: grid;\n      grid-template-columns: 42px 1fr 24px;\n      align-items: center;\n      gap: var(--gap-md);\n      cursor: pointer;\n    }\n    .service-item summary::-webkit-details-marker { display: none; }\n    .service-item summary::after { content: \"+\"; justify-self: end; color: var(--muted); font-size: 24px; line-height: 1; }\n    .service-item[open] summary::after { content: \"−\"; color: var(--fg); }\n    .service-item p { color: var(--muted); margin: 14px 0 0 62px; max-width: 58ch; }\n    .service-index { color: var(--muted); font-family: var(--font-mono); }\n\n    .proof-card { display: grid; grid-template-columns: 1fr 1fr; gap: var(--gap-lg); align-items: center; overflow: hidden; padding: 0; }\n    .proof-card img { width: 100%; height: 100%; min-height: 360px; object-fit: cover; }\n    .proof-copy { padding: clamp(28px, 5vw, 54px); }\n    .process-grid { counter-reset: step; }\n    .process-card { min-height: 230px; display: flex; flex-direction: column; justify-content: space-between; }\n    .process-card::before {\n      counter-increment: step;\n      content: counter(step, decimal-leading-zero);\n      font-family: var(--font-mono);\n      color: var(--muted);\n      font-size: 13px;\n    }\n\n    .project-teaser {\n      display: grid;\n      grid-template-columns: 1.2fr 0.8fr;\n      gap: var(--gap-lg);\n      align-items: end;\n      border-radius: var(--radius-lg);\n      border: 1px solid var(--border);\n      background: var(--surface);\n      padding: clamp(28px, 5vw, 52px);\n    }\n    .swatch-row { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 26px; }\n    .swatch { width: 68px; height: 68px; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; background: var(--bg); }\n    .swatch img { width: 100%; height: 100%; object-fit: cover; }\n\n    .faq-list { max-width: 860px; margin-inline: auto; }\n    .faq-item { border-top: 1px solid var(--border); padding: 24px 0; }\n    .faq-item summary {\n      list-style: none;\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      gap: var(--gap-md);\n      cursor: pointer;\n      font-family: var(--font-display);\n      font-weight: 720;\n      font-size: 20px;\n    }\n    .faq-item summary::-webkit-details-marker { display: none; }\n    .faq-item summary::after { content: \"+\"; color: var(--muted); font-size: 24px; }\n    .faq-item[open] summary::after { content: \"−\"; color: var(--fg); }\n    .faq-item p { color: var(--muted); max-width: 70ch; margin: 14px 0 0; }\n\n    .quote-cta {\n      position: relative;\n      overflow: hidden;\n      border-radius: var(--radius-lg);\n      min-height: 430px;\n      display: grid;\n      align-items: end;\n      color: var(--on-dark);\n      background: var(--fg);\n    }\n    .quote-cta img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.58; }\n    .quote-cta::after { content: \"\"; position: absolute; inset: 0; background: linear-gradient(90deg, var(--fg), transparent); }\n    .quote-cta-content { position: relative; z-index: 1; max-width: 640px; padding: clamp(28px, 5vw, 60px); }\n    .quote-cta .lead { color: color-mix(in oklch, var(--on-dark) 78%, transparent); }\n\n    .contact-form { display: grid; gap: var(--gap-sm); margin-top: 26px; }\n    .field { display: flex; flex-direction: column; gap: 6px; }\n    .field label { font-size: 13px; color: var(--muted); }\n    .input, .textarea {\n      width: 100%;\n      padding: 12px 14px;\n      border: 1px solid var(--border);\n      border-radius: var(--radius);\n      background: var(--surface);\n      color: var(--fg);\n      min-height: 44px;\n    }\n    .textarea { min-height: 108px; resize: vertical; line-height: 1.55; }\n    .input:focus, .textarea:focus { outline: 2px solid var(--accent-soft); border-color: var(--accent); }\n\n    .pagefoot { padding-block: var(--gap-xl); background: var(--surface); border-top: 1px solid var(--border); }\n    .footer-grid { display: grid; grid-template-columns: 1.4fr repeat(3, 1fr); gap: var(--gap-lg); }\n    .footer-grid a, .footer-grid p { color: var(--muted); font-size: 14px; margin: 0; }\n    .footer-grid a:hover { color: var(--fg); }\n    .footer-wordmark {\n      margin-top: var(--gap-xl);\n      font-family: var(--font-display);\n      font-size: clamp(54px, 12vw, 170px);\n      line-height: 0.86;\n      font-weight: 850;\n      letter-spacing: -0.04em;\n      color: color-mix(in oklch, var(--fg) 10%, transparent);\n    }\n\n    @media (max-width: 980px) {\n      .topnav nav { display: none; }\n      .hero-grid, .service-wrap, .proof-card, .project-teaser, .footer-grid { grid-template-columns: 1fr; }\n      .hero-panel, .hero-grid { min-height: 760px; }\n      .hero-panel::before { background: linear-gradient(0deg, color-mix(in oklch, var(--fg) 90%, transparent) 0%, color-mix(in oklch, var(--fg) 58%, transparent) 58%, color-mix(in oklch, var(--fg) 12%, transparent) 100%); }\n      .hero-panel::after { inset: 12px; }\n      .hero-media { position: absolute; min-height: 100%; order: initial; z-index: -2; }\n      .hero-media img { object-position: 62% center; }\n      .hero-copy { min-height: inherit; }\n      .hero-proof-card { position: relative; inset: auto; width: 100%; margin-top: 20px; }\n      .hero-proof-card img { display: none; }\n      .hero-dock, .logo-strip, .grid-2, .grid-3, .grid-4, .grid-2-1, .grid-1-2 { grid-template-columns: 1fr; }\n      .image-fill { min-height: 360px; }\n    }\n    @media (max-width: 620px) {\n      :root { --gutter: 18px; }\n      .nav-actions .btn-secondary { display: none; }\n      .brand-word { max-width: 145px; line-height: 1.1; }\n      .hero-copy { padding: 26px; }\n      .hero-content h1 { max-width: 9.6ch; }\n      .hero-panel, .hero-grid { min-height: 820px; }\n      .hero-cta, .row-between { align-items: stretch; flex-direction: column; }\n      .btn { width: 100%; }\n      .service-item summary { grid-template-columns: 34px 1fr 20px; }\n      .service-item p { margin-left: 0; }\n    }\n  </style>\n</head>\n<body>\n  <header class=\"topnav\">\n    <div class=\"container topnav-inner\">\n      <a class=\"brand\" href=\"#top\" aria-label=\"Roofex Roofing Systems home\">\n        <svg class=\"brand-mark\" viewBox=\"0 0 180 48\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Roofex logo\">\n          <path d=\"M8 27 30 9l22 18\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          <path d=\"M20 27h24v14H20z\" fill=\"var(--fg)\"/>\n          <text x=\"66\" y=\"32\" font-family=\"Inter, Arial, sans-serif\" font-size=\"24\" font-weight=\"800\" fill=\"var(--fg)\">RR</text>\n        </svg>\n        <span class=\"brand-word\">Roofex Roofing Systems</span>\n      </a>\n      <nav aria-label=\"Primary navigation\">\n        <a href=\"#materials\">Materials</a>\n        <a href=\"#services\">Services</a>\n        <a href=\"#process\">Process</a>\n        <a href=\"#faq\">FAQ</a>\n      </nav>\n      <div class=\"nav-actions\">\n        <a class=\"btn btn-secondary\" href=\"#faq\">Questions</a>\n        <a class=\"btn btn-primary\" href=\"#contact\">Request Quote</a>\n      </div>\n    </div>\n  </header>\n\n  <main id=\"top\">\n    <section class=\"section\" data-od-id=\"hero\">\n      <div class=\"container\">\n        <div class=\"hero-panel hero-grid\">\n          <div class=\"hero-media\">\n            <img src=\"assets/hero-modern-metal-roof-sunset-wide.png\" alt=\"Modern metal roof at sunset on a clean residential property\" />\n          </div>\n          <div class=\"hero-copy\">\n            <div class=\"hero-kicker-row\">\n              <p class=\"eyebrow\">Premium roofing systems · material-led quotes</p>\n              <p class=\"meta\">Roofex Roofing Systems</p>\n            </div>\n            <aside class=\"hero-proof-card\" aria-label=\"Inspection and material proof\">\n              <img src=\"assets/inspection-drone-roof-check.png\" alt=\"Drone inspection view documenting a roof before quote planning\" />\n              <strong>Inspection before proposal.</strong>\n              <span>Material recommendations begin with roof condition, access, ventilation, flashing, and visible surface notes.</span>\n            </aside>\n            <div class=\"hero-content\">\n              <h1>A better roof should look settled from the street.</h1>\n              <p class=\"lead\" style=\"margin-top: 22px;\">Roofex Roofing Systems helps homeowners and property teams choose modern roof materials, understand the inspection step, and request a clear quote conversation.</p>\n              <div class=\"hero-cta\">\n                <a class=\"btn btn-primary\" href=\"#contact\">Request a Roof Quote</a>\n                <a class=\"btn btn-secondary\" href=\"#materials\">Compare Materials</a>\n              </div>\n            </div>\n            <div class=\"hero-dock\" aria-label=\"Service highlights\">\n              <div class=\"hero-dock-intro\">\n                <strong>Modern metal roof shown</strong>\n                <span>A sunset roof profile sets the expectation for a cleaner exterior.</span>\n              </div>\n              <div class=\"hero-stat\">\n                <strong>Standing seam metal</strong>\n                <span>Clean architectural lines for modern homes.</span>\n              </div>\n              <div class=\"hero-stat\">\n                <strong>Tile and composite</strong>\n                <span>Material paths stay easy to compare before the call.</span>\n              </div>\n              <div class=\"hero-stat\">\n                <strong>Inspection led</strong>\n                <span>Quote requests start with real roof details.</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" data-od-id=\"proof\">\n      <div class=\"container stack\" style=\"gap: 34px;\">\n        <p class=\"eyebrow\">Built for clear roofing decisions</p>\n        <div class=\"logo-strip\" aria-label=\"Template trust strip\">\n          <span>Residential</span>\n          <span>Commercial</span>\n          <span>Inspection</span>\n          <span>Replacement</span>\n          <span>Maintenance</span>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"materials\" data-od-id=\"materials\">\n      <div class=\"container stack\" style=\"gap: 48px;\">\n        <div class=\"row-between\">\n          <div style=\"max-width: 620px;\">\n            <p class=\"eyebrow\">Material systems</p>\n            <h2>Present roof choices like products, not guesswork.</h2>\n          </div>\n          <p class=\"lead\">Each card gives the visitor a practical comparison point without using prices, brands, or unsupported claims.</p>\n        </div>\n        <div class=\"grid-3\">\n          <article class=\"card material-card\">\n            <img src=\"assets/product-standing-seam-metal-sample.png\" alt=\"Standing seam metal roof material sample\" />\n            <div class=\"card-body\">\n              <p class=\"meta\">Material option</p>\n              <h3>Standing seam metal</h3>\n              <ul>\n                <li>Clean lines for modern homes and additions</li>\n                <li>Good fit for simple, architectural roof planes</li>\n                <li>Shown with inspection and ventilation notes</li>\n              </ul>\n            </div>\n          </article>\n          <article class=\"card material-card\">\n            <img src=\"assets/product-terracotta-tile-sample.png\" alt=\"Terracotta roof tile material sample\" />\n            <div class=\"card-body\">\n              <p class=\"meta\">Material option</p>\n              <h3>Terracotta tile</h3>\n              <ul>\n                <li>Warm profile for Mediterranean-style properties</li>\n                <li>Useful for restoration and curb appeal conversations</li>\n                <li>Presented with underlayment and flashing checks</li>\n              </ul>\n            </div>\n          </article>\n          <article class=\"card material-card\">\n            <img src=\"assets/product-composite-shingle-sample.png\" alt=\"Composite roof shingle material sample\" />\n            <div class=\"card-body\">\n              <p class=\"meta\">Material option</p>\n              <h3>Composite shingle</h3>\n              <ul>\n                <li>Familiar look for replacement and repair packages</li>\n                <li>Works well for straightforward comparison pages</li>\n                <li>Pairs with maintenance and storm-readiness content</li>\n              </ul>\n            </div>\n          </article>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"services\" data-od-id=\"services\">\n      <div class=\"container service-wrap\">\n        <div>\n          <p class=\"eyebrow\">Services</p>\n          <h2>One calm list for every roof conversation.</h2>\n          <p class=\"lead\" style=\"margin-top: 18px;\">The accordion keeps the page compact while letting visitors understand what happens during each service.</p>\n          <div class=\"service-list\" role=\"list\">\n            <details class=\"service-item\" open>\n              <summary><span class=\"service-index\">01</span><h3>Roof replacement planning</h3></summary>\n              <p>Help homeowners compare material paths, understand installation scope, and request a quote without sorting through a long brochure page.</p>\n            </details>\n            <details class=\"service-item\">\n              <summary><span class=\"service-index\">02</span><h3>Roof inspections</h3></summary>\n              <p>Position photo review, attic checks, drainage observations, and repair recommendations as a tidy pre-quote step.</p>\n            </details>\n            <details class=\"service-item\">\n              <summary><span class=\"service-index\">03</span><h3>Repair and maintenance packages</h3></summary>\n              <p>Group common service requests around leaks, flashing, vents, gutters, and weather wear without promising a diagnosis online.</p>\n            </details>\n            <details class=\"service-item\">\n              <summary><span class=\"service-index\">04</span><h3>Commercial roof refresh</h3></summary>\n              <p>Keep facility inquiries focused on access, roof type, schedule windows, documentation, and the right next site visit.</p>\n            </details>\n          </div>\n        </div>\n        <div class=\"image-fill\">\n          <img src=\"assets/service-modern-roofer-metal-roof.png\" alt=\"Roofer working on a modern metal roof service detail\" />\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"process\" data-od-id=\"process\">\n      <div class=\"container stack\" style=\"gap: 48px;\">\n        <div class=\"proof-card card\">\n          <img src=\"assets/inspection-drone-roof-check.png\" alt=\"Drone inspection view over a residential roof\" />\n          <div class=\"proof-copy\">\n            <p class=\"eyebrow\">Inspection proof</p>\n            <h2>Make the condition check visible.</h2>\n            <p class=\"lead\" style=\"margin-top: 18px;\">Use drone-friendly imagery and simple language to show that the quote starts with observation, documentation, and a real roof conversation.</p>\n            <ul class=\"check-list\">\n              <li>Photo review and visible roof-surface notes</li>\n              <li>Material recommendations framed as options</li>\n              <li>Appointment request that asks for the right details</li>\n            </ul>\n          </div>\n        </div>\n        <div class=\"grid-4 process-grid\">\n          <article class=\"card process-card\">\n            <h3>Share the roof type</h3>\n            <p class=\"lead\" style=\"font-size: 15px;\">The form captures roof style, known concerns, and project timing.</p>\n          </article>\n          <article class=\"card process-card\">\n            <h3>Review material paths</h3>\n            <p class=\"lead\" style=\"font-size: 15px;\">Visitors compare the main system categories before a sales call.</p>\n          </article>\n          <article class=\"card process-card\">\n            <h3>Schedule a site visit</h3>\n            <p class=\"lead\" style=\"font-size: 15px;\">The next step is framed around inspection, measurements, and scope.</p>\n          </article>\n          <article class=\"card process-card\">\n            <h3>Receive a clear proposal</h3>\n            <p class=\"lead\" style=\"font-size: 15px;\">The page sets expectations for options, scope, and follow-up questions.</p>\n          </article>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" data-od-id=\"projects-teaser\">\n      <div class=\"container\">\n        <div class=\"project-teaser\">\n          <div>\n            <p class=\"eyebrow\">Project planning</p>\n            <h2>Keep roof decisions organized from first look to final proposal.</h2>\n            <p class=\"lead\" style=\"margin-top: 18px;\">Use material samples, inspection notes, and service categories to prepare for a more focused roofing conversation.</p>\n          </div>\n          <div>\n            <p class=\"meta\">Helpful quote details</p>\n            <ul class=\"check-list\">\n              <li>Current roof material and visible concerns</li>\n              <li>Preferred material style or replacement goal</li>\n              <li>Access notes, timing, and inspection questions</li>\n            </ul>\n            <div class=\"swatch-row\" aria-label=\"Material preview images\">\n              <span class=\"swatch\"><img src=\"assets/product-standing-seam-metal-sample.png\" alt=\"Metal material preview\" /></span>\n              <span class=\"swatch\"><img src=\"assets/product-terracotta-tile-sample.png\" alt=\"Terracotta material preview\" /></span>\n              <span class=\"swatch\"><img src=\"assets/product-composite-shingle-sample.png\" alt=\"Composite material preview\" /></span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"faq\" data-od-id=\"faq\">\n      <div class=\"container\">\n        <div style=\"text-align: center; max-width: 650px; margin: 0 auto 48px;\">\n          <p class=\"eyebrow\">Roofing questions</p>\n          <h2>Answer the practical concerns before the call.</h2>\n        </div>\n        <div class=\"faq-list\">\n          <details class=\"faq-item\" open>\n            <summary>Can I compare materials before requesting a quote?</summary>\n            <p>Yes. The page is designed to let visitors review common material categories first, then request a roof-specific conversation when they are ready.</p>\n          </details>\n          <details class=\"faq-item\">\n            <summary>Does the form replace an on-site inspection?</summary>\n            <p>No. The form helps collect context. A roofing professional still needs to review roof condition, access, measurements, ventilation, flashing, and related details.</p>\n          </details>\n          <details class=\"faq-item\">\n            <summary>Can you help with commercial roof inquiries?</summary>\n            <p>Yes. Commercial requests can start with roof type, access notes, scheduling windows, and any documentation the property team already has.</p>\n          </details>\n          <details class=\"faq-item\">\n            <summary>Where should warranties, licenses, or reviews appear?</summary>\n            <p>Those details should appear only when they are available from the roofing company and can be confirmed by the customer.</p>\n          </details>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"contact\" data-od-id=\"contact\">\n      <div class=\"container\">\n        <div class=\"grid-2\">\n          <div class=\"quote-cta\">\n            <img src=\"assets/hero-modern-metal-roof-sunset-wide.png\" alt=\"Clean metal roof used as quote request background\" />\n            <div class=\"quote-cta-content\">\n              <p class=\"eyebrow\">Quote path</p>\n              <h2>Start with the roof, not a sales script.</h2>\n              <p class=\"lead\" style=\"margin-top: 16px;\">A simple request path for roof replacements, inspections, repairs, and material comparisons.</p>\n            </div>\n          </div>\n          <div class=\"card\">\n            <p class=\"eyebrow\">Request a roofing quote</p>\n            <h2>Tell us what you want checked.</h2>\n            <form class=\"contact-form\">\n              <div class=\"field\">\n                <label for=\"name\">Name</label>\n                <input class=\"input\" id=\"name\" name=\"name\" autocomplete=\"name\" placeholder=\"Your name\" />\n              </div>\n              <div class=\"field\">\n                <label for=\"contact-method\">Email or phone</label>\n                <input class=\"input\" id=\"contact-method\" name=\"contact\" autocomplete=\"email\" placeholder=\"How should we reach you?\" />\n              </div>\n              <div class=\"field\">\n                <label for=\"project-type\">Project type</label>\n                <select class=\"input\" id=\"project-type\" name=\"project-type\">\n                  <option>Roof replacement</option>\n                  <option>Inspection</option>\n                  <option>Repair or maintenance</option>\n                  <option>Commercial roof inquiry</option>\n                </select>\n              </div>\n              <div class=\"field\">\n                <label for=\"message\">Roof notes</label>\n                <textarea class=\"textarea\" id=\"message\" name=\"message\" placeholder=\"Roof material, known issue, timeline, or preferred appointment window\"></textarea>\n              </div>\n              <button class=\"btn btn-primary\" type=\"button\">Send Quote Request</button>\n            </form>\n          </div>\n        </div>\n      </div>\n    </section>\n  </main>\n\n  <footer class=\"pagefoot\" data-od-id=\"footer\">\n    <div class=\"container\">\n      <div class=\"footer-grid\">\n        <div class=\"stack\">\n          <a class=\"brand\" href=\"#top\" aria-label=\"Roofex Roofing Systems home\">\n            <svg class=\"brand-mark\" viewBox=\"0 0 180 48\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Roofex logo\">\n              <path d=\"M8 27 30 9l22 18\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n              <path d=\"M20 27h24v14H20z\" fill=\"var(--fg)\"/>\n              <text x=\"66\" y=\"32\" font-family=\"Inter, Arial, sans-serif\" font-size=\"24\" font-weight=\"800\" fill=\"var(--fg)\">RR</text>\n            </svg>\n            <span class=\"brand-word\">Roofex Roofing Systems</span>\n          </a>\n          <p>Modern roofing conversations for materials, inspections, repairs, and replacement planning.</p>\n        </div>\n        <div class=\"stack\">\n          <h3 style=\"font-size: 15px;\">Services</h3>\n          <a href=\"#services\">Roof replacement</a>\n          <a href=\"#services\">Inspection</a>\n          <a href=\"#services\">Maintenance</a>\n          <a href=\"#services\">Commercial inquiry</a>\n        </div>\n        <div class=\"stack\">\n          <h3 style=\"font-size: 15px;\">Materials</h3>\n          <a href=\"#materials\">Standing seam metal</a>\n          <a href=\"#materials\">Terracotta tile</a>\n          <a href=\"#materials\">Composite shingle</a>\n          <a href=\"#faq\">Roofing FAQ</a>\n        </div>\n        <div class=\"stack\">\n          <h3 style=\"font-size: 15px;\">Contact</h3>\n          <p>Roofing quotes, inspections, and material questions.</p>\n          <a href=\"#contact\">Request quote</a>\n          <a href=\"#faq\">Read questions</a>\n        </div>\n      </div>\n      <div class=\"footer-wordmark\">ROOFEX</div>\n      <div class=\"row-between\" style=\"margin-top: 24px;\">\n        <p class=\"meta\">Roofing systems, service planning, and quote requests.</p>\n        <p class=\"meta\">Roofex Roofing Systems</p>\n      </div>\n    </div>\n  </footer>\n</body>\n</html>\n","isError":false}

