data: {"type":"tool_result","toolUseId":"item_26","content":"compact-one-page.html:9:      --bg: #FAF3E8;\ncompact-one-page.html:10:      --surface: #FFFDF8;\ncompact-one-page.html:11:      --fg: #1D2328;\ncompact-one-page.html:12:      --muted: #6B6258;\ncompact-one-page.html:13:      --border: #E8DCCA;\ncompact-one-page.html:14:      --accent: #C9472A;\ncompact-one-page.html:15:      --on-primary: #FFFFFF;\nstyle-guide.md:5:- `--bg`: `#FAF3E8` warm neutral page background.\nstyle-guide.md:6:- `--surface`: `#FFFDF8` form and card canvas.\nstyle-guide.md:7:- `--fg`: `#1D2328` charcoal contrast band, text, footer.\nstyle-guide.md:8:- `--muted`: `#6B6258` warm grey support copy.\nstyle-guide.md:9:- `--border`: `#E8DCCA` warm divider line.\nstyle-guide.md:10:- `--accent`: `#C9472A` roof-red action color.\nindex.html:9:      --bg: #FAF3E8;\nindex.html:10:      --surface: #FFFDF8;\nindex.html:11:      --fg: #1D2328;\nindex.html:12:      --muted: #6B6258;\nindex.html:13:      --border: #E8DCCA;\nindex.html:14:      --accent: #C9472A;\nindex.html:15:      --on-primary: #FFFFFF;\n","isError":false}

