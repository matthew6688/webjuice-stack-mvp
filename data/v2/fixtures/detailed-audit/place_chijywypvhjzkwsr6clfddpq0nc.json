    "issues": {
      "critical": [
        {
          "id": "phone_visible_above_fold",
          "rationale": "phone hidden below fold or missing",
          "max": 20,
          "plain_language": "电话号码在第一屏看不到 — 客户必须滚动才能找到怎么联系你。",
          "customer_impact": "本地服务客户 60-70% 倾向打电话沟通（不是填表单）。电话号没在第一屏 = 这部分客户里很多人会直接关掉去搜下一家。这是最便宜的转化优化之一。"
        }
      ],
      "major": [
        {
          "id": "homepage_title_clear",
          "rationale": "title='# Transform Your Local Business with Expert Digital Marketin' contains-name=false contains-niche=false",
          "max": 20,
          "plain_language": "你网站的浏览器标签 title 没把业务名字 + 服务关键词写清楚（比如该写「Hurricane Digital - SEO Brisbane - roofing Brisbane」，但目前是泛泛一句）。",
          "customer_impact": "Google 搜索结果里展示的就是这个 title。写不清楚 = 排名靠后 + 即使排上来客户也不知道是不是匹配的服务。SEO 最便宜的修复，但很多本地企业完全没做。"
        },
        {
          "id": "h1_unique",
          "rationale": "3 <h1> tags",
          "max": 20,
          "plain_language": "页面要么没有 H1 标题（搜索引擎无法理解页面主旨），要么有多个 H1（搜索引擎不知道哪个是主题）。",
          "customer_impact": "H1 是搜索引擎判断页面主题最权威的信号。写错或缺失 = 关键词排名拉低；同一页面同样的内容，H1 写对的可以排到前 3 页，写不对的可能挂在第 7 页。"
        }
      ],
      "minor": [
        {
          "id": "has_hours",
          "rationale": "no hours",
          "max": 5,
          "plain_language": "GBP 上没有完整的营业时间。",
          "customer_impact": "客户搜「现在还在营业的 roofer」时你不会被显示。"
        },
        {
          "id": "has_service_area",
          "rationale": "no service area",
          "max": 15,
          "plain_language": null,
          "customer_impact": null
        },
        {
          "id": "has_gallery",
          "rationale": "no gallery",
          "max": 5,
          "plain_language": "没有项目作品集 / before-after 图库。",
          "customer_impact": "屋顶 / renovation 行业，「眼见为实」是关键决策因素之一。没有作品集 = 客户没法判断你的工艺水准 = 比起有图库的同行落后一截。"
        }
      ]
