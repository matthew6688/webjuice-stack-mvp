      "major": [
        {
          "id": "review_volume_vs_peers",
          "rationale": "0 reviews",
          "max": 25,
          "plain_language": "你的 Google 评价数量低于同行平均水平。",
          "customer_impact": "本地搜索排名信号之一就是评价数量；不光是分数，连\"有多少条\"都算。短期可以做的：每个完工的客户群发一条「点评一下吧」的 SMS。"
        },
        {
          "id": "homepage_title_clear",
          "rationale": "title='#1 Rated on Gold Coast & Brisbane' contains-name=false contains-niche=false",
          "max": 20,
          "plain_language": "你网站的浏览器标签 title 没把业务名字 + 服务关键词写清楚（比如该写「Radiant Roof Repairs Gold Coast - roofing Gold Coast」，但目前是泛泛一句）。",
          "customer_impact": "Google 搜索结果里展示的就是这个 title。写不清楚 = 排名靠后 + 即使排上来客户也不知道是不是匹配的服务。SEO 最便宜的修复，但很多本地企业完全没做。"
        },
        {
          "id": "local_schema_markup",
          "rationale": "no LocalBusiness JSON-LD",
          "max": 20,
          "plain_language": "网站没有 LocalBusiness JSON-LD 结构化数据（让 Google / AI 知道你是本地企业、地址、电话、营业时间的标准格式）。",
          "customer_impact": "Google「附近的服务」「Knowledge Panel」「AI Overview」都依赖这类结构化数据。没有 = 即使排名上去也不会出现在右侧 Knowledge Panel 或地图卡片里 — 错失高转化的展示位。AI agent / ChatGPT 引用本地商家时也是基于这些数据。"
        }
      ],
      "minor": [
        {
          "id": "has_hours",
          "rationale": "no hours",
          "max": 5,
          "plain_language": "GBP 上没有完整的营业时间。",
          "customer_impact": "客户搜「现在还在营业的 roofer」时你不会被显示。"
        },
        {
          "id": "image_count",
          "rationale": "0 images",
          "max": 10,
          "plain_language": "GBP 上图片数量低于行业建议（一般 ≥ 10 张完工图 + 团队照 + 设备照）。",
          "customer_impact": "图片数量直接影响 GBP 在地图卡片里的展示效果。"
        },
        {
          "id": "has_business_description",
          "rationale": "no description",
          "max": 10,
          "plain_language": null,
          "customer_impact": null
        },
        {
          "id": "has_service_area",
          "rationale": "no service area",
          "max": 15,
          "plain_language": null,
          "customer_impact": null
        },
        {
          "id": "no_console_errors",
          "rationale": "4 console errors",
          "max": 5,
          "plain_language": "你的网站在浏览器控制台里有报错。访客看不到这些错误，但报错的脚本通常就是导致按钮点不动 / 表单提交不了 / 图片加载失败的原因。",
          "customer_impact": "一个失败的 click-to-call 按钮等于这次访问完全白来。每月成百上千次访问，哪怕只有 1% 受影响也是几十次失之交臂的咨询。"
        },
        {
          "id": "quote_or_booking_form",
          "rationale": "no form",
          "max": 20,
          "plain_language": "你的网站没有 quote / booking 表单 — 客户只能打电话或发邮件。",
          "customer_impact": "工作时间外（晚上 / 周末）的访客没办法联系你，只能等。家庭装修客户经常在晚上做决策；你正在错过非营业时间的转化窗口。"
        }
      ]
