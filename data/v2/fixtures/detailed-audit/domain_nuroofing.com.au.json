    "issues": {
      "critical": [
        {
          "id": "https_enabled",
          "rationale": "http only",
          "max": 20,
          "plain_language": "你的网站没有 HTTPS — 浏览器会在地址栏显示「不安全」标记，部分浏览器（Chrome / Firefox）甚至会弹出全屏警告挡住页面。",
          "customer_impact": "Google 早在 2018 年起把 HTTPS 列为搜索排名因素，没有 HTTPS 直接拉低自然搜索可见度；且超过 80% 的访客看到「不安全」标识会立刻关掉。对你这种 0 条 Google 评价积累起来的口碑来说，访客在网址栏就被劝退，等于浪费了所有 GBP 流量。"
        }
      ],
      "major": [
        {
          "id": "review_volume_vs_peers",
          "rationale": "0 reviews",
          "max": 25,
          "plain_language": "你的 Google 评价数量低于同行平均水平。",
          "customer_impact": "本地搜索排名信号之一就是评价数量；不光是分数，连\"有多少条\"都算。短期可以做的：每个完工的客户群发一条「点评一下吧」的 SMS。"
        },
        {
          "id": "homepage_title_clear",
          "rationale": "title='### Skylight' contains-name=false contains-niche=false",
          "max": 20,
          "plain_language": "你网站的浏览器标签 title 没把业务名字 + 服务关键词写清楚（比如该写「Nuroofing services pty ltd - roofing Sydney」，但目前是泛泛一句）。",
          "customer_impact": "Google 搜索结果里展示的就是这个 title。写不清楚 = 排名靠后 + 即使排上来客户也不知道是不是匹配的服务。SEO 最便宜的修复，但很多本地企业完全没做。"
        },
        {
          "id": "local_schema_markup",
          "rationale": "no LocalBusiness JSON-LD",
          "max": 20,
          "plain_language": "网站没有 LocalBusiness JSON-LD 结构化数据（让 Google / AI 知道你是本地企业、地址、电话、营业时间的标准格式）。",
          "customer_impact": "Google「附近的服务」「Knowledge Panel」「AI Overview」都依赖这类结构化数据。没有 = 即使排名上去也不会出现在右侧 Knowledge Panel 或地图卡片里 — 错失高转化的展示位。AI agent / ChatGPT 引用本地商家时也是基于这些数据。"
        }
      ],
      "minor": [
        {
          "id": "has_hours",
          "rationale": "no hours",
          "max": 5,
          "plain_language": "GBP 上没有完整的营业时间。",
          "customer_impact": "客户搜「现在还在营业的 roofer」时你不会被显示。"
        },
        {
          "id": "image_count",
          "rationale": "0 images",
          "max": 10,
          "plain_language": "GBP 上图片数量低于行业建议（一般 ≥ 10 张完工图 + 团队照 + 设备照）。",
          "customer_impact": "图片数量直接影响 GBP 在地图卡片里的展示效果。"
        },
