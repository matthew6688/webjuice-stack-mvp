    "issues": {
      "critical": [
        {
          "id": "phone_visible_above_fold",
          "rationale": "phone hidden below fold or missing",
          "max": 20,
          "plain_language": "电话号码在第一屏看不到 — 客户必须滚动才能找到怎么联系你。",
          "customer_impact": "本地服务客户 60-70% 倾向打电话沟通（不是填表单）。电话号没在第一屏 = 这部分客户里很多人会直接关掉去搜下一家。这是最便宜的转化优化之一。"
        }
      ],
      "major": [
        {
          "id": "review_volume_vs_peers",
          "rationale": "0 reviews",
          "max": 25,
          "plain_language": "你的 Google 评价数量低于同行平均水平。",
          "customer_impact": "本地搜索排名信号之一就是评价数量；不光是分数，连\"有多少条\"都算。短期可以做的：每个完工的客户群发一条「点评一下吧」的 SMS。"
        },
        {
          "id": "click_to_call_link",
          "rationale": "no tel: link",
          "max": 10,
          "plain_language": "电话号码不是 click-to-call 链接（手机上点击不会自动拨号）。",
          "customer_impact": "移动客户必须复制号码再切到拨号界面再粘贴 — 每多一步操作就流失一批客户。修复成本只是把 `<a href=\"tel:0712345678\">` 写对，但能立刻拉高电话转化率。"
        },
        {
          "id": "h1_unique",
          "rationale": "24 <h1> tags",
          "max": 20,
          "plain_language": "页面要么没有 H1 标题（搜索引擎无法理解页面主旨），要么有多个 H1（搜索引擎不知道哪个是主题）。",
          "customer_impact": "H1 是搜索引擎判断页面主题最权威的信号。写错或缺失 = 关键词排名拉低；同一页面同样的内容，H1 写对的可以排到前 3 页，写不对的可能挂在第 7 页。"
        },
        {
          "id": "local_schema_markup",
          "rationale": "no LocalBusiness JSON-LD",
          "max": 20,
          "plain_language": "网站没有 LocalBusiness JSON-LD 结构化数据（让 Google / AI 知道你是本地企业、地址、电话、营业时间的标准格式）。",
          "customer_impact": "Google「附近的服务」「Knowledge Panel」「AI Overview」都依赖这类结构化数据。没有 = 即使排名上去也不会出现在右侧 Knowledge Panel 或地图卡片里 — 错失高转化的展示位。AI agent / ChatGPT 引用本地商家时也是基于这些数据。"
        }
      ],
      "minor": [
        {
          "id": "has_hours",
          "rationale": "no hours",
          "max": 5,
          "plain_language": "GBP 上没有完整的营业时间。",
          "customer_impact": "客户搜「现在还在营业的 roofer」时你不会被显示。"
        },
        {
          "id": "image_count",
          "rationale": "0 images",
          "max": 10,
          "plain_language": "GBP 上图片数量低于行业建议（一般 ≥ 10 张完工图 + 团队照 + 设备照）。",
          "customer_impact": "图片数量直接影响 GBP 在地图卡片里的展示效果。"
        },
        {
          "id": "has_business_description",
          "rationale": "no description",
          "max": 10,
          "plain_language": null,
          "customer_impact": null
        },
        {
          "id": "has_service_area",
          "rationale": "no service area",
          "max": 15,
          "plain_language": null,
          "customer_impact": null
        },
        {
          "id": "quote_or_booking_form",
          "rationale": "no form",
          "max": 20,
          "plain_language": "你的网站没有 quote / booking 表单 — 客户只能打电话或发邮件。",
          "customer_impact": "工作时间外（晚上 / 周末）的访客没办法联系你，只能等。家庭装修客户经常在晚上做决策；你正在错过非营业时间的转化窗口。"
        },
        {
          "id": "has_gallery",
          "rationale": "no gallery",
          "max": 5,
          "plain_language": "没有项目作品集 / before-after 图库。",
          "customer_impact": "屋顶 / renovation 行业，「眼见为实」是关键决策因素之一。没有作品集 = 客户没法判断你的工艺水准 = 比起有图库的同行落后一截。"
        },
        {
          "id": "localized_content",
          "rationale": "no local mention",
          "max": 15,
          "plain_language": "网站文案没明确提到服务的城市 / 区域（比如 Brisbane / Sunshine Coast / Lawnton 等具体地名）。",
          "customer_impact": "本地搜索 SEO 的核心信号之一就是地理关键词。「Sydney roofing」这类搜索流量直接跟你网站里的本地化文案挂钩；不写具体地区 = 把流量让给写得清楚的同行。"
        }
      ]
    },
