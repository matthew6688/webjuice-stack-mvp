    ],
    "issues": {
      "critical": [
        {
          "id": "https_enabled",
          "rationale": "http only",
          "max": 20,
          "plain_language": "你的网站没有 HTTPS — 浏览器会在地址栏显示「不安全」标记，部分浏览器（Chrome / Firefox）甚至会弹出全屏警告挡住页面。",
          "customer_impact": "Google 早在 2018 年起把 HTTPS 列为搜索排名因素，没有 HTTPS 直接拉低自然搜索可见度；且超过 80% 的访客看到「不安全」标识会立刻关掉。对你这种 127 条 Google 评价积累起来的口碑来说，访客在网址栏就被劝退，等于浪费了所有 GBP 流量。"
        },
        {
          "id": "phone_visible_above_fold",
          "rationale": "phone hidden below fold or missing",
          "max": 20,
          "plain_language": "电话号码在第一屏看不到 — 客户必须滚动才能找到怎么联系你。",
          "customer_impact": "本地服务客户 60-70% 倾向打电话沟通（不是填表单）。电话号没在第一屏 = 这部分客户里很多人会直接关掉去搜下一家。这是最便宜的转化优化之一。"
        }
      ],
      "major": [
        {
          "id": "homepage_title_clear",
          "rationale": "title='# FIX MY ROOF TOTAL ROOF RESTORATIONS' contains-name=true contains-niche=false",
          "max": 20,
          "plain_language": "你网站的浏览器标签 title 没把业务名字 + 服务关键词写清楚（比如该写「FIX MY ROOF Total Roof Restorations - roofing Brisbane」，但目前是泛泛一句）。",
          "customer_impact": "Google 搜索结果里展示的就是这个 title。写不清楚 = 排名靠后 + 即使排上来客户也不知道是不是匹配的服务。SEO 最便宜的修复，但很多本地企业完全没做。"
        },
        {
          "id": "local_schema_markup",
          "rationale": "no LocalBusiness JSON-LD",
          "max": 20,
          "plain_language": "网站没有 LocalBusiness JSON-LD 结构化数据（让 Google / AI 知道你是本地企业、地址、电话、营业时间的标准格式）。",
          "customer_impact": "Google「附近的服务」「Knowledge Panel」「AI Overview」都依赖这类结构化数据。没有 = 即使排名上去也不会出现在右侧 Knowledge Panel 或地图卡片里 — 错失高转化的展示位。AI agent / ChatGPT 引用本地商家时也是基于这些数据。"
        }
      ],
      "minor": [
        {
          "id": "has_hours",
          "rationale": "no hours",
          "max": 5,
          "plain_language": "GBP 上没有完整的营业时间。",
          "customer_impact": "客户搜「现在还在营业的 roofer」时你不会被显示。"
        },
        {
          "id": "has_service_area",
          "rationale": "no service area",
          "max": 15,
          "plain_language": null,
          "customer_impact": null
        },
        {
          "id": "quote_or_booking_form",
          "rationale": "no form",
          "max": 20,
          "plain_language": "你的网站没有 quote / booking 表单 — 客户只能打电话或发邮件。",
          "customer_impact": "工作时间外（晚上 / 周末）的访客没办法联系你，只能等。家庭装修客户经常在晚上做决策；你正在错过非营业时间的转化窗口。"
        },
        {
          "id": "has_gallery",
          "rationale": "no gallery",
          "max": 5,
          "plain_language": "没有项目作品集 / before-after 图库。",
          "customer_impact": "屋顶 / renovation 行业，「眼见为实」是关键决策因素之一。没有作品集 = 客户没法判断你的工艺水准 = 比起有图库的同行落后一截。"
        },
