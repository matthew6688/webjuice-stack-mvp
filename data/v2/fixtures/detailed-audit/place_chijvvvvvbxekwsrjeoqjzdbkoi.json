    ],
    "issues": {
      "critical": [
        {
          "id": "https_enabled",
          "rationale": "http only",
          "max": 20,
          "plain_language": "你的网站没有 HTTPS — 浏览器会在地址栏显示「不安全」标记，部分浏览器（Chrome / Firefox）甚至会弹出全屏警告挡住页面。",
          "customer_impact": "Google 早在 2018 年起把 HTTPS 列为搜索排名因素，没有 HTTPS 直接拉低自然搜索可见度；且超过 80% 的访客看到「不安全」标识会立刻关掉。对你这种 65 条 Google 评价积累起来的口碑来说，访客在网址栏就被劝退，等于浪费了所有 GBP 流量。"
        },
        {
          "id": "phone_visible_above_fold",
          "rationale": "phone hidden below fold or missing",
          "max": 20,
          "plain_language": "电话号码在第一屏看不到 — 客户必须滚动才能找到怎么联系你。",
          "customer_impact": "本地服务客户 60-70% 倾向打电话沟通（不是填表单）。电话号没在第一屏 = 这部分客户里很多人会直接关掉去搜下一家。这是最便宜的转化优化之一。"
        }
      ],
      "major": [
        {
          "id": "homepage_title_clear",
          "rationale": "title='## Get a Free Quote' contains-name=false contains-niche=false",
          "max": 20,
          "plain_language": "你网站的浏览器标签 title 没把业务名字 + 服务关键词写清楚（比如该写「Diamond Roof Tiling & Restoration - roofing Brisbane」，但目前是泛泛一句）。",
          "customer_impact": "Google 搜索结果里展示的就是这个 title。写不清楚 = 排名靠后 + 即使排上来客户也不知道是不是匹配的服务。SEO 最便宜的修复，但很多本地企业完全没做。"
        },
        {
          "id": "h1_unique",
          "rationale": "0 <h1> tags",
          "max": 20,
          "plain_language": "页面要么没有 H1 标题（搜索引擎无法理解页面主旨），要么有多个 H1（搜索引擎不知道哪个是主题）。",
          "customer_impact": "H1 是搜索引擎判断页面主题最权威的信号。写错或缺失 = 关键词排名拉低；同一页面同样的内容，H1 写对的可以排到前 3 页，写不对的可能挂在第 7 页。"
        },
        {
          "id": "local_schema_markup",
          "rationale": "no LocalBusiness JSON-LD",
          "max": 20,
          "plain_language": "网站没有 LocalBusiness JSON-LD 结构化数据（让 Google / AI 知道你是本地企业、地址、电话、营业时间的标准格式）。",
          "customer_impact": "Google「附近的服务」「Knowledge Panel」「AI Overview」都依赖这类结构化数据。没有 = 即使排名上去也不会出现在右侧 Knowledge Panel 或地图卡片里 — 错失高转化的展示位。AI agent / ChatGPT 引用本地商家时也是基于这些数据。"
        }
      ],
      "minor": [
        {
          "id": "has_hours",
          "rationale": "no hours",
          "max": 5,
          "plain_language": "GBP 上没有完整的营业时间。",
          "customer_impact": "客户搜「现在还在营业的 roofer」时你不会被显示。"
        },
        {
          "id": "has_service_area",
          "rationale": "no service area",
          "max": 15,
          "plain_language": null,
          "customer_impact": null
        },
        {
          "id": "no_console_errors",
          "rationale": "1 console errors",
          "max": 5,
          "plain_language": "你的网站在浏览器控制台里有报错。访客看不到这些错误，但报错的脚本通常就是导致按钮点不动 / 表单提交不了 / 图片加载失败的原因。",
          "customer_impact": "一个失败的 click-to-call 按钮等于这次访问完全白来。每月成百上千次访问，哪怕只有 1% 受影响也是几十次失之交臂的咨询。"
        },
        {
          "id": "has_gallery",
          "rationale": "no gallery",
          "max": 5,
          "plain_language": "没有项目作品集 / before-after 图库。",
          "customer_impact": "屋顶 / renovation 行业，「眼见为实」是关键决策因素之一。没有作品集 = 客户没法判断你的工艺水准 = 比起有图库的同行落后一截。"
        },
        {
          "id": "image_alt_present",
          "rationale": "43 images, 49% with alt",
          "max": 20,
          "plain_language": "图片没有 alt 文字描述。",
          "customer_impact": "影响两件事：① 视障用户的可访问性（在澳洲是法律风险）；② Google 图片搜索流量（屋顶项目图片是极强的 SEO 资产，但没 alt 等于没标）。"
        }
      ]
