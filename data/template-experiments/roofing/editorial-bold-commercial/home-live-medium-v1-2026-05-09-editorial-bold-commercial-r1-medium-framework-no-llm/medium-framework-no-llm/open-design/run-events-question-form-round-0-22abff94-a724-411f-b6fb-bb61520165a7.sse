data: {"type":"text_delta","delta":"Got it — high-fidelity roofing home page for RidgeLine Roof Co. with the seeded commercial/editorial assets. Tell me the remaining direction choices:  \n<question-form id=\"discovery\" title=\"Quick brief — 30 seconds\">\n{\n  \"description\": \"I'll lock these in before building. Skip what doesn't apply — I'll fill defaults.\",\n  \"questions\": [\n    {\n      \"id\": \"platform\",\n      \"label\": \"Primary surface\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Desktop web\",\n        \"Responsive — all sizes\",\n        \"Mobile-first\",\n        \"Fixed canvas (1920×1080)\"\n      ]\n    },\n    {\n      \"id\": \"audience\",\n      \"label\": \"Who should this persuade first?\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Homeowners needing repairs\",\n        \"Commercial property managers\",\n        \"Both residential and commercial\",\n        \"Insurance / storm-damage callers\"\n      ]\n    },\n    {\n      \"id\": \"tone\",\n      \"label\": \"Visual tone\",\n      \"type\": \"checkbox\",\n      \"maxSelections\": 2,\n      \"options\": [\n        \"Editorial / magazine\",\n        \"Bold commercial\",\n        \"Modern minimal\",\n        \"Trade-practical\",\n        \"Premium / refined\"\n      ]\n    },\n    {\n      \"id\": \"brand\",\n      \"label\": \"Brand context\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Use the provided editorial bold commercial language\",\n        \"Pick a direction for me\",\n        \"I have a brand spec — I'll share it\",\n        \"Match a reference site / screenshot — I'll attach it\"\n      ]\n    },\n    {\n      \"id\": \"motion\",\n      \"label\": \"Motion level\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Subtle load and hover polish\",\n        \"Static and screenshot-first\",\n        \"More expressive editorial motion\"\n      ]\n    },\n    {\n      \"id\": \"constraints\",\n      \"label\": \"Anything else I should know?\",\n      \"type\": \"textarea\",\n      \"placeholder\": \"Copy angle, sections to emphasize, things to avoid…\"\n    }\n  ]\n}\n</question-form> \n"}

