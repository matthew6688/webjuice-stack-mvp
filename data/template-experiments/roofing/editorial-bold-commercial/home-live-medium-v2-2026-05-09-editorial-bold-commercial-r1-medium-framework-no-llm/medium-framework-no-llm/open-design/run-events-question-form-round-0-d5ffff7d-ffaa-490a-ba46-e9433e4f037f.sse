data: {"type":"text_delta","delta":"Got it — high-fidelity roofing home page for RidgeLine Roof Co.; I’ll lock the remaining direction details before building.\n<question-form id=\"discovery\" title=\"Quick brief — 30 seconds\">\n{\n  \"description\": \"I have the business facts and section contract. Pick the last design constraints and I’ll build index.html.\",\n  \"questions\": [\n    {\n      \"id\": \"platform\",\n      \"label\": \"Primary surface\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Responsive — all sizes\",\n        \"Desktop web\",\n        \"Mobile-first\"\n      ]\n    },\n    {\n      \"id\": \"audience\",\n      \"label\": \"Primary customer\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Homeowners needing repairs\",\n        \"Commercial property managers\",\n        \"Mixed residential + commercial\",\n        \"Insurance / storm repair leads\"\n      ]\n    },\n    {\n      \"id\": \"tone\",\n      \"label\": \"Visual tone\",\n      \"type\": \"checkbox\",\n      \"maxSelections\": 2,\n      \"options\": [\n        \"Editorial / magazine\",\n        \"Bold commercial\",\n        \"Modern minimal\",\n        \"Trade-professional\",\n        \"Premium / architectural\"\n      ]\n    },\n    {\n      \"id\": \"brand\",\n      \"label\": \"Brand context\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Pick a direction for me\",\n        \"Use the supplied editorial bold commercial language\",\n        \"I have a brand spec — I'll share it\",\n        \"Match a reference site / screenshot — I'll attach it\"\n      ]\n    },\n    {\n      \"id\": \"cta_style\",\n      \"label\": \"Quote path emphasis\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Phone-first with supporting form\",\n        \"Form-first with phone backup\",\n        \"Balanced phone + form\"\n      ]\n    },\n    {\n      \"id\": \"constraints\",\n      \"label\": \"Anything else I should know?\",\n      \"type\": \"textarea\",\n      \"placeholder\": \"Copy preferences, sections to avoid, stronger commercial vs residential emphasis…\"\n    }\n  ]\n}\n</question-form>"}

