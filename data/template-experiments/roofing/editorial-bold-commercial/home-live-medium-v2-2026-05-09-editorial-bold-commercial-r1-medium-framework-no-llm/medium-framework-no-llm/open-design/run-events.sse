data: {"type":"tool_result","toolUseId":"item_25","content":"<!doctype html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>RidgeLine Roof Co. | Roofing Contractor Brisbane & Gold Coast</title>\n  <meta name=\"description\" content=\"RidgeLine Roof Co. provides roof repairs, restorations, metal roofing, gutter repairs and roof inspections across Brisbane and the Gold Coast.\" />\n  <meta name=\"review-provenance\" content=\"ai-reference-placeholder; replace with real Google or customer reviews before live\" />\n  <script type=\"application/ld+json\">\n  {\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"RoofingContractor\",\n    \"name\": \"RidgeLine Roof Co.\",\n    \"telephone\": \"0400 000 000\",\n    \"url\": \"\",\n    \"image\": \"assets/hero-family2-hero-worker-standing-metal-roof-wide.png\",\n    \"address\": {\n      \"@type\": \"PostalAddress\",\n      \"streetAddress\": \"[Address placeholder]\",\n      \"addressLocality\": \"Brisbane\",\n      \"addressRegion\": \"QLD\",\n      \"postalCode\": \"[Postcode]\",\n      \"addressCountry\": \"AU\"\n    },\n    \"areaServed\": [\n      \"Brisbane\",\n      \"Gold Coast\"\n    ],\n    \"hasMap\": \"https://www.google.com/maps/search/?api=1&query=Brisbane+roofing+contractor\",\n    \"sameAs\": []\n  }\n  </script>\n  <style>\n    :root {\n      --bg:      oklch(98% 0.004 92);\n      --surface: oklch(100% 0 0);\n      --fg:      oklch(14% 0.01 85);\n      --muted:   oklch(43% 0.012 80);\n      --border:  oklch(86% 0.008 85);\n      --accent:  oklch(62% 0.19 42);\n\n      --accent-soft: color-mix(in oklch, var(--accent) 14%, transparent);\n      --fg-soft:     color-mix(in oklch, var(--fg) 6%, transparent);\n      --black:        oklch(10% 0.01 85);\n\n      --font-display: Impact, Haettenschweiler, 'Arial Narrow Bold', 'Roboto Condensed', sans-serif;\n      --font-body:    -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;\n      --font-mono:    ui-monospace, 'JetBrains Mono', 'SF Mono', Menlo, monospace;\n\n      --fs-h1: clamp(66px, 11vw, 164px);\n      --fs-h2: clamp(42px, 6vw, 86px);\n      --fs-h3: 24px;\n      --fs-lead: 20px;\n      --fs-body: 16px;\n      --fs-meta: 13px;\n\n      --gap-xs: 8px;\n      --gap-sm: 12px;\n      --gap-md: 20px;\n      --gap-lg: 32px;\n      --gap-xl: 56px;\n      --gap-2xl: 96px;\n      --container: 1240px;\n      --gutter: 28px;\n\n      --radius: 2px;\n      --radius-lg: 2px;\n    }\n\n    *, *::before, *::after { box-sizing: border-box; }\n    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }\n    body {\n      margin: 0;\n      background: var(--bg);\n      color: var(--fg);\n      font-family: var(--font-body);\n      font-size: var(--fs-body);\n      line-height: 1.5;\n      text-rendering: optimizeLegibility;\n      -webkit-font-smoothing: antialiased;\n    }\n    img, svg { display: block; max-width: 100%; }\n    img { object-fit: cover; }\n    a { color: inherit; text-decoration: none; }\n    button, input, textarea, select { font: inherit; }\n    button { cursor: pointer; }\n    p { text-wrap: pretty; }\n    h1, h2, h3, h4 { text-wrap: balance; }\n\n    .container {\n      max-width: var(--container);\n      margin-inline: auto;\n      padding-inline: var(--gutter);\n    }\n    .section { padding-block: clamp(56px, 8vw, var(--gap-2xl)); }\n    .section + .section { border-top: 1px solid var(--border); }\n    .stack { display: flex; flex-direction: column; }\n    .stack > * + * { margin-top: var(--gap-md); }\n    .row { display: flex; align-items: center; gap: var(--gap-md); }\n    .row-between { display: flex; align-items: center; justify-content: space-between; gap: var(--gap-md); }\n    .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--gap-lg); }\n    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap-lg); }\n    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--gap-md); }\n    .grid-2-1 { display: grid; grid-template-columns: 2fr 1fr; gap: var(--gap-xl); align-items: start; }\n    .grid-1-2 { display: grid; grid-template-columns: 1fr 2fr; gap: var(--gap-xl); align-items: start; }\n\n    .h1, h1 {\n      font-family: var(--font-display);\n      font-size: var(--fs-h1);\n      line-height: 0.84;\n      letter-spacing: 0;\n      text-transform: uppercase;\n      margin: 0;\n      font-weight: 900;\n    }\n    .h2, h2 {\n      font-family: var(--font-display);\n      font-size: var(--fs-h2);\n      line-height: 0.9;\n      letter-spacing: 0;\n      text-transform: uppercase;\n      margin: 0;\n      font-weight: 900;\n    }\n    .h3, h3 {\n      font-family: var(--font-display);\n      font-size: var(--fs-h3);\n      font-weight: 900;\n      line-height: 1;\n      letter-spacing: 0;\n      text-transform: uppercase;\n      margin: 0;\n    }\n    .lead { font-size: var(--fs-lead); line-height: 1.45; color: var(--muted); max-width: 60ch; margin: 0; }\n    .eyebrow {\n      font-family: var(--font-mono);\n      font-size: 12px;\n      letter-spacing: 0.08em;\n      text-transform: uppercase;\n      color: var(--accent);\n      margin: 0 0 var(--gap-md);\n    }\n    .meta { font-family: var(--font-mono); font-size: var(--fs-meta); color: var(--muted); }\n    .num { font-family: var(--font-mono); font-variant-numeric: tabular-nums; }\n\n    .topnav {\n      position: sticky;\n      top: 0;\n      z-index: 10;\n      background: color-mix(in oklch, var(--bg) 94%, transparent);\n      backdrop-filter: blur(12px);\n      border-bottom: 1px solid var(--fg);\n    }\n    .topnav-inner { display: flex; align-items: center; justify-content: space-between; padding-block: 12px; }\n    .topnav .logo { font-family: var(--font-display); font-size: 26px; font-weight: 900; letter-spacing: 0; text-transform: uppercase; }\n    .topnav nav { display: flex; gap: var(--gap-lg); }\n    .topnav nav a { font-size: 13px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.04em; }\n    .topnav nav a:hover { color: var(--fg); }\n\n    .btn {\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n      gap: 8px;\n      min-height: 44px;\n      padding: 12px 20px;\n      border-radius: var(--radius);\n      border: 1.5px solid transparent;\n      font-size: 14px;\n      font-weight: 800;\n      text-transform: uppercase;\n      letter-spacing: 0.04em;\n      transition: transform 0.05s ease, background 0.15s ease, border-color 0.15s ease;\n    }\n    .btn:active { transform: translateY(1px); }\n    .btn-primary { background: var(--accent); color: var(--surface); border-color: var(--accent); }\n    .btn-primary:hover { background: color-mix(in oklch, var(--accent) 86%, var(--fg)); }\n    .btn-secondary { background: var(--surface); color: var(--fg); border-color: var(--fg); }\n    .btn-secondary:hover { background: var(--fg); color: var(--surface); }\n    .btn-ghost { background: transparent; color: var(--fg); border-color: transparent; padding-inline: 8px; }\n    .btn-ghost:hover { color: var(--accent); }\n    .btn-arrow::after { content: '->'; transition: transform 0.15s ease; }\n    .btn-arrow:hover::after { transform: translateX(2px); }\n\n    .card {\n      background: var(--surface);\n      border: 1.5px solid var(--fg);\n      border-radius: var(--radius-lg);\n      padding: 28px;\n    }\n    .card-flat { background: transparent; border: 0; padding: 0; }\n    .card-rule { background: transparent; border: 0; border-top: 1.5px solid var(--fg); padding: 24px 0 0; border-radius: 0; }\n    .feature h3 { margin-bottom: 8px; }\n    .feature p { margin: 0; color: var(--muted); font-size: 15px; }\n    .feature-mark {\n      width: 36px;\n      height: 36px;\n      display: grid;\n      place-items: center;\n      border: 1.5px solid var(--fg);\n      border-radius: var(--radius);\n      color: var(--fg);\n      margin-bottom: var(--gap-md);\n      font-family: var(--font-mono);\n      font-size: 12px;\n    }\n\n    .field { display: flex; flex-direction: column; gap: 6px; }\n    .field label { font-size: 13px; color: var(--muted); }\n    .input, .textarea, .select {\n      width: 100%;\n      padding: 12px 14px;\n      border: 1.5px solid var(--fg);\n      border-radius: var(--radius);\n      background: var(--surface);\n      color: var(--fg);\n      font: inherit;\n      font-size: 15px;\n    }\n    .input:focus, .textarea:focus, .select:focus {\n","isError":false}

