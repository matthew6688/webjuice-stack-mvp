event: agent
data: {"type":"tool_result","toolUseId":"item_36","content":"<!doctype html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>RidgeLine Roof Co. | Roofing Contractor Brisbane & Gold Coast</title>\n  <meta name=\"description\" content=\"RidgeLine Roof Co. provides roof repairs, restorations, metal roofing, gutter repairs and roof inspections across Brisbane and the Gold Coast.\" />\n  <meta name=\"review-provenance\" content=\"ai-reference-placeholder; replace with real Google or customer reviews before live\" />\n  <script type=\"application/ld+json\">\n  {\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"RoofingContractor\",\n    \"name\": \"RidgeLine Roof Co.\",\n    \"telephone\": \"0400 000 000\",\n    \"url\": \"\",\n    \"image\": \"assets/hero-family2-hero-worker-standing-metal-roof-wide.png\",\n    \"address\": {\n      \"@type\": \"PostalAddress\",\n      \"streetAddress\": \"[Address placeholder]\",\n      \"addressLocality\": \"Brisbane\",\n      \"addressRegion\": \"QLD\",\n      \"postalCode\": \"[Postcode]\",\n      \"addressCountry\": \"AU\"\n    },\n    \"areaServed\": [\n      \"Brisbane\",\n      \"Gold Coast\"\n    ],\n    \"hasMap\": \"https://www.google.com/maps/search/?api=1&query=Brisbane+roofing+contractor\",\n    \"sameAs\": []\n  }\n  </script>\n  <style>\n    :root {\n      --bg:      oklch(98% 0.004 92);\n      --surface: oklch(100% 0 0);\n      --fg:      oklch(14% 0.01 85);\n      --muted:   oklch(43% 0.012 80);\n      --border:  oklch(86% 0.008 85);\n      --accent:  oklch(62% 0.19 42);\n\n      --accent-soft: color-mix(in oklch, var(--accent) 14%, transparent);\n      --fg-soft:     color-mix(in oklch, var(--fg) 6%, transparent);\n      --black:        oklch(10% 0.01 85);\n\n      --font-display: Impact, Haettenschweiler, 'Arial Narrow Bold', 'Roboto Condensed', sans-serif;\n      --font-body:    -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;\n      --font-mono:    ui-monospace, 'JetBrains Mono', 'SF Mono', Menlo, monospace;\n\n      --fs-h1: clamp(66px, 11vw, 164px);\n      --fs-h2: clamp(42px, 6vw, 86px);\n      --fs-h3: 24px;\n      --fs-lead: 20px;\n      --fs-body: 16px;\n      --fs-meta: 13px;\n\n      --gap-xs: 8px;\n      --gap-sm: 12px;\n      --gap-md: 20px;\n      --gap-lg: 32px;\n      --gap-xl: 56px;\n      --gap-2xl: 96px;\n      --container: 1240px;\n      --gutter: 28px;\n\n      --radius: 2px;\n      --radius-lg: 2px;\n    }\n\n    *, *::before, *::after { box-sizing: border-box; }\n    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }\n    body {\n      margin: 0;\n      background: var(--bg);\n      color: var(--fg);\n      font-family: var(--font-body);\n      font-size: var(--fs-body);\n      line-height: 1.5;\n      text-rendering: optimizeLegibility;\n      -webkit-font-smoothing: antialiased;\n    }\n    img, svg { display: block; max-width: 100%; }\n    img { object-fit: cover; }\n    a { color: inherit; text-decoration: none; }\n    button, input, textarea, select { font: inherit; }\n    button { cursor: pointer; }\n    p { text-wrap: pretty; }\n    h1, h2, h3, h4 { text-wrap: balance; }\n\n    .container {\n      max-width: var(--container);\n      margin-inline: auto;\n      padding-inline: var(--gutter);\n    }\n    .section { padding-block: clamp(56px, 8vw, var(--gap-2xl)); }\n    .section + .section { border-top: 1px solid var(--border); }\n    .stack { display: flex; flex-direction: column; }\n    .stack > * + * { margin-top: var(--gap-md); }\n    .row { display: flex; align-items: center; gap: var(--gap-md); }\n    .row-between { display: flex; align-items: center; justify-content: space-between; gap: var(--gap-md); }\n    .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--gap-lg); }\n    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap-lg); }\n    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--gap-md); }\n    .grid-2-1 { display: grid; grid-template-columns: 2fr 1fr; gap: var(--gap-xl); align-items: start; }\n    .grid-1-2 { display: grid; grid-template-columns: 1fr 2fr; gap: var(--gap-xl); align-items: start; }\n\n    .h1, h1 {\n      font-family: var(--font-display);\n      font-size: var(--fs-h1);\n      line-height: 0.84;\n      letter-spacing: 0;\n      text-transform: uppercase;\n      margin: 0;\n      font-weight: 900;\n    }\n    .h2, h2 {\n      font-family: var(--font-display);\n      font-size: var(--fs-h2);\n      line-height: 0.9;\n      letter-spacing: 0;\n      text-transform: uppercase;\n      margin: 0;\n      font-weight: 900;\n    }\n    .h3, h3 {\n      font-family: var(--font-display);\n      font-size: var(--fs-h3);\n      font-weight: 900;\n      line-height: 1;\n      letter-spacing: 0;\n      text-transform: uppercase;\n      margin: 0;\n    }\n    .lead { font-size: var(--fs-lead); line-height: 1.45; color: var(--muted); max-width: 60ch; margin: 0; }\n    .eyebrow {\n      font-family: var(--font-mono);\n      font-size: 12px;\n      letter-spacing: 0.08em;\n      text-transform: uppercase;\n      color: var(--muted);\n      margin: 0 0 var(--gap-md);\n    }\n    .meta { font-family: var(--font-mono); font-size: var(--fs-meta); color: var(--muted); }\n    .num { font-family: var(--font-mono); font-variant-numeric: tabular-nums; }\n\n    .topnav {\n      position: sticky;\n      top: 0;\n      z-index: 10;\n      background: color-mix(in oklch, var(--bg) 94%, transparent);\n      backdrop-filter: blur(12px);\n      border-bottom: 1px solid var(--fg);\n    }\n    .topnav-inner { display: flex; align-items: center; justify-content: space-between; padding-block: 12px; }\n    .topnav .logo { font-family: var(--font-display); font-size: 26px; font-weight: 900; letter-spacing: 0; text-transform: uppercase; }\n    .topnav nav { display: flex; gap: var(--gap-lg); }\n    .topnav nav a { font-size: 13px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.04em; }\n    .topnav nav a:hover { color: var(--fg); }\n\n    .btn {\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n      gap: 8px;\n      min-height: 44px;\n      padding: 12px 20px;\n      border-radius: var(--radius);\n      border: 1.5px solid transparent;\n      font-size: 14px;\n      font-weight: 800;\n      text-transform: uppercase;\n      letter-spacing: 0.04em;\n      transition: transform 0.05s ease, background 0.15s ease, border-color 0.15s ease;\n    }\n    .btn:active { transform: translateY(1px); }\n    .btn-primary { background: var(--accent); color: var(--surface); border-color: var(--accent); }\n    .btn-primary:hover { background: color-mix(in oklch, var(--accent) 86%, var(--fg)); }\n    .btn-secondary { background: var(--surface); color: var(--fg); border-color: var(--fg); }\n    .btn-secondary:hover { background: var(--fg); color: var(--surface); }\n    .btn-ghost { background: transparent; color: var(--fg); border-color: transparent; padding-inline: 8px; }\n    .btn-ghost:hover { color: var(--accent); }\n    .btn-arrow::after { content: '->'; transition: transform 0.15s ease; }\n    .btn-arrow:hover::after { transform: translateX(2px); }\n\n    .card {\n      background: var(--surface);\n      border: 1.5px solid var(--fg);\n      border-radius: var(--radius-lg);\n      padding: 28px;\n    }\n    .card-flat { background: transparent; border: 0; padding: 0; }\n    .card-rule { background: transparent; border: 0; border-top: 1.5px solid var(--fg); padding: 24px 0 0; border-radius: 0; }\n    .feature h3 { margin-bottom: 8px; }\n    .feature p { margin: 0; color: var(--muted); font-size: 15px; }\n    .feature-mark {\n      width: 36px;\n      height: 36px;\n      display: grid;\n      place-items: center;\n      border: 1.5px solid var(--fg);\n      border-radius: var(--radius);\n      color: var(--fg);\n      margin-bottom: var(--gap-md);\n      font-family: var(--font-mono);\n      font-size: 12px;\n    }\n\n    .field { display: flex; flex-direction: column; gap: 6px; }\n    .field label { font-size: 13px; color: var(--muted); }\n    .input, .textarea, .select {\n      width: 100%;\n      padding: 12px 14px;\n      border: 1.5px solid var(--fg);\n      border-radius: var(--radius);\n      background: var(--surface);\n      color: var(--fg);\n      font: inherit;\n      font-size: 15px;\n    }\n    .input:focus, .textarea:focus, .select:focus {\n      outline: 3px solid var(--accent-soft);\n      border-color: var(--accent);\n    }\n    .textarea { min-height: 112px; resize: vertical; line-height: 1.55; }\n\n    .hero-poster {\n      padding: clamp(30px, 5vw, 64px) 0 clamp(56px, 7vw, 96px);\n      overflow: clip;\n    }\n    .hero-frame {\n      display: grid;\n      grid-template-columns: minmax(0, 1.05fr) minmax(340px, 0.95fr);\n      min-height: clamp(620px, 82vh, 840px);\n      border-bottom: 1.5px solid var(--fg);\n      position: relative;\n    }\n    .hero-copy {\n      padding: clamp(38px, 6vw, 82px) var(--gutter) 42px max(var(--gutter), calc((100vw - var(--container)) / 2 + var(--gutter)));\n      display: flex;\n      flex-direction: column;\n      justify-content: space-between;\n      gap: var(--gap-xl);\n      position: relative;\n      z-index: 2;\n    }\n    .hero-word {\n      display: block;\n    }\n    .hero-word:nth-child(2) {\n      color: var(--accent);\n    }\n    .hero-copy .lead {\n      max-width: 34ch;\n      color: var(--fg);\n      font-weight: 650;\n    }\n    .hero-cta { display: flex; gap: var(--gap-sm); flex-wrap: wrap; margin-top: var(--gap-lg); }\n    .hero-visual {\n      position: relative;\n      min-height: 520px;\n      border-left: 1.5px solid var(--fg);\n      overflow: hidden;\n      background: var(--fg);\n    }\n    .hero-visual img {\n      width: 100%;\n      height: 100%;\n      min-height: inherit;\n      object-position: center;\n      filter: contrast(1.04) saturate(0.96);\n    }\n    .hero-ticket {\n      position: absolute;\n      right: clamp(18px, 4vw, 56px);\n      bottom: clamp(18px, 4vw, 56px);\n      width: min(330px, calc(100% - 36px));\n      background: var(--surface);\n      border: 1.5px solid var(--fg);\n      padding: 20px;\n    }\n    .hero-ticket strong {\n      display: block;\n      font-family: var(--font-display);\n      text-transform: uppercase;\n      font-size: 36px;\n      line-height: 0.9;\n    }\n    .service-marquee {\n      border-block: 1.5px solid var(--fg);\n      background: var(--surface);\n      overflow: hidden;\n    }\n    .service-marquee .track {\n      display: flex;\n      width: max-content;\n      animation: drift 28s linear infinite;\n    }\n    .service-marquee span {\n      display: inline-flex;\n      align-items: center;\n      gap: 18px;\n      padding: 18px 24px;\n      font-family: var(--font-display);\n      font-size: clamp(24px, 4vw, 44px);\n      line-height: 1;\n      text-transform: uppercase;\n      white-space: nowrap;\n    }\n    .service-marquee span::after {\n      content: '';\n      width: 12px;\n      height: 12px;\n      background: var(--fg);\n      display: inline-block;\n    }\n    @keyframes drift { to { transform: translateX(-50%); } }\n    @media (prefers-reduced-motion: reduce) {\n      .service-marquee .track { animation: none; }\n    }\n\n    .section-head {\n      display: grid;\n      grid-template-columns: minmax(0, 0.95fr) minmax(280px, 0.55fr);\n      gap: var(--gap-xl);\n      align-items: end;\n      margin-bottom: var(--gap-xl);\n    }\n    .service-list {\n      border-top: 1.5px solid var(--fg);\n    }\n    .service-row {\n      display: grid;\n      grid-template-columns: 88px minmax(0, 1fr) minmax(260px, 0.65fr);\n      gap: var(--gap-lg);\n      padding: 28px 0;\n      border-bottom: 1px solid var(--border);\n      align-items: start;\n    }\n    .service-row .num {\n      color: var(--muted);\n      font-size: 13px;\n      padding-top: 5px;\n    }\n    .service-row p {\n      margin: 0;\n      color: var(--muted);\n    }\n    .photo-band {\n      display: grid;\n      grid-template-columns: 1fr 0.72fr;\n      gap: var(--gap-md);\n      margin-top: var(--gap-xl);\n      align-items: stretch;\n    }\n    .photo-band img {\n      width: 100%;\n      height: 100%;\n      min-height: 360px;\n      border: 1.5px solid var(--fg);\n    }\n    .photo-band img:last-child { min-height: 480px; }\n\n    .proof-section {\n      background: var(--black);\n      color: var(--surface);\n      border-top: 0;\n    }\n    .proof-section .eyebrow { color: var(--accent); }\n    .proof-section .lead,\n    .proof-section .meta,\n    .proof-section p { color: color-mix(in oklch, var(--surface) 72%, transparent); }\n    .proof-grid {\n      display: grid;\n      grid-template-columns: 0.82fr 1fr;\n      gap: var(--gap-xl);\n      align-items: stretch;\n    }\n    .proof-photo {\n      position: relative;\n      min-height: 620px;\n    }\n    .proof-photo img {\n      width: 100%;\n      height: 100%;\n      border: 1.5px solid var(--surface);\n      object-position: center top;\n    }\n    .proof-card {\n      position: absolute;\n      left: -28px;\n      bottom: 38px;\n      width: min(270px, 86%);\n      background: var(--accent);\n      color: var(--surface);\n      padding: 18px;\n      border: 1.5px solid var(--surface);\n    }\n    .proof-card strong {\n      display: block;\n      font-family: var(--font-display);\n      font-size: 44px;\n      line-height: 0.9;\n      text-transform: uppercase;\n    }\n    .proof-list {\n      display: grid;\n      gap: 0;\n      border-top: 1px solid color-mix(in oklch, var(--surface) 38%, transparent);\n      margin-top: var(--gap-xl);\n    }\n    .proof-item {\n      display: grid;\n      grid-template-columns: 140px 1fr;\n      gap: var(--gap-lg);\n      padding: 22px 0;\n      border-bottom: 1px solid color-mix(in oklch, var(--surface) 24%, transparent);\n    }\n    .proof-item h3 { color: var(--surface); font-size: 28px; }\n\n    .process-grid {\n      display: grid;\n      grid-template-columns: 0.75fr 1fr;\n      gap: var(--gap-xl);\n      align-items: start;\n    }\n    .steps {\n      border-top: 1.5px solid var(--fg);\n    }\n    .step {\n      display: grid;\n      grid-template-columns: 68px 1fr;\n      gap: var(--gap-md);\n      padding: 24px 0;\n      border-bottom: 1px solid var(--border);\n    }\n    .step h3 { font-size: 25px; margin-bottom: 8px; }\n    .step p { margin: 0; color: var(--muted); }\n    .process-card img {\n      width: 100%;\n      aspect-ratio: 4 / 3;\n      border: 1.5px solid var(--fg);\n    }\n\n    .contact-section {\n      background: var(--surface);\n    }\n    .contact-shell {\n      display: grid;\n      grid-template-columns: 0.9fr 1.1fr;\n      gap: var(--gap-xl);\n      align-items: start;\n    }\n    .faq {\n      border-top: 1.5px solid var(--fg);\n      margin-top: var(--gap-xl);\n    }\n    .faq details {\n      border-bottom: 1px solid var(--border);\n      padding: 18px 0;\n    }\n    .faq summary {\n      cursor: pointer;\n      font-weight: 800;\n      text-transform: uppercase;\n      letter-spacing: 0.02em;\n    }\n    .faq p {\n      margin: 10px 0 0;\n      color: var(--muted);\n    }\n    .quote-form {\n      background: var(--bg);\n      border: 1.5px solid var(--fg);\n      padding: clamp(24px, 4vw, 38px);\n    }\n    .form-grid {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: var(--gap-md);\n    }\n    .full { grid-column: 1 / -1; }\n    .map-link {\n      display: inline-flex;\n      margin-top: var(--gap-md);\n      text-decoration: underline;\n      text-underline-offset: 4px;\n      color: var(--fg);\n    }\n    .pagefoot {\n      padding-block: var(--gap-xl);\n      color: var(--muted);\n      font-size: 13px;\n      border-top: 1.5px solid var(--fg);\n      background: var(--bg);\n    }\n    .pagefoot .row-between { flex-wrap: wrap; gap: var(--gap-md); }\n    .footer-links {\n      display: flex;\n      flex-wrap: wrap;\n      gap: var(--gap-md);\n    }\n\n    @media (max-width: 1020px) {\n      .topnav nav { display: none; }\n      .hero-frame,\n      .section-head,\n      .proof-grid,\n      .process-grid,\n      .contact-shell,\n      .photo-band {\n        grid-template-columns: 1fr;\n      }\n      .hero-visual { border-left: 0; border-top: 1.5px solid var(--fg); min-height: 420px; }\n      .proof-photo { min-height: 520px; }\n      .proof-card { left: 18px; }\n    }\n    @media (max-width: 920px) {\n      .grid-2, .grid-3, .grid-4, .grid-2-1, .grid-1-2 { grid-template-columns: 1fr; }\n      .service-row { grid-template-columns: 48px 1fr; }\n      .service-row p { grid-column: 2; }\n      .form-grid { grid-template-columns: 1fr; }\n      .full { grid-column: auto; }\n    }\n    @media (max-width: 640px) {\n      :root { --gutter: 18px; --fs-h1: clamp(58px, 18vw, 90px); }\n      .topnav .btn { display: none; }\n      .hero-copy { padding-inline: var(--gutter); }\n      .hero-frame { min-height: auto; }\n      .service-marquee span { padding-inline: 16px; }\n      .proof-item { grid-template-columns: 1fr; gap: 8px; }\n      .photo-band img,\n      .photo-band img:last-child,\n      .proof-photo,\n      .hero-visual { min-height: 340px; }\n    }\n  </style>\n</head>\n<body>\n  <header class=\"topnav\" data-od-id=\"topnav\">\n    <div class=\"container topnav-inner\">\n      <a class=\"logo\" href=\"#top\" aria-label=\"RidgeLine Roof Co. home\">RidgeLine Roof Co.</a>\n      <nav aria-label=\"Primary navigation\">\n        <a href=\"#services\">Services</a>\n        <a href=\"#work\">Roof work</a>\n        <a href=\"#process\">Process</a>\n        <a href=\"#quote\">Quote</a>\n      </nav>\n      <a class=\"btn btn-primary\" href=\"tel:0400000000\">Call 0400 000 000</a>\n    </div>\n  </header>\n\n  <main id=\"content\">\n    <section class=\"hero-poster\" data-od-id=\"hero\" id=\"top\">\n      <div class=\"hero-frame\">\n        <div class=\"hero-copy\">\n          <div>\n            <p class=\"eyebrow\">Roofing contractor · Brisbane + Gold Coast</p>\n            <h1>\n              <span class=\"hero-word\">Brisbane</span>\n              <span class=\"hero-word\">Gold Coast</span>\n              <span class=\"hero-word\">Roofing</span>\n            </h1>\n          </div>\n          <div>\n            <p class=\"lead\">RidgeLine Roof Co. handles repairs, restorations, metal roofing, gutter repairs and inspections for homes and commercial properties across Brisbane and the Gold Coast.</p>\n            <div class=\"hero-cta\">\n              <a class=\"btn btn-primary\" href=\"#quote\">Request a roof inspection</a>\n              <a class=\"btn btn-secondary\" href=\"tel:0400000000\">Call 0400 000 000</a>\n            </div>\n          </div>\n        </div>\n        <div class=\"hero-visual\">\n          <img src=\"assets/hero-family2-hero-worker-standing-metal-roof-wide.png\" alt=\"Roofing contractor standing on a metal roof during an inspection\" width=\"1916\" height=\"821\" />\n          <div class=\"hero-ticket\">\n            <span class=\"meta\">Inspection path</span>\n            <strong>Find the leak. Price the fix.</strong>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <div class=\"service-marquee\" aria-label=\"Roofing service categories\">\n      <div class=\"track\">\n        <span>Roof repairs</span>\n        <span>Roof restoration</span>\n        <span>Metal roofing</span>\n        <span>Gutter repairs</span>\n        <span>Roof inspections</span>\n        <span>Roof repairs</span>\n        <span>Roof restoration</span>\n        <span>Metal roofing</span>\n        <span>Gutter repairs</span>\n        <span>Roof inspections</span>\n      </div>\n    </div>\n\n    <section class=\"section\" data-od-id=\"services\" id=\"services\">\n      <div class=\"container\">\n        <div class=\"section-head\">\n          <div>\n            <p class=\"eyebrow\">What you can request</p>\n            <h2>Clear roofing work, without the sales theatre.</h2>\n          </div>\n          <p class=\"lead\">Start with a roof issue, inspection need or upgrade plan. The site visit focuses on what is visible, what needs opening up, and which next step is worth quoting.</p>\n        </div>\n\n        <div class=\"service-list\">\n          <article class=\"service-row\">\n            <span class=\"num\">01</span>\n            <h3>Roof repairs</h3>\n            <p>Leaks, storm damage, lifted sheets, cracked bedding and localised roof faults assessed before a repair scope is written.</p>\n          </article>\n          <article class=\"service-row\">\n            <span class=\"num\">02</span>\n            <h3>Roof restoration</h3>\n            <p>Cleaning, preparation and restoration planning for tired roofs where the structure is still worth bringing back.</p>\n          </article>\n          <article class=\"service-row\">\n            <span class=\"num\">03</span>\n            <h3>Metal roofing</h3>\n            <p>Metal roof replacement and upgrade enquiries, including roofline details, flashings and drainage considerations.</p>\n          </article>\n          <article class=\"service-row\">\n            <span class=\"num\">04</span>\n            <h3>Gutter repairs</h3>\n            <p>Overflow, rust, fall issues and damaged sections reviewed alongside the roof edge so water has a proper path off the building.</p>\n          </article>\n          <article class=\"service-row\">\n            <span class=\"num\">05</span>\n            <h3>Roof inspections</h3>\n            <p>Roof condition checks for homeowners, property managers and pre-work planning across Brisbane and the Gold Coast.</p>\n          </article>\n        </div>\n\n        <div class=\"photo-band\" id=\"work\">\n          <img src=\"assets/service-family2-service-roofer-metal-roof-diagonal.png\" alt=\"Roofer working across a diagonal metal roof section\" width=\"1672\" height=\"941\" loading=\"lazy\" />\n          <img src=\"assets/projectDetail-family2-project-commercial-metal-roof-detail.png\" alt=\"Detailed commercial metal roofing surface and flashing work\" width=\"1448\" height=\"1086\" loading=\"lazy\" />\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section proof-section\" data-od-id=\"proof\">\n      <div class=\"container proof-grid\">\n        <div class=\"proof-photo\">\n          <img src=\"assets/story-family2-story-two-roofers-metal-roof-portrait.png\" alt=\"Two roofers coordinating work on a metal roof\" width=\"1122\" height=\"1402\" loading=\"lazy\" />\n          <div class=\"proof-card\">\n            <span class=\"meta\">Proof without pretending</span>\n            <strong>See the roof. Then scope it.</strong>\n          </div>\n        </div>\n        <div>\n          <p class=\"eyebrow\">How the work becomes concrete</p>\n          <h2>Site condition first. Quote second.</h2>\n          <p class=\"lead\" style=\"margin-top: 24px;\">The page is built for real roofing enquiries: inspection notes, roof-material cues and plain next steps instead of unsupported claims.</p>\n          <div class=\"proof-list\">\n            <article class=\"proof-item\">\n              <span class=\"meta\">Process proof</span>\n              <div>\n                <h3>Photo-led inspection notes</h3>\n                <p>Visible damage, roof access limits and likely repair zones are documented before the quote path is confirmed.</p>\n              </div>\n            </article>\n            <article class=\"proof-item\">\n              <span class=\"meta\">Material cues</span>\n              <div>\n                <h3>Flashings, gutters, sheets</h3>\n                <p>The assessment looks at more than the obvious leak point: edges, joins, drainage and surrounding roof condition matter.</p>\n              </div>\n            </article>\n            <article class=\"proof-item\">\n              <span class=\"meta\">Project structure</span>\n              <div>\n                <h3>Repair, restore, replace</h3>\n                <p>Enquiries are framed around the least confusing route for the property: immediate repair, staged restoration or replacement planning.</p>\n              </div>\n            </article>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" data-od-id=\"quote-process\" id=\"process\">\n      <div class=\"container process-grid\">\n        <div class=\"process-card\">\n          <p class=\"eyebrow\">Inspection to quote</p>\n          <h2>Three steps. No mystery handoff.</h2>\n          <p class=\"lead\" style=\"margin-top: 20px;\">Call or send the form, describe the roof issue, then get a practical inspection path for the property.</p>\n          <img src=\"assets/projectTile-family2-service-orange-accent-roof-work.png\" alt=\"Roof work with orange safety accent on a residential roof\" width=\"1448\" height=\"1086\" loading=\"lazy\" style=\"margin-top: 32px;\" />\n        </div>\n        <div class=\"steps\">\n          <article class=\"step\">\n            <span class=\"num\">01</span>\n            <div>\n              <h3>Tell us what changed</h3>\n              <p>Leaks, stains, loose sheets, storm damage, gutter overflow or a roof that simply needs a condition check.</p>\n            </div>\n          </article>\n          <article class=\"step\">\n            <span class=\"num\">02</span>\n            <div>\n              <h3>Book the roof inspection</h3>\n              <p>A suitable inspection time is arranged for the Brisbane or Gold Coast property, with access notes captured upfront.</p>\n            </div>\n          </article>\n          <article class=\"step\">\n            <span class=\"num\">03</span>\n            <div>\n              <h3>Receive the next-step quote</h3>\n              <p>The quote path is based on the visible roof condition and the work required, not a one-size-fits-all package.</p>\n            </div>\n          </article>\n          <div style=\"padding-top: 28px;\">\n            <a class=\"btn btn-primary\" href=\"#quote\">Start the enquiry</a>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section contact-section\" data-od-id=\"faq-contact-footer\" id=\"quote\">\n      <div class=\"container contact-shell\">\n        <div>\n          <p class=\"eyebrow\">Questions before you book</p>\n          <h2>Roofing FAQs for Brisbane and Gold Coast properties.</h2>\n          <div class=\"faq\">\n            <details open>\n              <summary>Can I request an inspection before choosing a repair?</summary>\n              <p>Yes. The enquiry can start with a roof inspection, especially when the source of a leak or drainage issue is not obvious from ground level.</p>\n            </details>\n            <details>\n              <summary>Do you handle both homes and commercial roofs?</summary>\n              <p>Yes. The service mix covers residential and commercial enquiries, including repairs, restoration planning, metal roofing and gutter issues.</p>\n            </details>\n            <details>\n              <summary>What should I include in the form?</summary>\n              <p>Include the suburb, roof type if known, what changed, access notes, and whether the enquiry is urgent after weather damage.</p>\n            </details>\n            <details>\n              <summary>Where do you work?</summary>\n              <p>RidgeLine Roof Co. services Brisbane and the Gold Coast. Use the form if you are close to those areas and need confirmation.</p>\n            </details>\n          </div>\n          <a class=\"map-link\" href=\"https://www.google.com/maps/search/?api=1&query=Brisbane+roofing+contractor\">Open Brisbane roofing contractor directions search</a>\n        </div>\n\n        <form class=\"quote-form\" aria-label=\"Roof inspection and quote enquiry form\">\n          <p class=\"eyebrow\">Request a roof inspection or quote</p>\n          <h2 style=\"font-size: clamp(36px, 5vw, 64px);\">Send the roof details.</h2>\n          <div class=\"form-grid\" style=\"margin-top: 28px;\">\n            <div class=\"field\">\n              <label for=\"name\">Name</label>\n              <input class=\"input\" id=\"name\" name=\"name\" autocomplete=\"name\" />\n            </div>\n            <div class=\"field\">\n              <label for=\"phone\">Phone</label>\n              <input class=\"input\" id=\"phone\" name=\"phone\" autocomplete=\"tel\" />\n            </div>\n            <div class=\"field\">\n              <label for=\"suburb\">Suburb</label>\n              <input class=\"input\" id=\"suburb\" name=\"suburb\" autocomplete=\"address-level2\" />\n            </div>\n            <div class=\"field\">\n              <label for=\"service\">Service needed</label>\n              <select class=\"select\" id=\"service\" name=\"service\">\n                <option>Roof inspection</option>\n                <option>Roof repairs</option>\n                <option>Roof restoration</option>\n                <option>Metal roofing</option>\n                <option>Gutter repairs</option>\n              </select>\n            </div>\n            <div class=\"field full\">\n              <label for=\"message\">What is happening with the roof?</label>\n              <textarea class=\"textarea\" id=\"message\" name=\"message\"></textarea>\n            </div>\n            <div class=\"full row-between\" style=\"align-items: flex-start; flex-wrap: wrap;\">\n              <button class=\"btn btn-primary\" type=\"button\">Send enquiry</button>\n              <a class=\"btn btn-secondary\" href=\"tel:0400000000\">Call 0400 000 000</a>\n            </div>\n            <p class=\"meta full\" style=\"margin: 0;\">Hours: available by enquiry. Service area: Brisbane and the Gold Coast.</p>\n          </div>\n        </form>\n      </div>\n    </section>\n  </main>\n\n  <footer class=\"pagefoot\" data-od-id=\"footer\">\n    <div class=\"container row-between\">\n      <span>© 2026 RidgeLine Roof Co. · Roofing contractor serving Brisbane and the Gold Coast</span>\n      <div class=\"footer-links\">\n        <a href=\"#services\">Services</a>\n        <a href=\"#process\">Process</a>\n        <a href=\"#quote\">Quote form</a>\n        <a href=\"tel:0400000000\">0400 000 000</a>\n      </div>\n    </div>\n  </footer>\n</body>\n</html>\n","isError":false}

