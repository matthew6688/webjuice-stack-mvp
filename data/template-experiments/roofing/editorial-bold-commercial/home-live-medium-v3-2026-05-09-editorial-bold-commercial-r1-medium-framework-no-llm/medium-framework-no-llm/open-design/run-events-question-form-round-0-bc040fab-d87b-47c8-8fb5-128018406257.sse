data: {"type":"text_delta","delta":"Got it — high-fidelity roofing home page for RidgeLine Roof Co.; I’ll lock the remaining direction choices before building.\n\n<question-form id=\"discovery\" title=\"Quick brief — 30 seconds\">\n{\n  \"description\": \"I’ll lock these in before building. Skip what doesn’t apply — I’ll fill defaults.\",\n  \"questions\": [\n    {\n      \"id\": \"platform\",\n      \"label\": \"Primary surface\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Responsive — all sizes\",\n        \"Desktop web\",\n        \"Mobile (iOS/Android)\",\n        \"Tablet\",\n        \"Fixed canvas (1920×1080)\"\n      ]\n    },\n    {\n      \"id\": \"audience\",\n      \"label\": \"Primary customer\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Homeowners needing repair/restoration\",\n        \"Commercial property managers\",\n        \"Mixed residential + commercial\",\n        \"Body corporate / strata managers\"\n      ]\n    },\n    {\n      \"id\": \"tone\",\n      \"label\": \"Visual tone\",\n      \"type\": \"checkbox\",\n      \"maxSelections\": 2,\n      \"options\": [\n        \"Editorial / magazine\",\n        \"Bold commercial\",\n        \"Modern minimal\",\n        \"Trade-professional\",\n        \"Luxury / refined\",\n        \"High-contrast brutalist\"\n      ]\n    },\n    {\n      \"id\": \"brand\",\n      \"label\": \"Brand context\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Pick a direction for me\",\n        \"Use the provided editorial bold commercial direction\",\n        \"I have a brand spec — I’ll share it\",\n        \"Match a reference site / screenshot — I’ll attach it\"\n      ]\n    },\n    {\n      \"id\": \"cta_preference\",\n      \"label\": \"Quote path emphasis\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Phone-first with supporting form\",\n        \"Form-first with supporting phone\",\n        \"Equal phone and form weight\"\n      ]\n    },\n    {\n      \"id\": \"constraints\",\n      \"label\": \"Anything else I should know?\",\n      \"type\": \"textarea\",\n      \"placeholder\": \"Copy preferences, sections to avoid, stronger residential vs commercial emphasis…\"\n    }\n  ]\n}\n</question-form>"}

