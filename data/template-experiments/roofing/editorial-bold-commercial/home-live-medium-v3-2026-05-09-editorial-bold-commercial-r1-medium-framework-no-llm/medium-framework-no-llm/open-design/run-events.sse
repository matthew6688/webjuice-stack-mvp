id: 210
event: agent
data: {"type":"text_delta","delta":"Built `index.html` as a polished one-page roofing home page using the seeded local assets, with SEO basics, contact form UI, phone CTA, and safe placeholder handling.\n\n<artifact identifier=\"ridgeline-roofing-home\" type=\"text/html\" title=\"RidgeLine Roof Co. Home Page\">\n<!doctype html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>RidgeLine Roof Co. | Roofing Contractor Brisbane and Gold Coast</title>\n  <meta name=\"description\" content=\"RidgeLine Roof Co. provides roof repairs, roof restoration, metal roofing, gutter repairs and roof inspections across Brisbane and the Gold Coast.\" />\n  <meta name=\"review-provenance\" content=\"ai-reference-placeholder; replace with real Google or customer reviews before live\" />\n  <style>\n    :root {\n      --bg:      oklch(98% 0.006 90);\n      --surface: oklch(100% 0 0);\n      --fg:      oklch(13% 0.01 80);\n      --muted:   oklch(45% 0.014 80);\n      --border:  oklch(86% 0.012 80);\n      --accent:  oklch(62% 0.19 42);\n\n      --accent-soft: color-mix(in oklch, var(--accent) 14%, transparent);\n      --fg-soft:     color-mix(in oklch, var(--fg) 6%, transparent);\n      --metal:       color-mix(in oklch, var(--border) 65%, var(--fg));\n\n      --font-display: Impact, Haettenschweiler, 'Arial Narrow Bold', 'Franklin Gothic Condensed', 'Arial Narrow', sans-serif;\n      --font-body:    -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;\n      --font-mono:    ui-monospace, 'JetBrains Mono', 'SF Mono', Menlo, monospace;\n\n      --fs-h1: clamp(58px, 10vw, 168px);\n      --fs-h2: clamp(36px, 5.4vw, 82px);\n      --fs-h3: 24px;\n      --fs-lead: 20px;\n      --fs-body: 16px;\n      --fs-meta: 13px;\n\n      --gap-xs: 8px;\n      --gap-sm: 12px;\n      --gap-md: 20px;\n      --gap-lg: 32px;\n      --gap-xl: 56px;\n      --gap-2xl: 96px;\n      --container: 1240px;\n      --gutter: clamp(18px, 4vw, 44px);\n\n      --radius: 2px;\n      --radius-lg: 2px;\n    }\n\n    *, *::before, *::after { box-sizing: border-box; }\n    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }\n    body {\n      margin: 0;\n      background: var(--bg);\n      color: var(--fg);\n      font-family: var(--font-body);\n      font-size: var(--fs-body);\n      line-height: 1.55;\n      text-rendering: optimizeLegibility;\n      -webkit-font-smoothing: antialiased;\n    }\n    img, svg { display: block; max-width: 100%; }\n    img { object-fit: cover; }\n    a { color: inherit; text-decoration: none; }\n    button, input, textarea, select { font: inherit; }\n    p { text-wrap: pretty; }\n    h1, h2, h3, h4 { text-wrap: balance; }\n\n    .container { max-width: var(--container); margin-inline: auto; padding-inline: var(--gutter); }\n    .section { padding-block: clamp(60px, 8vw, var(--gap-2xl)); }\n    .section + .section { border-top: 1px solid var(--border); }\n    .stack { display: flex; flex-direction: column; }\n    .stack > * + * { margin-top: var(--gap-md); }\n    .row { display: flex; align-items: center; gap: var(--gap-md); }\n    .row-between { display: flex; align-items: center; justify-content: space-between; gap: var(--gap-md); }\n    .grid-2 { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--gap-lg); }\n    .grid-3 { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: var(--gap-lg); }\n    .grid-4 { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: var(--gap-md); }\n    .grid-2-1 { display: grid; grid-template-columns: 2fr 1fr; gap: var(--gap-xl); align-items: start; }\n    .grid-1-2 { display: grid; grid-template-columns: 1fr 2fr; gap: var(--gap-xl); align-items: start; }\n\n    .h1, h1 {\n      font-family: var(--font-display);\n      font-size: var(--fs-h1);\n      line-height: 0.82;\n      letter-spacing: 0;\n      margin: 0;\n      text-transform: uppercase;\n      font-weight: 900;\n    }\n    .h2, h2 {\n      font-family: var(--font-display);\n      font-size: var(--fs-h2);\n      line-height: 0.9;\n      letter-spacing: 0;\n      margin: 0;\n      text-transform: uppercase;\n      font-weight: 900;\n    }\n    .h3, h3 { font-family: var(--font-display); font-size: var(--fs-h3); font-weight: 900; line-height: 1; letter-spacing: 0.01em; margin: 0; text-transform: uppercase; }\n    .lead { font-size: var(--fs-lead); line-height: 1.45; color: var(--muted); max-width: 56ch; margin: 0; }\n    .eyebrow {\n      font-family: var(--font-mono);\n      font-size: 12px;\n      letter-spacing: 0.08em;\n      text-transform: uppercase;\n      color: var(--accent);\n      margin: 0 0 var(--gap-md);\n    }\n    .meta { font-family: var(--font-mono); font-size: var(--fs-meta); color: var(--muted); }\n    .num { font-family: var(--font-mono); font-variant-numeric: tabular-nums; }\n\n    .topnav {\n      position: sticky;\n      top: 0;\n      z-index: 10;\n      background: color-mix(in oklch, var(--surface) 92%, transparent);\n      backdrop-filter: blur(12px);\n      border-bottom: 1px solid var(--border);\n    }\n    .topnav-inner { display: flex; align-items: center; justify-content: space-between; padding-block: 14px; }\n    .logo { display: inline-flex; align-items: center; gap: 10px; font-family: var(--font-display); font-size: 26px; line-height: 1; text-transform: uppercase; }\n    .logo-mark { width: 34px; height: 22px; border: 2px solid var(--fg); transform: skewX(-18deg); background: var(--accent); }\n    .topnav nav { display: flex; gap: var(--gap-lg); }\n    .topnav nav a { font-size: 14px; color: var(--muted); }\n    .topnav nav a:hover { color: var(--fg); }\n    .pagefoot { padding-block: var(--gap-xl); color: var(--muted); font-size: 13px; border-top: 1px solid var(--border); }\n    .pagefoot .row-between { flex-wrap: wrap; gap: var(--gap-md); }\n\n    .btn {\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n      gap: 8px;\n      min-height: 46px;\n      padding: 12px 22px;\n      border-radius: var(--radius);\n      border: 1px solid transparent;\n      font-size: 14px;\n      font-weight: 800;\n      letter-spacing: 0.03em;\n      text-transform: uppercase;\n      cursor: pointer;\n      transition: transform 0.05s ease, background 0.15s ease, border-color 0.15s ease;\n    }\n    .btn:active { transform: translateY(1px); }\n    .btn-primary { background: var(--accent); color: var(--surface); border-color: var(--accent); }\n    .btn-primary:hover { background: color-mix(in oklch, var(--accent) 86%, var(--fg)); }\n    .btn-secondary { background: var(--fg); color: var(--surface); border-color: var(--fg); }\n    .btn-secondary:hover { background: color-mix(in oklch, var(--fg) 88%, var(--surface)); }\n    .btn-ghost { background: transparent; color: var(--fg); border-color: var(--border); }\n    .btn-ghost:hover { border-color: var(--fg); }\n    .btn-arrow::after { content: '→'; transition: transform 0.15s ease; }\n    .btn-arrow:hover::after { transform: translateX(2px); }\n\n    .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 28px; }\n    .card-flat { background: transparent; border: 0; padding: 0; }\n    .card-rule { background: transparent; border: 0; border-top: 1px solid var(--fg); padding: 24px 0 0; border-radius: 0; }\n    .feature .feature-mark { width: 38px; height: 38px; display: grid; place-items: center; border: 1px solid var(--fg); color: var(--fg); margin-bottom: var(--gap-md); }\n    .feature .feature-mark svg { width: 19px; height: 19px; }\n    .feature h3 { margin-bottom: 10px; }\n    .feature p { margin: 0; color: var(--muted); font-size: 15px; }\n\n    .stat .stat-num { font-family: var(--font-display); font-size: clamp(56px, 8vw, 112px); line-height: 0.8; letter-spacing: 0; color: var(--fg); font-weight: 900; }\n    .stat .stat-label { color: var(--muted); font-size: 14px; margin-top: 10px; max-width: 26ch; }\n    .pill { display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; background: var(--accent-soft); color: var(--fg); border: 1px solid color-mix(in oklch, var(--accent) 35%, var(--border)); border-radius: 999px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.04em; text-transform: uppercase; }\n    .tag { display: inline-flex; align-items: center; padding: 4px 10px; background: transparent; color: var(--muted); border: 1px solid var(--border); border-radius: 999px; font-size: 12px; }\n    .field { display: flex; flex-direction: column; gap: 6px; }\n    .field label { font-size: 13px; color: var(--muted); }\n    .input, .textarea, .select {\n      width: 100%;\n      padding: 12px 14px;\n      border: 1px solid var(--border);\n      border-radius: var(--radius);\n      background: var(--surface);\n      color: var(--fg);\n      font: inherit;\n      font-size: 15px;\n    }\n    .input:focus, .textarea:focus, .select:focus { outline: 2px solid var(--accent-soft); border-color: var(--accent); }\n    .textarea { min-height: 112px; resize: vertical; line-height: 1.55; }\n    .ds-table { width: 100%; border-collapse: collapse; font-size: 14px; }\n    .ds-table th, .ds-table td { padding: 16px 0; text-align: left; border-bottom: 1px solid var(--border); vertical-align: top; }\n    .ds-table th { color: var(--muted); font-weight: 700; font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.04em; text-transform: uppercase; }\n    .ds-table tbody tr:hover { background: var(--fg-soft); }\n    .ds-table .num-col { font-family: var(--font-mono); font-variant-numeric: tabular-nums; text-align: right; }\n    .rule { border: 0; border-top: 1px solid var(--border); margin: 0; }\n    .rule-strong { border: 0; border-top: 1px solid var(--fg); margin: 0; }\n    .log-row { display: grid; grid-template-columns: 120px 1fr 120px; gap: var(--gap-lg); padding: 24px 0; border-top: 1px solid var(--border); align-items: baseline; }\n    .log-row .pull { text-align: right; }\n    .ph-img { background: var(--surface); border: 1px solid var(--border); aspect-ratio: 16 / 10; display: grid; place-items: center; color: var(--muted); font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.04em; }\n    .ph-img.square { aspect-ratio: 1 / 1; }\n    .ph-img.portrait { aspect-ratio: 3 / 4; }\n    .ph-img.wide { aspect-ratio: 16 / 9; }\n\n    .hero-poster { padding-block: clamp(42px, 6vw, 88px) clamp(58px, 8vw, 120px); overflow: hidden; }\n    .hero-grid { display: grid; grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.92fr); gap: clamp(28px, 5vw, 72px); align-items: end; }\n    .hero-copy { position: relative; z-index: 1; }\n    .hero-copy h1 { max-width: 7.2ch; }\n    .hero-copy .lead { margin-top: 26px; }\n    .hero-cta { display: flex; gap: var(--gap-sm); flex-wrap: wrap; margin-top: 28px; }\n    .hero-media { position: relative; min-height: 520px; border: 1px solid var(--fg); background: var(--fg); }\n    .hero-media img { width: 100%; height: 100%; min-height: 520px; object-position: center; filter: saturate(0.96) contrast(1.03); }\n    .hero-card {\n      position: absolute;\n      left: -28px;\n      bottom: 28px;\n      width: min(360px, 82%);\n      background: var(--surface);\n      border: 1px solid var(--fg);\n      padding: 20px;\n    }\n    .hero-card strong { display: block; font-family: var(--font-display); font-size: 38px; line-height: 0.9; text-transform: uppercase; }\n    .marquee { border-block: 1px solid var(--fg); background: var(--surface); overflow: hidden; }\n    .marquee-inner { display: flex; gap: clamp(20px, 4vw, 54px); padding-block: 14px; white-space: nowrap; font-family: var(--font-display); font-size: clamp(26px, 4vw, 58px); line-height: 1; text-transform: uppercase; }\n    .marquee-inner span:nth-child(even) { color: var(--muted); }\n    .image-stack { display: grid; grid-template-columns: 1fr 0.72fr; gap: var(--gap-md); align-items: end; }\n    .image-stack img:first-child { aspect-ratio: 4 / 5; }\n    .image-stack img:last-child { aspect-ratio: 1 / 1; margin-bottom: 42px; }\n    .story-block { background: var(--fg); color: var(--surface); }\n    .story-block .eyebrow, .story-block .lead, .story-block .meta { color: color-mix(in oklch, var(--surface) 72%, var(--fg)); }\n    .story-block .card-rule { border-top-color: color-mix(in oklch, var(--surface) 28%, var(--fg)); }\n    .story-block h2, .story-block h3 { color: var(--surface); }\n    .service-row { display: grid; grid-template-columns: 92px 1fr 1.2fr 48px; gap: var(--gap-lg); align-items: start; padding: 28px 0; border-top: 1px solid var(--border); }\n    .service-row .arrow { display: grid; place-items: center; width: 44px; height: 44px; border: 1px solid var(--border); font-size: 24px; }\n    .project-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; grid-template-rows: auto auto; gap: var(--gap-md); }\n    .project-grid img { width: 100%; border: 1px solid var(--border); }\n    .project-grid img:first-child { grid-row: span 2; height: 100%; min-height: 520px; }\n    .project-grid img:not(:first-child) { aspect-ratio: 4 / 3; }\n    .process-card { border-top: 1px solid var(--fg); padding-top: 18px; }\n    .contact-wrap { display: grid; grid-template-columns: 0.8fr 1.2fr; gap: var(--gap-xl); align-items: start; }\n    .contact-panel { background: var(--surface); border: 1px solid var(--fg); padding: clamp(24px, 4vw, 40px); }\n    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--gap-md); }\n    .faq-item { padding: 20px 0; border-top: 1px solid var(--border); }\n    .faq-item h3 { font-size: 20px; margin-bottom: 8px; }\n    .faq-item p { margin: 0; color: var(--muted); }\n\n    @media (max-width: 980px) {\n      .grid-2, .grid-3, .grid-4, .grid-2-1, .grid-1-2, .hero-grid, .contact-wrap, .project-grid, .image-stack { grid-template-columns: 1fr; }\n      .topnav nav { display: none; }\n      .hero-media, .hero-media img { min-height: 360px; }\n      .hero-card { left: 16px; right: 16px; bottom: 16px; width: auto; }\n      .service-row { grid-template-columns: 54px 1fr; gap: var(--gap-md); }\n      .service-row p { grid-column: 2; }\n      .service-row .arrow { grid-column: 2; }\n      .project-grid img:first-child { min-height: 340px; }\n      .form-grid { grid-template-columns: 1fr; }\n      .log-row { grid-template-columns: 1fr; gap: 8px; }\n      .log-row .pull { text-align: left; }\n    }\n    @media (max-width: 560px) {\n      .topnav .btn { display: none; }\n      .hero-copy h1 { max-width: 8ch; }\n      .btn { width: 100%; }\n      .hero-cta { width: 100%; }\n    }\n  </style>\n  <script type=\"application/ld+json\">\n    {\n      \"@context\": \"https://schema.org\",\n      \"@type\": \"RoofingContractor\",\n      \"name\": \"RidgeLine Roof Co.\",\n      \"telephone\": \"0400 000 000\",\n      \"areaServed\": [\n        \"Brisbane\",\n        \"Gold Coast\"\n      ],\n      \"address\": {\n        \"@type\": \"PostalAddress\",\n        \"streetAddress\": \"Address available on request\",\n        \"addressLocality\": \"Brisbane\",\n        \"addressRegion\": \"QLD\",\n        \"addressCountry\": \"AU\"\n      },\n      \"url\": \"\",\n      \"sameAs\": [],\n      \"priceRange\": \"\",\n      \"hasMap\": \"https://www.google.com/maps/search/?api=1&query=Brisbane+roofing+contractor\"\n    }\n  </script>\n</head>\n<body>\n  <header class=\"topnav\" data-od-id=\"topnav\">\n    <div class=\"container topnav-inner\">\n      <a class=\"logo\" href=\"#top\" aria-label=\"RidgeLine Roof Co. home\"><span class=\"logo-mark\" aria-hidden=\"true\"></span>RidgeLine</a>\n      <nav aria-label=\"Primary navigation\">\n        <a href=\"#services\">Services</a>\n        <a href=\"#work\">Work</a>\n        <a href=\"#process\">Process</a>\n        <a href=\"#contact\">Contact</a>\n      </nav>\n      <a class=\"btn btn-primary\" href=\"tel:0400000000\">Call 0400 000 000</a>\n    </div>\n  </header>\n\n  <main id=\"content\">\n    <section class=\"section hero-poster\" id=\"top\" data-od-id=\"hero\">\n      <div class=\"container hero-grid\">\n        <div class=\"hero-copy\">\n          <p class=\"eyebrow\">Roof repairs · Restoration · Metal roofing</p>\n          <h1>Roofing for Brisbane and Gold Coast properties.</h1>\n          <p class=\"lead\">RidgeLine Roof Co. helps homeowners and property managers plan roof repairs, restorations, gutter repairs and inspections with straight answers before the work starts.</p>\n          <div class=\"hero-cta\">\n            <a class=\"btn btn-primary\" href=\"#contact\">Request a roof inspection</a>\n            <a class=\"btn btn-secondary\" href=\"tel:0400000000\">Call 0400 000 000</a>\n          </div>\n        </div>\n        <div class=\"hero-media\">\n          <img src=\"assets/hero-family2-hero-worker-standing-metal-roof-wide.png\" alt=\"Roofing contractor standing on a metal roof during inspection work\" />\n          <div class=\"hero-card\">\n            <span class=\"meta\">Service area</span>\n            <strong>Brisbane to Gold Coast</strong>\n            <p style=\"margin: 12px 0 0; color: var(--muted);\">Repairs, restoration and metal roof work for residential and light commercial properties.</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <div class=\"marquee\" aria-label=\"Roofing services\">\n      <div class=\"container marquee-inner\">\n        <span>Roof repairs</span>\n        <span>Roof restoration</span>\n        <span>Metal roofing</span>\n        <span>Gutter repairs</span>\n        <span>Roof inspections</span>\n      </div>\n    </div>\n\n    <section class=\"section\" id=\"services\" data-od-id=\"services\">\n      <div class=\"container stack\" style=\"gap: 56px;\">\n        <div class=\"grid-2-1\">\n          <div>\n            <p class=\"eyebrow\">What you can request</p>\n            <h2>Clear scope before roof work begins.</h2>\n          </div>\n          <p class=\"lead\">Use the form for a repair, restoration or inspection request. The page focuses on the work customers commonly need assessed and priced.</p>\n        </div>\n        <div>\n          <article class=\"service-row\">\n            <span class=\"meta num\">01</span>\n            <h3>Roof repairs</h3>\n            <p>Leak tracing, storm damage assessment, flashing issues, cracked bedding and targeted repairs where a full replacement is not the first answer.</p>\n            <a class=\"arrow\" href=\"#contact\" aria-label=\"Enquire about roof repairs\">→</a>\n          </article>\n          <article class=\"service-row\">\n            <span class=\"meta num\">02</span>\n            <h3>Roof restoration</h3>\n            <p>Cleaning, preparation and restoration planning for tired tile or metal roofs, with visible issues explained before quote approval.</p>\n            <a class=\"arrow\" href=\"#contact\" aria-label=\"Enquire about roof restoration\">→</a>\n          </article>\n          <article class=\"service-row\">\n            <span class=\"meta num\">03</span>\n            <h3>Metal roofing</h3>\n            <p>Metal roof repair and replacement enquiries for homes, sheds and light commercial buildings across the local service area.</p>\n            <a class=\"arrow\" href=\"#contact\" aria-label=\"Enquire about metal roofing\">→</a>\n          </article>\n          <article class=\"service-row\">\n            <span class=\"meta num\">04</span>\n            <h3>Gutters and inspections</h3>\n            <p>Gutter repairs, roof condition checks and pre-work inspections for owners who need a practical next step, not guesswork.</p>\n            <a class=\"arrow\" href=\"#contact\" aria-label=\"Enquire about gutter repairs and inspections\">→</a>\n          </article>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section story-block\" data-od-id=\"proof\">\n      <div class=\"container grid-1-2\">\n        <div class=\"stack\">\n          <p class=\"eyebrow\">Workmanship cues</p>\n          <h2>Large-format roof work, shown plainly.</h2>\n          <p class=\"lead\">The proof here is process-led: visible roof access, material details, before-work checks and clear quote steps. Replace this section with verified project notes when the live business has them.</p>\n          <div class=\"grid-2\">\n            <div class=\"card-rule\">\n              <h3>Document the issue</h3>\n              <p class=\"meta\">Photos, roof area, likely cause and next action captured before quoting.</p>\n            </div>\n            <div class=\"card-rule\">\n              <h3>Explain the option</h3>\n              <p class=\"meta\">Repair, restore or replace recommendations described in plain language.</p>\n            </div>\n          </div>\n        </div>\n        <div class=\"image-stack\">\n          <img src=\"assets/story-family2-story-two-roofers-metal-roof-portrait.png\" alt=\"Two roofers working on a metal roof section\" loading=\"lazy\" />\n          <img src=\"assets/projectTile-family2-service-orange-accent-roof-work.png\" alt=\"Roofing work detail with orange safety accent on site\" loading=\"lazy\" />\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"work\" data-od-id=\"featured-work\">\n      <div class=\"container stack\" style=\"gap: 42px;\">\n        <div class=\"row-between\" style=\"align-items: end;\">\n          <div style=\"max-width: 620px;\">\n            <p class=\"eyebrow\">Project structure</p>\n            <h2>Built to make the quote feel concrete.</h2>\n          </div>\n          <a class=\"btn btn-ghost btn-arrow\" href=\"#contact\">Start with an inspection</a>\n        </div>\n        <div class=\"project-grid\">\n          <img src=\"assets/projectDetail-family2-project-commercial-metal-roof-detail.png\" alt=\"Close detail of commercial metal roofing sheets and fasteners\" loading=\"lazy\" />\n          <img src=\"assets/service-family2-service-roofer-metal-roof-diagonal.png\" alt=\"Roofer working diagonally across a metal roof surface\" loading=\"lazy\" />\n          <div class=\"card\">\n            <span class=\"pill\">Typical project path</span>\n            <h3 style=\"margin-top: 22px;\">Inspection → scope → quote → scheduled work</h3>\n            <p style=\"margin: 12px 0 0; color: var(--muted);\">A roof enquiry is translated into a practical scope: the issue, the roof area, the recommended next action and the works to be scheduled.</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"process\" data-od-id=\"quote-process\">\n      <div class=\"container grid-2-1\">\n        <div>\n          <p class=\"eyebrow\">Quote process</p>\n          <h2>One obvious path from roof problem to next step.</h2>\n          <p class=\"lead\" style=\"margin-top: 20px;\">Call the team or send the form with the roof issue, property type and suburb. A clear request makes it easier to confirm whether the job starts with an inspection, repair quote or restoration discussion.</p>\n          <div class=\"hero-cta\">\n            <a class=\"btn btn-primary\" href=\"#contact\">Send roof details</a>\n            <a class=\"btn btn-ghost btn-arrow\" href=\"https://www.google.com/maps/search/?api=1&query=Brisbane+roofing+contractor\">View service area map</a>\n          </div>\n        </div>\n        <div class=\"grid-1-2\" style=\"grid-template-columns: 1fr; gap: 28px;\">\n          <div class=\"process-card\">\n            <span class=\"meta num\">01</span>\n            <h3 style=\"margin-top: 10px;\">Tell us what you see</h3>\n            <p style=\"color: var(--muted); margin: 8px 0 0;\">Leaks, loose flashing, blocked gutters, storm damage or restoration plans.</p>\n          </div>\n          <div class=\"process-card\">\n            <span class=\"meta num\">02</span>\n            <h3 style=\"margin-top: 10px;\">Confirm the roof context</h3>\n            <p style=\"color: var(--muted); margin: 8px 0 0;\">Property type, suburb, roof material and how urgent the issue feels.</p>\n          </div>\n          <div class=\"process-card\">\n            <span class=\"meta num\">03</span>\n            <h3 style=\"margin-top: 10px;\">Agree the next action</h3>\n            <p style=\"color: var(--muted); margin: 8px 0 0;\">Inspection, targeted repair quote, restoration scope or a larger metal roofing discussion.</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"contact\" data-od-id=\"faq-contact-footer\">\n      <div class=\"container contact-wrap\">\n        <div class=\"stack\">\n          <p class=\"eyebrow\">FAQ and enquiry</p>\n          <h2>Ask for a roof inspection or quote.</h2>\n          <p class=\"lead\">Phone is available for urgent enquiries. The form is best when you can describe the roof issue and include the suburb.</p>\n          <div class=\"faq-item\">\n            <h3>Do you handle both repairs and restorations?</h3>\n            <p>Yes. The enquiry can start with either a specific leak or a broader restoration discussion.</p>\n          </div>\n          <div class=\"faq-item\">\n            <h3>What should I include in the form?</h3>\n            <p>Property type, suburb, roof material if known, the issue you noticed and whether water is entering the property.</p>\n          </div>\n          <div class=\"faq-item\">\n            <h3>Can I request gutter work too?</h3>\n            <p>Yes. Gutter repairs can be requested alongside roof repairs or inspections.</p>\n          </div>\n          <div class=\"card\" style=\"padding: 20px;\">\n            <p class=\"meta\" style=\"margin: 0;\">Service area</p>\n            <p style=\"margin: 6px 0 0;\"><strong>Brisbane and Gold Coast</strong></p>\n            <p class=\"meta\" style=\"margin: 10px 0 0;\">Hours: Enquiry hours to be confirmed by the business.</p>\n          </div>\n        </div>\n        <form class=\"contact-panel\" aria-label=\"Roofing quote enquiry form\">\n          <div class=\"row-between\" style=\"margin-bottom: 28px; align-items: start;\">\n            <div>\n              <p class=\"eyebrow\" style=\"margin-bottom: 10px;\">Roof details</p>\n              <h3>Send an enquiry</h3>\n            </div>\n            <a class=\"btn btn-secondary\" href=\"tel:0400000000\">Call now</a>\n          </div>\n          <div class=\"form-grid\">\n            <div class=\"field\">\n              <label for=\"name\">Name</label>\n              <input class=\"input\" id=\"name\" name=\"name\" autocomplete=\"name\" />\n            </div>\n            <div class=\"field\">\n              <label for=\"phone\">Phone</label>\n              <input class=\"input\" id=\"phone\" name=\"phone\" autocomplete=\"tel\" />\n            </div>\n            <div class=\"field\">\n              <label for=\"suburb\">Suburb</label>\n              <input class=\"input\" id=\"suburb\" name=\"suburb\" />\n            </div>\n            <div class=\"field\">\n              <label for=\"service\">Service needed</label>\n              <select class=\"select\" id=\"service\" name=\"service\">\n                <option>Roof repair</option>\n                <option>Roof restoration</option>\n                <option>Metal roofing</option>\n                <option>Gutter repair</option>\n                <option>Roof inspection</option>\n              </select>\n            </div>\n          </div>\n          <div class=\"field\" style=\"margin-top: 20px;\">\n            <label for=\"message\">What is happening with the roof?</label>\n            <textarea class=\"textarea\" id=\"message\" name=\"message\"></textarea>\n          </div>\n          <button class=\"btn btn-primary\" type=\"submit\" style=\"margin-top: 22px; width: 100%;\">Request inspection or quote</button>\n          <p class=\"meta\" style=\"margin: 16px 0 0;\">Submitting this form records the roof details needed for a follow-up call.</p>\n        </form>\n      </div>\n    </section>\n  </main>\n\n  <footer class=\"pagefoot\" data-od-id=\"footer\">\n    <div class=\"container row-between\">\n      <span>© 2026 RidgeLine Roof Co. · Local roofing contractor</span>\n      <span class=\"meta\">Brisbane and Gold Coast · <a href=\"tel:0400000000\">0400 000 000</a> · <a href=\"https://www.google.com/maps/search/?api=1&query=Brisbane+roofing+contractor\">Service area map</a></span>\n    </div>\n  </footer>\n</body>\n</html>\n</artifact>"}

