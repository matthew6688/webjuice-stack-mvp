data: {"type":"tool_result","toolUseId":"item_14","content":"6:  <title>RidgeLine Roof Co. | Roofing Contractor Brisbane and Gold Coast</title>\n7:  <meta name=\"description\" content=\"RidgeLine Roof Co. provides roof repairs, roof restoration, metal roofing, gutter repairs and roof inspections across Brisbane and the Gold Coast.\" />\n254:  <script type=\"application/ld+json\">\n279:  <header class=\"topnav\" data-od-id=\"topnav\">\n293:    <section class=\"section hero-poster\" id=\"top\" data-od-id=\"hero\">\n297:          <h1>Roofing for Brisbane and Gold Coast properties.</h1>\n305:          <img src=\"assets/hero-family2-hero-worker-standing-metal-roof-wide.png\" alt=\"Roofing contractor standing on a metal roof during inspection work\" />\n325:    <section class=\"section\" id=\"services\" data-od-id=\"services\">\n363:    <section class=\"section story-block\" data-od-id=\"proof\">\n381:          <img src=\"assets/story-family2-story-two-roofers-metal-roof-portrait.png\" alt=\"Two roofers working on a metal roof section\" loading=\"lazy\" />\n382:          <img src=\"assets/projectTile-family2-service-orange-accent-roof-work.png\" alt=\"Roofing work detail with orange safety accent on site\" loading=\"lazy\" />\n387:    <section class=\"section\" id=\"work\" data-od-id=\"featured-work\">\n397:          <img src=\"assets/projectDetail-family2-project-commercial-metal-roof-detail.png\" alt=\"Close detail of commercial metal roofing sheets and fasteners\" loading=\"lazy\" />\n398:          <img src=\"assets/service-family2-service-roofer-metal-roof-diagonal.png\" alt=\"Roofer working diagonally across a metal roof surface\" loading=\"lazy\" />\n408:    <section class=\"section\" id=\"process\" data-od-id=\"quote-process\">\n439:    <section class=\"section\" id=\"contact\" data-od-id=\"faq-contact-footer\">\n506:  <footer class=\"pagefoot\" data-od-id=\"footer\">\n","isError":false}

