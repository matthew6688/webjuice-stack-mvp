data: {"type":"text_delta","delta":"Got it — high-fidelity home page prototype for RidgeLine Roof Co.; I’ll lock the remaining design choices first.\n<question-form id=\"discovery\" title=\"Quick brief — 30 seconds\">\n{\n  \"description\": \"I have the business facts, assets, and required sections. Pick the remaining direction details; skip what does not matter and I will choose defaults.\",\n  \"questions\": [\n    {\n      \"id\": \"platform\",\n      \"label\": \"Primary surface\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Desktop web\",\n        \"Responsive — all sizes\",\n        \"Mobile-first\"\n      ]\n    },\n    {\n      \"id\": \"audience\",\n      \"label\": \"Who is the main homeowner/business buyer?\",\n      \"type\": \"text\",\n      \"placeholder\": \"e.g. Brisbane homeowners comparing roof restoration options\"\n    },\n    {\n      \"id\": \"tone\",\n      \"label\": \"Visual tone\",\n      \"type\": \"checkbox\",\n      \"maxSelections\": 2,\n      \"options\": [\n        \"Modern minimal\",\n        \"Tech / utility\",\n        \"Luxury / refined\",\n        \"Soft / warm\",\n        \"Editorial / magazine\"\n      ]\n    },\n    {\n      \"id\": \"brand\",\n      \"label\": \"Brand context\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Pick a direction for me\",\n        \"I have a brand spec — I'll share it\",\n        \"Match a reference site / screenshot — I'll attach it\"\n      ]\n    },\n    {\n      \"id\": \"motion\",\n      \"label\": \"Motion level\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Subtle polish only\",\n        \"No motion\",\n        \"A little more expressive\"\n      ]\n    },\n    {\n      \"id\": \"constraints\",\n      \"label\": \"Anything else I should know?\",\n      \"type\": \"textarea\",\n      \"placeholder\": \"Copy preferences, sections to emphasize, things to avoid, or local SEO wording...\"\n    }\n  ]\n}\n</question-form>"}

