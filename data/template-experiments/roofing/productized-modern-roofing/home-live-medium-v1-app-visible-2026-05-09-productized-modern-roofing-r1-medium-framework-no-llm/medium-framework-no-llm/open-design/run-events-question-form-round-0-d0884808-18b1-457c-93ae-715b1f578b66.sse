data: {"type":"text_delta","delta":"Got it — high-fidelity home page prototype for RidgeLine Roof Co. Tell me the remaining design choices:\n<question-form id=\"discovery\" title=\"Quick brief — 30 seconds\">\n{\n  \"description\": \"I'll lock these in before building. Skip what doesn't apply — I'll fill defaults.\",\n  \"questions\": [\n    {\n      \"id\": \"platform\",\n      \"label\": \"Primary surface\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Desktop web\",\n        \"Responsive — all sizes\",\n        \"Mobile-first\",\n        \"Fixed canvas (1920×1080)\"\n      ]\n    },\n    {\n      \"id\": \"audience\",\n      \"label\": \"Primary visitor\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Homeowners comparing roof options\",\n        \"Homeowners with urgent roof damage\",\n        \"Property managers / body corporate\",\n        \"Mixed residential audience\"\n      ]\n    },\n    {\n      \"id\": \"tone\",\n      \"label\": \"Visual tone\",\n      \"type\": \"checkbox\",\n      \"maxSelections\": 2,\n      \"options\": [\n        \"Modern minimal\",\n        \"Premium consultative\",\n        \"Productized / comparison-led\",\n        \"Trade-practical\",\n        \"Soft / approachable\"\n      ]\n    },\n    {\n      \"id\": \"brand\",\n      \"label\": \"Brand context\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Pick a direction for me\",\n        \"Use the provided roofing design language\",\n        \"I have a brand spec — I'll share it\",\n        \"Match a reference site / screenshot — I'll attach it\"\n      ]\n    },\n    {\n      \"id\": \"page_length\",\n      \"label\": \"Homepage density\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Polished medium page\",\n        \"Compact above-the-fold heavy\",\n        \"Longer SEO/conversion page\"\n      ]\n    },\n    {\n      \"id\": \"quote_path\",\n      \"label\": \"Quote path emphasis\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Phone + short form equally prominent\",\n        \"Phone-first\",\n        \"Form-first\"\n      ]\n    },\n    {\n      \"id\": \"constraints\",\n      \"label\": \"Anything else I should know?\",\n      \"type\": \"textarea\",\n      \"placeholder\": \"Copy style, sections to avoid, a specific visual reference, preferred CTA wording…\"\n    }\n  ]\n}\n</question-form>"}

