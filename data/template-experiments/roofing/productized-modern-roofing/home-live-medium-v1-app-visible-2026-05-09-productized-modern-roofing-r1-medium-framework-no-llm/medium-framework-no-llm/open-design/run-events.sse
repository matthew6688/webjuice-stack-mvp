id: 262
event: agent
data: {"type":"text_delta","delta":"Built `index.html` as the polished one-page roofing homepage concept using the seeded local assets, phone CTA, enquiry form, SEO basics, and JSON-LD.\n\n<artifact identifier=\"ridgeline-roofing-homepage\" type=\"text/html\" title=\"RidgeLine Roof Co. Homepage\">\n<!doctype html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>RidgeLine Roof Co. | Roofing contractor for Brisbane and Gold Coast</title>\n  <meta name=\"description\" content=\"RidgeLine Roof Co. helps Brisbane and Gold Coast homeowners request roof repairs, restoration, metal roofing, gutter repairs, and roof inspections.\" />\n  <meta name=\"review-provenance\" content=\"ai-reference-placeholder; replace with real Google or customer reviews before live\" />\n  <style>\n    :root {\n      --bg:      oklch(98% 0.004 245);\n      --surface: oklch(100% 0 0);\n      --fg:      oklch(19% 0.018 245);\n      --muted:   oklch(48% 0.016 245);\n      --border:  oklch(89% 0.008 245);\n      --accent:  oklch(47% 0.11 170);\n\n      --accent-soft: color-mix(in oklch, var(--accent) 12%, transparent);\n      --fg-soft:     color-mix(in oklch, var(--fg) 6%, transparent);\n\n      --font-display: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', system-ui, sans-serif;\n      --font-body:    -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI', system-ui, sans-serif;\n      --font-mono:    ui-monospace, 'JetBrains Mono', 'SF Mono', Menlo, monospace;\n\n      --fs-h1: clamp(44px, 6vw, 76px);\n      --fs-h2: clamp(32px, 4vw, 48px);\n      --fs-h3: 22px;\n      --fs-lead: 19px;\n      --fs-body: 16px;\n      --fs-meta: 13px;\n\n      --gap-xs: 8px;\n      --gap-sm: 12px;\n      --gap-md: 20px;\n      --gap-lg: 32px;\n      --gap-xl: 56px;\n      --gap-2xl: 96px;\n      --container: 1180px;\n      --gutter: 32px;\n\n      --radius: 10px;\n      --radius-lg: 16px;\n    }\n\n    *, *::before, *::after { box-sizing: border-box; }\n    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }\n    body {\n      margin: 0;\n      background: var(--bg);\n      color: var(--fg);\n      font-family: var(--font-body);\n      font-size: var(--fs-body);\n      line-height: 1.55;\n      text-rendering: optimizeLegibility;\n      -webkit-font-smoothing: antialiased;\n    }\n    img, svg { display: block; max-width: 100%; }\n    a { color: inherit; text-decoration: none; }\n    button { font: inherit; cursor: pointer; }\n    p { text-wrap: pretty; }\n    h1, h2, h3, h4 { text-wrap: balance; }\n\n    .container { max-width: var(--container); margin-inline: auto; padding-inline: var(--gutter); }\n    .section { padding-block: clamp(56px, 8vw, var(--gap-2xl)); }\n    .section + .section { border-top: 1px solid var(--border); }\n    .stack { display: flex; flex-direction: column; }\n    .stack > * + * { margin-top: var(--gap-md); }\n    .row { display: flex; align-items: center; gap: var(--gap-md); }\n    .row-between { display: flex; align-items: center; justify-content: space-between; gap: var(--gap-md); }\n    .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--gap-lg); }\n    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap-lg); }\n    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--gap-md); }\n    .grid-2-1 { display: grid; grid-template-columns: 2fr 1fr; gap: var(--gap-xl); align-items: start; }\n    .grid-1-2 { display: grid; grid-template-columns: 1fr 2fr; gap: var(--gap-xl); align-items: start; }\n\n    .h1, h1 { font-family: var(--font-display); font-size: var(--fs-h1); line-height: 1.02; letter-spacing: 0; margin: 0; }\n    .h2, h2 { font-family: var(--font-display); font-size: var(--fs-h2); line-height: 1.08; letter-spacing: 0; margin: 0; }\n    .h3, h3 { font-family: var(--font-display); font-size: var(--fs-h3); font-weight: 650; line-height: 1.25; letter-spacing: 0; margin: 0; }\n    .lead { font-size: var(--fs-lead); line-height: 1.55; color: var(--muted); max-width: 60ch; margin: 0; }\n    .eyebrow {\n      font-family: var(--font-mono);\n      font-size: 12px;\n      letter-spacing: 0.08em;\n      text-transform: uppercase;\n      color: var(--muted);\n      margin: 0 0 var(--gap-md);\n    }\n    .meta { font-family: var(--font-mono); font-size: var(--fs-meta); color: var(--muted); }\n    .num { font-family: var(--font-mono); font-variant-numeric: tabular-nums; }\n\n    .topnav {\n      position: sticky;\n      top: 0;\n      z-index: 10;\n      background: color-mix(in oklch, var(--bg) 92%, transparent);\n      backdrop-filter: blur(12px);\n      border-bottom: 1px solid var(--border);\n    }\n    .topnav-inner { display: flex; align-items: center; justify-content: space-between; padding-block: 14px; }\n    .topnav .logo { font-family: var(--font-display); font-size: 18px; font-weight: 750; letter-spacing: 0; }\n    .topnav nav { display: flex; gap: var(--gap-lg); }\n    .topnav nav a { font-size: 14px; color: var(--muted); }\n    .topnav nav a:hover { color: var(--fg); }\n    .pagefoot { padding-block: var(--gap-xl); color: var(--muted); font-size: 13px; border-top: 1px solid var(--border); }\n    .pagefoot .row-between { flex-wrap: wrap; gap: var(--gap-md); }\n\n    .btn {\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n      gap: 8px;\n      min-height: 44px;\n      padding: 11px 20px;\n      border-radius: var(--radius);\n      border: 1px solid transparent;\n      font-size: 15px;\n      font-weight: 650;\n      letter-spacing: 0;\n      transition: transform 0.05s ease, background 0.15s ease, border-color 0.15s ease;\n    }\n    .btn:active { transform: translateY(1px); }\n    .btn-primary { background: var(--accent); color: var(--surface); border-color: var(--accent); }\n    .btn-primary:hover { background: color-mix(in oklch, var(--accent) 88%, black); }\n    .btn-secondary { background: transparent; color: var(--fg); border-color: var(--border); }\n    .btn-secondary:hover { border-color: var(--fg); }\n    .btn-ghost { background: transparent; color: var(--fg); border-color: transparent; padding-inline: 8px; }\n    .btn-ghost:hover { color: var(--accent); }\n    .btn-arrow::after { content: '->'; transition: transform 0.15s ease; }\n    .btn-arrow:hover::after { transform: translateX(2px); }\n\n    .card {\n      background: var(--surface);\n      border: 1px solid var(--border);\n      border-radius: var(--radius-lg);\n      padding: 28px;\n    }\n    .card-flat { background: transparent; border: 0; padding: 0; }\n    .card-rule { background: transparent; border: 0; border-top: 1px solid var(--fg); padding: 24px 0 0; border-radius: 0; }\n    .feature .feature-mark {\n      width: 36px;\n      height: 36px;\n      display: grid;\n      place-items: center;\n      border: 1px solid var(--border);\n      border-radius: 10px;\n      color: var(--fg);\n      margin-bottom: var(--gap-md);\n    }\n    .feature .feature-mark svg { width: 18px; height: 18px; }\n    .feature h3 { margin-bottom: 6px; }\n    .feature p { margin: 0; color: var(--muted); font-size: 15px; }\n\n    .pill {\n      display: inline-flex;\n      align-items: center;\n      gap: 6px;\n      padding: 4px 10px;\n      background: var(--fg-soft);\n      color: var(--muted);\n      border-radius: 999px;\n      font-family: var(--font-mono);\n      font-size: 11px;\n      letter-spacing: 0.04em;\n      text-transform: uppercase;\n    }\n    .tag {\n      display: inline-flex;\n      align-items: center;\n      padding: 4px 10px;\n      background: transparent;\n      color: var(--muted);\n      border: 1px solid var(--border);\n      border-radius: 999px;\n      font-size: 12px;\n    }\n\n    .field { display: flex; flex-direction: column; gap: 6px; }\n    .field label { font-size: 13px; color: var(--muted); }\n    .input, .textarea, .select {\n      width: 100%;\n      padding: 11px 14px;\n      border: 1px solid var(--border);\n      border-radius: var(--radius);\n      background: var(--surface);\n      color: var(--fg);\n      font: inherit;\n      font-size: 15px;\n    }\n    .input:focus, .textarea:focus, .select:focus {\n      outline: 2px solid var(--accent-soft);\n      border-color: var(--accent);\n    }\n    .textarea { min-height: 112px; resize: vertical; line-height: 1.55; }\n\n    .hero { padding-block: clamp(44px, 7vw, 92px); }\n    .hero-split { display: grid; grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.15fr); gap: var(--gap-xl); align-items: center; }\n    .hero-cta { display: inline-flex; gap: var(--gap-sm); flex-wrap: wrap; }\n    .hero-card {\n      overflow: hidden;\n      border-radius: 24px;\n      border: 1px solid var(--border);\n      background: var(--surface);\n      box-shadow: 0 24px 80px color-mix(in oklch, var(--fg) 13%, transparent);\n    }\n    .hero-card img { width: 100%; height: clamp(320px, 42vw, 560px); object-fit: cover; }\n    .hero-strip {\n      display: grid;\n      grid-template-columns: repeat(3, 1fr);\n      border-top: 1px solid var(--border);\n      background: var(--surface);\n    }\n    .hero-strip div { padding: 16px 18px; border-right: 1px solid var(--border); }\n    .hero-strip div:last-child { border-right: 0; }\n    .hero-strip strong { display: block; font-size: 15px; }\n    .hero-strip span { display: block; margin-top: 4px; color: var(--muted); font-size: 13px; }\n\n    .material-card {\n      overflow: hidden;\n      padding: 0;\n    }\n    .material-card img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; border-bottom: 1px solid var(--border); }\n    .material-card .stack { padding: 22px; }\n\n    .service-panel {\n      display: grid;\n      grid-template-columns: 1.1fr 0.9fr;\n      gap: var(--gap-lg);\n      align-items: stretch;\n    }\n    .service-panel img { width: 100%; height: 100%; min-height: 420px; object-fit: cover; border-radius: var(--radius-lg); border: 1px solid var(--border); }\n    .service-row {\n      display: grid;\n      grid-template-columns: 32px 1fr;\n      gap: 16px;\n      padding: 18px 0;\n      border-top: 1px solid var(--border);\n    }\n    .service-row:first-child { border-top: 0; padding-top: 0; }\n    .service-row p { margin: 4px 0 0; color: var(--muted); font-size: 15px; }\n\n    .process-step {\n      display: grid;\n      grid-template-columns: 44px 1fr;\n      gap: 18px;\n      padding: 22px 0;\n      border-top: 1px solid var(--border);\n    }\n    .process-step:first-child { border-top: 0; }\n    .step-num {\n      width: 44px;\n      height: 44px;\n      display: grid;\n      place-items: center;\n      border: 1px solid var(--border);\n      border-radius: 999px;\n      font-family: var(--font-mono);\n      color: var(--fg);\n    }\n    .checklist {\n      display: grid;\n      gap: 12px;\n      margin: 0;\n      padding: 0;\n      list-style: none;\n    }\n    .checklist li {\n      display: grid;\n      grid-template-columns: 18px 1fr;\n      gap: 10px;\n      color: var(--muted);\n      font-size: 15px;\n    }\n    .checklist li::before { content: ''; width: 10px; height: 10px; border: 1px solid var(--border); background: var(--fg-soft); border-radius: 999px; margin-top: 7px; }\n\n    details { border-top: 1px solid var(--border); padding: 18px 0; }\n    details:last-child { border-bottom: 1px solid var(--border); }\n    summary { cursor: pointer; font-weight: 650; font-family: var(--font-display); font-size: 19px; }\n    details p { margin: 10px 0 0; color: var(--muted); }\n\n    .contact-band {\n      background: var(--surface);\n      border: 1px solid var(--border);\n      border-radius: 24px;\n      padding: clamp(24px, 4vw, 44px);\n    }\n    .wordmark {\n      font-family: var(--font-display);\n      font-size: clamp(52px, 11vw, 144px);\n      line-height: 0.88;\n      letter-spacing: 0;\n      color: color-mix(in oklch, var(--fg) 12%, transparent);\n      margin-top: var(--gap-xl);\n      overflow-wrap: anywhere;\n    }\n\n    @media (max-width: 920px) {\n      .grid-2, .grid-3, .grid-4, .grid-2-1, .grid-1-2, .hero-split, .service-panel { grid-template-columns: 1fr; }\n      .topnav nav { display: none; }\n      .topnav .btn { padding-inline: 14px; }\n      .hero-card img { height: 360px; }\n      .hero-strip { grid-template-columns: 1fr; }\n      .hero-strip div { border-right: 0; border-bottom: 1px solid var(--border); }\n      .hero-strip div:last-child { border-bottom: 0; }\n      .container { padding-inline: 20px; }\n      .service-panel img { min-height: 300px; }\n    }\n  </style>\n  <script type=\"application/ld+json\">\n    {\n      \"@context\": \"https://schema.org\",\n      \"@type\": \"RoofingContractor\",\n      \"name\": \"RidgeLine Roof Co.\",\n      \"telephone\": \"0400 000 000\",\n      \"areaServed\": [\n        \"Brisbane\",\n        \"Gold Coast\"\n      ],\n      \"address\": {\n        \"@type\": \"PostalAddress\",\n        \"streetAddress\": \"Address to be confirmed\",\n        \"addressLocality\": \"Brisbane\",\n        \"addressRegion\": \"QLD\",\n        \"addressCountry\": \"AU\"\n      },\n      \"url\": \"\",\n      \"sameAs\": [],\n      \"hasMap\": \"https://www.google.com/maps/search/?api=1&query=Brisbane+roofing+contractor\",\n      \"priceRange\": \"Contact for quote\",\n      \"description\": \"Local roofing contractor offering roof repairs, roof restoration, metal roofing, gutter repairs, and roof inspections across Brisbane and Gold Coast.\"\n    }\n  </script>\n</head>\n<body>\n  <header class=\"topnav\" data-od-id=\"topnav\">\n    <div class=\"container topnav-inner\">\n      <a class=\"logo\" href=\"#top\" aria-label=\"RidgeLine Roof Co. home\">RidgeLine Roof Co.</a>\n      <nav aria-label=\"Primary navigation\">\n        <a href=\"#services\">Services</a>\n        <a href=\"#materials\">Roof systems</a>\n        <a href=\"#process\">Quote process</a>\n        <a href=\"#faq\">FAQ</a>\n      </nav>\n      <a class=\"btn btn-secondary\" href=\"tel:0400000000\">Call 0400 000 000</a>\n    </div>\n  </header>\n\n  <main id=\"content\">\n    <section class=\"section hero\" id=\"top\" data-od-id=\"hero\">\n      <div class=\"container hero-split\">\n        <div class=\"stack\">\n          <div>\n            <p class=\"eyebrow\">Roof repairs, restoration and inspections</p>\n            <h1>Modern roofing help for Brisbane and Gold Coast homes.</h1>\n          </div>\n          <p class=\"lead\">RidgeLine Roof Co. helps homeowners compare repair, restoration, gutter and metal roofing options before committing to the right next step.</p>\n          <div class=\"hero-cta\">\n            <a class=\"btn btn-primary\" href=\"#contact\">Request an inspection</a>\n            <a class=\"btn btn-secondary\" href=\"tel:0400000000\">Call 0400 000 000</a>\n          </div>\n          <div class=\"row\" style=\"flex-wrap: wrap;\">\n            <span class=\"tag\">Roof repairs</span>\n            <span class=\"tag\">Restoration</span>\n            <span class=\"tag\">Metal roofing</span>\n            <span class=\"tag\">Gutters</span>\n          </div>\n        </div>\n        <figure class=\"hero-card\" aria-label=\"Modern metal roofing at sunset\">\n          <img src=\"assets/hero-family3-hero-modern-metal-roof-sunset-wide.png\" alt=\"Modern home with a clean metal roof at sunset\" />\n          <figcaption class=\"hero-strip\">\n            <div><strong>Start with the roof condition</strong><span>Inspection-first advice before scope is set.</span></div>\n            <div><strong>Compare clear options</strong><span>Repair, restore, replace, or schedule gutter work.</span></div>\n            <div><strong>Built for local weather</strong><span>Practical guidance for Brisbane and Gold Coast homes.</span></div>\n          </figcaption>\n        </figure>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"services\" data-od-id=\"services\">\n      <div class=\"container stack\" style=\"gap: 56px;\">\n        <div class=\"row-between\" style=\"align-items: end;\">\n          <div style=\"max-width: 42ch;\">\n            <p class=\"eyebrow\">Request the right work</p>\n            <h2>Roofing services arranged around what the home needs now.</h2>\n          </div>\n          <a class=\"btn btn-ghost btn-arrow\" href=\"#contact\">Send roof details</a>\n        </div>\n        <div class=\"service-panel\">\n          <div class=\"card\">\n            <article class=\"service-row\">\n              <span class=\"meta num\">01</span>\n              <div>\n                <h3>Roof repairs</h3>\n                <p>For leaks, storm damage, loose sheets, cracked tiles and localised roof failures that need practical attention.</p>\n              </div>\n            </article>\n            <article class=\"service-row\">\n              <span class=\"meta num\">02</span>\n              <div>\n                <h3>Roof restoration</h3>\n                <p>For tired roofs that may need cleaning, preparation, coating or staged remediation before bigger issues appear.</p>\n              </div>\n            </article>\n            <article class=\"service-row\">\n              <span class=\"meta num\">03</span>\n              <div>\n                <h3>Metal roofing</h3>\n                <p>For homeowners considering a clean, modern roof profile or replacing a worn roof with a metal system.</p>\n              </div>\n            </article>\n            <article class=\"service-row\">\n              <span class=\"meta num\">04</span>\n              <div>\n                <h3>Gutter repairs</h3>\n                <p>For overflow, rust, sagging sections and drainage problems that are affecting the roof edge and walls below.</p>\n              </div>\n            </article>\n            <article class=\"service-row\">\n              <span class=\"meta num\">05</span>\n              <div>\n                <h3>Roof inspections</h3>\n                <p>For buyers, sellers and homeowners who want the roof checked before choosing a repair or restoration path.</p>\n              </div>\n            </article>\n          </div>\n          <img src=\"assets/service-family3-service-modern-roofer-metal-roof.png\" alt=\"Roofing professional working on a modern metal roof\" loading=\"lazy\" />\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"materials\" data-od-id=\"materials\">\n      <div class=\"container stack\" style=\"gap: 48px;\">\n        <div class=\"grid-2\" style=\"align-items: end;\">\n          <div>\n            <p class=\"eyebrow\">Roof system comparison</p>\n            <h2>Material conversations made easier to understand.</h2>\n          </div>\n          <p class=\"lead\">Use the inspection to narrow the work: keep the existing profile, restore what is sound, or compare a more durable roof system.</p>\n        </div>\n        <div class=\"grid-3\">\n          <article class=\"card material-card\">\n            <img src=\"assets/materialMetal-family3-product-standing-seam-metal-sample.png\" alt=\"Standing seam metal roofing material sample\" loading=\"lazy\" />\n            <div class=\"stack\">\n              <span class=\"pill\">Metal profile</span>\n              <h3>Standing seam metal</h3>\n              <p style=\"margin: 0; color: var(--muted);\">A crisp profile for modern homes and replacement projects where clean lines matter.</p>\n            </div>\n          </article>\n          <article class=\"card material-card\">\n            <img src=\"assets/materialTerracotta-family3-product-terracotta-tile-sample.png\" alt=\"Terracotta tile roofing material sample\" loading=\"lazy\" />\n            <div class=\"stack\">\n              <span class=\"pill\">Tile profile</span>\n              <h3>Terracotta tile</h3>\n              <p style=\"margin: 0; color: var(--muted);\">A familiar option for homes where tile character, repairability and street fit are part of the decision.</p>\n            </div>\n          </article>\n          <article class=\"card material-card\">\n            <img src=\"assets/materialComposite-family3-product-composite-shingle-sample.png\" alt=\"Composite shingle roofing material sample\" loading=\"lazy\" />\n            <div class=\"stack\">\n              <span class=\"pill\">Composite profile</span>\n              <h3>Composite shingle</h3>\n              <p style=\"margin: 0; color: var(--muted);\">A textured look that can suit selected repairs, upgrades and style-led roof conversations.</p>\n            </div>\n          </article>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" data-od-id=\"proof\">\n      <div class=\"container grid-1-2\">\n        <div class=\"stack\">\n          <p class=\"eyebrow\">Before a quote</p>\n          <h2>Inspection evidence keeps the decision grounded.</h2>\n          <p class=\"lead\">A roof quote should be based on visible condition, access, likely water paths, edge drainage and the work that will actually solve the problem.</p>\n        </div>\n        <div class=\"grid-2\">\n          <img src=\"assets/inspection-family3-inspection-drone-roof-check.png\" alt=\"Drone-style roof inspection view showing roof condition\" loading=\"lazy\" style=\"width: 100%; height: 100%; min-height: 360px; object-fit: cover; border: 1px solid var(--border); border-radius: var(--radius-lg);\" />\n          <div class=\"card stack\">\n            <h3>What gets checked</h3>\n            <ul class=\"checklist\">\n              <li>Leak symptoms and roof penetrations.</li>\n              <li>Sheet, tile, ridge and flashing condition.</li>\n              <li>Gutter fall, overflow and roof edge details.</li>\n              <li>Access, safety and staging considerations.</li>\n              <li>Repair versus restoration trade-offs.</li>\n            </ul>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"process\" data-od-id=\"quote-process\">\n      <div class=\"container grid-2-1\">\n        <div class=\"card\">\n          <div class=\"process-step\">\n            <span class=\"step-num num\">01</span>\n            <div>\n              <h3>Describe the issue</h3>\n              <p style=\"margin: 6px 0 0; color: var(--muted);\">Tell RidgeLine what you can see: leak location, roof type, visible damage, or whether you need a general inspection.</p>\n            </div>\n          </div>\n          <div class=\"process-step\">\n            <span class=\"step-num num\">02</span>\n            <div>\n              <h3>Arrange an inspection path</h3>\n              <p style=\"margin: 6px 0 0; color: var(--muted);\">The next step is scoped around access, urgency and whether the home needs repair, restoration or replacement advice.</p>\n            </div>\n          </div>\n          <div class=\"process-step\">\n            <span class=\"step-num num\">03</span>\n            <div>\n              <h3>Compare the recommended work</h3>\n              <p style=\"margin: 6px 0 0; color: var(--muted);\">You receive a clear direction for the requested roofing work, with no invented package pricing on this page.</p>\n            </div>\n          </div>\n        </div>\n        <aside class=\"stack\">\n          <p class=\"eyebrow\">Quote path</p>\n          <h2>Start with a call or a short form.</h2>\n          <p class=\"lead\">For urgent roof damage, call first. For planned repairs or restoration, the enquiry form gives enough context to prepare the next conversation.</p>\n          <a class=\"btn btn-primary\" href=\"tel:0400000000\">Call 0400 000 000</a>\n        </aside>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"faq\" data-od-id=\"faq-contact-footer\">\n      <div class=\"container contact-band\" id=\"contact\">\n        <div class=\"grid-2\" style=\"gap: var(--gap-xl);\">\n          <div class=\"stack\">\n            <div>\n              <p class=\"eyebrow\">Common questions</p>\n              <h2>Answers before you request a roof inspection.</h2>\n            </div>\n            <div>\n              <details open>\n                <summary>Can I ask for a repair instead of a full replacement?</summary>\n                <p>Yes. The enquiry can begin with a specific repair concern, and the inspection path should confirm whether a smaller repair is suitable.</p>\n              </details>\n              <details>\n                <summary>Do you cover Brisbane and Gold Coast homes?</summary>\n                <p>Yes. The service area for this concept page is Brisbane and Gold Coast.</p>\n              </details>\n              <details>\n                <summary>Can you compare roof materials?</summary>\n                <p>Yes. RidgeLine can discuss metal roofing, tile roof considerations and other material options during the quote conversation.</p>\n              </details>\n              <details>\n                <summary>What should I prepare before enquiring?</summary>\n                <p>Share the suburb, roof type if you know it, photos if available, and whether the issue is urgent or part of planned maintenance.</p>\n              </details>\n            </div>\n            <p class=\"meta\">Directions: <a href=\"https://www.google.com/maps/search/?api=1&amp;query=Brisbane+roofing+contractor\">Brisbane roofing contractor map search</a></p>\n          </div>\n          <form class=\"stack\" aria-label=\"Roofing enquiry form\">\n            <div>\n              <p class=\"eyebrow\">Request an inspection or quote</p>\n              <h2>Tell us what is happening on the roof.</h2>\n            </div>\n            <div class=\"grid-2\" style=\"gap: 14px;\">\n              <div class=\"field\">\n                <label for=\"name\">Name</label>\n                <input class=\"input\" id=\"name\" name=\"name\" autocomplete=\"name\" />\n              </div>\n              <div class=\"field\">\n                <label for=\"phone\">Phone</label>\n                <input class=\"input\" id=\"phone\" name=\"phone\" autocomplete=\"tel\" />\n              </div>\n            </div>\n            <div class=\"field\">\n              <label for=\"suburb\">Suburb</label>\n              <input class=\"input\" id=\"suburb\" name=\"suburb\" autocomplete=\"address-level2\" />\n            </div>\n            <div class=\"field\">\n              <label for=\"service\">What do you need?</label>\n              <select class=\"select\" id=\"service\" name=\"service\">\n                <option>Roof inspection</option>\n                <option>Roof repairs</option>\n                <option>Roof restoration</option>\n                <option>Metal roofing</option>\n                <option>Gutter repairs</option>\n              </select>\n            </div>\n            <div class=\"field\">\n              <label for=\"message\">Roof details</label>\n              <textarea class=\"textarea\" id=\"message\" name=\"message\" placeholder=\"Leak location, roof material, visible damage, access notes or preferred timing.\"></textarea>\n            </div>\n            <button class=\"btn btn-primary\" type=\"button\">Send enquiry</button>\n            <p class=\"meta\">Prefer to talk? <a href=\"tel:0400000000\">Call 0400 000 000</a>. Opening hours can be confirmed when you enquire.</p>\n          </form>\n        </div>\n        <div class=\"wordmark\" aria-hidden=\"true\">RIDGELINE</div>\n      </div>\n    </section>\n  </main>\n\n  <footer class=\"pagefoot\" data-od-id=\"footer\">\n    <div class=\"container row-between\">\n      <span>RidgeLine Roof Co. · Roofing contractor · Brisbane and Gold Coast</span>\n      <span class=\"meta\">Roof repairs · Restoration · Metal roofing · Gutter repairs · Inspections</span>\n    </div>\n  </footer>\n</body>\n</html>\n</artifact>"}

