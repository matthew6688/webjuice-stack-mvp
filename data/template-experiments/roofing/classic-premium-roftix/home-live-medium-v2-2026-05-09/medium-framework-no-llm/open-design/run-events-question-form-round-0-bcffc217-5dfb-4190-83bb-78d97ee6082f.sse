data: {"type":"text_delta","delta":"Got it — one polished high-fidelity home page for RidgeLine Roof Co.; lock these choices before I build:\n\n<question-form id=\"discovery\" title=\"Quick brief — 30 seconds\">\n{\n  \"description\": \"I'll use the supplied roofing assets and Roftix design language. Skip what doesn't apply — I'll fill sensible defaults.\",\n  \"questions\": [\n    {\n      \"id\": \"platform\",\n      \"label\": \"Primary surface\",\n      \"type\": \"radio\",\n      \"required\": true,\n      \"options\": [\n        \"Responsive — all sizes\",\n        \"Desktop web\",\n        \"Mobile-first\",\n        \"Fixed screenshot canvas\"\n      ]\n    },\n    {\n      \"id\": \"tone\",\n      \"label\": \"Visual emphasis\",\n      \"type\": \"checkbox\",\n      \"maxSelections\": 2,\n      \"options\": [\n        \"Classic premium\",\n        \"Cinematic roof photography\",\n        \"Editorial and refined\",\n        \"Practical local contractor\",\n        \"Dark dramatic\",\n        \"Warm homeowner-friendly\"\n      ]\n    },\n    {\n      \"id\": \"hero_style\",\n      \"label\": \"Hero approach\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Full-bleed photographic hero\",\n        \"Split hero with image and quote form\",\n        \"Dark nav over image\",\n        \"Clean white nav above image\"\n      ]\n    },\n    {\n      \"id\": \"conversion\",\n      \"label\": \"Quote path priority\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Phone-first with secondary form\",\n        \"Form-first with phone support\",\n        \"Equal phone and form CTAs\"\n      ]\n    },\n    {\n      \"id\": \"section_density\",\n      \"label\": \"Page density\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Premium and spacious\",\n        \"Balanced\",\n        \"Dense with more service detail\"\n      ]\n    },\n    {\n      \"id\": \"constraints\",\n      \"label\": \"Anything else to avoid or emphasize?\",\n      \"type\": \"textarea\",\n      \"placeholder\": \"e.g. avoid orange, make the form above the fold, lean more luxury than trade...\"\n    }\n  ]\n}\n</question-form>"}

