data: {"type":"tool_result","toolUseId":"item_20","content":"index.html:1:<!doctype html>\nindex.html:2:<html lang=\"en\">\nindex.html:3:<head>\nindex.html:4:  <meta charset=\"utf-8\" />\nindex.html:5:  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\nindex.html:6:  <title>RidgeLine Roof Co. · Brisbane and Gold Coast Roofing</title>\nindex.html:7:  <style>\nindex.html:8:    :root {\nindex.html:9:      --bg:      oklch(97% 0.012 80);\nindex.html:10:      --surface: oklch(99% 0.005 80);\nindex.html:11:      --fg:      oklch(18% 0.035 245);\nindex.html:12:      --muted:   oklch(46% 0.018 72);\nindex.html:13:      --border:  oklch(88% 0.012 78);\nindex.html:14:      --accent:  oklch(46% 0.13 145);\nindex.html:15:\nindex.html:16:      --accent-soft: color-mix(in oklch, var(--accent) 14%, transparent);\nindex.html:17:      --fg-soft:     color-mix(in oklch, var(--fg) 6%, transparent);\nindex.html:18:\nindex.html:19:      --font-display: 'Iowan Old Style', 'Charter', Georgia, 'Times New Roman', serif;\nindex.html:20:      --font-body:    -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;\nindex.html:21:      --font-mono:    ui-monospace, 'JetBrains Mono', 'SF Mono', Menlo, monospace;\nindex.html:22:\nindex.html:23:      --fs-h1: clamp(46px, 6.6vw, 86px);\nindex.html:24:      --fs-h2: clamp(32px, 4vw, 52px);\nindex.html:25:      --fs-h3: 22px;\nindex.html:26:      --fs-lead: 19px;\nindex.html:27:      --fs-body: 16px;\nindex.html:28:      --fs-meta: 13px;\nindex.html:29:\nindex.html:30:      --gap-xs: 8px;\nindex.html:31:      --gap-sm: 12px;\nindex.html:32:      --gap-md: 20px;\nindex.html:33:      --gap-lg: 32px;\nindex.html:34:      --gap-xl: 56px;\nindex.html:35:      --gap-2xl: 96px;\nindex.html:36:      --container: 1180px;\nindex.html:37:      --gutter: 32px;\nindex.html:38:\nindex.html:39:      --radius: 10px;\nindex.html:40:      --radius-lg: 16px;\nindex.html:41:    }\nindex.html:42:\nindex.html:43:    *, *::before, *::after { box-sizing: border-box; }\nindex.html:44:    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }\nindex.html:45:    body {\nindex.html:46:      margin: 0;\nindex.html:47:      background: var(--bg);\nindex.html:48:      color: var(--fg);\nindex.html:49:      font-family: var(--font-body);\nindex.html:50:      font-size: var(--fs-body);\nindex.html:51:      line-height: 1.55;\nindex.html:52:      text-rendering: optimizeLegibility;\nindex.html:53:      -webkit-font-smoothing: antialiased;\nindex.html:54:    }\nindex.html:55:    img, svg { display: block; max-width: 100%; }\nindex.html:56:    a { color: inherit; text-decoration: none; }\nindex.html:57:    button { font: inherit; cursor: pointer; }\nindex.html:58:    p { text-wrap: pretty; }\nindex.html:59:    h1, h2, h3, h4 { text-wrap: balance; }\nindex.html:60:\nindex.html:61:    .container { max-width: var(--container); margin-inline: auto; padding-inline: var(--gutter); }\nindex.html:62:    .section { padding-block: clamp(56px, 8vw, var(--gap-2xl)); }\nindex.html:63:    .section + .section { border-top: 1px solid var(--border); }\nindex.html:64:    .stack { display: flex; flex-direction: column; }\nindex.html:65:    .stack > * + * { margin-top: var(--gap-md); }\nindex.html:66:    .row { display: flex; align-items: center; gap: var(--gap-md); }\nindex.html:67:    .row-between { display: flex; align-items: center; justify-content: space-between; gap: var(--gap-md); }\nindex.html:68:    .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--gap-lg); }\nindex.html:69:    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap-lg); }\nindex.html:70:    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--gap-md); }\nindex.html:71:    .grid-2-1 { display: grid; grid-template-columns: 2fr 1fr; gap: var(--gap-xl); align-items: start; }\nindex.html:72:    .grid-1-2 { display: grid; grid-template-columns: 1fr 2fr; gap: var(--gap-xl); align-items: start; }\nindex.html:73:    @media (max-width: 920px) {\nindex.html:74:      .grid-2, .grid-3, .grid-4, .grid-2-1, .grid-1-2 { grid-template-columns: 1fr; }\nindex.html:75:    }\nindex.html:76:\nindex.html:77:    .h1, h1 { font-family: var(--font-display); font-size: var(--fs-h1); line-height: 1.02; letter-spacing: -0.02em; margin: 0; }\nindex.html:78:    .h2, h2 { font-family: var(--font-display); font-size: var(--fs-h2); line-height: 1.08; letter-spacing: -0.015em; margin: 0; }\nindex.html:79:    .h3, h3 { font-family: var(--font-display); font-size: var(--fs-h3); font-weight: 600; line-height: 1.25; letter-spacing: -0.005em; margin: 0; }\nindex.html:80:    .lead { font-size: var(--fs-lead); line-height: 1.55; color: var(--muted); max-width: 60ch; margin: 0; }\nindex.html:81:    .eyebrow {\nindex.html:82:      font-family: var(--font-mono);\nindex.html:83:      font-size: 12px;\nindex.html:84:      letter-spacing: 0.08em;\nindex.html:85:      text-transform: uppercase;\nindex.html:86:      color: var(--accent);\nindex.html:87:      margin: 0 0 var(--gap-md);\nindex.html:88:    }\nindex.html:89:    .meta { font-family: var(--font-mono); font-size: var(--fs-meta); color: var(--muted); }\nindex.html:90:    .num { font-family: var(--font-mono); font-variant-numeric: tabular-nums; }\nindex.html:91:\nindex.html:92:    .topnav {\nindex.html:93:      position: sticky; top: 0; z-index: 10;\nindex.html:94:      background: color-mix(in oklch, var(--surface) 92%, transparent);\nindex.html:95:      backdrop-filter: blur(12px);\nindex.html:96:      border-bottom: 1px solid var(--border);\nindex.html:97:    }\nindex.html:98:    .topnav-inner { display: flex; align-items: center; justify-content: space-between; padding-block: 14px; }\nindex.html:99:    .topnav .logo { font-family: var(--font-display); font-size: 22px; font-weight: 600; letter-spacing: -0.01em; }\nindex.html:100:    .topnav nav { display: flex; gap: var(--gap-lg); }\nindex.html:101:    .topnav nav a { font-size: 14px; color: var(--muted); }\nindex.html:102:    .topnav nav a:hover { color: var(--fg); }\nindex.html:103:    .pagefoot { padding-block: var(--gap-xl); color: color-mix(in oklch, var(--surface) 68%, transparent); font-size: 13px; background: var(--fg); }\nindex.html:104:    .pagefoot .row-between { flex-wrap: wrap; gap: var(--gap-md); }\nindex.html:105:    .pagefoot a:hover { color: var(--surface); }\nindex.html:106:\nindex.html:107:    .btn {\nindex.html:108:      display: inline-flex; align-items: center; justify-content: center; gap: 8px;\nindex.html:109:      min-height: 44px;\nindex.html:110:      padding: 11px 20px;\nindex.html:111:      border-radius: var(--radius);\nindex.html:112:      border: 1px solid transparent;\nindex.html:113:      font-size: 15px;\nindex.html:114:      font-weight: 650;\nindex.html:115:      letter-spacing: -0.005em;\nindex.html:116:      transition: transform 0.05s ease, background 0.15s ease, border-color 0.15s ease, color 0.15s ease;\nindex.html:117:    }\nindex.html:118:    .btn:active { transform: translateY(1px); }\nindex.html:119:    .btn-primary { background: var(--accent); color: var(--surface); border-color: var(--accent); }\nindex.html:120:    .btn-primary:hover { background: color-mix(in oklch, var(--accent) 88%, black); }\nindex.html:121:    .btn-secondary { background: transparent; color: var(--fg); border-color: var(--border); }\nindex.html:122:    .btn-secondary:hover { border-color: var(--fg); }\nindex.html:123:    .btn-ghost { background: transparent; color: var(--fg); border-color: transparent; padding-inline: 8px; }\nindex.html:124:    .btn-ghost:hover { color: var(--accent); }\nindex.html:125:    .btn-arrow::after { content: '>'; transition: transform 0.15s ease; }\nindex.html:126:    .btn-arrow:hover::after { transform: translateX(2px); }\nindex.html:127:\nindex.html:128:    .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 28px; }\nindex.html:129:    .card-flat { background: transparent; border: 0; padding: 0; }\nindex.html:130:    .card-rule { background: transparent; border: 0; border-top: 1px solid var(--fg); padding: 24px 0 0; border-radius: 0; }\nindex.html:131:    .feature .feature-mark {\nindex.html:132:      width: 36px; height: 36px;\nindex.html:133:      display: grid; place-items: center;\nindex.html:134:      border: 1px solid var(--border);\nindex.html:135:      border-radius: 10px;\nindex.html:136:      color: var(--accent);\nindex.html:137:      margin-bottom: var(--gap-md);\nindex.html:138:    }\nindex.html:139:    .feature .feature-mark svg { width: 18px; height: 18px; }\nindex.html:140:    .feature h3 { margin-bottom: 6px; }\nindex.html:141:    .feature p { margin: 0; color: var(--muted); font-size: 15px; }\nindex.html:142:    .pill {\nindex.html:143:      display: inline-flex; align-items: center; gap: 6px;\nindex.html:144:      padding: 4px 10px;\nindex.html:145:      background: var(--accent-soft);\nindex.html:146:      color: var(--accent);\nindex.html:147:      border-radius: 999px;\nindex.html:148:      font-family: var(--font-mono);\nindex.html:149:      font-size: 11px;\nindex.html:150:      letter-spacing: 0.04em;\nindex.html:151:      text-transform: uppercase;\nindex.html:152:    }\nindex.html:153:    .tag {\nindex.html:154:      display: inline-flex; align-items: center;\nindex.html:155:      padding: 4px 10px;\nindex.html:156:      background: transparent;\nindex.html:157:      color: var(--muted);\nindex.html:158:      border: 1px solid var(--border);\nindex.html:159:      border-radius: 999px;\nindex.html:160:      font-size: 12px;\nindex.html:161:    }\nindex.html:162:    .field { display: flex; flex-direction: column; gap: 6px; }\nindex.html:163:    .field label { font-size: 13px; color: var(--muted); }\nindex.html:164:    .input, .textarea {\nindex.html:165:      width: 100%;\nindex.html:166:      padding: 12px 14px;\nindex.html:167:      border: 1px solid var(--border);\nindex.html:168:      border-radius: var(--radius);\nindex.html:169:      background: var(--surface);\nindex.html:170:      color: var(--fg);\nindex.html:171:      font: inherit;\nindex.html:172:      font-size: 15px;\nindex.html:173:    }\nindex.html:174:    .input:focus, .textarea:focus { outline: 2px solid var(--accent-soft); border-color: var(--accent); }\nindex.html:175:    .textarea { min-height: 106px; resize: vertical; line-height: 1.55; }\nindex.html:176:    .rule { border: 0; border-top: 1px solid var(--border); margin: 0; }\nindex.html:177:    .rule-strong { border: 0; border-top: 1px solid var(--fg); margin: 0; }\nindex.html:178:    .hero { padding-block: clamp(80px, 12vw, 156px); }\nindex.html:179:    .hero-cta { display: inline-flex; gap: var(--gap-sm); flex-wrap: wrap; }\nindex.html:180:    .hero-split { display: grid; grid-template-columns: minmax(0, .86fr) minmax(0, 1.14fr); gap: var(--gap-xl); align-items: center; }\nindex.html:181:    @media (max-width: 920px) { .hero-split { grid-template-columns: 1fr; } }\nindex.html:182:\nindex.html:183:    .hero-photo {\nindex.html:184:      position: relative;\nindex.html:185:      min-height: clamp(420px, 48vw, 650px);\nindex.html:186:      border-radius: 0 0 0 64px;\nindex.html:187:      overflow: hidden;\nindex.html:188:      border: 1px solid color-mix(in oklch, var(--surface) 22%, transparent);\nindex.html:189:      background: var(--fg);\nindex.html:190:    }\nindex.html:191:    .hero-photo img, .image-panel img { width: 100%; height: 100%; object-fit: cover; }\nindex.html:192:    .hero-photo::after {\nindex.html:193:      content: \"\";\nindex.html:194:      position: absolute; inset: 0;\nindex.html:195:      background: linear-gradient(180deg, transparent, color-mix(in oklch, var(--fg) 38%, transparent));\nindex.html:196:    }\nindex.html:197:    .hero-note {\nindex.html:198:      position: absolute;\nindex.html:199:      left: 28px; right: 28px; bottom: 28px;\nindex.html:200:      z-index: 1;\nindex.html:201:      display: flex;\nindex.html:202:      justify-content: space-between;\nindex.html:203:      gap: var(--gap-md);\nindex.html:204:      color: var(--surface);\nindex.html:205:      border-top: 1px solid color-mix(in oklch, var(--surface) 42%, transparent);\nindex.html:206:      padding-top: 18px;\nindex.html:207:    }\nindex.html:208:    .hero-note strong { font-family: var(--font-display); font-size: 26px; line-height: 1.1; }\nindex.html:209:    .dark-band { background: var(--fg); color: var(--surface); }\nindex.html:210:    .dark-band .lead, .dark-band .meta, .dark-band p { color: color-mix(in oklch, var(--surface) 72%, transparent); }\nindex.html:211:    .dark-band .card { background: color-mix(in oklch, var(--surface) 8%, transparent); border-color: color-mix(in oklch, var(--surface) 20%, transparent); }\nindex.html:212:    .dark-band .tag { border-color: color-mix(in oklch, var(--surface) 25%, transparent); color: color-mix(in oklch, var(--surface) 75%, transparent); }\nindex.html:213:    .image-panel { min-height: 320px; overflow: hidden; border-radius: var(--radius-lg); border: 1px solid var(--border); background: var(--surface); }\nindex.html:214:    .service-card { padding: 0; overflow: hidden; }\nindex.html:215:    .service-card img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; border-bottom: 1px solid var(--border); }\nindex.html:216:    .service-card div { padding: 24px; }\nindex.html:217:    .process-step { display: grid; grid-template-columns: 48px 1fr; gap: var(--gap-md); padding-block: 22px; border-top: 1px solid var(--border); }\nindex.html:218:    .process-step:first-child { border-top: 0; padding-top: 0; }\nindex.html:219:    .step-num { width: 40px; height: 40px; display: grid; place-items: center; border: 1px solid var(--border); border-radius: 999px; font-family: var(--font-mono); color: var(--muted); }\nindex.html:220:    .faq-row { border-top: 1px solid var(--border); padding-block: 22px; }\nindex.html:221:    .faq-row p { margin: 8px 0 0; color: var(--muted); }\nindex.html:222:    .contact-grid { display: grid; grid-template-columns: .85fr 1.15fr; gap: var(--gap-xl); align-items: start; }\nindex.html:223:    @media (max-width: 920px) {\nindex.html:224:      .topnav nav { display: none; }\nindex.html:225:      .topnav .btn { display: none; }\nindex.html:226:      .hero-note { position: relative; left: auto; right: auto; bottom: auto; margin: -96px 20px 20px; flex-direction: column; }\nindex.html:227:      .contact-grid { grid-template-columns: 1fr; }\nindex.html:228:      .section { padding-block: 56px; }\nindex.html:229:      .hero { padding-top: 64px; }\nindex.html:230:    }\nindex.html:231:  </style>\nindex.html:232:</head>\nindex.html:233:<body>\nindex.html:234:  <header class=\"topnav\" data-od-id=\"topnav\">\nindex.html:235:    <div class=\"container topnav-inner\">\nindex.html:236:      <a class=\"logo\" href=\"#top\" aria-label=\"RidgeLine Roof Co. home\">RidgeLine Roof Co.</a>\nindex.html:237:      <nav aria-label=\"Primary navigation\">\nindex.html:238:        <a href=\"#services\">Services</a>\nindex.html:239:        <a href=\"#work\">Work</a>\nindex.html:240:        <a href=\"#process\">Process</a>\nindex.html:241:        <a href=\"#contact\">Contact</a>\nindex.html:242:      </nav>\nindex.html:243:      <a class=\"btn btn-primary\" href=\"tel:0400000000\">Call 0400 000 000</a>\nindex.html:244:    </div>\nindex.html:245:  </header>\nindex.html:246:\nindex.html:247:  <main id=\"content\">\nindex.html:248:    <section class=\"section hero\" data-od-id=\"hero\" id=\"top\">\nindex.html:249:      <div class=\"container hero-split\">\nindex.html:250:        <div>\nindex.html:251:          <p class=\"eyebrow\">Roofing · Brisbane and Gold Coast</p>\nindex.html:252:          <h1>Premium roof repairs and restorations for homes that need proper attention.</h1>\nindex.html:253:          <p class=\"lead\" style=\"margin-top: 20px;\">RidgeLine Roof Co. helps homeowners request roof repairs, restorations, metal roofing, gutter repairs, and inspections with a clear quote path from the first call.</p>\nindex.html:254:          <div class=\"hero-cta\" style=\"margin-top: 30px;\">\nindex.html:255:            <a class=\"btn btn-primary\" href=\"#contact\">Request an inspection</a>\nindex.html:256:            <a class=\"btn btn-secondary\" href=\"tel:0400000000\">Call 0400 000 000</a>\nindex.html:257:          </div>\nindex.html:258:        </div>\nindex.html:259:        <figure class=\"hero-photo\" aria-label=\"Premium residential roof illustration\">\nindex.html:260:          <img src=\"assets/roof-hero.svg\" alt=\"Premium residential roof at blue hour\" />\nindex.html:261:          <figcaption class=\"hero-note\">\nindex.html:262:            <strong>Designed for weather, presentation, and long-term care.</strong>\nindex.html:263:            <span class=\"meta\">Inspection-led roofing for established homes.</span>\nindex.html:264:          </figcaption>\nindex.html:265:        </figure>\nindex.html:266:      </div>\nindex.html:267:    </section>\nindex.html:268:\nindex.html:269:    <section class=\"section\" data-od-id=\"services\" id=\"services\">\nindex.html:270:      <div class=\"container stack\" style=\"gap: 56px;\">\nindex.html:271:        <div class=\"row-between\" style=\"align-items: end;\">\nindex.html:272:          <div style=\"max-width: 42ch;\">\nindex.html:273:            <p class=\"eyebrow\">What you can request</p>\nindex.html:274:            <h2>Roofing work explained plainly before anyone climbs a ladder.</h2>\nindex.html:275:          </div>\nindex.html:276:          <p class=\"lead\" style=\"max-width: 34ch;\">Choose the closest service and the team can confirm the right scope after an inspection.</p>\nindex.html:277:        </div>\nindex.html:278:        <div class=\"grid-3\">\nindex.html:279:          <article class=\"card service-card\">\nindex.html:280:            <img src=\"assets/roof-detail.svg\" alt=\"Roof flashing repair detail\" />\nindex.html:281:            <div>\nindex.html:282:              <h3>Roof repairs</h3>\nindex.html:283:              <p>For leaks, flashing issues, storm damage, cracked bedding, and localised roof problems that need careful diagnosis.</p>\nindex.html:284:            </div>\nindex.html:285:          </article>\nindex.html:286:          <article class=\"card service-card\">\nindex.html:287:            <img src=\"assets/roof-install.svg\" alt=\"Metal roofing installation detail\" />\nindex.html:288:            <div>\nindex.html:289:              <h3>Roof restoration</h3>\nindex.html:290:              <p>Cleaning, preparation, repair planning, and finish recommendations for roofs that need renewed performance and street appeal.</p>\nindex.html:291:            </div>\nindex.html:292:          </article>\nindex.html:293:          <article class=\"card service-card\">\nindex.html:294:            <img src=\"assets/roof-proof.svg\" alt=\"Before and after roof transformation structure\" />\nindex.html:295:            <div>\nindex.html:296:              <h3>Metal roofing and gutters</h3>\nindex.html:297:              <p>Metal roof installation enquiries, gutter repairs, and roof inspection requests across Brisbane and the Gold Coast.</p>\nindex.html:298:            </div>\nindex.html:299:          </article>\nindex.html:300:        </div>\nindex.html:301:      </div>\nindex.html:302:    </section>\nindex.html:303:\nindex.html:304:    <section class=\"section dark-band\" data-od-id=\"proof\" id=\"work\">\nindex.html:305:      <div class=\"container grid-1-2\">\nindex.html:306:        <div>\nindex.html:307:          <p class=\"eyebrow\">Work you can assess</p>\nindex.html:308:          <h2>Concrete project structure without inflated claims.</h2>\nindex.html:309:          <p class=\"lead\" style=\"margin-top: 18px;\">A useful roofing website should show the work type, material considerations, inspection notes, and next steps without leaning on fake reviews or unverifiable badges.</p>\nindex.html:310:        </div>\nindex.html:311:        <div class=\"grid-2\">\nindex.html:312:          <div class=\"card\">\nindex.html:313:            <span class=\"tag\">Inspection</span>\nindex.html:314:            <h3 style=\"margin-top: 18px;\">Roof condition notes</h3>\nindex.html:315:            <p>Capture visible roof age, water entry points, gutter condition, access constraints, and priority repairs before presenting a scope.</p>\nindex.html:316:          </div>\nindex.html:317:          <div class=\"card\">\nindex.html:318:            <span class=\"tag\">Materials</span>\nindex.html:319:            <h3 style=\"margin-top: 18px;\">Repair and finish options</h3>\nindex.html:320:            <p>Explain whether the likely path is repair, restoration, metal roofing, or gutter work in homeowner language.</p>\nindex.html:321:          </div>\nindex.html:322:          <div class=\"card\">\nindex.html:323:            <span class=\"tag\">Photos</span>\nindex.html:324:            <h3 style=\"margin-top: 18px;\">Before and after records</h3>\nindex.html:325:            <p>Use project photos to make workmanship visible, with captions that describe the actual work completed.</p>\nindex.html:326:          </div>\nindex.html:327:          <div class=\"card\">\nindex.html:328:            <span class=\"tag\">Quote</span>\nindex.html:329:            <h3 style=\"margin-top: 18px;\">Clear scope next</h3>\nindex.html:330:            <p>Turn the inspection into a written scope so the homeowner knows what is included before approving work.</p>\nindex.html:331:          </div>\nindex.html:332:        </div>\nindex.html:333:      </div>\nindex.html:334:    </section>\nindex.html:335:\nindex.html:336:    <section class=\"section\" data-od-id=\"quote-process\" id=\"process\">\nindex.html:337:      <div class=\"container grid-2\">\nindex.html:338:        <div class=\"image-panel\">\nindex.html:339:          <img src=\"assets/roof-install.svg\" alt=\"Metal roofing detail\" />\nindex.html:340:        </div>\nindex.html:341:        <div>\nindex.html:342:          <p class=\"eyebrow\">Inspection to quote</p>\nindex.html:343:          <h2>A simple path from roof concern to next action.</h2>\nindex.html:344:          <div style=\"margin-top: 34px;\">\nindex.html:345:            <div class=\"process-step\">\nindex.html:346:              <span class=\"step-num num\">01</span>\nindex.html:347:              <div>\nindex.html:348:                <h3>Send the roof concern</h3>\nindex.html:349:                <p>Use the form or call with the suburb, roof type if known, and what you have noticed.</p>\nindex.html:350:              </div>\nindex.html:351:            </div>\nindex.html:352:            <div class=\"process-step\">\nindex.html:353:              <span class=\"step-num num\">02</span>\nindex.html:354:              <div>\nindex.html:355:                <h3>Arrange an inspection</h3>\nindex.html:356:                <p>The visit focuses on the visible problem, access, safety constraints, and the right service path.</p>\nindex.html:357:              </div>\nindex.html:358:            </div>\nindex.html:359:            <div class=\"process-step\">\nindex.html:360:              <span class=\"step-num num\">03</span>\nindex.html:361:              <div>\nindex.html:362:                <h3>Receive a scoped quote</h3>\nindex.html:363:                <p>The quote should separate immediate repairs from optional restoration or improvement work.</p>\nindex.html:364:              </div>\nindex.html:365:            </div>\nindex.html:366:          </div>\nindex.html:367:        </div>\nindex.html:368:      </div>\nindex.html:369:    </section>\nindex.html:370:\nindex.html:371:    <section class=\"section\" data-od-id=\"faq-contact-footer\" id=\"contact\">\nindex.html:372:      <div class=\"container contact-grid\">\nindex.html:373:        <div>\nindex.html:374:          <p class=\"eyebrow\">Questions and enquiry</p>\nindex.html:375:          <h2>Ask for a roof inspection or quote.</h2>\nindex.html:376:          <div style=\"margin-top: 34px;\">\nindex.html:377:            <div class=\"faq-row\">\nindex.html:378:              <h3>What areas do you service?</h3>\nindex.html:379:              <p>RidgeLine Roof Co. handles roofing enquiries across Brisbane and the Gold Coast.</p>\nindex.html:380:            </div>\nindex.html:381:            <div class=\"faq-row\">\nindex.html:382:              <h3>Can I request only a repair?</h3>\nindex.html:383:              <p>Yes. The enquiry can start with a specific roof leak, gutter problem, flashing issue, or storm-related concern.</p>\nindex.html:384:            </div>\nindex.html:385:            <div class=\"faq-row\">\nindex.html:386:              <h3>Do you publish prices online?</h3>\nindex.html:387:              <p>No fixed prices are listed here because roof condition, access, materials, and scope need to be assessed first.</p>\nindex.html:388:            </div>\nindex.html:389:          </div>\nindex.html:390:        </div>\nindex.html:391:        <form class=\"card stack\" action=\"#\" method=\"post\" aria-label=\"Roofing enquiry form\">\nindex.html:392:          <div class=\"row-between\" style=\"align-items: start;\">\nindex.html:393:            <div>\nindex.html:394:              <h3>Roofing enquiry</h3>\nindex.html:395:              <p style=\"margin: 8px 0 0; color: var(--muted);\">Share the basics and request a call back.</p>\nindex.html:396:            </div>\nindex.html:397:            <span class=\"pill\">Quote path</span>\nindex.html:398:          </div>\nindex.html:399:          <div class=\"grid-2\" style=\"gap: 16px;\">\nindex.html:400:            <div class=\"field\">\nindex.html:401:              <label for=\"name\">Name</label>\nindex.html:402:              <input class=\"input\" id=\"name\" name=\"name\" autocomplete=\"name\" />\nindex.html:403:            </div>\nindex.html:404:            <div class=\"field\">\nindex.html:405:              <label for=\"phone\">Phone</label>\nindex.html:406:              <input class=\"input\" id=\"phone\" name=\"phone\" autocomplete=\"tel\" />\nindex.html:407:            </div>\nindex.html:408:          </div>\nindex.html:409:          <div class=\"grid-2\" style=\"gap: 16px;\">\nindex.html:410:            <div class=\"field\">\nindex.html:411:              <label for=\"suburb\">Suburb</label>\nindex.html:412:              <input class=\"input\" id=\"suburb\" name=\"suburb\" />\nindex.html:413:            </div>\nindex.html:414:            <div class=\"field\">\nindex.html:415:              <label for=\"service\">Service needed</label>\nindex.html:416:              <select class=\"input\" id=\"service\" name=\"service\">\nindex.html:417:                <option>Roof inspection</option>\nindex.html:418:                <option>Roof repairs</option>\nindex.html:419:                <option>Roof restoration</option>\nindex.html:420:                <option>Metal roofing</option>\nindex.html:421:                <option>Gutter repairs</option>\nindex.html:422:              </select>\nindex.html:423:            </div>\nindex.html:424:          </div>\nindex.html:425:          <div class=\"field\">\nindex.html:426:            <label for=\"message\">What is happening with the roof?</label>\nindex.html:427:            <textarea class=\"textarea\" id=\"message\" name=\"message\"></textarea>\nindex.html:428:          </div>\nindex.html:429:          <div class=\"row-between\" style=\"align-items: center;\">\nindex.html:430:            <button class=\"btn btn-primary\" type=\"submit\">Request an inspection</button>\nindex.html:431:            <a class=\"btn btn-ghost\" href=\"tel:0400000000\">Call 0400 000 000</a>\nindex.html:432:          </div>\nindex.html:433:        </form>\nindex.html:434:      </div>\nindex.html:435:    </section>\nindex.html:436:  </main>\nindex.html:437:\nindex.html:438:  <footer class=\"pagefoot\" data-od-id=\"footer\">\nindex.html:439:    <div class=\"container row-between\">\nindex.html:440:      <span>RidgeLine Roof Co. · Local roofing contractor</span>\nindex.html:441:      <span class=\"meta\">Brisbane and Gold Coast · <a href=\"tel:0400000000\">0400 000 000</a></span>\nindex.html:442:    </div>\nindex.html:443:  </footer>\nindex.html:444:</body>\nindex.html:445:</html>\nassets/roof-detail.svg:1:<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 900 620\" role=\"img\" aria-label=\"Roof flashing repair detail\">\nassets/roof-detail.svg:2:  <rect width=\"900\" height=\"620\" fill=\"oklch(91% 0.014 75)\"/>\nassets/roof-detail.svg:3:  <path d=\"M0 220 900 60v160L0 380Z\" fill=\"oklch(30% 0.045 245)\"/>\nassets/roof-detail.svg:4:  <path d=\"M0 380 900 220v260L0 620Z\" fill=\"oklch(20% 0.035 245)\"/>\nassets/roof-detail.svg:5:  <g stroke=\"oklch(62% 0.025 245)\" stroke-width=\"4\" opacity=\".6\">\nassets/roof-detail.svg:6:    <path d=\"M80 365 860 230\"/>\nassets/roof-detail.svg:7:    <path d=\"M70 430 850 295\"/>\nassets/roof-detail.svg:8:    <path d=\"M60 495 840 360\"/>\nassets/roof-detail.svg:9:  </g>\nassets/roof-detail.svg:10:  <rect x=\"470\" y=\"110\" width=\"92\" height=\"420\" rx=\"6\" fill=\"oklch(54% 0.018 72)\"/>\nassets/roof-detail.svg:11:  <path d=\"M438 255h160l-30 82H468Z\" fill=\"oklch(58% 0.11 145)\"/>\nassets/roof-detail.svg:12:  <circle cx=\"338\" cy=\"310\" r=\"58\" fill=\"oklch(93% 0.014 76)\" opacity=\".95\"/>\nassets/roof-detail.svg:13:  <path d=\"M316 309h44M338 287v44\" stroke=\"oklch(19% 0.03 245)\" stroke-width=\"8\" stroke-linecap=\"round\"/>\nassets/roof-detail.svg:14:</svg>\nassets/roof-install.svg:1:<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 900 620\" role=\"img\" aria-label=\"Metal roofing installation detail\">\nassets/roof-install.svg:2:  <rect width=\"900\" height=\"620\" fill=\"oklch(95% 0.01 78)\"/>\nassets/roof-install.svg:3:  <path d=\"M0 250 900 80v540H0Z\" fill=\"oklch(25% 0.04 245)\"/>\nassets/roof-install.svg:4:  <g stroke=\"oklch(57% 0.03 245)\" stroke-width=\"6\" opacity=\".7\">\nassets/roof-install.svg:5:    <path d=\"M70 292 820 150\"/>\nassets/roof-install.svg:6:    <path d=\"M70 362 820 220\"/>\nassets/roof-install.svg:7:    <path d=\"M70 432 820 290\"/>\nassets/roof-install.svg:8:    <path d=\"M70 502 820 360\"/>\nassets/roof-install.svg:9:  </g>\nassets/roof-install.svg:10:  <path d=\"M105 214 765 90 820 134 162 258Z\" fill=\"oklch(58% 0.11 145)\"/>\nassets/roof-install.svg:11:  <rect x=\"596\" y=\"225\" width=\"165\" height=\"86\" rx=\"12\" fill=\"oklch(91% 0.014 76)\"/>\nassets/roof-install.svg:12:  <path d=\"M635 266h88\" stroke=\"oklch(18% 0.03 245)\" stroke-width=\"10\" stroke-linecap=\"round\"/>\nassets/roof-install.svg:13:</svg>\nassets/roof-hero.svg:1:<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1400 980\" role=\"img\" aria-label=\"Premium residential roof at blue hour\">\nassets/roof-hero.svg:2:  <defs>\nassets/roof-hero.svg:3:    <linearGradient id=\"sky\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\nassets/roof-hero.svg:4:      <stop offset=\"0\" stop-color=\"oklch(21% 0.05 250)\"/>\nassets/roof-hero.svg:5:      <stop offset=\"0.58\" stop-color=\"oklch(32% 0.055 245)\"/>\nassets/roof-hero.svg:6:      <stop offset=\"1\" stop-color=\"oklch(45% 0.07 55)\"/>\nassets/roof-hero.svg:7:    </linearGradient>\nassets/roof-hero.svg:8:    <linearGradient id=\"roof\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\nassets/roof-hero.svg:9:      <stop offset=\"0\" stop-color=\"oklch(30% 0.045 240)\"/>\nassets/roof-hero.svg:10:      <stop offset=\"1\" stop-color=\"oklch(15% 0.035 245)\"/>\nassets/roof-hero.svg:11:    </linearGradient>\nassets/roof-hero.svg:12:    <filter id=\"soft\" x=\"-20%\" y=\"-20%\" width=\"140%\" height=\"140%\">\nassets/roof-hero.svg:13:      <feGaussianBlur stdDeviation=\"18\"/>\nassets/roof-hero.svg:14:    </filter>\nassets/roof-hero.svg:15:  </defs>\nassets/roof-hero.svg:16:  <rect width=\"1400\" height=\"980\" fill=\"url(#sky)\"/>\nassets/roof-hero.svg:17:  <circle cx=\"1130\" cy=\"190\" r=\"150\" fill=\"oklch(87% 0.09 70)\" opacity=\".18\" filter=\"url(#soft)\"/>\nassets/roof-hero.svg:18:  <path d=\"M0 610 350 365 700 610Z\" fill=\"url(#roof)\"/>\nassets/roof-hero.svg:19:  <path d=\"M330 365 700 610 1120 338 1400 505v475H0V610Z\" fill=\"oklch(18% 0.036 245)\"/>\nassets/roof-hero.svg:20:  <path d=\"M700 610 1120 338 1400 505v128L1120 465 700 738Z\" fill=\"oklch(11% 0.03 245)\" opacity=\".85\"/>\nassets/roof-hero.svg:21:  <path d=\"M330 365 700 610 700 738 330 493 0 722V610Z\" fill=\"oklch(24% 0.04 245)\"/>\nassets/roof-hero.svg:22:  <g opacity=\".36\" stroke=\"oklch(65% 0.035 235)\" stroke-width=\"3\">\nassets/roof-hero.svg:23:    <path d=\"M380 400 80 610\"/>\nassets/roof-hero.svg:24:    <path d=\"M455 450 155 660\"/>\nassets/roof-hero.svg:25:    <path d=\"M530 500 230 710\"/>\nassets/roof-hero.svg:26:    <path d=\"M605 550 305 760\"/>\nassets/roof-hero.svg:27:    <path d=\"M760 595 1160 338\"/>\nassets/roof-hero.svg:28:    <path d=\"M830 645 1230 388\"/>\nassets/roof-hero.svg:29:    <path d=\"M900 695 1300 438\"/>\nassets/roof-hero.svg:30:  </g>\nassets/roof-hero.svg:31:  <rect x=\"735\" y=\"690\" width=\"560\" height=\"290\" fill=\"oklch(93% 0.014 76)\"/>\nassets/roof-hero.svg:32:  <rect x=\"790\" y=\"755\" width=\"135\" height=\"110\" fill=\"oklch(21% 0.04 248)\"/>\nassets/roof-hero.svg:33:  <rect x=\"990\" y=\"755\" width=\"135\" height=\"110\" fill=\"oklch(21% 0.04 248)\"/>\nassets/roof-hero.svg:34:  <rect x=\"0\" y=\"0\" width=\"1400\" height=\"980\" fill=\"oklch(10% 0.03 245)\" opacity=\".18\"/>\nassets/roof-hero.svg:35:</svg>\nassets/roof-proof.svg:1:<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1000 620\" role=\"img\" aria-label=\"Before and after roof transformation\">\nassets/roof-proof.svg:2:  <rect width=\"1000\" height=\"620\" fill=\"oklch(94% 0.012 78)\"/>\nassets/roof-proof.svg:3:  <rect x=\"64\" y=\"76\" width=\"408\" height=\"468\" rx=\"18\" fill=\"oklch(99% 0.005 80)\"/>\nassets/roof-proof.svg:4:  <rect x=\"528\" y=\"76\" width=\"408\" height=\"468\" rx=\"18\" fill=\"oklch(99% 0.005 80)\"/>\nassets/roof-proof.svg:5:  <path d=\"M90 325 268 190 446 325v176H90Z\" fill=\"oklch(46% 0.018 75)\"/>\nassets/roof-proof.svg:6:  <path d=\"M555 325 733 190 911 325v176H555Z\" fill=\"oklch(21% 0.04 245)\"/>\nassets/roof-proof.svg:7:  <g opacity=\".42\" stroke=\"oklch(70% 0.018 75)\" stroke-width=\"4\">\nassets/roof-proof.svg:8:    <path d=\"M118 330h300M118 380h300M118 430h300\"/>\nassets/roof-proof.svg:9:  </g>\nassets/roof-proof.svg:10:  <g opacity=\".48\" stroke=\"oklch(61% 0.025 245)\" stroke-width=\"4\">\nassets/roof-proof.svg:11:    <path d=\"M582 330h300M582 380h300M582 430h300\"/>\nassets/roof-proof.svg:12:  </g>\nassets/roof-proof.svg:13:  <path d=\"M90 325 268 190 446 325\" fill=\"none\" stroke=\"oklch(34% 0.018 75)\" stroke-width=\"22\" stroke-linejoin=\"round\"/>\nassets/roof-proof.svg:14:  <path d=\"M555 325 733 190 911 325\" fill=\"none\" stroke=\"oklch(58% 0.11 145)\" stroke-width=\"22\" stroke-linejoin=\"round\"/>\nassets/roof-proof.svg:15:  <text x=\"102\" y=\"124\" font-family=\"ui-monospace, Menlo, monospace\" font-size=\"24\" fill=\"oklch(50% 0.018 50)\">BEFORE</text>\nassets/roof-proof.svg:16:  <text x=\"566\" y=\"124\" font-family=\"ui-monospace, Menlo, monospace\" font-size=\"24\" fill=\"oklch(50% 0.018 50)\">AFTER</text>\nassets/roof-proof.svg:17:</svg>\n","isError":false}

