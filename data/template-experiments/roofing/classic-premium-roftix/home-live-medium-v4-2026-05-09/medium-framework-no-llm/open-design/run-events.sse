event: agent
data: {"type":"tool_result","toolUseId":"item_14","content":"1:<!doctype html>\n2:<html lang=\"en\">\n3:<head>\n4:  <meta charset=\"utf-8\" />\n5:  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n6:  <title>RidgeLine Roof Co. · Brisbane and Gold Coast roofing</title>\n7:  <style>\n8:    :root {\n9:      --bg:      oklch(97% 0.014 82);\n10:      --surface: oklch(100% 0 0);\n11:      --fg:      oklch(17% 0.028 250);\n12:      --muted:   oklch(46% 0.018 245);\n13:      --border:  oklch(88% 0.012 82);\n14:      --accent:  oklch(44% 0.105 152);\n15:\n16:      --accent-soft: color-mix(in oklch, var(--accent) 14%, transparent);\n17:      --fg-soft:     color-mix(in oklch, var(--fg) 6%, transparent);\n18:\n19:      --font-display: 'Iowan Old Style', 'Charter', Georgia, 'Times New Roman', serif;\n20:      --font-body:    -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;\n21:      --font-mono:    ui-monospace, 'JetBrains Mono', 'SF Mono', Menlo, monospace;\n22:\n23:      --fs-h1: clamp(46px, 6.6vw, 86px);\n24:      --fs-h2: clamp(34px, 4vw, 52px);\n25:      --fs-h3: 22px;\n26:      --fs-lead: 19px;\n27:      --fs-body: 16px;\n28:      --fs-meta: 13px;\n29:\n30:      --gap-xs: 8px;\n31:      --gap-sm: 12px;\n32:      --gap-md: 20px;\n33:      --gap-lg: 32px;\n34:      --gap-xl: 56px;\n35:      --gap-2xl: 96px;\n36:      --container: 1180px;\n37:      --gutter: 32px;\n38:\n39:      --radius: 8px;\n40:      --radius-lg: 14px;\n41:    }\n42:\n43:    *, *::before, *::after { box-sizing: border-box; }\n44:    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }\n45:    body {\n46:      margin: 0;\n47:      background: var(--bg);\n48:      color: var(--fg);\n49:      font-family: var(--font-body);\n50:      font-size: var(--fs-body);\n51:      line-height: 1.55;\n52:      text-rendering: optimizeLegibility;\n53:      -webkit-font-smoothing: antialiased;\n54:    }\n55:    img, svg { display: block; max-width: 100%; }\n56:    a { color: inherit; text-decoration: none; }\n57:    button { font: inherit; cursor: pointer; }\n58:    p { text-wrap: pretty; }\n59:    h1, h2, h3, h4 { text-wrap: balance; }\n60:\n61:    .container { max-width: var(--container); margin-inline: auto; padding-inline: var(--gutter); }\n62:    .section { padding-block: clamp(56px, 8vw, var(--gap-2xl)); }\n63:    .section + .section { border-top: 1px solid var(--border); }\n64:    .stack { display: flex; flex-direction: column; }\n65:    .stack > * + * { margin-top: var(--gap-md); }\n66:    .row { display: flex; align-items: center; gap: var(--gap-md); }\n67:    .row-between { display: flex; align-items: center; justify-content: space-between; gap: var(--gap-md); }\n68:    .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--gap-lg); }\n69:    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap-lg); }\n70:    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--gap-md); }\n71:    .grid-2-1 { display: grid; grid-template-columns: 2fr 1fr; gap: var(--gap-xl); align-items: start; }\n72:    .grid-1-2 { display: grid; grid-template-columns: 1fr 2fr; gap: var(--gap-xl); align-items: start; }\n73:    @media (max-width: 920px) {\n74:      .grid-2, .grid-3, .grid-4, .grid-2-1, .grid-1-2 { grid-template-columns: 1fr; }\n75:    }\n76:\n77:    .h1, h1 { font-family: var(--font-display); font-size: var(--fs-h1); line-height: 1.02; letter-spacing: 0; margin: 0; }\n78:    .h2, h2 { font-family: var(--font-display); font-size: var(--fs-h2); line-height: 1.08; letter-spacing: 0; margin: 0; }\n79:    .h3, h3 { font-family: var(--font-display); font-size: var(--fs-h3); font-weight: 600; line-height: 1.26; letter-spacing: 0; margin: 0; }\n80:    .lead { font-size: var(--fs-lead); line-height: 1.55; color: var(--muted); max-width: 60ch; margin: 0; }\n81:    .eyebrow {\n82:      font-family: var(--font-mono);\n83:      font-size: 12px;\n84:      letter-spacing: 0.08em;\n85:      text-transform: uppercase;\n86:      color: var(--accent);\n87:      margin: 0 0 var(--gap-md);\n88:    }\n89:    .meta { font-family: var(--font-mono); font-size: var(--fs-meta); color: var(--muted); }\n90:    .num { font-family: var(--font-mono); font-variant-numeric: tabular-nums; }\n91:\n92:    .topnav {\n93:      position: sticky; top: 0; z-index: 10;\n94:      background: color-mix(in oklch, var(--bg) 92%, transparent);\n95:      backdrop-filter: blur(12px);\n96:      border-bottom: 1px solid var(--border);\n97:    }\n98:    .topnav-inner { display: flex; align-items: center; justify-content: space-between; padding-block: 14px; }\n99:    .topnav .logo { font-family: var(--font-display); font-size: 21px; font-weight: 600; letter-spacing: 0; }\n100:    .topnav nav { display: flex; gap: var(--gap-lg); }\n101:    .topnav nav a { font-size: 14px; color: var(--muted); }\n102:    .topnav nav a:hover { color: var(--fg); }\n103:    .pagefoot { padding-block: var(--gap-xl); color: color-mix(in oklch, var(--surface) 62%, var(--muted)); font-size: 14px; border-top: 1px solid color-mix(in oklch, var(--surface) 16%, transparent); background: var(--fg); }\n104:    .pagefoot .row-between { flex-wrap: wrap; gap: var(--gap-md); align-items: flex-start; }\n105:    .pagefoot a:hover { color: var(--surface); }\n106:\n107:    .btn {\n108:      display: inline-flex; align-items: center; justify-content: center; gap: 8px;\n109:      min-height: 44px;\n110:      padding: 11px 20px;\n111:      border-radius: var(--radius);\n112:      border: 1px solid transparent;\n113:      font-size: 15px;\n114:      font-weight: 650;\n115:      letter-spacing: 0;\n116:      transition: transform 0.05s ease, background 0.15s ease, border-color 0.15s ease;\n117:    }\n118:    .btn:active { transform: translateY(1px); }\n119:    .btn-primary { background: var(--accent); color: var(--surface); border-color: var(--accent); }\n120:    .btn-primary:hover { background: color-mix(in oklch, var(--accent) 86%, var(--fg)); }\n121:    .btn-secondary { background: transparent; color: var(--fg); border-color: var(--border); }\n122:    .btn-secondary:hover { border-color: var(--fg); }\n123:    .btn-ghost { background: transparent; color: var(--fg); border-color: transparent; padding-inline: 8px; }\n124:    .btn-ghost:hover { color: var(--accent); }\n125:    .btn-arrow::after { content: '>'; transition: transform 0.15s ease; }\n126:    .btn-arrow:hover::after { transform: translateX(2px); }\n127:\n128:    .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 28px; }\n129:    .card-flat { background: transparent; border: 0; padding: 0; }\n130:    .card-rule { background: transparent; border: 0; border-top: 1px solid var(--fg); padding: 24px 0 0; border-radius: 0; }\n131:    .feature .feature-mark {\n132:      width: 36px; height: 36px;\n133:      display: grid; place-items: center;\n134:      border: 1px solid var(--border);\n135:      border-radius: 10px;\n136:      color: var(--accent);\n137:      margin-bottom: var(--gap-md);\n138:    }\n139:    .feature .feature-mark svg { width: 18px; height: 18px; }\n140:    .feature h3 { margin-bottom: 6px; }\n141:    .feature p { margin: 0; color: var(--muted); font-size: 15px; }\n142:    .pill {\n143:      display: inline-flex; align-items: center; gap: 6px;\n144:      padding: 4px 10px;\n145:      background: var(--accent-soft);\n146:      color: var(--accent);\n147:      border-radius: 999px;\n148:      font-family: var(--font-mono);\n149:      font-size: 11px;\n150:      letter-spacing: 0.04em;\n151:      text-transform: uppercase;\n152:    }\n153:    .tag {\n154:      display: inline-flex; align-items: center;\n155:      padding: 4px 10px;\n156:      background: transparent;\n157:      color: var(--muted);\n158:      border: 1px solid var(--border);\n159:      border-radius: 999px;\n160:      font-size: 12px;\n161:    }\n162:    .field { display: flex; flex-direction: column; gap: 6px; }\n163:    .field label { font-size: 13px; color: var(--muted); }\n164:    .input, .textarea, .select {\n165:      width: 100%;\n166:      padding: 11px 14px;\n167:      border: 1px solid var(--border);\n168:      border-radius: var(--radius);\n169:      background: var(--surface);\n170:      color: var(--fg);\n171:      font: inherit;\n172:      font-size: 15px;\n173:    }\n174:    .input:focus, .textarea:focus, .select:focus { outline: 2px solid var(--accent-soft); border-color: var(--accent); }\n175:    .textarea { min-height: 110px; resize: vertical; line-height: 1.55; }\n176:    .ph-img {\n177:      background: linear-gradient(135deg, var(--accent-soft), var(--fg-soft)), var(--surface);\n178:      border: 1px solid var(--border);\n179:      border-radius: var(--radius-lg);\n180:      aspect-ratio: 16 / 10;\n181:      display: grid; place-items: center;\n182:      color: var(--muted);\n183:      font-family: var(--font-mono);\n184:      font-size: 12px;\n185:      letter-spacing: 0.04em;\n186:    }\n187:    .ph-img.square { aspect-ratio: 1 / 1; }\n188:    .ph-img.portrait { aspect-ratio: 3 / 4; }\n189:    .ph-img.wide { aspect-ratio: 16 / 9; }\n190:    .rule { border: 0; border-top: 1px solid var(--border); margin: 0; }\n191:    .rule-strong { border: 0; border-top: 1px solid var(--fg); margin: 0; }\n192:    .hero { padding-block: clamp(80px, 12vw, 160px); }\n193:    .hero-center { text-align: center; max-width: 32ch; margin-inline: auto; }\n194:    .hero h1 { margin-bottom: var(--gap-md); }\n195:    .hero .lead { margin-bottom: var(--gap-lg); }\n196:    .hero-cta { display: inline-flex; gap: var(--gap-sm); flex-wrap: wrap; }\n197:    .hero-center .hero-cta { justify-content: center; }\n198:    .hero-split { display: grid; grid-template-columns: 1fr 1fr; gap: var(--gap-2xl); align-items: center; }\n199:    @media (max-width: 920px) { .hero-split { grid-template-columns: 1fr; } }\n200:    .log-row { display: grid; grid-template-columns: 120px 1fr 100px; gap: var(--gap-lg); padding: 22px 0; border-top: 1px solid var(--border); align-items: baseline; }\n201:    .log-row .meta { color: var(--muted); }\n202:    .log-row h3 { font-size: 19px; }\n203:    .log-row .pull { text-align: right; }\n204:\n205:    .roof-hero {\n206:      min-height: clamp(680px, 88vh, 900px);\n207:      display: grid;\n208:      align-items: end;\n209:      padding: 0;\n210:      color: var(--surface);\n211:      background:\n212:        linear-gradient(180deg, color-mix(in oklch, var(--fg) 62%, transparent) 0%, color-mix(in oklch, var(--fg) 18%, transparent) 42%, color-mix(in oklch, var(--fg) 84%, transparent) 100%),\n213:        url('assets/hero-family1-hero-premium-roof-at-blue-hour.png') center / cover no-repeat;\n214:    }\n215:    .roof-hero .container { width: 100%; padding-block: 140px 86px; }\n216:    .hero-panel { max-width: 800px; }\n217:    .hero-panel .eyebrow { color: color-mix(in oklch, var(--surface) 88%, var(--accent)); }\n218:    .hero-panel .lead { color: color-mix(in oklch, var(--surface) 78%, transparent); max-width: 52ch; }\n219:    .hero-actions { display: flex; flex-wrap: wrap; gap: var(--gap-sm); margin-top: 30px; }\n220:    .hero-note {\n221:      margin-top: 34px;\n222:      display: grid;\n223:      grid-template-columns: repeat(3, minmax(0, 1fr));\n224:      max-width: 760px;\n225:      border-top: 1px solid color-mix(in oklch, var(--surface) 30%, transparent);\n226:    }\n227:    .hero-note span { padding: 16px 18px 0 0; color: color-mix(in oklch, var(--surface) 78%, transparent); font-size: 14px; }\n228:    .hero-note strong { display: block; color: var(--surface); font-family: var(--font-display); font-size: 22px; font-weight: 600; }\n229:    .nav-phone { display: inline-flex; align-items: center; gap: 8px; color: var(--fg); font-weight: 650; }\n230:    .section-intro { max-width: 620px; margin-bottom: 48px; }\n231:    .service-card { overflow: hidden; padding: 0; }\n232:    .service-card img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; }\n233:    .service-card .service-copy { padding: 24px; }\n234:    .service-list { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 18px; }\n235:    .proof-panel {\n236:      background: var(--surface);\n237:      border: 1px solid var(--border);\n238:      border-radius: var(--radius-lg);\n239:      overflow: hidden;\n240:    }\n241:    .proof-panel img { width: 100%; height: 100%; min-height: 420px; object-fit: cover; }\n242:    .proof-copy { padding: clamp(28px, 5vw, 52px); }\n243:    .cue-list { list-style: none; margin: 28px 0 0; padding: 0; display: grid; gap: 16px; }\n244:    .cue-list li { border-top: 1px solid var(--border); padding-top: 16px; color: var(--muted); }\n245:    .cue-list strong { display: block; color: var(--fg); font-family: var(--font-display); font-size: 21px; margin-bottom: 4px; }\n246:    .process-step { border-top: 1px solid var(--border); padding-top: 22px; }\n247:    .step-num { color: var(--accent); margin-bottom: 14px; display: block; }\n248:    .contact-band { background: var(--fg); color: var(--surface); }\n249:    .contact-band .lead, .contact-band .meta, .contact-band .field label { color: color-mix(in oklch, var(--surface) 70%, transparent); }\n250:    .contact-band .card { color: var(--fg); }\n251:    .contact-band .eyebrow { color: color-mix(in oklch, var(--surface) 84%, var(--accent)); }\n252:    .faq-list { display: grid; gap: 14px; }\n253:    details {\n254:      border-top: 1px solid color-mix(in oklch, var(--surface) 18%, transparent);\n255:      padding: 18px 0;\n256:    }\n257:    summary { cursor: pointer; font-family: var(--font-display); font-size: 22px; }\n258:    details p { color: color-mix(in oklch, var(--surface) 70%, transparent); margin-bottom: 0; }\n259:    .footer-grid { display: grid; grid-template-columns: 1.4fr 1fr 1fr; gap: var(--gap-lg); width: 100%; }\n260:\n261:    @media (max-width: 760px) {\n262:      :root { --gutter: 20px; }\n263:      .topnav nav { display: none; }\n264:      .topnav .btn { padding-inline: 14px; }\n265:      .roof-hero { min-height: 720px; }\n266:      .roof-hero .container { padding-block: 120px 56px; }\n267:      .hero-note { grid-template-columns: 1fr; }\n268:      .hero-note span { padding-top: 12px; }\n269:      .footer-grid { grid-template-columns: 1fr; }\n270:    }\n271:  </style>\n272:</head>\n273:<body>\n274:  <header class=\"topnav\" data-od-id=\"topnav\">\n275:    <div class=\"container topnav-inner\">\n276:      <a class=\"logo\" href=\"#top\" aria-label=\"RidgeLine Roof Co. home\">RidgeLine Roof Co.</a>\n277:      <nav aria-label=\"Primary navigation\">\n278:        <a href=\"#services\">Services</a>\n279:        <a href=\"#proof\">Work</a>\n280:        <a href=\"#process\">Process</a>\n281:        <a href=\"#contact\">Contact</a>\n282:      </nav>\n283:      <a class=\"btn btn-primary\" href=\"tel:0400000000\">Call 0400 000 000</a>\n284:    </div>\n285:  </header>\n286:\n287:  <main id=\"content\">\n288:    <section class=\"section roof-hero\" id=\"top\" data-od-id=\"hero\">\n289:      <div class=\"container\">\n290:        <div class=\"hero-panel\">\n291:          <p class=\"eyebrow\">Roofing contractor · Brisbane and Gold Coast</p>\n292:          <h1>Premium roof repairs and restoration for Queensland homes.</h1>\n293:          <p class=\"lead\">RidgeLine Roof Co. helps homeowners inspect, repair, restore, and replace roofing with clear advice before any work begins.</p>\n294:          <div class=\"hero-actions\">\n295:            <a class=\"btn btn-primary\" href=\"#contact\">Request an inspection</a>\n296:            <a class=\"btn btn-secondary\" href=\"tel:0400000000\">Phone 0400 000 000</a>\n297:          </div>\n298:          <div class=\"hero-note\" aria-label=\"Service highlights\">\n299:            <span><strong>Repairs</strong>Leaks, flashing, storm damage, gutters</span>\n300:            <span><strong>Restoration</strong>Cleaning, preparation, repainting, finish care</span>\n301:            <span><strong>Roofing</strong>Metal roofing and practical inspections</span>\n302:          </div>\n303:        </div>\n304:      </div>\n305:    </section>\n306:\n307:    <section class=\"section\" id=\"services\" data-od-id=\"services\">\n308:      <div class=\"container\">\n309:        <div class=\"section-intro\">\n310:          <p class=\"eyebrow\">What homeowners can request</p>\n311:          <h2>Roofing work explained plainly before the ladder goes up.</h2>\n312:          <p class=\"lead\" style=\"margin-top: 16px;\">From a small leak to a full roof restoration, the first step is a clear inspection and a written scope that separates urgent fixes from optional improvements.</p>\n313:        </div>\n314:        <div class=\"grid-3\">\n315:          <article class=\"card service-card\">\n316:            <img src=\"assets/serviceRepair-family1-service-roof-repair-flashing-detail.png\" alt=\"Close detail of roof repair and flashing work\">\n317:            <div class=\"service-copy\">\n318:              <h3>Roof repairs</h3>\n319:              <p style=\"color: var(--muted); margin-bottom: 0;\">Leak tracing, flashing attention, storm damage checks, and targeted repair work for problem areas.</p>\n320:            </div>\n321:          </article>\n322:          <article class=\"card service-card\">\n323:            <img src=\"assets/serviceInstall-family1-service-roof-installation-detail.png\" alt=\"Roofing material installation detail\">\n324:            <div class=\"service-copy\">\n325:              <h3>Restoration and metal roofing</h3>\n326:              <p style=\"color: var(--muted); margin-bottom: 0;\">Preparation-led restoration and metal roofing conversations for homes ready for a longer-term plan.</p>\n327:            </div>\n328:          </article>\n329:          <article class=\"card service-card\">\n330:            <img src=\"assets/about-family1-about-roofer-working-roof-frame.png\" alt=\"Roofer working on a residential roof frame\">\n331:            <div class=\"service-copy\">\n332:              <h3>Gutters and inspections</h3>\n333:              <p style=\"color: var(--muted); margin-bottom: 0;\">Gutter repairs, roof condition checks, and practical reporting for homeowners planning next steps.</p>\n334:            </div>\n335:          </article>\n336:        </div>\n337:        <div class=\"service-list\" aria-label=\"Available services\">\n338:          <span class=\"tag\">Roof repairs</span>\n339:          <span class=\"tag\">Roof restoration</span>\n340:          <span class=\"tag\">Metal roofing</span>\n341:          <span class=\"tag\">Gutter repairs</span>\n342:          <span class=\"tag\">Roof inspections</span>\n343:        </div>\n344:      </div>\n345:    </section>\n346:\n347:    <section class=\"section\" id=\"proof\" data-od-id=\"proof\">\n348:      <div class=\"container proof-panel\">\n349:        <div class=\"grid-1-2\" style=\"gap: 0;\">\n350:          <div class=\"proof-copy\">\n351:            <p class=\"eyebrow\">Concrete work cues</p>\n352:            <h2>A roof scope should show what was checked, not just what was quoted.</h2>\n353:            <p class=\"lead\" style=\"margin-top: 18px;\">The strongest roofing decisions come from visible conditions: flashings, ridges, gutters, roof sheets, drainage paths, and surface preparation.</p>\n354:            <ul class=\"cue-list\">\n355:              <li><strong>Before and after structure</strong>Use project photos to compare roof condition, access, preparation, and finished presentation.</li>\n356:              <li><strong>Material-specific notes</strong>Separate repair, restoration, and metal roofing recommendations instead of bundling everything into one vague quote.</li>\n357:              <li><strong>Clear exclusions</strong>If something needs further access or specialist confirmation, name it clearly before approval.</li>\n358:            </ul>\n359:          </div>\n360:          <img src=\"assets/proof-family1-project-before-after-roof-transformation.png\" alt=\"Before and after residential roof transformation\">\n361:        </div>\n362:      </div>\n363:    </section>\n364:\n365:    <section class=\"section\" id=\"process\" data-od-id=\"quote-process\">\n366:      <div class=\"container\">\n367:        <div class=\"row-between\" style=\"margin-bottom: 46px; align-items: end;\">\n368:          <div style=\"max-width: 620px;\">\n369:            <p class=\"eyebrow\">Inspection to quote</p>\n370:            <h2>A simple path from roof concern to written next step.</h2>\n371:          </div>\n372:          <a class=\"btn btn-secondary\" href=\"#contact\">Start an enquiry</a>\n373:        </div>\n374:        <div class=\"grid-4\">\n375:          <article class=\"process-step\">\n376:            <span class=\"meta step-num\">01</span>\n377:            <h3>Tell us what you are seeing</h3>\n378:            <p style=\"color: var(--muted);\">Leaks, visible wear, gutter overflow, storm concerns, or a roof you are planning to restore.</p>\n379:          </article>\n380:          <article class=\"process-step\">\n381:            <span class=\"meta step-num\">02</span>\n382:            <h3>Book a practical inspection</h3>\n383:            <p style=\"color: var(--muted);\">A roofing professional checks the relevant areas and asks about access, timing, and priorities.</p>\n384:          </article>\n385:          <article class=\"process-step\">\n386:            <span class=\"meta step-num\">03</span>\n387:            <h3>Review the recommended scope</h3>\n388:            <p style=\"color: var(--muted);\">You get plain-language repair or restoration recommendations before deciding what proceeds.</p>\n389:          </article>\n390:          <article class=\"process-step\">\n391:            <span class=\"meta step-num\">04</span>\n392:            <h3>Schedule the work</h3>\n393:            <p style=\"color: var(--muted);\">Timing, access, and site preparation are confirmed so the work can be completed with less disruption.</p>\n394:          </article>\n395:        </div>\n396:      </div>\n397:    </section>\n398:\n399:    <section class=\"section contact-band\" id=\"contact\" data-od-id=\"faq-contact-footer\">\n400:      <div class=\"container grid-2\" style=\"align-items: start;\">\n401:        <div>\n402:          <p class=\"eyebrow\">Questions and quotes</p>\n403:          <h2>Request a roof inspection or quote.</h2>\n404:          <p class=\"lead\" style=\"margin-top: 18px;\">Call RidgeLine Roof Co. or send the enquiry form with the service you need and where the roof is located.</p>\n405:          <div style=\"margin-top: 28px;\">\n406:            <a class=\"btn btn-primary\" href=\"tel:0400000000\">Call 0400 000 000</a>\n407:          </div>\n408:          <div class=\"faq-list\" style=\"margin-top: 54px;\">\n409:            <details open>\n410:              <summary>Can I ask for repairs only?</summary>\n411:              <p>Yes. The enquiry can be for a specific roof leak, flashing issue, gutter repair, or inspection before larger work is considered.</p>\n412:            </details>\n413:            <details>\n414:              <summary>Do you service both Brisbane and the Gold Coast?</summary>\n415:              <p>Yes, the service area for this page is Brisbane and Gold Coast.</p>\n416:            </details>\n417:            <details>\n418:              <summary>What should I include in the form?</summary>\n419:              <p>Share the suburb, roof concern, preferred timing, and any visible symptoms such as leaks, rust, loose flashing, or gutter overflow.</p>\n420:            </details>\n421:          </div>\n422:        </div>\n423:        <form class=\"card\" aria-label=\"Roofing enquiry form\">\n424:          <div class=\"grid-2\" style=\"gap: 16px;\">\n425:            <div class=\"field\">\n426:              <label for=\"name\">Name</label>\n427:              <input class=\"input\" id=\"name\" name=\"name\" autocomplete=\"name\">\n428:            </div>\n429:            <div class=\"field\">\n430:              <label for=\"phone\">Phone</label>\n431:              <input class=\"input\" id=\"phone\" name=\"phone\" autocomplete=\"tel\">\n432:            </div>\n433:          </div>\n434:          <div class=\"field\" style=\"margin-top: 16px;\">\n435:            <label for=\"suburb\">Suburb or service area</label>\n436:            <input class=\"input\" id=\"suburb\" name=\"suburb\" placeholder=\"Brisbane or Gold Coast area\">\n437:          </div>\n438:          <div class=\"field\" style=\"margin-top: 16px;\">\n439:            <label for=\"service\">What do you need?</label>\n440:            <select class=\"select\" id=\"service\" name=\"service\">\n441:              <option>Roof inspection</option>\n442:              <option>Roof repairs</option>\n443:              <option>Roof restoration</option>\n444:              <option>Metal roofing</option>\n445:              <option>Gutter repairs</option>\n446:            </select>\n447:          </div>\n448:          <div class=\"field\" style=\"margin-top: 16px;\">\n449:            <label for=\"message\">Roof details</label>\n450:            <textarea class=\"textarea\" id=\"message\" name=\"message\" placeholder=\"Tell us what you have noticed and when you would like the roof checked.\"></textarea>\n451:          </div>\n452:          <button class=\"btn btn-primary\" type=\"button\" style=\"width: 100%; margin-top: 20px;\">Send enquiry</button>\n453:          <p class=\"meta\" style=\"margin: 14px 0 0;\">For urgent roof concerns, phone the team directly.</p>\n454:        </form>\n455:      </div>\n456:    </section>\n457:  </main>\n458:\n459:  <footer class=\"pagefoot\" data-od-id=\"footer\">\n460:    <div class=\"container footer-grid\">\n461:      <div>\n462:        <h3 style=\"color: var(--surface); margin-bottom: 10px;\">RidgeLine Roof Co.</h3>\n463:        <p style=\"margin: 0; max-width: 40ch;\">Local roofing contractor for roof repairs, restoration, metal roofing, gutter repairs, and roof inspections.</p>\n464:      </div>\n465:      <div class=\"stack\">\n466:        <span class=\"meta\">Service area</span>\n467:        <a href=\"#contact\">Brisbane</a>\n468:        <a href=\"#contact\">Gold Coast</a>\n469:      </div>\n470:      <div class=\"stack\">\n471:        <span class=\"meta\">Contact</span>\n472:        <a href=\"tel:0400000000\">0400 000 000</a>\n473:        <a href=\"#contact\">Request an inspection</a>\n474:      </div>\n475:    </div>\n476:  </footer>\n477:</body>\n478:</html>\n","isError":false}

