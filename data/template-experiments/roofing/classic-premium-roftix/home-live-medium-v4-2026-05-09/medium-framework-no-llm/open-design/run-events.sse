id: 249
event: agent
data: {"type":"tool_result","toolUseId":"item_33","content":"<!doctype html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>RidgeLine Roof Co. · Brisbane and Gold Coast roofing</title>\n  <style>\n    :root {\n      --bg:      oklch(97% 0.014 82);\n      --surface: oklch(100% 0 0);\n      --fg:      oklch(17% 0.028 250);\n      --muted:   oklch(46% 0.018 245);\n      --border:  oklch(88% 0.012 82);\n      --accent:  oklch(44% 0.105 152);\n\n      --accent-soft: color-mix(in oklch, var(--accent) 14%, transparent);\n      --fg-soft:     color-mix(in oklch, var(--fg) 6%, transparent);\n\n      --font-display: 'Iowan Old Style', 'Charter', Georgia, 'Times New Roman', serif;\n      --font-body:    -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;\n      --font-mono:    ui-monospace, 'JetBrains Mono', 'SF Mono', Menlo, monospace;\n\n      --fs-h1: clamp(46px, 6.6vw, 86px);\n      --fs-h2: clamp(34px, 4vw, 52px);\n      --fs-h3: 22px;\n      --fs-lead: 19px;\n      --fs-body: 16px;\n      --fs-meta: 13px;\n\n      --gap-xs: 8px;\n      --gap-sm: 12px;\n      --gap-md: 20px;\n      --gap-lg: 32px;\n      --gap-xl: 56px;\n      --gap-2xl: 96px;\n      --container: 1180px;\n      --gutter: 32px;\n\n      --radius: 8px;\n      --radius-lg: 14px;\n    }\n\n    *, *::before, *::after { box-sizing: border-box; }\n    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }\n    body {\n      margin: 0;\n      background: var(--bg);\n      color: var(--fg);\n      font-family: var(--font-body);\n      font-size: var(--fs-body);\n      line-height: 1.55;\n      text-rendering: optimizeLegibility;\n      -webkit-font-smoothing: antialiased;\n    }\n    img, svg { display: block; max-width: 100%; }\n    a { color: inherit; text-decoration: none; }\n    button { font: inherit; cursor: pointer; }\n    p { text-wrap: pretty; }\n    h1, h2, h3, h4 { text-wrap: balance; }\n\n    .container { max-width: var(--container); margin-inline: auto; padding-inline: var(--gutter); }\n    .section { padding-block: clamp(56px, 8vw, var(--gap-2xl)); }\n    .section + .section { border-top: 1px solid var(--border); }\n    .stack { display: flex; flex-direction: column; }\n    .stack > * + * { margin-top: var(--gap-md); }\n    .row { display: flex; align-items: center; gap: var(--gap-md); }\n    .row-between { display: flex; align-items: center; justify-content: space-between; gap: var(--gap-md); }\n    .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--gap-lg); }\n    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap-lg); }\n    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--gap-md); }\n    .grid-2-1 { display: grid; grid-template-columns: 2fr 1fr; gap: var(--gap-xl); align-items: start; }\n    .grid-1-2 { display: grid; grid-template-columns: 1fr 2fr; gap: var(--gap-xl); align-items: start; }\n    @media (max-width: 920px) {\n      .grid-2, .grid-3, .grid-4, .grid-2-1, .grid-1-2 { grid-template-columns: 1fr; }\n    }\n\n    .h1, h1 { font-family: var(--font-display); font-size: var(--fs-h1); line-height: 1.02; letter-spacing: 0; margin: 0; }\n    .h2, h2 { font-family: var(--font-display); font-size: var(--fs-h2); line-height: 1.08; letter-spacing: 0; margin: 0; }\n    .h3, h3 { font-family: var(--font-display); font-size: var(--fs-h3); font-weight: 600; line-height: 1.26; letter-spacing: 0; margin: 0; }\n    .lead { font-size: var(--fs-lead); line-height: 1.55; color: var(--muted); max-width: 60ch; margin: 0; }\n    .eyebrow {\n      font-family: var(--font-mono);\n      font-size: 12px;\n      letter-spacing: 0.08em;\n      text-transform: uppercase;\n      color: var(--accent);\n      margin: 0 0 var(--gap-md);\n    }\n    .meta { font-family: var(--font-mono); font-size: var(--fs-meta); color: var(--muted); }\n    .num { font-family: var(--font-mono); font-variant-numeric: tabular-nums; }\n\n    .topnav {\n      position: sticky; top: 0; z-index: 10;\n      background: color-mix(in oklch, var(--bg) 92%, transparent);\n      backdrop-filter: blur(12px);\n      border-bottom: 1px solid var(--border);\n    }\n    .topnav-inner { display: flex; align-items: center; justify-content: space-between; padding-block: 14px; }\n    .topnav .logo { font-family: var(--font-display); font-size: 21px; font-weight: 600; letter-spacing: 0; }\n    .topnav nav { display: flex; gap: var(--gap-lg); }\n    .topnav nav a { font-size: 14px; color: var(--muted); }\n    .topnav nav a:hover { color: var(--fg); }\n    .pagefoot { padding-block: var(--gap-xl); color: color-mix(in oklch, var(--surface) 62%, var(--muted)); font-size: 14px; border-top: 1px solid color-mix(in oklch, var(--surface) 16%, transparent); background: var(--fg); }\n    .pagefoot .row-between { flex-wrap: wrap; gap: var(--gap-md); align-items: flex-start; }\n    .pagefoot a:hover { color: var(--surface); }\n\n    .btn {\n      display: inline-flex; align-items: center; justify-content: center; gap: 8px;\n      min-height: 44px;\n      padding: 11px 20px;\n      border-radius: var(--radius);\n      border: 1px solid transparent;\n      font-size: 15px;\n      font-weight: 650;\n      letter-spacing: 0;\n      transition: transform 0.05s ease, background 0.15s ease, border-color 0.15s ease;\n    }\n    .btn:active { transform: translateY(1px); }\n    .btn-primary { background: var(--accent); color: var(--surface); border-color: var(--accent); }\n    .btn-primary:hover { background: color-mix(in oklch, var(--accent) 86%, var(--fg)); }\n    .btn-secondary { background: transparent; color: var(--fg); border-color: var(--border); }\n    .btn-secondary:hover { border-color: var(--fg); }\n    .btn-ghost { background: transparent; color: var(--fg); border-color: transparent; padding-inline: 8px; }\n    .btn-ghost:hover { color: var(--accent); }\n    .btn-arrow::after { content: '>'; transition: transform 0.15s ease; }\n    .btn-arrow:hover::after { transform: translateX(2px); }\n\n    .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 28px; }\n    .card-flat { background: transparent; border: 0; padding: 0; }\n    .card-rule { background: transparent; border: 0; border-top: 1px solid var(--fg); padding: 24px 0 0; border-radius: 0; }\n    .feature .feature-mark {\n      width: 36px; height: 36px;\n      display: grid; place-items: center;\n      border: 1px solid var(--border);\n      border-radius: 10px;\n      color: var(--accent);\n      margin-bottom: var(--gap-md);\n    }\n    .feature .feature-mark svg { width: 18px; height: 18px; }\n    .feature h3 { margin-bottom: 6px; }\n    .feature p { margin: 0; color: var(--muted); font-size: 15px; }\n    .pill {\n      display: inline-flex; align-items: center; gap: 6px;\n      padding: 4px 10px;\n      background: var(--accent-soft);\n      color: var(--accent);\n      border-radius: 999px;\n      font-family: var(--font-mono);\n      font-size: 11px;\n      letter-spacing: 0.04em;\n      text-transform: uppercase;\n    }\n    .tag {\n      display: inline-flex; align-items: center;\n      padding: 4px 10px;\n      background: transparent;\n      color: var(--muted);\n      border: 1px solid var(--border);\n      border-radius: 999px;\n      font-size: 12px;\n    }\n    .field { display: flex; flex-direction: column; gap: 6px; }\n    .field label { font-size: 13px; color: var(--muted); }\n    .input, .textarea, .select {\n      width: 100%;\n      padding: 11px 14px;\n      border: 1px solid var(--border);\n      border-radius: var(--radius);\n      background: var(--surface);\n      color: var(--fg);\n      font: inherit;\n      font-size: 15px;\n    }\n    .input:focus, .textarea:focus, .select:focus { outline: 2px solid var(--accent-soft); border-color: var(--accent); }\n    .textarea { min-height: 110px; resize: vertical; line-height: 1.55; }\n    .ph-img {\n      background: linear-gradient(135deg, var(--accent-soft), var(--fg-soft)), var(--surface);\n      border: 1px solid var(--border);\n      border-radius: var(--radius-lg);\n      aspect-ratio: 16 / 10;\n      display: grid; place-items: center;\n      color: var(--muted);\n      font-family: var(--font-mono);\n      font-size: 12px;\n      letter-spacing: 0.04em;\n    }\n    .ph-img.square { aspect-ratio: 1 / 1; }\n    .ph-img.portrait { aspect-ratio: 3 / 4; }\n    .ph-img.wide { aspect-ratio: 16 / 9; }\n    .rule { border: 0; border-top: 1px solid var(--border); margin: 0; }\n    .rule-strong { border: 0; border-top: 1px solid var(--fg); margin: 0; }\n    .hero { padding-block: clamp(80px, 12vw, 160px); }\n    .hero-center { text-align: center; max-width: 32ch; margin-inline: auto; }\n    .hero h1 { margin-bottom: var(--gap-md); }\n    .hero .lead { margin-bottom: var(--gap-lg); }\n    .hero-cta { display: inline-flex; gap: var(--gap-sm); flex-wrap: wrap; }\n    .hero-center .hero-cta { justify-content: center; }\n    .hero-split { display: grid; grid-template-columns: 1fr 1fr; gap: var(--gap-2xl); align-items: center; }\n    @media (max-width: 920px) { .hero-split { grid-template-columns: 1fr; } }\n    .log-row { display: grid; grid-template-columns: 120px 1fr 100px; gap: var(--gap-lg); padding: 22px 0; border-top: 1px solid var(--border); align-items: baseline; }\n    .log-row .meta { color: var(--muted); }\n    .log-row h3 { font-size: 19px; }\n    .log-row .pull { text-align: right; }\n\n    .roof-hero {\n      min-height: clamp(680px, 88vh, 900px);\n      display: grid;\n      align-items: end;\n      padding: 0;\n      color: var(--surface);\n      background:\n        linear-gradient(180deg, color-mix(in oklch, var(--fg) 62%, transparent) 0%, color-mix(in oklch, var(--fg) 18%, transparent) 42%, color-mix(in oklch, var(--fg) 84%, transparent) 100%),\n        url('assets/hero-family1-hero-premium-roof-at-blue-hour.png') center / cover no-repeat;\n    }\n    .roof-hero .container { width: 100%; padding-block: 140px 86px; }\n    .hero-panel { max-width: 800px; }\n    .hero-panel .eyebrow { color: color-mix(in oklch, var(--surface) 88%, var(--accent)); }\n    .hero-panel .lead { color: color-mix(in oklch, var(--surface) 78%, transparent); max-width: 52ch; }\n    .hero-actions { display: flex; flex-wrap: wrap; gap: var(--gap-sm); margin-top: 30px; }\n    .hero-note {\n      margin-top: 34px;\n      display: grid;\n      grid-template-columns: repeat(3, minmax(0, 1fr));\n      max-width: 760px;\n      border-top: 1px solid color-mix(in oklch, var(--surface) 30%, transparent);\n    }\n    .hero-note span { padding: 16px 18px 0 0; color: color-mix(in oklch, var(--surface) 78%, transparent); font-size: 14px; }\n    .hero-note strong { display: block; color: var(--surface); font-family: var(--font-display); font-size: 22px; font-weight: 600; }\n    .nav-phone { display: inline-flex; align-items: center; gap: 8px; color: var(--fg); font-weight: 650; }\n    .section-intro { max-width: 620px; margin-bottom: 48px; }\n    .service-card { overflow: hidden; padding: 0; }\n    .service-card img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; }\n    .service-card .service-copy { padding: 24px; }\n    .service-list { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 18px; }\n    .proof-panel {\n      background: var(--surface);\n      border: 1px solid var(--border);\n      border-radius: var(--radius-lg);\n      overflow: hidden;\n    }\n    .proof-panel img { width: 100%; height: 100%; min-height: 420px; object-fit: cover; }\n    .proof-copy { padding: clamp(28px, 5vw, 52px); }\n    .cue-list { list-style: none; margin: 28px 0 0; padding: 0; display: grid; gap: 16px; }\n    .cue-list li { border-top: 1px solid var(--border); padding-top: 16px; color: var(--muted); }\n    .cue-list strong { display: block; color: var(--fg); font-family: var(--font-display); font-size: 21px; margin-bottom: 4px; }\n    .process-step { border-top: 1px solid var(--border); padding-top: 22px; }\n    .step-num { color: var(--muted); margin-bottom: 14px; display: block; }\n    .contact-band { background: var(--fg); color: var(--surface); }\n    .contact-band .lead, .contact-band .meta, .contact-band .field label { color: color-mix(in oklch, var(--surface) 70%, transparent); }\n    .contact-band .card { color: var(--fg); }\n    .contact-band .eyebrow { color: color-mix(in oklch, var(--surface) 84%, var(--accent)); }\n    .faq-list { display: grid; gap: 14px; }\n    details {\n      border-top: 1px solid color-mix(in oklch, var(--surface) 18%, transparent);\n      padding: 18px 0;\n    }\n    summary { cursor: pointer; font-family: var(--font-display); font-size: 22px; }\n    details p { color: color-mix(in oklch, var(--surface) 70%, transparent); margin-bottom: 0; }\n    .footer-grid { display: grid; grid-template-columns: 1.4fr 1fr 1fr; gap: var(--gap-lg); width: 100%; }\n\n    @media (max-width: 760px) {\n      :root { --gutter: 20px; }\n      .topnav nav { display: none; }\n      .topnav .btn { padding-inline: 14px; }\n      .roof-hero { min-height: 720px; }\n      .roof-hero .container { padding-block: 120px 56px; }\n      .hero-note { grid-template-columns: 1fr; }\n      .hero-note span { padding-top: 12px; }\n      .footer-grid { grid-template-columns: 1fr; }\n    }\n  </style>\n</head>\n<body>\n  <header class=\"topnav\" data-od-id=\"topnav\">\n    <div class=\"container topnav-inner\">\n      <a class=\"logo\" href=\"#top\" aria-label=\"RidgeLine Roof Co. home\">RidgeLine Roof Co.</a>\n      <nav aria-label=\"Primary navigation\">\n        <a href=\"#services\">Services</a>\n        <a href=\"#proof\">Work</a>\n        <a href=\"#process\">Process</a>\n        <a href=\"#contact\">Contact</a>\n      </nav>\n      <a class=\"btn btn-secondary\" href=\"tel:0400000000\">Call 0400 000 000</a>\n    </div>\n  </header>\n\n  <main id=\"content\">\n    <section class=\"section roof-hero\" id=\"top\" data-od-id=\"hero\">\n      <div class=\"container\">\n        <div class=\"hero-panel\">\n          <p class=\"eyebrow\">Roofing contractor · Brisbane and Gold Coast</p>\n          <h1>Premium roof repairs and restoration for Queensland homes.</h1>\n          <p class=\"lead\">RidgeLine Roof Co. helps homeowners inspect, repair, restore, and replace roofing with clear advice before any work begins.</p>\n          <div class=\"hero-actions\">\n            <a class=\"btn btn-primary\" href=\"#contact\">Request an inspection</a>\n            <a class=\"btn btn-secondary\" href=\"tel:0400000000\">Phone 0400 000 000</a>\n          </div>\n          <div class=\"hero-note\" aria-label=\"Service highlights\">\n            <span><strong>Repairs</strong>Leaks, flashing, storm damage, gutters</span>\n            <span><strong>Restoration</strong>Cleaning, preparation, repainting, finish care</span>\n            <span><strong>Roofing</strong>Metal roofing and practical inspections</span>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"services\" data-od-id=\"services\">\n      <div class=\"container\">\n        <div class=\"section-intro\">\n          <p class=\"eyebrow\">What homeowners can request</p>\n          <h2>Roofing work explained plainly before the ladder goes up.</h2>\n          <p class=\"lead\" style=\"margin-top: 16px;\">From a small leak to a full roof restoration, the first step is a clear inspection and a written scope that separates urgent fixes from optional improvements.</p>\n        </div>\n        <div class=\"grid-3\">\n          <article class=\"card service-card\">\n            <img src=\"assets/serviceRepair-family1-service-roof-repair-flashing-detail.png\" alt=\"Close detail of roof repair and flashing work\">\n            <div class=\"service-copy\">\n              <h3>Roof repairs</h3>\n              <p style=\"color: var(--muted); margin-bottom: 0;\">Leak tracing, flashing attention, storm damage checks, and targeted repair work for problem areas.</p>\n            </div>\n          </article>\n          <article class=\"card service-card\">\n            <img src=\"assets/serviceInstall-family1-service-roof-installation-detail.png\" alt=\"Roofing material installation detail\">\n            <div class=\"service-copy\">\n              <h3>Restoration and metal roofing</h3>\n              <p style=\"color: var(--muted); margin-bottom: 0;\">Preparation-led restoration and metal roofing conversations for homes ready for a longer-term plan.</p>\n            </div>\n          </article>\n          <article class=\"card service-card\">\n            <img src=\"assets/about-family1-about-roofer-working-roof-frame.png\" alt=\"Roofer working on a residential roof frame\">\n            <div class=\"service-copy\">\n              <h3>Gutters and inspections</h3>\n              <p style=\"color: var(--muted); margin-bottom: 0;\">Gutter repairs, roof condition checks, and practical reporting for homeowners planning next steps.</p>\n            </div>\n          </article>\n        </div>\n        <div class=\"service-list\" aria-label=\"Available services\">\n          <span class=\"tag\">Roof repairs</span>\n          <span class=\"tag\">Roof restoration</span>\n          <span class=\"tag\">Metal roofing</span>\n          <span class=\"tag\">Gutter repairs</span>\n          <span class=\"tag\">Roof inspections</span>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"proof\" data-od-id=\"proof\">\n      <div class=\"container proof-panel\">\n        <div class=\"grid-1-2\" style=\"gap: 0;\">\n          <div class=\"proof-copy\">\n            <p class=\"eyebrow\">Concrete work cues</p>\n            <h2>A roof scope should show what was checked, not just what was quoted.</h2>\n            <p class=\"lead\" style=\"margin-top: 18px;\">The strongest roofing decisions come from visible conditions: flashings, ridges, gutters, roof sheets, drainage paths, and surface preparation.</p>\n            <ul class=\"cue-list\">\n              <li><strong>Before and after structure</strong>Use project photos to compare roof condition, access, preparation, and finished presentation.</li>\n              <li><strong>Material-specific notes</strong>Separate repair, restoration, and metal roofing recommendations instead of bundling everything into one vague quote.</li>\n              <li><strong>Clear exclusions</strong>If something needs further access or specialist confirmation, name it clearly before approval.</li>\n            </ul>\n          </div>\n          <img src=\"assets/proof-family1-project-before-after-roof-transformation.png\" alt=\"Before and after residential roof transformation\">\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"process\" data-od-id=\"quote-process\">\n      <div class=\"container\">\n        <div class=\"row-between\" style=\"margin-bottom: 46px; align-items: end;\">\n          <div style=\"max-width: 620px;\">\n            <p class=\"eyebrow\">Inspection to quote</p>\n            <h2>A simple path from roof concern to written next step.</h2>\n          </div>\n          <a class=\"btn btn-secondary\" href=\"#contact\">Start an enquiry</a>\n        </div>\n        <div class=\"grid-4\">\n          <article class=\"process-step\">\n            <span class=\"meta step-num\">01</span>\n            <h3>Tell us what you are seeing</h3>\n            <p style=\"color: var(--muted);\">Leaks, visible wear, gutter overflow, storm concerns, or a roof you are planning to restore.</p>\n          </article>\n          <article class=\"process-step\">\n            <span class=\"meta step-num\">02</span>\n            <h3>Book a practical inspection</h3>\n            <p style=\"color: var(--muted);\">A roofing professional checks the relevant areas and asks about access, timing, and priorities.</p>\n          </article>\n          <article class=\"process-step\">\n            <span class=\"meta step-num\">03</span>\n            <h3>Review the recommended scope</h3>\n            <p style=\"color: var(--muted);\">You get plain-language repair or restoration recommendations before deciding what proceeds.</p>\n          </article>\n          <article class=\"process-step\">\n            <span class=\"meta step-num\">04</span>\n            <h3>Schedule the work</h3>\n            <p style=\"color: var(--muted);\">Timing, access, and site preparation are confirmed so the work can be completed with less disruption.</p>\n          </article>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section contact-band\" id=\"contact\" data-od-id=\"faq-contact-footer\">\n      <div class=\"container grid-2\" style=\"align-items: start;\">\n        <div>\n          <p class=\"eyebrow\">Questions and quotes</p>\n          <h2>Request a roof inspection or quote.</h2>\n          <p class=\"lead\" style=\"margin-top: 18px;\">Call RidgeLine Roof Co. or send the enquiry form with the service you need and where the roof is located.</p>\n          <div style=\"margin-top: 28px;\">\n            <a class=\"btn btn-primary\" href=\"tel:0400000000\">Call 0400 000 000</a>\n          </div>\n          <div class=\"faq-list\" style=\"margin-top: 54px;\">\n            <details open>\n              <summary>Can I ask for repairs only?</summary>\n              <p>Yes. The enquiry can be for a specific roof leak, flashing issue, gutter repair, or inspection before larger work is considered.</p>\n            </details>\n            <details>\n              <summary>Do you service both Brisbane and the Gold Coast?</summary>\n              <p>Yes, the service area for this page is Brisbane and Gold Coast.</p>\n            </details>\n            <details>\n              <summary>What should I include in the form?</summary>\n              <p>Share the suburb, roof concern, preferred timing, and any visible symptoms such as leaks, rust, loose flashing, or gutter overflow.</p>\n            </details>\n          </div>\n        </div>\n        <form class=\"card\" aria-label=\"Roofing enquiry form\">\n          <div class=\"grid-2\" style=\"gap: 16px;\">\n            <div class=\"field\">\n              <label for=\"name\">Name</label>\n              <input class=\"input\" id=\"name\" name=\"name\" autocomplete=\"name\">\n            </div>\n            <div class=\"field\">\n              <label for=\"phone\">Phone</label>\n              <input class=\"input\" id=\"phone\" name=\"phone\" autocomplete=\"tel\">\n            </div>\n          </div>\n          <div class=\"field\" style=\"margin-top: 16px;\">\n            <label for=\"suburb\">Suburb or service area</label>\n            <input class=\"input\" id=\"suburb\" name=\"suburb\" placeholder=\"Brisbane or Gold Coast area\">\n          </div>\n          <div class=\"field\" style=\"margin-top: 16px;\">\n            <label for=\"service\">What do you need?</label>\n            <select class=\"select\" id=\"service\" name=\"service\">\n              <option>Roof inspection</option>\n              <option>Roof repairs</option>\n              <option>Roof restoration</option>\n              <option>Metal roofing</option>\n              <option>Gutter repairs</option>\n            </select>\n          </div>\n          <div class=\"field\" style=\"margin-top: 16px;\">\n            <label for=\"message\">Roof details</label>\n            <textarea class=\"textarea\" id=\"message\" name=\"message\" placeholder=\"Tell us what you have noticed and when you would like the roof checked.\"></textarea>\n          </div>\n          <button class=\"btn btn-secondary\" type=\"button\" style=\"width: 100%; margin-top: 20px;\">Send enquiry</button>\n          <p class=\"meta\" style=\"margin: 14px 0 0;\">For urgent roof concerns, phone the team directly.</p>\n        </form>\n      </div>\n    </section>\n  </main>\n\n  <footer class=\"pagefoot\" data-od-id=\"footer\">\n    <div class=\"container footer-grid\">\n      <div>\n        <h3 style=\"color: var(--surface); margin-bottom: 10px;\">RidgeLine Roof Co.</h3>\n        <p style=\"margin: 0; max-width: 40ch;\">Local roofing contractor for roof repairs, restoration, metal roofing, gutter repairs, and roof inspections.</p>\n      </div>\n      <div class=\"stack\">\n        <span class=\"meta\">Service area</span>\n        <a href=\"#contact\">Brisbane</a>\n        <a href=\"#contact\">Gold Coast</a>\n      </div>\n      <div class=\"stack\">\n        <span class=\"meta\">Contact</span>\n        <a href=\"tel:0400000000\">0400 000 000</a>\n        <a href=\"#contact\">Request an inspection</a>\n      </div>\n    </div>\n  </footer>\n</body>\n</html>\n","isError":false}

