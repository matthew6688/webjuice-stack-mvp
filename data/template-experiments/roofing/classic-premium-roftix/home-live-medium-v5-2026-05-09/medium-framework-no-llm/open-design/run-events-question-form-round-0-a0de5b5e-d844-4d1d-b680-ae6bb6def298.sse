data: {"type":"text_delta","delta":"Got it — high-fidelity roofing home page with fixed business facts. Tell me the last design choices before I build:\n\n<question-form id=\"discovery\" title=\"Quick brief — 30 seconds\">\n{\n  \"description\": \"I'll lock these in before building. Skip what doesn't apply — I'll fill defaults.\",\n  \"questions\": [\n    {\n      \"id\": \"platform\",\n      \"label\": \"Primary surface\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Desktop web\",\n        \"Responsive — all sizes\",\n        \"Mobile-first\"\n      ]\n    },\n    {\n      \"id\": \"audience\",\n      \"label\": \"Primary homeowner\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Premium residential owners\",\n        \"Storm-damage repair leads\",\n        \"Renovation / restoration buyers\",\n        \"Property managers\"\n      ]\n    },\n    {\n      \"id\": \"tone\",\n      \"label\": \"Visual tone\",\n      \"type\": \"checkbox\",\n      \"maxSelections\": 2,\n      \"options\": [\n        \"Classic premium\",\n        \"Editorial / magazine\",\n        \"Practical local trades\",\n        \"Modern minimal\",\n        \"Warm / approachable\"\n      ]\n    },\n    {\n      \"id\": \"brand\",\n      \"label\": \"Brand context\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Use the provided Classic Premium Roftix direction\",\n        \"Pick a direction for me\",\n        \"I have a brand spec — I'll share it\",\n        \"Match a reference site / screenshot — I'll attach it\"\n      ]\n    },\n    {\n      \"id\": \"quote_path\",\n      \"label\": \"Quote path emphasis\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Phone-first with supporting form\",\n        \"Form-first with visible phone\",\n        \"Balanced phone and form\"\n      ]\n    },\n    {\n      \"id\": \"motion\",\n      \"label\": \"Motion level\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Subtle premium motion\",\n        \"Mostly static\",\n        \"A little more cinematic\"\n      ]\n    },\n    {\n      \"id\": \"constraints\",\n      \"label\": \"Anything else I should know?\",\n      \"type\": \"textarea\",\n      \"placeholder\": \"Copy preferences, layout dislikes, sections to emphasize, anything to avoid…\"\n    }\n  ]\n}\n</question-form>"}

