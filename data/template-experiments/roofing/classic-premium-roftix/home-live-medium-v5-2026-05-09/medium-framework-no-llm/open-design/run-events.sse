data: {"type":"tool_result","toolUseId":"item_28","content":"<!doctype html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>RidgeLine Roof Co. | Roofing Brisbane & Gold Coast</title>\n  <meta name=\"description\" content=\"RidgeLine Roof Co. helps Brisbane and Gold Coast homeowners request roof repairs, restoration, metal roofing, gutter repairs, and roof inspections.\" />\n  <meta name=\"review-provenance\" content=\"ai-reference-placeholder; replace with real Google or customer reviews before live\" />\n  <style>\n    :root {\n      --bg: oklch(97% 0.008 85);\n      --surface: oklch(100% 0 0);\n      --fg: oklch(18% 0.035 250);\n      --muted: oklch(48% 0.026 250);\n      --border: oklch(88% 0.012 85);\n      --accent: oklch(47% 0.12 150);\n\n      --navy: oklch(20% 0.055 250);\n      --navy-deep: oklch(14% 0.045 250);\n      --warm: oklch(66% 0.145 54);\n      --accent-soft: color-mix(in oklch, var(--accent) 13%, transparent);\n      --fg-soft: color-mix(in oklch, var(--fg) 6%, transparent);\n      --navy-soft: color-mix(in oklch, var(--navy) 8%, transparent);\n\n      --font-display: 'Iowan Old Style', 'Charter', Georgia, 'Times New Roman', serif;\n      --font-body: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;\n      --font-mono: ui-monospace, 'JetBrains Mono', 'SF Mono', Menlo, monospace;\n\n      --fs-h1: clamp(48px, 6.4vw, 88px);\n      --fs-h2: clamp(34px, 4.4vw, 56px);\n      --fs-h3: 23px;\n      --fs-lead: 19px;\n      --fs-body: 16px;\n      --fs-meta: 13px;\n\n      --gap-xs: 8px;\n      --gap-sm: 12px;\n      --gap-md: 20px;\n      --gap-lg: 32px;\n      --gap-xl: 56px;\n      --gap-2xl: 96px;\n      --container: 1180px;\n      --gutter: 32px;\n      --radius: 8px;\n      --radius-lg: 14px;\n    }\n\n    *, *::before, *::after { box-sizing: border-box; }\n    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }\n    body {\n      margin: 0;\n      background: var(--bg);\n      color: var(--fg);\n      font-family: var(--font-body);\n      font-size: var(--fs-body);\n      line-height: 1.55;\n      text-rendering: optimizeLegibility;\n      -webkit-font-smoothing: antialiased;\n    }\n    img, svg { display: block; max-width: 100%; }\n    img { object-fit: cover; }\n    a { color: inherit; text-decoration: none; }\n    button { font: inherit; cursor: pointer; }\n    p { text-wrap: pretty; }\n    h1, h2, h3, h4 { text-wrap: balance; }\n\n    .container { max-width: var(--container); margin-inline: auto; padding-inline: var(--gutter); }\n    .section { padding-block: clamp(58px, 8vw, var(--gap-2xl)); }\n    .section + .section { border-top: 1px solid var(--border); }\n    .stack { display: flex; flex-direction: column; }\n    .stack > * + * { margin-top: var(--gap-md); }\n    .row { display: flex; align-items: center; gap: var(--gap-md); }\n    .row-between { display: flex; align-items: center; justify-content: space-between; gap: var(--gap-md); }\n    .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--gap-lg); }\n    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap-lg); }\n    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--gap-md); }\n    .grid-2-1 { display: grid; grid-template-columns: 2fr 1fr; gap: var(--gap-xl); align-items: start; }\n    .grid-1-2 { display: grid; grid-template-columns: 1fr 2fr; gap: var(--gap-xl); align-items: start; }\n\n    .h1, h1 { font-family: var(--font-display); font-size: var(--fs-h1); line-height: 0.98; letter-spacing: -0.02em; margin: 0; }\n    .h2, h2 { font-family: var(--font-display); font-size: var(--fs-h2); line-height: 1.04; letter-spacing: -0.015em; margin: 0; }\n    .h3, h3 { font-family: var(--font-display); font-size: var(--fs-h3); font-weight: 600; line-height: 1.22; margin: 0; }\n    .lead { font-size: var(--fs-lead); line-height: 1.55; color: var(--muted); max-width: 60ch; margin: 0; }\n    .eyebrow {\n      font-family: var(--font-mono);\n      font-size: 12px;\n      letter-spacing: 0.08em;\n      text-transform: uppercase;\n      color: var(--accent);\n      margin: 0 0 var(--gap-md);\n    }\n    .meta { font-family: var(--font-mono); font-size: var(--fs-meta); color: var(--muted); }\n    .num { font-family: var(--font-mono); font-variant-numeric: tabular-nums; }\n\n    .topnav {\n      position: fixed;\n      top: 0;\n      inset-inline: 0;\n      z-index: 20;\n      color: var(--surface);\n      border-bottom: 1px solid color-mix(in oklch, var(--surface) 18%, transparent);\n      background: color-mix(in oklch, var(--navy-deep) 72%, transparent);\n      backdrop-filter: blur(14px);\n    }\n    .topnav-inner { display: flex; align-items: center; justify-content: space-between; padding-block: 15px; }\n    .topnav .logo { font-family: var(--font-display); font-size: 21px; font-weight: 600; letter-spacing: -0.01em; }\n    .topnav nav { display: flex; gap: var(--gap-lg); align-items: center; }\n    .topnav nav a { font-size: 14px; color: color-mix(in oklch, var(--surface) 78%, transparent); }\n    .topnav nav a:hover { color: var(--surface); }\n    .nav-phone { border: 1px solid color-mix(in oklch, var(--surface) 32%, transparent); padding: 8px 12px; border-radius: 999px; }\n\n    .btn {\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n      gap: 8px;\n      min-height: 44px;\n      padding: 11px 20px;\n      border-radius: var(--radius);\n      border: 1px solid transparent;\n      font-size: 15px;\n      font-weight: 650;\n      letter-spacing: -0.005em;\n      transition: transform 0.05s ease, background 0.15s ease, border-color 0.15s ease;\n    }\n    .btn:active { transform: translateY(1px); }\n    .btn-primary { background: var(--accent); color: var(--surface); border-color: var(--accent); }\n    .btn-primary:hover { background: color-mix(in oklch, var(--accent) 84%, var(--fg)); }\n    .btn-secondary { background: var(--surface); color: var(--fg); border-color: var(--border); }\n    .btn-secondary:hover { border-color: var(--fg); }\n    .btn-ghost { background: transparent; color: var(--fg); border-color: transparent; padding-inline: 8px; }\n    .btn-ghost:hover { color: var(--accent); }\n    .btn-arrow::after { content: '→'; transition: transform 0.15s ease; }\n    .btn-arrow:hover::after { transform: translateX(2px); }\n\n    .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 28px; }\n    .card-flat { background: transparent; border: 0; padding: 0; }\n    .card-rule { background: transparent; border: 0; border-top: 1px solid var(--fg); padding: 24px 0 0; border-radius: 0; }\n    .feature .feature-mark {\n      width: 38px;\n      height: 38px;\n      display: grid;\n      place-items: center;\n      border: 1px solid var(--border);\n      border-radius: 10px;\n      color: var(--accent);\n      margin-bottom: var(--gap-md);\n    }\n    .feature .feature-mark svg { width: 18px; height: 18px; }\n    .feature h3 { margin-bottom: 7px; }\n    .feature p { margin: 0; color: var(--muted); font-size: 15px; }\n    .pill {\n      display: inline-flex;\n      align-items: center;\n      gap: 6px;\n      padding: 4px 10px;\n      background: var(--accent-soft);\n      color: var(--accent);\n      border-radius: 999px;\n      font-family: var(--font-mono);\n      font-size: 11px;\n      letter-spacing: 0.04em;\n      text-transform: uppercase;\n    }\n    .tag {\n      display: inline-flex;\n      align-items: center;\n      padding: 4px 10px;\n      background: transparent;\n      color: var(--muted);\n      border: 1px solid var(--border);\n      border-radius: 999px;\n      font-size: 12px;\n    }\n    .field { display: flex; flex-direction: column; gap: 6px; }\n    .field label { font-size: 13px; color: var(--muted); }\n    .input, .textarea, select {\n      width: 100%;\n      padding: 12px 14px;\n      border: 1px solid var(--border);\n      border-radius: var(--radius);\n      background: var(--surface);\n      color: var(--fg);\n      font: inherit;\n      font-size: 15px;\n    }\n    .input:focus, .textarea:focus, select:focus { outline: 2px solid var(--accent-soft); border-color: var(--accent); }\n    .textarea { min-height: 112px; resize: vertical; line-height: 1.55; }\n    .rule { height: 1px; background: var(--border); width: 100%; }\n    .rule-strong { height: 1px; background: var(--fg); width: 100%; }\n\n    .hero-photo {\n      min-height: 760px;\n      display: grid;\n      align-items: end;\n      padding-top: 90px;\n      padding-bottom: 72px;\n      color: var(--surface);\n      background:\n        linear-gradient(90deg, color-mix(in oklch, var(--navy-deep) 84%, transparent), color-mix(in oklch, var(--navy-deep) 34%, transparent) 58%, color-mix(in oklch, var(--navy-deep) 10%, transparent)),\n        linear-gradient(0deg, color-mix(in oklch, var(--navy-deep) 72%, transparent), transparent 54%),\n        url('assets/hero-family1-hero-premium-roof-at-blue-hour.png') center / cover no-repeat;\n    }\n    .hero-grid { display: grid; grid-template-columns: minmax(0, 1.05fr) 360px; gap: var(--gap-xl); align-items: end; }\n    .hero-copy { max-width: 780px; }\n    .hero-copy .lead { color: color-mix(in oklch, var(--surface) 82%, transparent); margin-top: 22px; }\n    .hero-cta { display: flex; gap: var(--gap-sm); flex-wrap: wrap; margin-top: 30px; }\n    .hero-panel {\n      background: color-mix(in oklch, var(--surface) 92%, transparent);\n      color: var(--fg);\n      border: 1px solid color-mix(in oklch, var(--surface) 45%, transparent);\n      border-radius: var(--radius-lg);\n      padding: 26px;\n      box-shadow: 0 24px 60px color-mix(in oklch, var(--navy-deep) 30%, transparent);\n    }\n    .hero-panel .eyebrow { margin-bottom: 12px; }\n    .hero-panel ul { list-style: none; padding: 0; margin: 18px 0 0; display: grid; gap: 10px; }\n    .hero-panel li { display: flex; gap: 10px; color: var(--muted); font-size: 14px; }\n    .hero-panel li::before { content: ''; width: 7px; height: 7px; margin-top: 8px; border-radius: 999px; background: var(--accent); flex: 0 0 auto; }\n\n    .image-card { position: relative; overflow: hidden; min-height: 300px; border-radius: var(--radius-lg); border: 1px solid var(--border); background: var(--surface); }\n    .image-card img { width: 100%; height: 100%; min-height: inherit; }\n    .image-card .caption {\n      position: absolute;\n      left: 18px;\n      bottom: 18px;\n      right: 18px;\n      color: var(--surface);\n      background: color-mix(in oklch, var(--navy-deep) 72%, transparent);\n      border: 1px solid color-mix(in oklch, var(--surface) 20%, transparent);\n      border-radius: var(--radius);\n      padding: 12px 14px;\n      backdrop-filter: blur(10px);\n    }\n    .caption strong { display: block; font-family: var(--font-display); font-size: 19px; line-height: 1.15; }\n    .caption span { display: block; margin-top: 4px; color: color-mix(in oklch, var(--surface) 76%, transparent); font-size: 13px; }\n\n    .service-card { display: grid; grid-template-rows: 210px auto; overflow: hidden; padding: 0; }\n    .service-card img { width: 100%; height: 210px; }\n    .service-card .service-body { padding: 24px; }\n    .service-card p { margin: 9px 0 0; color: var(--muted); font-size: 15px; }\n    .service-card .meta { display: block; margin-top: 18px; }\n\n    .proof-band { background: var(--navy); color: var(--surface); }\n    .proof-band .lead, .proof-band .meta { color: color-mix(in oklch, var(--surface) 72%, transparent); }\n    .proof-band .eyebrow { color: color-mix(in oklch, var(--warm) 82%, var(--surface)); }\n    .proof-list { display: grid; gap: 0; border-top: 1px solid color-mix(in oklch, var(--surface) 18%, transparent); }\n    .proof-row { display: grid; grid-template-columns: 110px 1fr; gap: 22px; padding: 20px 0; border-bottom: 1px solid color-mix(in oklch, var(--surface) 18%, transparent); }\n    .proof-row h3 { color: var(--surface); }\n    .proof-row p { margin: 5px 0 0; color: color-mix(in oklch, var(--surface) 68%, transparent); }\n\n    .step { border-left: 1px solid var(--border); padding-left: 22px; position: relative; }\n    .step::before {\n      content: attr(data-step);\n      position: absolute;\n      left: -17px;\n      top: 0;\n      width: 34px;\n      height: 34px;\n      display: grid;\n      place-items: center;\n      border-radius: 999px;\n      background: var(--surface);\n      border: 1px solid var(--border);\n      font-family: var(--font-mono);\n      color: var(--accent);\n      font-size: 12px;\n    }\n    .step h3, .step p { margin-left: 12px; }\n    .step p { color: var(--muted); margin-top: 7px; }\n\n    .faq-list { display: grid; gap: 12px; }\n    details { border-top: 1px solid var(--border); padding: 18px 0; }\n    details:last-child { border-bottom: 1px solid var(--border); }\n    summary { cursor: pointer; font-family: var(--font-display); font-size: 21px; font-weight: 600; }\n    details p { color: var(--muted); margin: 10px 0 0; max-width: 64ch; }\n    .contact-panel { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 30px; }\n    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }\n    .form-grid .wide-field { grid-column: 1 / -1; }\n\n    .pagefoot { background: var(--navy-deep); color: color-mix(in oklch, var(--surface) 68%, transparent); padding-block: 48px; font-size: 14px; }\n    .pagefoot a:hover { color: var(--surface); }\n    .footer-grid { display: grid; grid-template-columns: 1.4fr repeat(3, 1fr); gap: var(--gap-lg); }\n    .pagefoot h3 { color: var(--surface); font-size: 20px; margin-bottom: 12px; }\n    .pagefoot ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 8px; }\n\n    @media (max-width: 920px) {\n      :root { --gutter: 20px; --fs-h1: clamp(42px, 13vw, 62px); }\n      .grid-2, .grid-3, .grid-4, .grid-2-1, .grid-1-2, .hero-grid, .footer-grid { grid-template-columns: 1fr; }\n      .topnav nav a:not(.nav-phone) { display: none; }\n      .hero-photo { min-height: 760px; padding-bottom: 44px; }\n      .hero-panel { max-width: 440px; }\n      .form-grid { grid-template-columns: 1fr; }\n      .proof-row { grid-template-columns: 1fr; gap: 6px; }\n    }\n  </style>\n  <script type=\"application/ld+json\">\n    {\n      \"@context\": \"https://schema.org\",\n      \"@type\": \"RoofingContractor\",\n      \"name\": \"RidgeLine Roof Co.\",\n      \"telephone\": \"0400 000 000\",\n      \"url\": \"\",\n      \"areaServed\": [\n        \"Brisbane\",\n        \"Gold Coast\"\n      ],\n      \"address\": {\n        \"@type\": \"PostalAddress\",\n        \"addressLocality\": \"Service area placeholder\",\n        \"addressRegion\": \"QLD\",\n        \"addressCountry\": \"AU\"\n      },\n      \"makesOffer\": [\n        { \"@type\": \"Offer\", \"itemOffered\": { \"@type\": \"Service\", \"name\": \"Roof repairs\" } },\n        { \"@type\": \"Offer\", \"itemOffered\": { \"@type\": \"Service\", \"name\": \"Roof restoration\" } },\n        { \"@type\": \"Offer\", \"itemOffered\": { \"@type\": \"Service\", \"name\": \"Metal roofing\" } },\n        { \"@type\": \"Offer\", \"itemOffered\": { \"@type\": \"Service\", \"name\": \"Gutter repairs\" } },\n        { \"@type\": \"Offer\", \"itemOffered\": { \"@type\": \"Service\", \"name\": \"Roof inspections\" } }\n      ]\n    }\n  </script>\n</head>\n<body>\n  <header class=\"topnav\">\n    <div class=\"container topnav-inner\">\n      <a class=\"logo\" href=\"#top\" aria-label=\"RidgeLine Roof Co. home\">RidgeLine Roof Co.</a>\n      <nav aria-label=\"Primary navigation\">\n        <a href=\"#services\">Services</a>\n        <a href=\"#proof\">Workmanship</a>\n        <a href=\"#process\">Quote process</a>\n        <a href=\"#contact\">Contact</a>\n        <a class=\"nav-phone\" href=\"tel:0400000000\">0400 000 000</a>\n      </nav>\n    </div>\n  </header>\n\n  <main id=\"content\">\n    <section class=\"hero-photo\" id=\"top\" data-od-id=\"hero\">\n      <div class=\"container hero-grid\">\n        <div class=\"hero-copy\">\n          <p class=\"eyebrow\">Roof repairs · restoration · metal roofing</p>\n          <h1>Roofing for Brisbane and Gold Coast homes</h1>\n          <p class=\"lead\">RidgeLine Roof Co. helps homeowners inspect, repair, restore, and replace roof systems with clear advice before any work begins.</p>\n          <div class=\"hero-cta\">\n            <a class=\"btn btn-primary\" href=\"#contact\">Request a roof inspection</a>\n            <a class=\"btn btn-secondary\" href=\"tel:0400000000\">Call 0400 000 000</a>\n          </div>\n        </div>\n        <aside class=\"hero-panel\" aria-label=\"Quote pathway\">\n          <p class=\"eyebrow\">What to expect</p>\n          <h3>Start with the roof condition, not a sales script.</h3>\n          <ul>\n            <li>Tell us what you are seeing: leak, rust, loose flashing, storm damage, or planned restoration.</li>\n            <li>We review access, urgency, roof type, and the best next inspection path.</li>\n            <li>You receive practical repair or quote guidance before committing to work.</li>\n          </ul>\n        </aside>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"services\" data-od-id=\"services\">\n      <div class=\"container stack\" style=\"gap: 56px;\">\n        <div class=\"row-between\" style=\"align-items: end;\">\n          <div style=\"max-width: 46ch;\">\n            <p class=\"eyebrow\">Services</p>\n            <h2>Roof work homeowners can request without guesswork.</h2>\n          </div>\n          <a class=\"btn btn-ghost btn-arrow\" href=\"#contact\">Send an enquiry</a>\n        </div>\n        <div class=\"grid-3\">\n          <article class=\"service-card card\">\n            <img src=\"assets/serviceRepair-family1-service-roof-repair-flashing-detail.png\" alt=\"Close detail of roof flashing repair work\" loading=\"lazy\" />\n            <div class=\"service-body\">\n              <h3>Roof repairs</h3>\n              <p>Leak tracing, flashing issues, damaged sheets or tiles, and weather-related repair requests assessed with a clear scope.</p>\n              <span class=\"meta\">Repairs · inspections</span>\n            </div>\n          </article>\n          <article class=\"service-card card\">\n            <img src=\"assets/serviceInstall-family1-service-roof-installation-detail.png\" alt=\"Metal roofing installation detail on a residential roof\" loading=\"lazy\" />\n            <div class=\"service-body\">\n              <h3>Metal roofing</h3>\n              <p>New metal roof installation and replacement enquiries for residential properties across Brisbane and the Gold Coast.</p>\n              <span class=\"meta\">Install · replacement</span>\n            </div>\n          </article>\n          <article class=\"service-card card\">\n            <img src=\"assets/about-family1-about-roofer-working-roof-frame.png\" alt=\"Roofer working on a residential roof frame\" loading=\"lazy\" />\n            <div class=\"service-body\">\n              <h3>Restoration and gutters</h3>\n              <p>Roof restoration, gutter repairs, and maintenance planning for homes where the existing roof needs careful attention.</p>\n              <span class=\"meta\">Restore · maintain</span>\n            </div>\n          </article>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section proof-band\" id=\"proof\" data-od-id=\"proof\">\n      <div class=\"container grid-1-2\">\n        <div class=\"stack\">\n          <p class=\"eyebrow\">Workmanship cues</p>\n          <h2>A roof should be explained before it is quoted.</h2>\n          <p class=\"lead\">The process is built around visible roof condition, plain recommendations, and clear next steps. A homeowner can expect the roof to be inspected, the visible issues documented, and material choices explained before work proceeds.</p>\n        </div>\n        <div class=\"image-card\">\n          <img src=\"assets/proof-family1-project-before-after-roof-transformation.png\" alt=\"Before and after roof transformation showing residential roofing work\" loading=\"lazy\" />\n          <div class=\"caption\">\n            <strong>Project structure without fake proof</strong>\n            <span>Use real project captions and customer permission before publishing live examples.</span>\n          </div>\n        </div>\n      </div>\n      <div class=\"container\" style=\"margin-top: 52px;\">\n        <div class=\"proof-list\">\n          <article class=\"proof-row\">\n            <span class=\"meta\">Inspect</span>\n            <div>\n              <h3>Visible condition first</h3>\n              <p>Roof type, access, water entry points, gutters, flashing, and safety constraints shape the recommended path.</p>\n            </div>\n          </article>\n          <article class=\"proof-row\">\n            <span class=\"meta\">Explain</span>\n            <div>\n              <h3>Plain scope language</h3>\n              <p>Homeowners can understand whether the request is repair, restoration, replacement, or a staged maintenance issue.</p>\n            </div>\n          </article>\n          <article class=\"proof-row\">\n            <span class=\"meta\">Quote</span>\n            <div>\n              <h3>Clear next step</h3>\n              <p>The enquiry path is built around a phone call or form request, not pressure to book blind.</p>\n            </div>\n          </article>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"process\" data-od-id=\"quote-process\">\n      <div class=\"container grid-2-1\">\n        <div class=\"image-card\" style=\"min-height: 520px;\">\n          <img src=\"assets/serviceInstall-family1-service-roof-installation-detail.png\" alt=\"Premium metal roof installation detail with roofing sheets aligned\" loading=\"lazy\" />\n          <div class=\"caption\">\n            <strong>Inspection-led quoting</strong>\n            <span>Helpful for roof repairs, restoration planning, and metal roofing enquiries.</span>\n          </div>\n        </div>\n        <div class=\"stack\" style=\"gap: 28px;\">\n          <div>\n            <p class=\"eyebrow\">Quote process</p>\n            <h2>From roof concern to practical plan.</h2>\n          </div>\n          <article class=\"step\" data-step=\"01\">\n            <h3>Share the roof issue</h3>\n            <p>Use the form or phone number to describe leaks, storm damage, rust, ageing materials, or planned upgrades.</p>\n          </article>\n          <article class=\"step\" data-step=\"02\">\n            <h3>Confirm the inspection path</h3>\n            <p>RidgeLine Roof Co. checks the property type, urgency, access notes, and service area before recommending a next step.</p>\n          </article>\n          <article class=\"step\" data-step=\"03\">\n            <h3>Review repair or quote options</h3>\n            <p>You receive plain-language guidance on what needs attention and what can wait, subject to the on-site findings.</p>\n          </article>\n          <div class=\"row\" style=\"flex-wrap: wrap; padding-top: 8px;\">\n            <a class=\"btn btn-primary\" href=\"#contact\">Request a quote</a>\n            <a class=\"btn btn-secondary\" href=\"tel:0400000000\">Call now</a>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"contact\" data-od-id=\"faq-contact-footer\">\n      <div class=\"container grid-2\">\n        <div>\n          <p class=\"eyebrow\">FAQ</p>\n          <h2>Common roofing questions.</h2>\n          <div class=\"faq-list\" style=\"margin-top: 28px;\">\n            <details open>\n              <summary>Can I request a roof inspection before deciding on repairs?</summary>\n              <p>Yes. The enquiry should begin with what you are seeing, where the issue appears, and whether it is urgent. A roof inspection or quote path can then be recommended.</p>\n            </details>\n            <details>\n              <summary>Do you handle both repairs and restoration?</summary>\n              <p>Yes. The listed services include roof repairs, roof restoration, metal roofing, gutter repairs, and roof inspections for Brisbane and Gold Coast homeowners.</p>\n            </details>\n            <details>\n              <summary>What should I include in the enquiry?</summary>\n              <p>Share the suburb, roof concern, property type, preferred contact method, and any safe notes about access or visible damage.</p>\n            </details>\n            <details>\n              <summary>Can project photos and customer reviews be added?</summary>\n              <p>Yes. Real project captions, customer reviews, licence details, and insurance information can be added once the business has supplied the confirmed details.</p>\n            </details>\n          </div>\n        </div>\n        <aside class=\"contact-panel\">\n          <p class=\"eyebrow\">Request an inspection or quote</p>\n          <h2 style=\"font-size: clamp(30px, 3vw, 42px);\">Tell us what your roof needs.</h2>\n          <p class=\"lead\" style=\"margin-top: 12px;\">For urgent roof concerns, call <a href=\"tel:0400000000\">0400 000 000</a>. For planned work, send the form and include a short description.</p>\n          <form style=\"margin-top: 26px;\" action=\"#\" method=\"post\">\n            <div class=\"form-grid\">\n              <div class=\"field\">\n                <label for=\"name\">Name</label>\n                <input class=\"input\" id=\"name\" name=\"name\" autocomplete=\"name\" />\n              </div>\n              <div class=\"field\">\n                <label for=\"phone\">Phone</label>\n                <input class=\"input\" id=\"phone\" name=\"phone\" autocomplete=\"tel\" />\n              </div>\n              <div class=\"field\">\n                <label for=\"suburb\">Suburb</label>\n                <input class=\"input\" id=\"suburb\" name=\"suburb\" />\n              </div>\n              <div class=\"field\">\n                <label for=\"service\">Service needed</label>\n                <select id=\"service\" name=\"service\">\n                  <option>Roof inspection</option>\n                  <option>Roof repairs</option>\n                  <option>Roof restoration</option>\n                  <option>Metal roofing</option>\n                  <option>Gutter repairs</option>\n                </select>\n              </div>\n              <div class=\"field wide-field\">\n                <label for=\"message\">Roof concern</label>\n                <textarea class=\"textarea\" id=\"message\" name=\"message\" placeholder=\"Tell us what you are seeing: leak, rust, storm damage, cracked material, gutter issue, or planned replacement.\"></textarea>\n              </div>\n            </div>\n            <button class=\"btn btn-primary\" style=\"width: 100%; margin-top: 16px;\" type=\"submit\">Send enquiry</button>\n          </form>\n          <div class=\"rule\" style=\"margin: 26px 0 18px;\"></div>\n          <p class=\"meta\">Service area: Brisbane and Gold Coast</p>\n          <p class=\"meta\">Hours: add verified trading hours before launch</p>\n          <p class=\"meta\"><a href=\"#\" aria-label=\"Directions link placeholder\">Directions / map link placeholder</a></p>\n        </aside>\n      </div>\n    </section>\n  </main>\n\n  <footer class=\"pagefoot\">\n    <div class=\"container footer-grid\">\n      <div>\n        <h3>RidgeLine Roof Co.</h3>\n        <p style=\"margin: 0; max-width: 34ch;\">Local roofing contractor for roof repairs, restoration, metal roofing, gutter repairs, and roof inspections.</p>\n      </div>\n      <div>\n        <h3>Services</h3>\n        <ul>\n          <li><a href=\"#services\">Roof repairs</a></li>\n          <li><a href=\"#services\">Roof restoration</a></li>\n          <li><a href=\"#services\">Metal roofing</a></li>\n          <li><a href=\"#services\">Gutter repairs</a></li>\n        </ul>\n      </div>\n      <div>\n        <h3>Areas</h3>\n        <ul>\n          <li>Brisbane</li>\n          <li>Gold Coast</li>\n          <li>Nearby service area enquiries</li>\n        </ul>\n      </div>\n      <div>\n        <h3>Contact</h3>\n        <ul>\n          <li><a href=\"tel:0400000000\">0400 000 000</a></li>\n          <li><a href=\"#contact\">Request a quote</a></li>\n          <li><a href=\"#\">Directions placeholder</a></li>\n        </ul>\n      </div>\n    </div>\n  </footer>\n</body>\n</html>\n","isError":false}

