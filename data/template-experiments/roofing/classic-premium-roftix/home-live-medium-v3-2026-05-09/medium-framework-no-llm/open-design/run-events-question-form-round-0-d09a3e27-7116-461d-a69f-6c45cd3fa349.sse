data: {"type":"text_delta","delta":"Got it — high-fidelity one-page roofing home page with the Roftix premium direction already set. I’ll lock the remaining build choices first:\n<question-form id=\"discovery\" title=\"Quick brief — 30 seconds\">\n{\n  \"description\": \"I have the page type, fidelity, business facts, imagery, and design language. These last choices will keep the build aligned.\",\n  \"questions\": [\n    {\n      \"id\": \"platform\",\n      \"label\": \"Primary surface\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Responsive — all sizes\",\n        \"Desktop web\",\n        \"Mobile (iOS/Android)\",\n        \"Tablet\",\n        \"Fixed canvas (1920×1080)\"\n      ]\n    },\n    {\n      \"id\": \"audience\",\n      \"label\": \"Primary homeowner\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Premium residential homeowners\",\n        \"Storm-damage repair leads\",\n        \"Roof restoration shoppers\",\n        \"Property managers\",\n        \"Mixed residential audience\"\n      ]\n    },\n    {\n      \"id\": \"conversion\",\n      \"label\": \"Lead path emphasis\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Phone-first with supporting form\",\n        \"Form-first with supporting phone\",\n        \"Balanced phone and form\"\n      ]\n    },\n    {\n      \"id\": \"tone\",\n      \"label\": \"Visual tone\",\n      \"type\": \"checkbox\",\n      \"maxSelections\": 2,\n      \"options\": [\n        \"Classic premium\",\n        \"Cinematic trust\",\n        \"Editorial / magazine\",\n        \"Modern minimal\",\n        \"Warm local\",\n        \"Technical / workmanship\"\n      ]\n    },\n    {\n      \"id\": \"motion\",\n      \"label\": \"Motion level\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Subtle polish only\",\n        \"No motion\",\n        \"More cinematic\"\n      ]\n    },\n    {\n      \"id\": \"constraints\",\n      \"label\": \"Anything else to avoid or emphasize?\",\n      \"type\": \"textarea\",\n      \"placeholder\": \"e.g. avoid dark pages except hero/footer, make the form short, emphasize metal roofing…\"\n    }\n  ]\n}\n</question-form>"}

