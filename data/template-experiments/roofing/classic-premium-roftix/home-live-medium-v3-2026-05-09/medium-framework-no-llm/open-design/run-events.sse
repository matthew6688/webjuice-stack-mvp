data: {"type":"tool_result","toolUseId":"item_15","content":"1:<!doctype html>\n2:<html lang=\"en\">\n3:<head>\n4:  <meta charset=\"utf-8\" />\n5:  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n6:  <title>RidgeLine Roof Co. · Roofing Brisbane and Gold Coast</title>\n7:  <style>\n8:    :root {\n9:      --bg: oklch(97% 0.009 86);\n10:      --surface: oklch(100% 0 0);\n11:      --fg: oklch(19% 0.028 248);\n12:      --muted: oklch(48% 0.024 248);\n13:      --border: oklch(88% 0.012 86);\n14:      --accent: oklch(43% 0.104 151);\n15:\n16:      --accent-soft: color-mix(in oklch, var(--accent) 14%, transparent);\n17:      --fg-soft: color-mix(in oklch, var(--fg) 6%, transparent);\n18:      --ink: oklch(16% 0.027 248);\n19:      --footer: oklch(14% 0.02 248);\n20:      --warm: oklch(94% 0.014 80);\n21:\n22:      --font-display: 'Iowan Old Style', 'Charter', Georgia, 'Times New Roman', serif;\n23:      --font-body: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;\n24:      --font-mono: ui-monospace, 'JetBrains Mono', 'SF Mono', Menlo, monospace;\n25:\n26:      --fs-h1: clamp(48px, 6.4vw, 86px);\n27:      --fs-h2: clamp(34px, 4.2vw, 54px);\n28:      --fs-h3: 22px;\n29:      --fs-lead: 19px;\n30:      --fs-body: 16px;\n31:      --fs-meta: 13px;\n32:\n33:      --gap-xs: 8px;\n34:      --gap-sm: 12px;\n35:      --gap-md: 20px;\n36:      --gap-lg: 32px;\n37:      --gap-xl: 56px;\n38:      --gap-2xl: 96px;\n39:      --container: 1180px;\n40:      --gutter: 32px;\n41:\n42:      --radius: 8px;\n43:      --radius-lg: 14px;\n44:    }\n45:\n46:    *, *::before, *::after { box-sizing: border-box; }\n47:    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }\n48:    body {\n49:      margin: 0;\n50:      background: var(--bg);\n51:      color: var(--fg);\n52:      font-family: var(--font-body);\n53:      font-size: var(--fs-body);\n54:      line-height: 1.55;\n55:      text-rendering: optimizeLegibility;\n56:      -webkit-font-smoothing: antialiased;\n57:    }\n58:    img, svg { display: block; max-width: 100%; }\n59:    a { color: inherit; text-decoration: none; }\n60:    button { font: inherit; cursor: pointer; }\n61:    p { text-wrap: pretty; }\n62:    h1, h2, h3, h4 { text-wrap: balance; }\n63:\n64:    .container { max-width: var(--container); margin-inline: auto; padding-inline: var(--gutter); }\n65:    .section { padding-block: clamp(56px, 8vw, var(--gap-2xl)); }\n66:    .section + .section { border-top: 1px solid var(--border); }\n67:    .stack { display: flex; flex-direction: column; }\n68:    .stack > * + * { margin-top: var(--gap-md); }\n69:    .row { display: flex; align-items: center; gap: var(--gap-md); }\n70:    .row-between { display: flex; align-items: center; justify-content: space-between; gap: var(--gap-md); }\n71:    .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--gap-lg); }\n72:    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap-lg); }\n73:    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--gap-md); }\n74:    .grid-2-1 { display: grid; grid-template-columns: 2fr 1fr; gap: var(--gap-xl); align-items: start; }\n75:    .grid-1-2 { display: grid; grid-template-columns: 1fr 2fr; gap: var(--gap-xl); align-items: start; }\n76:    @media (max-width: 920px) {\n77:      .grid-2, .grid-3, .grid-4, .grid-2-1, .grid-1-2 { grid-template-columns: 1fr; }\n78:    }\n79:\n80:    .h1, h1 { font-family: var(--font-display); font-size: var(--fs-h1); line-height: 1.02; letter-spacing: -0.025em; margin: 0; }\n81:    .h2, h2 { font-family: var(--font-display); font-size: var(--fs-h2); line-height: 1.06; letter-spacing: -0.018em; margin: 0; }\n82:    .h3, h3 { font-family: var(--font-display); font-size: var(--fs-h3); font-weight: 600; line-height: 1.25; letter-spacing: -0.005em; margin: 0; }\n83:    .lead { font-size: var(--fs-lead); line-height: 1.55; color: var(--muted); max-width: 60ch; margin: 0; }\n84:    .eyebrow {\n85:      font-family: var(--font-mono);\n86:      font-size: 12px;\n87:      letter-spacing: 0.08em;\n88:      text-transform: uppercase;\n89:      color: var(--accent);\n90:      margin: 0 0 var(--gap-md);\n91:    }\n92:    .meta { font-family: var(--font-mono); font-size: var(--fs-meta); color: var(--muted); }\n93:    .num { font-family: var(--font-mono); font-variant-numeric: tabular-nums; }\n94:\n95:    .topnav {\n96:      position: sticky;\n97:      top: 0;\n98:      z-index: 10;\n99:      background: color-mix(in oklch, var(--bg) 92%, transparent);\n100:      backdrop-filter: blur(12px);\n101:      border-bottom: 1px solid var(--border);\n102:    }\n103:    .topnav-inner { display: flex; align-items: center; justify-content: space-between; padding-block: 14px; }\n104:    .topnav .logo { font-family: var(--font-display); font-size: 21px; font-weight: 600; letter-spacing: -0.01em; }\n105:    .topnav nav { display: flex; gap: var(--gap-lg); }\n106:    .topnav nav a { font-size: 14px; color: var(--muted); }\n107:    .topnav nav a:hover { color: var(--fg); }\n108:    .nav-phone { font-family: var(--font-mono); font-size: 13px; color: var(--fg); }\n109:\n110:    .btn {\n111:      display: inline-flex; align-items: center; justify-content: center; gap: 8px;\n112:      padding: 12px 21px;\n113:      border-radius: var(--radius);\n114:      border: 1px solid transparent;\n115:      font-size: 15px;\n116:      font-weight: 600;\n117:      letter-spacing: -0.005em;\n118:      transition: transform 0.05s ease, background 0.15s ease, border-color 0.15s ease;\n119:    }\n120:    .btn:active { transform: translateY(1px); }\n121:    .btn-primary { background: var(--accent); color: var(--surface); border-color: var(--accent); }\n122:    .btn-primary:hover { background: color-mix(in oklch, var(--accent) 86%, black); }\n123:    .btn-secondary { background: transparent; color: var(--fg); border-color: var(--border); }\n124:    .btn-secondary:hover { border-color: var(--fg); }\n125:    .btn-ghost { background: transparent; color: var(--fg); border-color: transparent; padding-inline: 8px; }\n126:    .btn-ghost:hover { color: var(--accent); }\n127:    .btn-arrow::after { content: '→'; transition: transform 0.15s ease; }\n128:    .btn-arrow:hover::after { transform: translateX(2px); }\n129:\n130:    .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 28px; }\n131:    .card-flat { background: transparent; border: 0; padding: 0; }\n132:    .card-rule { background: transparent; border: 0; border-top: 1px solid var(--fg); padding: 24px 0 0; border-radius: 0; }\n133:\n134:    .feature .feature-mark {\n135:      width: 36px; height: 36px;\n136:      display: grid; place-items: center;\n137:      border: 1px solid var(--border);\n138:      border-radius: 10px;\n139:      color: var(--accent);\n140:      margin-bottom: var(--gap-md);\n141:    }\n142:    .feature .feature-mark svg { width: 18px; height: 18px; }\n143:    .feature h3 { margin-bottom: 6px; }\n144:    .feature p { margin: 0; color: var(--muted); font-size: 15px; }\n145:\n146:    .pill {\n147:      display: inline-flex; align-items: center; gap: 6px;\n148:      padding: 4px 10px;\n149:      background: var(--accent-soft);\n150:      color: var(--accent);\n151:      border-radius: 999px;\n152:      font-family: var(--font-mono);\n153:      font-size: 11px;\n154:      letter-spacing: 0.04em;\n155:      text-transform: uppercase;\n156:    }\n157:    .tag {\n158:      display: inline-flex; align-items: center;\n159:      padding: 4px 10px;\n160:      background: transparent;\n161:      color: var(--muted);\n162:      border: 1px solid var(--border);\n163:      border-radius: 999px;\n164:      font-size: 12px;\n165:    }\n166:    .field { display: flex; flex-direction: column; gap: 6px; }\n167:    .field label { font-size: 13px; color: var(--muted); }\n168:    .input, .textarea {\n169:      width: 100%;\n170:      padding: 11px 14px;\n171:      border: 1px solid var(--border);\n172:      border-radius: var(--radius);\n173:      background: var(--surface);\n174:      color: var(--fg);\n175:      font: inherit;\n176:      font-size: 15px;\n177:    }\n178:    .input:focus, .textarea:focus { outline: 2px solid var(--accent-soft); border-color: var(--accent); }\n179:    .textarea { min-height: 96px; resize: vertical; line-height: 1.55; }\n180:\n181:    .ph-img {\n182:      background:\n183:        linear-gradient(135deg, var(--accent-soft), var(--fg-soft)),\n184:        var(--surface);\n185:      border: 1px solid var(--border);\n186:      border-radius: var(--radius-lg);\n187:      color: var(--muted);\n188:      display: grid;\n189:      place-items: center;\n190:      min-height: 280px;\n191:      overflow: hidden;\n192:      position: relative;\n193:    }\n194:    .wide { aspect-ratio: 16 / 9; }\n195:    .portrait { aspect-ratio: 4 / 5; }\n196:    .square { aspect-ratio: 1; }\n197:    .rule { height: 1px; background: var(--border); }\n198:    .rule-strong { height: 1px; background: var(--fg); }\n199:\n200:    .hero-roof {\n201:      min-height: min(820px, calc(100vh - 62px));\n202:      color: var(--surface);\n203:      background:\n204:        linear-gradient(90deg, color-mix(in oklch, var(--ink) 92%, transparent), color-mix(in oklch, var(--ink) 52%, transparent) 48%, color-mix(in oklch, var(--ink) 18%, transparent)),\n205:        radial-gradient(circle at 72% 22%, color-mix(in oklch, var(--accent) 35%, transparent), transparent 20%),\n206:        linear-gradient(145deg, oklch(27% 0.045 248), oklch(15% 0.03 248) 52%, oklch(36% 0.05 75));\n207:      position: relative;\n208:      overflow: hidden;\n209:      display: grid;\n210:      align-items: end;\n211:      padding-block: 96px 72px;\n212:    }\n213:    .hero-roof::before {\n214:      content: \"\";\n215:      position: absolute;\n216:      inset: auto -10% -14% 30%;\n217:      height: 54%;\n218:      background:\n219:        linear-gradient(158deg, transparent 0 28%, color-mix(in oklch, var(--surface) 18%, transparent) 29% 30%, transparent 31%),\n220:        repeating-linear-gradient(158deg, color-mix(in oklch, var(--surface) 18%, transparent) 0 2px, transparent 2px 38px),\n221:        linear-gradient(158deg, transparent 0 23%, color-mix(in oklch, var(--surface) 13%, transparent) 24% 58%, transparent 59%);\n222:      transform: skewY(-8deg);\n223:      opacity: 0.88;\n224:    }\n225:    .hero-roof::after {\n226:      content: \"\";\n227:      position: absolute;\n228:      inset: 0;\n229:      background:\n230:        linear-gradient(180deg, transparent, color-mix(in oklch, var(--ink) 32%, transparent)),\n231:        repeating-linear-gradient(90deg, transparent 0 108px, color-mix(in oklch, var(--surface) 6%, transparent) 108px 109px);\n232:      pointer-events: none;\n233:    }\n234:    .hero-inner { position: relative; z-index: 1; max-width: 760px; }\n235:    .hero-inner .eyebrow { color: color-mix(in oklch, var(--surface) 88%, var(--accent)); }\n236:    .hero-inner .lead { color: color-mix(in oklch, var(--surface) 78%, var(--border)); }\n237:    .hero-cta { display: flex; flex-wrap: wrap; gap: var(--gap-sm); margin-top: 30px; }\n238:    .hero-note {\n239:      margin-top: 34px;\n240:      display: grid;\n241:      grid-template-columns: repeat(3, minmax(0, 1fr));\n242:      gap: 1px;\n243:      max-width: 680px;\n244:      background: color-mix(in oklch, var(--surface) 22%, transparent);\n245:      border: 1px solid color-mix(in oklch, var(--surface) 22%, transparent);\n246:    }\n247:    .hero-note div {\n248:      background: color-mix(in oklch, var(--ink) 42%, transparent);\n249:      padding: 16px;\n250:      min-height: 92px;\n251:    }\n252:    .hero-note strong { display: block; font-family: var(--font-display); font-size: 22px; margin-bottom: 3px; }\n253:    .hero-note span { display: block; color: color-mix(in oklch, var(--surface) 72%, transparent); font-size: 13px; }\n254:\n255:    .roof-visual {\n256:      min-height: 420px;\n257:      background:\n258:        linear-gradient(180deg, color-mix(in oklch, var(--surface) 14%, transparent), transparent 28%),\n259:        linear-gradient(135deg, color-mix(in oklch, var(--fg) 90%, transparent) 0 34%, transparent 34%),\n260:        repeating-linear-gradient(135deg, color-mix(in oklch, var(--fg) 16%, transparent) 0 2px, transparent 2px 30px),\n261:        linear-gradient(145deg, oklch(32% 0.028 247), oklch(58% 0.038 80));\n262:    }\n263:    .roof-visual::before {\n264:      content: \"\";\n265:      position: absolute;\n266:      inset: 18% 12% auto auto;\n267:      width: 42%;\n268:      height: 34%;\n269:      background: color-mix(in oklch, var(--surface) 22%, transparent);\n270:      border: 1px solid color-mix(in oklch, var(--surface) 30%, transparent);\n271:      clip-path: polygon(0 50%, 50% 0, 100% 50%, 100% 100%, 0 100%);\n272:    }\n273:    .roof-visual::after {\n274:      content: \"roofline inspection\";\n275:      position: absolute;\n276:      left: 24px;\n277:      bottom: 22px;\n278:      color: color-mix(in oklch, var(--surface) 82%, transparent);\n279:      font-family: var(--font-mono);\n280:      font-size: 12px;\n281:      letter-spacing: 0.08em;\n282:      text-transform: uppercase;\n283:    }\n284:\n285:    .service-photo {\n286:      min-height: 280px;\n287:      background:\n288:        radial-gradient(circle at 68% 28%, color-mix(in oklch, var(--accent) 32%, transparent), transparent 18%),\n289:        repeating-linear-gradient(112deg, color-mix(in oklch, var(--fg) 14%, transparent) 0 2px, transparent 2px 24px),\n290:        linear-gradient(140deg, oklch(37% 0.03 247), oklch(82% 0.025 74));\n291:    }\n292:    .project-photo {\n293:      min-height: 360px;\n294:      background:\n295:        linear-gradient(90deg, color-mix(in oklch, var(--surface) 56%, transparent) 0 49%, color-mix(in oklch, var(--fg) 20%, transparent) 49% 51%, transparent 51%),\n296:        repeating-linear-gradient(150deg, color-mix(in oklch, var(--fg) 12%, transparent) 0 2px, transparent 2px 32px),\n297:        linear-gradient(140deg, oklch(76% 0.017 84), oklch(30% 0.035 246));\n298:    }\n299:    .project-photo::after {\n300:      content: \"project structure preview\";\n301:      position: absolute;\n302:      left: 22px;\n303:      bottom: 20px;\n304:      font-family: var(--font-mono);\n305:      font-size: 12px;\n306:      letter-spacing: 0.08em;\n307:      text-transform: uppercase;\n308:      color: var(--surface);\n309:    }\n310:\n311:    .process-list { counter-reset: step; display: grid; gap: 18px; }\n312:    .process-item {\n313:      counter-increment: step;\n314:      display: grid;\n315:      grid-template-columns: 48px 1fr;\n316:      gap: 18px;\n317:      padding-top: 18px;\n318:      border-top: 1px solid var(--border);\n319:    }\n320:    .process-item::before {\n321:      content: counter(step, decimal-leading-zero);\n322:      font-family: var(--font-mono);\n323:      color: var(--muted);\n324:      font-size: 13px;\n325:    }\n326:    .faq-list { display: grid; gap: 1px; background: var(--border); border: 1px solid var(--border); }\n327:    .faq-item { background: var(--surface); padding: 22px; }\n328:    .faq-item h3 { font-size: 21px; margin-bottom: 8px; }\n329:    .faq-item p { margin: 0; color: var(--muted); }\n330:    .contact-panel {\n331:      background: var(--ink);\n332:      color: var(--surface);\n333:      border-radius: var(--radius-lg);\n334:      padding: clamp(28px, 4vw, 42px);\n335:    }\n336:    .contact-panel .lead, .contact-panel label { color: color-mix(in oklch, var(--surface) 72%, transparent); }\n337:    .contact-panel .input, .contact-panel .textarea {\n338:      background: color-mix(in oklch, var(--surface) 8%, transparent);\n339:      color: var(--surface);\n340:      border-color: color-mix(in oklch, var(--surface) 22%, transparent);\n341:    }\n342:    .contact-panel .input::placeholder, .contact-panel .textarea::placeholder { color: color-mix(in oklch, var(--surface) 48%, transparent); }\n343:    .pagefoot {\n344:      padding-block: var(--gap-xl);\n345:      background: var(--footer);\n346:      color: color-mix(in oklch, var(--surface) 60%, transparent);\n347:      font-size: 13px;\n348:      border-top: 0;\n349:    }\n350:    .pagefoot .row-between { flex-wrap: wrap; gap: var(--gap-md); }\n351:    .footer-brand { color: var(--surface); font-family: var(--font-display); font-size: 24px; }\n352:\n353:    @media (max-width: 720px) {\n354:      :root { --gutter: 20px; }\n355:      .topnav nav { display: none; }\n356:      .hero-roof { min-height: 720px; padding-block: 82px 52px; }\n357:      .hero-note { grid-template-columns: 1fr; }\n358:      .hero-cta .btn { width: 100%; }\n359:      .nav-phone { display: none; }\n360:    }\n361:  </style>\n362:</head>\n363:<body>\n364:  <header class=\"topnav\">\n365:    <div class=\"container topnav-inner\">\n366:      <a class=\"logo\" href=\"#top\" aria-label=\"RidgeLine Roof Co. home\">RidgeLine Roof Co.</a>\n367:      <nav aria-label=\"Main navigation\">\n368:        <a href=\"#services\">Services</a>\n369:        <a href=\"#work\">Work</a>\n370:        <a href=\"#process\">Process</a>\n371:        <a href=\"#contact\">Contact</a>\n372:      </nav>\n373:      <a class=\"nav-phone\" href=\"tel:0400000000\">0400 000 000</a>\n374:    </div>\n375:  </header>\n376:\n377:  <main id=\"content\">\n378:    <section class=\"section hero-roof\" id=\"top\" data-od-id=\"hero\">\n379:      <div class=\"container hero-inner\">\n380:        <p class=\"eyebrow\">Residential roofing · Brisbane and Gold Coast</p>\n381:        <h1>Premium roof care for homes that need a clear next step.</h1>\n382:        <p class=\"lead\" style=\"margin-top: 22px;\">RidgeLine Roof Co. helps homeowners request roof repairs, restorations, metal roofing, gutter repairs, and roof inspections without guesswork.</p>\n383:        <div class=\"hero-cta\">\n384:          <a class=\"btn btn-primary\" href=\"#contact\">Request an inspection</a>\n385:          <a class=\"btn btn-secondary\" href=\"tel:0400000000\">Call 0400 000 000</a>\n386:        </div>\n387:        <div class=\"hero-note\" aria-label=\"Roofing service highlights\">\n388:          <div><strong>Repair</strong><span>Leaking, flashing, storm, and gutter issues.</span></div>\n389:          <div><strong>Restore</strong><span>Coating, cleaning, and visible roof renewal.</span></div>\n390:          <div><strong>Inspect</strong><span>Clear findings before larger roof decisions.</span></div>\n391:        </div>\n392:      </div>\n393:    </section>\n394:\n395:    <section class=\"section\" id=\"services\" data-od-id=\"services\">\n396:      <div class=\"container stack\" style=\"gap: 56px;\">\n397:        <div class=\"grid-2-1\">\n398:          <div>\n399:            <p class=\"eyebrow\">What you can request</p>\n400:            <h2>Roofing help shaped around the problem you can see.</h2>\n401:          </div>\n402:          <p class=\"lead\">Start with the symptom: a leak, a tired roofline, loose guttering, or a home purchase that needs a roof check. The enquiry can be scoped from there.</p>\n403:        </div>\n404:        <div class=\"grid-3\">\n405:          <div class=\"feature card-flat\">\n406:            <div class=\"feature-mark\" aria-hidden=\"true\">\n407:              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\"><path d=\"M4 12 12 5l8 7\"/><path d=\"M7 12v7h10v-7\"/><path d=\"M10 19v-5h4v5\"/></svg>\n408:            </div>\n409:            <h3>Roof repairs</h3>\n410:            <p>Targeted repair enquiries for leaks, flashing, cracked bedding, slipped sheets, and visible storm wear.</p>\n411:          </div>\n412:          <div class=\"feature card-flat\">\n413:            <div class=\"feature-mark\" aria-hidden=\"true\">\n414:              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\"><path d=\"M4 16c4-7 12-7 16 0\"/><path d=\"M6 18h12\"/><path d=\"M8 20h8\"/></svg>\n415:            </div>\n416:            <h3>Roof restoration</h3>\n417:            <p>Cleaning, surface preparation, coating, and detail work for homeowners weighing restoration before replacement.</p>\n418:          </div>\n419:          <div class=\"feature card-flat\">\n420:            <div class=\"feature-mark\" aria-hidden=\"true\">\n421:              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\"><path d=\"M5 7h14\"/><path d=\"M6 11h12\"/><path d=\"M7 15h10\"/><path d=\"M8 19h8\"/></svg>\n422:            </div>\n423:            <h3>Metal roofing</h3>\n424:            <p>New metal roof and replacement enquiries with attention to roof profile, drainage, ventilation, and finish.</p>\n425:          </div>\n426:        </div>\n427:        <div class=\"grid-2\">\n428:          <div class=\"ph-img service-photo wide\" aria-label=\"Roof repair detail visual\"></div>\n429:          <div class=\"card stack\">\n430:            <span class=\"pill\">Also available</span>\n431:            <h3>Gutter repairs and roof inspections</h3>\n432:            <p style=\"margin: 0; color: var(--muted);\">Gutters, downpipes, valley drainage, pre-sale checks, post-storm concerns, and practical inspection reports can all be requested through the same form.</p>\n433:            <div class=\"row\" style=\"flex-wrap: wrap;\">\n434:              <span class=\"tag\">Gutter repairs</span>\n435:              <span class=\"tag\">Roof inspections</span>\n436:              <span class=\"tag\">Storm concerns</span>\n437:            </div>\n438:          </div>\n439:        </div>\n440:      </div>\n441:    </section>\n442:\n443:    <section class=\"section\" id=\"work\" data-od-id=\"proof\">\n444:      <div class=\"container grid-1-2\">\n445:        <div class=\"stack\">\n446:          <p class=\"eyebrow\">Concrete proof, no invented claims</p>\n447:          <h2>See the work as a sequence, not a slogan.</h2>\n448:          <p class=\"lead\">A roof quote should make the condition, the work area, and the recommended next step easy to understand. This page uses project-style structure without pretending to have reviews, awards, or certifications.</p>\n449:          <a class=\"btn btn-secondary btn-arrow\" href=\"#contact\" style=\"width: fit-content;\">Send roof details</a>\n450:        </div>\n451:        <div class=\"stack\">\n452:          <div class=\"ph-img project-photo wide\" aria-label=\"Before and after roof structure visual\"></div>\n453:          <div class=\"grid-3\">\n454:            <div class=\"card-rule\">\n455:              <h3>Condition</h3>\n456:              <p style=\"margin: 8px 0 0; color: var(--muted); font-size: 15px;\">What is visible from ground level, ceiling space, or inspection photos.</p>\n457:            </div>\n458:            <div class=\"card-rule\">\n459:              <h3>Scope</h3>\n460:              <p style=\"margin: 8px 0 0; color: var(--muted); font-size: 15px;\">The repair, restoration, gutter, or roofing area to be priced.</p>\n461:            </div>\n462:            <div class=\"card-rule\">\n463:              <h3>Next step</h3>\n464:              <p style=\"margin: 8px 0 0; color: var(--muted); font-size: 15px;\">A clear inspection or quote request instead of a vague callback.</p>\n465:            </div>\n466:          </div>\n467:        </div>\n468:      </div>\n469:    </section>\n470:\n471:    <section class=\"section\" id=\"process\" data-od-id=\"quote-process\" style=\"background: var(--warm);\">\n472:      <div class=\"container grid-2\">\n473:        <div class=\"ph-img roof-visual portrait\" aria-label=\"Premium roofline visual\"></div>\n474:        <div class=\"stack\" style=\"justify-content: center;\">\n475:          <p class=\"eyebrow\">Inspection and quote path</p>\n476:          <h2>A simple way to move from roof concern to scoped enquiry.</h2>\n477:          <div class=\"process-list\" style=\"margin-top: 22px;\">\n478:            <div class=\"process-item\">\n479:              <div>\n480:                <h3>Describe the roof issue</h3>\n481:                <p style=\"margin: 6px 0 0; color: var(--muted);\">Share whether it is a leak, restoration, metal roofing, gutters, or inspection request.</p>\n482:              </div>\n483:            </div>\n484:            <div class=\"process-item\">\n485:              <div>\n486:                <h3>Attach the right context</h3>\n487:                <p style=\"margin: 6px 0 0; color: var(--muted);\">Mention the suburb, roof type if known, access notes, and whether the issue is urgent.</p>\n488:              </div>\n489:            </div>\n490:            <div class=\"process-item\">\n491:              <div>\n492:                <h3>Book the next step</h3>\n493:                <p style=\"margin: 6px 0 0; color: var(--muted);\">Use the form or phone CTA to request an inspection or quote for Brisbane and Gold Coast homes.</p>\n494:              </div>\n495:            </div>\n496:          </div>\n497:          <div class=\"hero-cta\">\n498:            <a class=\"btn btn-primary\" href=\"#contact\">Request a quote</a>\n499:            <a class=\"btn btn-secondary\" href=\"tel:0400000000\">Call now</a>\n500:          </div>\n501:        </div>\n502:      </div>\n503:    </section>\n504:\n505:    <section class=\"section\" id=\"contact\" data-od-id=\"faq-contact-footer\">\n506:      <div class=\"container grid-2\">\n507:        <div class=\"stack\">\n508:          <p class=\"eyebrow\">Questions homeowners ask</p>\n509:          <h2>Useful answers before you send the form.</h2>\n510:          <div class=\"faq-list\" style=\"margin-top: 18px;\">\n511:            <article class=\"faq-item\">\n512:              <h3>Can I ask about a small leak?</h3>\n513:              <p>Yes. Small roof issues can still need prompt attention, especially around flashing, valleys, vents, and gutters.</p>\n514:            </article>\n515:            <article class=\"faq-item\">\n516:              <h3>Do I need to know the roof material?</h3>\n517:              <p>No. If you know it is tile or metal, include that. If not, describe the problem and the team can scope the next step.</p>\n518:            </article>\n519:            <article class=\"faq-item\">\n520:              <h3>What areas are covered?</h3>\n521:              <p>RidgeLine Roof Co. is presented for Brisbane and Gold Coast roofing enquiries.</p>\n522:            </article>\n523:          </div>\n524:        </div>\n525:        <div class=\"contact-panel stack\">\n526:          <div>\n527:            <p class=\"eyebrow\">Request an inspection</p>\n528:            <h2>Tell us what is happening with the roof.</h2>\n529:            <p class=\"lead\" style=\"margin-top: 14px;\">Use the form for repair, restoration, metal roofing, gutter, and inspection enquiries. For phone enquiries, call <a href=\"tel:0400000000\" style=\"text-decoration: underline;\">0400 000 000</a>.</p>\n530:          </div>\n531:          <form class=\"stack\" aria-label=\"Roofing enquiry form\">\n532:            <div class=\"grid-2\">\n533:              <div class=\"field\">\n534:                <label for=\"name\">Name</label>\n535:                <input class=\"input\" id=\"name\" name=\"name\" autocomplete=\"name\" placeholder=\"Your name\" />\n536:              </div>\n537:              <div class=\"field\">\n538:                <label for=\"phone\">Phone</label>\n539:                <input class=\"input\" id=\"phone\" name=\"phone\" autocomplete=\"tel\" placeholder=\"Best contact number\" />\n540:              </div>\n541:            </div>\n542:            <div class=\"field\">\n543:              <label for=\"service\">What do you need?</label>\n544:              <select class=\"input\" id=\"service\" name=\"service\">\n545:                <option>Roof repairs</option>\n546:                <option>Roof restoration</option>\n547:                <option>Metal roofing</option>\n548:                <option>Gutter repairs</option>\n549:                <option>Roof inspection</option>\n550:              </select>\n551:            </div>\n552:            <div class=\"field\">\n553:              <label for=\"message\">Roof details</label>\n554:              <textarea class=\"textarea\" id=\"message\" name=\"message\" placeholder=\"Suburb, roof concern, access notes, and anything visible from the ground.\"></textarea>\n555:            </div>\n556:            <button class=\"btn btn-primary\" type=\"button\">Send enquiry</button>\n557:          </form>\n558:        </div>\n559:      </div>\n560:    </section>\n561:  </main>\n562:\n563:  <footer class=\"pagefoot\">\n564:    <div class=\"container row-between\">\n565:      <div>\n566:        <div class=\"footer-brand\">RidgeLine Roof Co.</div>\n567:        <p style=\"margin: 8px 0 0;\">Local roofing contractor for Brisbane and Gold Coast homeowners.</p>\n568:      </div>\n569:      <div class=\"row\" style=\"flex-wrap: wrap;\">\n570:        <a href=\"#services\">Services</a>\n571:        <a href=\"#process\">Quote process</a>\n572:        <a href=\"#contact\">Contact</a>\n573:        <a href=\"tel:0400000000\">0400 000 000</a>\n574:      </div>\n575:    </div>\n576:  </footer>\n577:</body>\n578:</html>\n","isError":false}

