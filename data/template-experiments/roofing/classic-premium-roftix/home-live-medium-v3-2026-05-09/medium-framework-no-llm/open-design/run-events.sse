id: 186
event: agent
data: {"type":"tool_result","toolUseId":"item_24","content":"<!doctype html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>RidgeLine Roof Co. · Roofing Brisbane and Gold Coast</title>\n  <style>\n    :root {\n      --bg: oklch(97% 0.009 86);\n      --surface: oklch(100% 0 0);\n      --fg: oklch(19% 0.028 248);\n      --muted: oklch(48% 0.024 248);\n      --border: oklch(88% 0.012 86);\n      --accent: oklch(43% 0.104 151);\n\n      --accent-soft: color-mix(in oklch, var(--accent) 14%, transparent);\n      --fg-soft: color-mix(in oklch, var(--fg) 6%, transparent);\n      --ink: oklch(16% 0.027 248);\n      --footer: oklch(14% 0.02 248);\n      --warm: oklch(94% 0.014 80);\n      --roof-blue: oklch(27% 0.045 248);\n      --roof-night: oklch(15% 0.03 248);\n      --roof-gold: oklch(36% 0.05 75);\n      --roof-slate: oklch(32% 0.028 247);\n      --roof-sand: oklch(58% 0.038 80);\n      --roof-steel: oklch(37% 0.03 247);\n      --roof-warm: oklch(82% 0.025 74);\n      --roof-before: oklch(76% 0.017 84);\n      --roof-after: oklch(30% 0.035 246);\n\n      --font-display: 'Iowan Old Style', 'Charter', Georgia, 'Times New Roman', serif;\n      --font-body: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;\n      --font-mono: ui-monospace, 'JetBrains Mono', 'SF Mono', Menlo, monospace;\n\n      --fs-h1: clamp(48px, 6.4vw, 86px);\n      --fs-h2: clamp(34px, 4.2vw, 54px);\n      --fs-h3: 22px;\n      --fs-lead: 19px;\n      --fs-body: 16px;\n      --fs-meta: 13px;\n\n      --gap-xs: 8px;\n      --gap-sm: 12px;\n      --gap-md: 20px;\n      --gap-lg: 32px;\n      --gap-xl: 56px;\n      --gap-2xl: 96px;\n      --container: 1180px;\n      --gutter: 32px;\n\n      --radius: 8px;\n      --radius-lg: 14px;\n    }\n\n    *, *::before, *::after { box-sizing: border-box; }\n    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }\n    body {\n      margin: 0;\n      background: var(--bg);\n      color: var(--fg);\n      font-family: var(--font-body);\n      font-size: var(--fs-body);\n      line-height: 1.55;\n      text-rendering: optimizeLegibility;\n      -webkit-font-smoothing: antialiased;\n    }\n    img, svg { display: block; max-width: 100%; }\n    a { color: inherit; text-decoration: none; }\n    button { font: inherit; cursor: pointer; }\n    p { text-wrap: pretty; }\n    h1, h2, h3, h4 { text-wrap: balance; }\n\n    .container { max-width: var(--container); margin-inline: auto; padding-inline: var(--gutter); }\n    .section { padding-block: clamp(56px, 8vw, var(--gap-2xl)); }\n    .section + .section { border-top: 1px solid var(--border); }\n    .stack { display: flex; flex-direction: column; }\n    .stack > * + * { margin-top: var(--gap-md); }\n    .row { display: flex; align-items: center; gap: var(--gap-md); }\n    .row-between { display: flex; align-items: center; justify-content: space-between; gap: var(--gap-md); }\n    .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--gap-lg); }\n    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap-lg); }\n    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--gap-md); }\n    .grid-2-1 { display: grid; grid-template-columns: 2fr 1fr; gap: var(--gap-xl); align-items: start; }\n    .grid-1-2 { display: grid; grid-template-columns: 1fr 2fr; gap: var(--gap-xl); align-items: start; }\n    @media (max-width: 920px) {\n      .grid-2, .grid-3, .grid-4, .grid-2-1, .grid-1-2 { grid-template-columns: 1fr; }\n    }\n\n    .h1, h1 { font-family: var(--font-display); font-size: var(--fs-h1); line-height: 1.02; letter-spacing: -0.025em; margin: 0; }\n    .h2, h2 { font-family: var(--font-display); font-size: var(--fs-h2); line-height: 1.06; letter-spacing: -0.018em; margin: 0; }\n    .h3, h3 { font-family: var(--font-display); font-size: var(--fs-h3); font-weight: 600; line-height: 1.25; letter-spacing: -0.005em; margin: 0; }\n    .lead { font-size: var(--fs-lead); line-height: 1.55; color: var(--muted); max-width: 60ch; margin: 0; }\n    .eyebrow {\n      font-family: var(--font-mono);\n      font-size: 12px;\n      letter-spacing: 0.08em;\n      text-transform: uppercase;\n      color: var(--accent);\n      margin: 0 0 var(--gap-md);\n    }\n    .meta { font-family: var(--font-mono); font-size: var(--fs-meta); color: var(--muted); }\n    .num { font-family: var(--font-mono); font-variant-numeric: tabular-nums; }\n\n    .topnav {\n      position: sticky;\n      top: 0;\n      z-index: 10;\n      background: color-mix(in oklch, var(--bg) 92%, transparent);\n      backdrop-filter: blur(12px);\n      border-bottom: 1px solid var(--border);\n    }\n    .topnav-inner { display: flex; align-items: center; justify-content: space-between; padding-block: 14px; }\n    .topnav .logo { font-family: var(--font-display); font-size: 21px; font-weight: 600; letter-spacing: -0.01em; }\n    .topnav nav { display: flex; gap: var(--gap-lg); }\n    .topnav nav a { font-size: 14px; color: var(--muted); }\n    .topnav nav a:hover { color: var(--fg); }\n    .nav-phone { font-family: var(--font-mono); font-size: 13px; color: var(--fg); }\n\n    .btn {\n      display: inline-flex; align-items: center; justify-content: center; gap: 8px;\n      padding: 12px 21px;\n      border-radius: var(--radius);\n      border: 1px solid transparent;\n      font-size: 15px;\n      font-weight: 600;\n      letter-spacing: -0.005em;\n      transition: transform 0.05s ease, background 0.15s ease, border-color 0.15s ease;\n    }\n    .btn:active { transform: translateY(1px); }\n    .btn-primary { background: var(--accent); color: var(--surface); border-color: var(--accent); }\n    .btn-primary:hover { background: color-mix(in oklch, var(--accent) 86%, black); }\n    .btn-secondary { background: transparent; color: var(--fg); border-color: var(--border); }\n    .btn-secondary:hover { border-color: var(--fg); }\n    .btn-ghost { background: transparent; color: var(--fg); border-color: transparent; padding-inline: 8px; }\n    .btn-ghost:hover { color: var(--accent); }\n    .btn-arrow::after { content: '→'; transition: transform 0.15s ease; }\n    .btn-arrow:hover::after { transform: translateX(2px); }\n\n    .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 28px; }\n    .card-flat { background: transparent; border: 0; padding: 0; }\n    .card-rule { background: transparent; border: 0; border-top: 1px solid var(--fg); padding: 24px 0 0; border-radius: 0; }\n\n    .feature .feature-mark {\n      width: 36px; height: 36px;\n      display: grid; place-items: center;\n      border: 1px solid var(--border);\n      border-radius: 10px;\n      color: var(--accent);\n      margin-bottom: var(--gap-md);\n    }\n    .feature .feature-mark svg { width: 18px; height: 18px; }\n    .feature h3 { margin-bottom: 6px; }\n    .feature p { margin: 0; color: var(--muted); font-size: 15px; }\n\n    .pill {\n      display: inline-flex; align-items: center; gap: 6px;\n      padding: 4px 10px;\n      background: var(--accent-soft);\n      color: var(--accent);\n      border-radius: 999px;\n      font-family: var(--font-mono);\n      font-size: 11px;\n      letter-spacing: 0.04em;\n      text-transform: uppercase;\n    }\n    .tag {\n      display: inline-flex; align-items: center;\n      padding: 4px 10px;\n      background: transparent;\n      color: var(--muted);\n      border: 1px solid var(--border);\n      border-radius: 999px;\n      font-size: 12px;\n    }\n    .field { display: flex; flex-direction: column; gap: 6px; }\n    .field label { font-size: 13px; color: var(--muted); }\n    .input, .textarea {\n      width: 100%;\n      padding: 11px 14px;\n      border: 1px solid var(--border);\n      border-radius: var(--radius);\n      background: var(--surface);\n      color: var(--fg);\n      font: inherit;\n      font-size: 15px;\n    }\n    .input:focus, .textarea:focus { outline: 2px solid var(--accent-soft); border-color: var(--accent); }\n    .textarea { min-height: 96px; resize: vertical; line-height: 1.55; }\n\n    .ph-img {\n      background:\n        linear-gradient(135deg, var(--accent-soft), var(--fg-soft)),\n        var(--surface);\n      border: 1px solid var(--border);\n      border-radius: var(--radius-lg);\n      color: var(--muted);\n      display: grid;\n      place-items: center;\n      min-height: 280px;\n      overflow: hidden;\n      position: relative;\n    }\n    .wide { aspect-ratio: 16 / 9; }\n    .portrait { aspect-ratio: 4 / 5; }\n    .square { aspect-ratio: 1; }\n    .rule { height: 1px; background: var(--border); }\n    .rule-strong { height: 1px; background: var(--fg); }\n\n    .hero-roof {\n      min-height: min(820px, calc(100vh - 62px));\n      color: var(--surface);\n      background:\n        linear-gradient(90deg, color-mix(in oklch, var(--ink) 92%, transparent), color-mix(in oklch, var(--ink) 52%, transparent) 48%, color-mix(in oklch, var(--ink) 18%, transparent)),\n        radial-gradient(circle at 72% 22%, color-mix(in oklch, var(--accent) 35%, transparent), transparent 20%),\n        linear-gradient(145deg, var(--roof-blue), var(--roof-night) 52%, var(--roof-gold));\n      position: relative;\n      overflow: hidden;\n      display: grid;\n      align-items: end;\n      padding-block: 96px 72px;\n    }\n    .hero-roof::before {\n      content: \"\";\n      position: absolute;\n      inset: auto -10% -14% 30%;\n      height: 54%;\n      background:\n        linear-gradient(158deg, transparent 0 28%, color-mix(in oklch, var(--surface) 18%, transparent) 29% 30%, transparent 31%),\n        repeating-linear-gradient(158deg, color-mix(in oklch, var(--surface) 18%, transparent) 0 2px, transparent 2px 38px),\n        linear-gradient(158deg, transparent 0 23%, color-mix(in oklch, var(--surface) 13%, transparent) 24% 58%, transparent 59%);\n      transform: skewY(-8deg);\n      opacity: 0.88;\n    }\n    .hero-roof::after {\n      content: \"\";\n      position: absolute;\n      inset: 0;\n      background:\n        linear-gradient(180deg, transparent, color-mix(in oklch, var(--ink) 32%, transparent)),\n        repeating-linear-gradient(90deg, transparent 0 108px, color-mix(in oklch, var(--surface) 6%, transparent) 108px 109px);\n      pointer-events: none;\n    }\n    .hero-inner { position: relative; z-index: 1; max-width: 760px; }\n    .hero-inner .eyebrow { color: color-mix(in oklch, var(--surface) 88%, var(--accent)); }\n    .hero-inner .lead { color: color-mix(in oklch, var(--surface) 78%, var(--border)); }\n    .hero-cta { display: flex; flex-wrap: wrap; gap: var(--gap-sm); margin-top: 30px; }\n    .hero-note {\n      margin-top: 34px;\n      display: grid;\n      grid-template-columns: repeat(3, minmax(0, 1fr));\n      gap: 1px;\n      max-width: 680px;\n      background: color-mix(in oklch, var(--surface) 22%, transparent);\n      border: 1px solid color-mix(in oklch, var(--surface) 22%, transparent);\n    }\n    .hero-note div {\n      background: color-mix(in oklch, var(--ink) 42%, transparent);\n      padding: 16px;\n      min-height: 92px;\n    }\n    .hero-note strong { display: block; font-family: var(--font-display); font-size: 22px; margin-bottom: 3px; }\n    .hero-note span { display: block; color: color-mix(in oklch, var(--surface) 72%, transparent); font-size: 13px; }\n\n    .roof-visual {\n      min-height: 420px;\n      background:\n        linear-gradient(180deg, color-mix(in oklch, var(--surface) 14%, transparent), transparent 28%),\n        linear-gradient(135deg, color-mix(in oklch, var(--fg) 90%, transparent) 0 34%, transparent 34%),\n        repeating-linear-gradient(135deg, color-mix(in oklch, var(--fg) 16%, transparent) 0 2px, transparent 2px 30px),\n        linear-gradient(145deg, var(--roof-slate), var(--roof-sand));\n    }\n    .roof-visual::before {\n      content: \"\";\n      position: absolute;\n      inset: 18% 12% auto auto;\n      width: 42%;\n      height: 34%;\n      background: color-mix(in oklch, var(--surface) 22%, transparent);\n      border: 1px solid color-mix(in oklch, var(--surface) 30%, transparent);\n      clip-path: polygon(0 50%, 50% 0, 100% 50%, 100% 100%, 0 100%);\n    }\n    .roof-visual::after {\n      content: \"roofline inspection\";\n      position: absolute;\n      left: 24px;\n      bottom: 22px;\n      color: color-mix(in oklch, var(--surface) 82%, transparent);\n      font-family: var(--font-mono);\n      font-size: 12px;\n      letter-spacing: 0.08em;\n      text-transform: uppercase;\n    }\n\n    .service-photo {\n      min-height: 280px;\n      background:\n        radial-gradient(circle at 68% 28%, color-mix(in oklch, var(--accent) 32%, transparent), transparent 18%),\n        repeating-linear-gradient(112deg, color-mix(in oklch, var(--fg) 14%, transparent) 0 2px, transparent 2px 24px),\n        linear-gradient(140deg, var(--roof-steel), var(--roof-warm));\n    }\n    .project-photo {\n      min-height: 360px;\n      background:\n        linear-gradient(90deg, color-mix(in oklch, var(--surface) 56%, transparent) 0 49%, color-mix(in oklch, var(--fg) 20%, transparent) 49% 51%, transparent 51%),\n        repeating-linear-gradient(150deg, color-mix(in oklch, var(--fg) 12%, transparent) 0 2px, transparent 2px 32px),\n        linear-gradient(140deg, var(--roof-before), var(--roof-after));\n    }\n    .project-photo::after {\n      content: \"before / after roof areas\";\n      position: absolute;\n      left: 22px;\n      bottom: 20px;\n      font-family: var(--font-mono);\n      font-size: 12px;\n      letter-spacing: 0.08em;\n      text-transform: uppercase;\n      color: var(--surface);\n    }\n\n    .process-list { counter-reset: step; display: grid; gap: 18px; }\n    .process-item {\n      counter-increment: step;\n      display: grid;\n      grid-template-columns: 48px 1fr;\n      gap: 18px;\n      padding-top: 18px;\n      border-top: 1px solid var(--border);\n    }\n    .process-item::before {\n      content: counter(step, decimal-leading-zero);\n      font-family: var(--font-mono);\n      color: var(--muted);\n      font-size: 13px;\n    }\n    .faq-list { display: grid; gap: 1px; background: var(--border); border: 1px solid var(--border); }\n    .faq-item { background: var(--surface); padding: 22px; }\n    .faq-item h3 { font-size: 21px; margin-bottom: 8px; }\n    .faq-item p { margin: 0; color: var(--muted); }\n    .contact-panel {\n      background: var(--ink);\n      color: var(--surface);\n      border-radius: var(--radius-lg);\n      padding: clamp(28px, 4vw, 42px);\n    }\n    .contact-panel .lead, .contact-panel label { color: color-mix(in oklch, var(--surface) 72%, transparent); }\n    .contact-panel .input, .contact-panel .textarea {\n      background: color-mix(in oklch, var(--surface) 8%, transparent);\n      color: var(--surface);\n      border-color: color-mix(in oklch, var(--surface) 22%, transparent);\n    }\n    .contact-panel .input::placeholder, .contact-panel .textarea::placeholder { color: color-mix(in oklch, var(--surface) 48%, transparent); }\n    .pagefoot {\n      padding-block: var(--gap-xl);\n      background: var(--footer);\n      color: color-mix(in oklch, var(--surface) 60%, transparent);\n      font-size: 13px;\n      border-top: 0;\n    }\n    .pagefoot .row-between { flex-wrap: wrap; gap: var(--gap-md); }\n    .footer-brand { color: var(--surface); font-family: var(--font-display); font-size: 24px; }\n\n    @media (max-width: 720px) {\n      :root { --gutter: 20px; }\n      .topnav nav { display: none; }\n      .hero-roof { min-height: 720px; padding-block: 82px 52px; }\n      .hero-note { grid-template-columns: 1fr; }\n      .hero-cta .btn { width: 100%; }\n      .nav-phone { display: none; }\n    }\n  </style>\n</head>\n<body>\n  <header class=\"topnav\">\n    <div class=\"container topnav-inner\">\n      <a class=\"logo\" href=\"#top\" aria-label=\"RidgeLine Roof Co. home\">RidgeLine Roof Co.</a>\n      <nav aria-label=\"Main navigation\">\n        <a href=\"#services\">Services</a>\n        <a href=\"#work\">Work</a>\n        <a href=\"#process\">Process</a>\n        <a href=\"#contact\">Contact</a>\n      </nav>\n      <a class=\"nav-phone\" href=\"tel:0400000000\">0400 000 000</a>\n    </div>\n  </header>\n\n  <main id=\"content\">\n    <section class=\"section hero-roof\" id=\"top\" data-od-id=\"hero\">\n      <div class=\"container hero-inner\">\n        <p class=\"eyebrow\">Residential roofing · Brisbane and Gold Coast</p>\n        <h1>Premium roof care for homes that need a clear next step.</h1>\n        <p class=\"lead\" style=\"margin-top: 22px;\">RidgeLine Roof Co. helps homeowners request roof repairs, restorations, metal roofing, gutter repairs, and roof inspections without guesswork.</p>\n        <div class=\"hero-cta\">\n          <a class=\"btn btn-primary\" href=\"#contact\">Request an inspection</a>\n          <a class=\"btn btn-secondary\" href=\"tel:0400000000\">Call 0400 000 000</a>\n        </div>\n        <div class=\"hero-note\" aria-label=\"Roofing service highlights\">\n          <div><strong>Repair</strong><span>Leaking, flashing, storm, and gutter issues.</span></div>\n          <div><strong>Restore</strong><span>Coating, cleaning, and visible roof renewal.</span></div>\n          <div><strong>Inspect</strong><span>Clear findings before larger roof decisions.</span></div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"services\" data-od-id=\"services\">\n      <div class=\"container stack\" style=\"gap: 56px;\">\n        <div class=\"grid-2-1\">\n          <div>\n            <p class=\"eyebrow\">What you can request</p>\n            <h2>Roofing help shaped around the problem you can see.</h2>\n          </div>\n          <p class=\"lead\">Start with the symptom: a leak, a tired roofline, loose guttering, or a home purchase that needs a roof check. The enquiry can be scoped from there.</p>\n        </div>\n        <div class=\"grid-3\">\n          <div class=\"feature card-flat\">\n            <div class=\"feature-mark\" aria-hidden=\"true\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\"><path d=\"M4 12 12 5l8 7\"/><path d=\"M7 12v7h10v-7\"/><path d=\"M10 19v-5h4v5\"/></svg>\n            </div>\n            <h3>Roof repairs</h3>\n            <p>Targeted repair enquiries for leaks, flashing, cracked bedding, slipped sheets, and visible storm wear.</p>\n          </div>\n          <div class=\"feature card-flat\">\n            <div class=\"feature-mark\" aria-hidden=\"true\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\"><path d=\"M4 16c4-7 12-7 16 0\"/><path d=\"M6 18h12\"/><path d=\"M8 20h8\"/></svg>\n            </div>\n            <h3>Roof restoration</h3>\n            <p>Cleaning, surface preparation, coating, and detail work for homeowners weighing restoration before replacement.</p>\n          </div>\n          <div class=\"feature card-flat\">\n            <div class=\"feature-mark\" aria-hidden=\"true\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\"><path d=\"M5 7h14\"/><path d=\"M6 11h12\"/><path d=\"M7 15h10\"/><path d=\"M8 19h8\"/></svg>\n            </div>\n            <h3>Metal roofing</h3>\n            <p>New metal roof and replacement enquiries with attention to roof profile, drainage, ventilation, and finish.</p>\n          </div>\n        </div>\n        <div class=\"grid-2\">\n          <div class=\"ph-img service-photo wide\" aria-label=\"Roof repair detail visual\"></div>\n          <div class=\"card stack\">\n            <span class=\"pill\">Also available</span>\n            <h3>Gutter repairs and roof inspections</h3>\n            <p style=\"margin: 0; color: var(--muted);\">Gutters, downpipes, valley drainage, pre-sale checks, post-storm concerns, and practical inspection reports can all be requested through the same form.</p>\n            <div class=\"row\" style=\"flex-wrap: wrap;\">\n              <span class=\"tag\">Gutter repairs</span>\n              <span class=\"tag\">Roof inspections</span>\n              <span class=\"tag\">Storm concerns</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"work\" data-od-id=\"proof\">\n      <div class=\"container grid-1-2\">\n        <div class=\"stack\">\n          <p class=\"eyebrow\">Concrete proof, no invented claims</p>\n          <h2>See the work as a sequence, not a slogan.</h2>\n          <p class=\"lead\">A roof quote should make the condition, the work area, and the recommended next step easy to understand before larger decisions are made.</p>\n          <a class=\"btn btn-secondary btn-arrow\" href=\"#contact\" style=\"width: fit-content;\">Send roof details</a>\n        </div>\n        <div class=\"stack\">\n          <div class=\"ph-img project-photo wide\" aria-label=\"Before and after roof structure visual\"></div>\n          <div class=\"grid-3\">\n            <div class=\"card-rule\">\n              <h3>Condition</h3>\n              <p style=\"margin: 8px 0 0; color: var(--muted); font-size: 15px;\">What is visible from ground level, ceiling space, or inspection photos.</p>\n            </div>\n            <div class=\"card-rule\">\n              <h3>Scope</h3>\n              <p style=\"margin: 8px 0 0; color: var(--muted); font-size: 15px;\">The repair, restoration, gutter, or roofing area to be assessed.</p>\n            </div>\n            <div class=\"card-rule\">\n              <h3>Next step</h3>\n              <p style=\"margin: 8px 0 0; color: var(--muted); font-size: 15px;\">A clear inspection or quote request instead of a vague callback.</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"process\" data-od-id=\"quote-process\" style=\"background: var(--warm);\">\n      <div class=\"container grid-2\">\n        <div class=\"ph-img roof-visual portrait\" aria-label=\"Premium roofline visual\"></div>\n        <div class=\"stack\" style=\"justify-content: center;\">\n          <p class=\"eyebrow\">Inspection and quote path</p>\n          <h2>A simple way to move from roof concern to scoped enquiry.</h2>\n          <div class=\"process-list\" style=\"margin-top: 22px;\">\n            <div class=\"process-item\">\n              <div>\n                <h3>Describe the roof issue</h3>\n                <p style=\"margin: 6px 0 0; color: var(--muted);\">Share whether it is a leak, restoration, metal roofing, gutters, or inspection request.</p>\n              </div>\n            </div>\n            <div class=\"process-item\">\n              <div>\n                <h3>Attach the right context</h3>\n                <p style=\"margin: 6px 0 0; color: var(--muted);\">Mention the suburb, roof type if known, access notes, and whether the issue is urgent.</p>\n              </div>\n            </div>\n            <div class=\"process-item\">\n              <div>\n                <h3>Book the next step</h3>\n                <p style=\"margin: 6px 0 0; color: var(--muted);\">Use the form or phone CTA to request an inspection or quote for Brisbane and Gold Coast homes.</p>\n              </div>\n            </div>\n          </div>\n          <div class=\"hero-cta\">\n            <a class=\"btn btn-primary\" href=\"#contact\">Request a quote</a>\n            <a class=\"btn btn-secondary\" href=\"tel:0400000000\">Call now</a>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"contact\" data-od-id=\"faq-contact-footer\">\n      <div class=\"container grid-2\">\n        <div class=\"stack\">\n          <p class=\"eyebrow\">Questions homeowners ask</p>\n          <h2>Useful answers before you send the form.</h2>\n          <div class=\"faq-list\" style=\"margin-top: 18px;\">\n            <article class=\"faq-item\">\n              <h3>Can I ask about a small leak?</h3>\n              <p>Yes. Small roof issues can still need prompt attention, especially around flashing, valleys, vents, and gutters.</p>\n            </article>\n            <article class=\"faq-item\">\n              <h3>Do I need to know the roof material?</h3>\n              <p>No. If you know it is tile or metal, include that. If not, describe the problem and the team can scope the next step.</p>\n            </article>\n            <article class=\"faq-item\">\n              <h3>What areas are covered?</h3>\n              <p>RidgeLine Roof Co. is presented for Brisbane and Gold Coast roofing enquiries.</p>\n            </article>\n          </div>\n        </div>\n        <div class=\"contact-panel stack\">\n          <div>\n            <p class=\"eyebrow\">Request an inspection</p>\n            <h2>Tell us what is happening with the roof.</h2>\n            <p class=\"lead\" style=\"margin-top: 14px;\">Use the form for repair, restoration, metal roofing, gutter, and inspection enquiries. For phone enquiries, call <a href=\"tel:0400000000\" style=\"text-decoration: underline;\">0400 000 000</a>.</p>\n          </div>\n          <form class=\"stack\" aria-label=\"Roofing enquiry form\">\n            <div class=\"grid-2\">\n              <div class=\"field\">\n                <label for=\"name\">Name</label>\n                <input class=\"input\" id=\"name\" name=\"name\" autocomplete=\"name\" placeholder=\"Your name\" />\n              </div>\n              <div class=\"field\">\n                <label for=\"phone\">Phone</label>\n                <input class=\"input\" id=\"phone\" name=\"phone\" autocomplete=\"tel\" placeholder=\"Best contact number\" />\n              </div>\n            </div>\n            <div class=\"field\">\n              <label for=\"service\">What do you need?</label>\n              <select class=\"input\" id=\"service\" name=\"service\">\n                <option>Roof repairs</option>\n                <option>Roof restoration</option>\n                <option>Metal roofing</option>\n                <option>Gutter repairs</option>\n                <option>Roof inspection</option>\n              </select>\n            </div>\n            <div class=\"field\">\n              <label for=\"message\">Roof details</label>\n              <textarea class=\"textarea\" id=\"message\" name=\"message\" placeholder=\"Suburb, roof concern, access notes, and anything visible from the ground.\"></textarea>\n            </div>\n            <button class=\"btn btn-primary\" type=\"button\">Send enquiry</button>\n          </form>\n        </div>\n      </div>\n    </section>\n  </main>\n\n  <footer class=\"pagefoot\">\n    <div class=\"container row-between\">\n      <div>\n        <div class=\"footer-brand\">RidgeLine Roof Co.</div>\n        <p style=\"margin: 8px 0 0;\">Local roofing contractor for Brisbane and Gold Coast homeowners.</p>\n      </div>\n      <div class=\"row\" style=\"flex-wrap: wrap;\">\n        <a href=\"#services\">Services</a>\n        <a href=\"#process\">Quote process</a>\n        <a href=\"#contact\">Contact</a>\n        <a href=\"tel:0400000000\">0400 000 000</a>\n      </div>\n    </div>\n  </footer>\n</body>\n</html>\n","isError":false}

