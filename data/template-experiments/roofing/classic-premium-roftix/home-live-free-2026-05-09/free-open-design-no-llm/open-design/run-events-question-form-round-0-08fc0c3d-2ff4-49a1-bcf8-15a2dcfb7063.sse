data: {"type":"text_delta","delta":"Got it — high-fidelity roofing home page with fixed business facts and approved imagery. Tell me the remaining direction choices:\n\n<question-form id=\"discovery\" title=\"Quick brief — 30 seconds\">\n{\n  \"description\": \"I'll lock these in before building. Skip what doesn't apply — I'll fill defaults.\",\n  \"questions\": [\n    {\n      \"id\": \"platform\",\n      \"label\": \"Primary surface\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Desktop web\",\n        \"Responsive — all sizes\",\n        \"Mobile-first\"\n      ]\n    },\n    {\n      \"id\": \"audience\",\n      \"label\": \"Who should this speak to most?\",\n      \"type\": \"text\",\n      \"placeholder\": \"e.g. Brisbane homeowners, property managers, premium residential clients\"\n    },\n    {\n      \"id\": \"tone\",\n      \"label\": \"Visual tone\",\n      \"type\": \"checkbox\",\n      \"maxSelections\": 2,\n      \"options\": [\n        \"Classic premium\",\n        \"Modern minimal\",\n        \"Warm local\",\n        \"Trade-practical\",\n        \"Editorial / magazine\"\n      ]\n    },\n    {\n      \"id\": \"brand\",\n      \"label\": \"Brand context\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Pick a direction for me\",\n        \"I have a brand spec — I'll share it\",\n        \"Match a reference site / screenshot — I'll attach it\"\n      ]\n    },\n    {\n      \"id\": \"sections\",\n      \"label\": \"Any must-have sections?\",\n      \"type\": \"textarea\",\n      \"placeholder\": \"e.g. hero, services, process, recent work teaser, FAQ, quote form\"\n    },\n    {\n      \"id\": \"constraints\",\n      \"label\": \"Anything else I should know?\",\n      \"type\": \"textarea\",\n      \"placeholder\": \"Words to avoid, preferred colours, form fields, layout references…\"\n    }\n  ]\n}\n</question-form>"}

