event: agent
data: {"type":"tool_result","toolUseId":"item_15","content":"1:<!doctype html>\n2:<html lang=\"en\">\n3:<head>\n4:  <meta charset=\"utf-8\" />\n5:  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n6:  <title>RidgeLine Roof Co. · Brisbane and Gold Coast roofing</title>\n7:  <style>\n8:    :root {\n9:      --bg:      oklch(97% 0.012 80);\n10:      --surface: oklch(99% 0.005 80);\n11:      --fg:      oklch(20% 0.02 60);\n12:      --muted:   oklch(48% 0.015 60);\n13:      --border:  oklch(89% 0.012 80);\n14:      --accent:  oklch(58% 0.16 35);\n15:\n16:      --accent-soft: color-mix(in oklch, var(--accent) 14%, transparent);\n17:      --fg-soft:     color-mix(in oklch, var(--fg) 6%, transparent);\n18:\n19:      --font-display: 'Iowan Old Style', 'Charter', Georgia, 'Times New Roman', serif;\n20:      --font-body:    -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;\n21:      --font-mono:    ui-monospace, 'JetBrains Mono', 'SF Mono', Menlo, monospace;\n22:\n23:      --fs-h1: clamp(44px, 6vw, 76px);\n24:      --fs-h2: clamp(32px, 4vw, 48px);\n25:      --fs-h3: 22px;\n26:      --fs-lead: 19px;\n27:      --fs-body: 16px;\n28:      --fs-meta: 13px;\n29:\n30:      --gap-xs: 8px;\n31:      --gap-sm: 12px;\n32:      --gap-md: 20px;\n33:      --gap-lg: 32px;\n34:      --gap-xl: 56px;\n35:      --gap-2xl: 96px;\n36:      --container: 1160px;\n37:      --gutter: 32px;\n38:\n39:      --radius: 8px;\n40:      --radius-lg: 12px;\n41:    }\n42:\n43:    *, *::before, *::after { box-sizing: border-box; }\n44:    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }\n45:    body {\n46:      margin: 0;\n47:      background: var(--bg);\n48:      color: var(--fg);\n49:      font-family: var(--font-body);\n50:      font-size: var(--fs-body);\n51:      line-height: 1.55;\n52:      text-rendering: optimizeLegibility;\n53:      -webkit-font-smoothing: antialiased;\n54:    }\n55:    img, svg { display: block; max-width: 100%; }\n56:    a { color: inherit; text-decoration: none; }\n57:    button { font: inherit; cursor: pointer; }\n58:    p { text-wrap: pretty; }\n59:    h1, h2, h3, h4 { text-wrap: balance; }\n60:\n61:    .container { max-width: var(--container); margin-inline: auto; padding-inline: var(--gutter); }\n62:    .section { padding-block: clamp(56px, 8vw, var(--gap-2xl)); }\n63:    .section + .section { border-top: 1px solid var(--border); }\n64:    .stack { display: flex; flex-direction: column; }\n65:    .stack > * + * { margin-top: var(--gap-md); }\n66:    .row { display: flex; align-items: center; gap: var(--gap-md); }\n67:    .row-between { display: flex; align-items: center; justify-content: space-between; gap: var(--gap-md); }\n68:    .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--gap-lg); }\n69:    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap-lg); }\n70:    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--gap-md); }\n71:    .grid-2-1 { display: grid; grid-template-columns: 2fr 1fr; gap: var(--gap-xl); align-items: start; }\n72:    .grid-1-2 { display: grid; grid-template-columns: 1fr 2fr; gap: var(--gap-xl); align-items: start; }\n73:\n74:    .h1, h1 { font-family: var(--font-display); font-size: var(--fs-h1); line-height: 1.04; letter-spacing: -0.02em; margin: 0; }\n75:    .h2, h2 { font-family: var(--font-display); font-size: var(--fs-h2); line-height: 1.1; letter-spacing: -0.015em; margin: 0; }\n76:    .h3, h3 { font-family: var(--font-display); font-size: var(--fs-h3); font-weight: 600; line-height: 1.3; letter-spacing: -0.005em; margin: 0; }\n77:    .lead { font-size: var(--fs-lead); line-height: 1.55; color: var(--muted); max-width: 60ch; margin: 0; }\n78:    .eyebrow {\n79:      font-family: var(--font-mono);\n80:      font-size: 12px;\n81:      letter-spacing: 0.08em;\n82:      text-transform: uppercase;\n83:      color: var(--accent);\n84:      margin: 0 0 var(--gap-md);\n85:    }\n86:    .meta { font-family: var(--font-mono); font-size: var(--fs-meta); color: var(--muted); }\n87:    .num { font-family: var(--font-mono); font-variant-numeric: tabular-nums; }\n88:\n89:    .topnav {\n90:      position: sticky; top: 0; z-index: 10;\n91:      background: color-mix(in oklch, var(--bg) 92%, transparent);\n92:      backdrop-filter: blur(12px);\n93:      border-bottom: 1px solid var(--border);\n94:    }\n95:    .topnav-inner { display: flex; align-items: center; justify-content: space-between; padding-block: 14px; }\n96:    .topnav .logo { font-family: var(--font-display); font-size: 21px; font-weight: 650; letter-spacing: -0.01em; }\n97:    .topnav nav { display: flex; gap: var(--gap-lg); }\n98:    .topnav nav a { font-size: 14px; color: var(--muted); }\n99:    .topnav nav a:hover { color: var(--fg); }\n100:    .pagefoot { padding-block: var(--gap-xl); color: var(--muted); font-size: 13px; border-top: 1px solid var(--border); }\n101:    .pagefoot .row-between { flex-wrap: wrap; gap: var(--gap-md); }\n102:\n103:    .btn {\n104:      display: inline-flex; align-items: center; justify-content: center; gap: 8px;\n105:      min-height: 44px;\n106:      padding: 11px 20px;\n107:      border-radius: var(--radius);\n108:      border: 1px solid transparent;\n109:      font-size: 15px;\n110:      font-weight: 600;\n111:      letter-spacing: -0.005em;\n112:      transition: transform 0.05s ease, background 0.15s ease, border-color 0.15s ease;\n113:    }\n114:    .btn:active { transform: translateY(1px); }\n115:    .btn-primary { background: var(--accent); color: var(--surface); border-color: var(--accent); }\n116:    .btn-primary:hover { background: color-mix(in oklch, var(--accent) 88%, black); }\n117:    .btn-secondary { background: transparent; color: var(--fg); border-color: var(--border); }\n118:    .btn-secondary:hover { border-color: var(--fg); }\n119:    .btn-ghost { background: transparent; color: var(--fg); border-color: transparent; padding-inline: 8px; }\n120:    .btn-ghost:hover { color: var(--accent); }\n121:    .btn-arrow::after { content: '→'; transition: transform 0.15s ease; }\n122:    .btn-arrow:hover::after { transform: translateX(2px); }\n123:\n124:    .card {\n125:      background: var(--surface);\n126:      border: 1px solid var(--border);\n127:      border-radius: var(--radius-lg);\n128:      padding: 28px;\n129:    }\n130:    .card-flat { background: transparent; border: 0; padding: 0; }\n131:    .card-rule { background: transparent; border: 0; border-top: 1px solid var(--fg); padding: 24px 0 0; border-radius: 0; }\n132:\n133:    .feature .feature-mark {\n134:      width: 36px; height: 36px;\n135:      display: grid; place-items: center;\n136:      border: 1px solid var(--border);\n137:      border-radius: 10px;\n138:      color: var(--accent);\n139:      margin-bottom: var(--gap-md);\n140:    }\n141:    .feature .feature-mark svg { width: 18px; height: 18px; }\n142:    .feature h3 { margin-bottom: 6px; }\n143:    .feature p { margin: 0; color: var(--muted); font-size: 15px; }\n144:\n145:    .pill {\n146:      display: inline-flex; align-items: center; gap: 6px;\n147:      padding: 4px 10px;\n148:      background: var(--accent-soft);\n149:      color: var(--accent);\n150:      border-radius: 999px;\n151:      font-family: var(--font-mono);\n152:      font-size: 11px;\n153:      letter-spacing: 0.04em;\n154:      text-transform: uppercase;\n155:    }\n156:    .tag {\n157:      display: inline-flex; align-items: center;\n158:      padding: 4px 10px;\n159:      background: transparent;\n160:      color: var(--muted);\n161:      border: 1px solid var(--border);\n162:      border-radius: 999px;\n163:      font-size: 12px;\n164:    }\n165:\n166:    .field { display: flex; flex-direction: column; gap: 6px; }\n167:    .field label { font-size: 13px; color: var(--muted); }\n168:    .input, .textarea, .select {\n169:      width: 100%;\n170:      padding: 11px 14px;\n171:      border: 1px solid var(--border);\n172:      border-radius: var(--radius);\n173:      background: var(--surface);\n174:      color: var(--fg);\n175:      font: inherit;\n176:      font-size: 15px;\n177:    }\n178:    .input:focus, .textarea:focus, .select:focus {\n179:      outline: 2px solid var(--accent-soft);\n180:      border-color: var(--accent);\n181:    }\n182:    .textarea { min-height: 112px; resize: vertical; line-height: 1.55; }\n183:\n184:    .ds-table { width: 100%; border-collapse: collapse; font-size: 14px; }\n185:    .ds-table th, .ds-table td { padding: 12px 14px; text-align: left; border-bottom: 1px solid var(--border); }\n186:    .ds-table th { color: var(--muted); font-weight: 500; font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.04em; text-transform: uppercase; }\n187:    .ds-table tbody tr:hover { background: var(--fg-soft); }\n188:\n189:    .hero { padding-block: clamp(74px, 10vw, 132px); }\n190:    .hero h1 { margin-bottom: var(--gap-md); }\n191:    .hero-cta { display: inline-flex; gap: var(--gap-sm); flex-wrap: wrap; }\n192:    .hero-split { display: grid; grid-template-columns: 0.92fr 1.08fr; gap: var(--gap-2xl); align-items: center; }\n193:    .roof-visual {\n194:      overflow: hidden;\n195:      border: 1px solid var(--border);\n196:      border-radius: var(--radius-lg);\n197:      background: var(--surface);\n198:    }\n199:    .roof-visual img { width: 100%; height: 100%; object-fit: cover; }\n200:    .roof-visual.hero-img { aspect-ratio: 16 / 11; }\n201:    .roof-visual.square { aspect-ratio: 1 / 1; }\n202:    .roof-visual.wide { aspect-ratio: 16 / 9; }\n203:    .service-list { display: flex; flex-wrap: wrap; gap: var(--gap-sm); margin-top: var(--gap-lg); }\n204:    .service-card {\n205:      display: grid;\n206:      grid-template-columns: 104px 1fr;\n207:      gap: var(--gap-md);\n208:      align-items: center;\n209:      padding: 16px 0;\n210:      border-top: 1px solid var(--border);\n211:    }\n212:    .service-card img { width: 104px; height: 78px; object-fit: cover; border-radius: var(--radius); border: 1px solid var(--border); }\n213:    .process-step { border-top: 1px solid var(--fg); padding-top: 20px; }\n214:    .process-step .meta { display: block; margin-bottom: 12px; }\n215:    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--gap-md); }\n216:    .form-grid .full { grid-column: 1 / -1; }\n217:    .contact-panel { position: sticky; top: 96px; }\n218:    .faq-row { display: grid; grid-template-columns: 0.8fr 1.2fr; gap: var(--gap-xl); padding: 24px 0; border-top: 1px solid var(--border); }\n219:    .mobile-call { display: none; }\n220:\n221:    @media (max-width: 920px) {\n222:      .grid-2, .grid-3, .grid-4, .grid-2-1, .grid-1-2, .hero-split, .faq-row { grid-template-columns: 1fr; }\n223:      .topnav nav { display: none; }\n224:      .topnav .btn { display: none; }\n225:      .form-grid { grid-template-columns: 1fr; }\n226:      .contact-panel { position: static; }\n227:      .mobile-call {\n228:        display: flex;\n229:        position: fixed;\n230:        left: 16px; right: 16px; bottom: 16px;\n231:        z-index: 20;\n232:        box-shadow: 0 12px 30px color-mix(in oklch, var(--fg) 18%, transparent);\n233:      }\n234:      body { padding-bottom: 76px; }\n235:    }\n236:    @media (max-width: 560px) {\n237:      :root { --gutter: 20px; }\n238:      .service-card { grid-template-columns: 1fr; }\n239:      .service-card img { width: 100%; height: auto; aspect-ratio: 16 / 9; }\n240:      .hero-cta { display: flex; width: 100%; }\n241:      .hero-cta .btn { flex: 1 1 100%; }\n242:    }\n243:  </style>\n244:</head>\n245:<body>\n246:  <header class=\"topnav\" data-od-id=\"topnav\">\n247:    <div class=\"container topnav-inner\">\n248:      <a class=\"logo\" href=\"#top\" aria-label=\"RidgeLine Roof Co. home\">RidgeLine Roof Co.</a>\n249:      <nav aria-label=\"Primary navigation\">\n250:        <a href=\"#services\">Services</a>\n251:        <a href=\"#process\">Process</a>\n252:        <a href=\"#enquiry\">Enquiry</a>\n253:      </nav>\n254:      <a class=\"btn btn-primary\" href=\"tel:0400000000\">Call 0400 000 000</a>\n255:    </div>\n256:  </header>\n257:\n258:  <main id=\"content\">\n259:    <section class=\"section hero\" data-od-id=\"hero\" id=\"top\">\n260:      <div class=\"container hero-split\">\n261:        <div>\n262:          <p class=\"eyebrow\">Roofing · Brisbane and Gold Coast</p>\n263:          <h1>Premium roof care for homes that need a clear plan.</h1>\n264:          <p class=\"lead\" style=\"margin-top: 20px;\">RidgeLine Roof Co. handles roof repairs, restoration, metal roofing, gutter repairs, and inspections with a calm, practical quote process.</p>\n265:          <div class=\"hero-cta\" style=\"margin-top: 28px;\">\n266:            <a class=\"btn btn-primary\" href=\"#enquiry\">Request an inspection or quote</a>\n267:            <a class=\"btn btn-secondary\" href=\"tel:0400000000\">Call 0400 000 000</a>\n268:          </div>\n269:          <div class=\"service-list\" aria-label=\"Service area\">\n270:            <span class=\"tag\">Brisbane</span>\n271:            <span class=\"tag\">Gold Coast</span>\n272:            <span class=\"tag\">Residential roofing</span>\n273:          </div>\n274:        </div>\n275:        <figure class=\"roof-visual hero-img\" aria-label=\"Premium roofline at blue hour\">\n276:          <img src=\"assets/hero-roof-blue-hour.svg\" alt=\"Premium home roofline at blue hour\" />\n277:        </figure>\n278:      </div>\n279:    </section>\n280:\n281:    <section class=\"section\" data-od-id=\"services\" id=\"services\">\n282:      <div class=\"container stack\" style=\"gap: 56px;\">\n283:        <div class=\"grid-2-1\">\n284:          <div>\n285:            <p class=\"eyebrow\">Roofing services</p>\n286:            <h2>Start with the roof issue, then get the right scope.</h2>\n287:          </div>\n288:          <p class=\"lead\">The goal is not to oversell a replacement. It is to separate urgent leaks, worn surfaces, gutter faults, and longer-term roof restoration needs.</p>\n289:        </div>\n290:        <div class=\"grid-3\">\n291:          <div class=\"feature card-flat\">\n292:            <div class=\"feature-mark\">\n293:              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\"><path d=\"M4 13 12 5l8 8\"/><path d=\"M7 12v7h10v-7\"/></svg>\n294:            </div>\n295:            <h3>Roof repairs</h3>\n296:            <p>Leak paths, flashing problems, damaged sheets, and small repair scopes explained before work begins.</p>\n297:          </div>\n298:          <div class=\"feature card-flat\">\n299:            <div class=\"feature-mark\">\n300:              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\"><path d=\"M5 18h14\"/><path d=\"M7 14 12 6l5 8\"/><path d=\"M9 14h6\"/></svg>\n301:            </div>\n302:            <h3>Restoration and metal roofing</h3>\n303:            <p>Clear options for restoring tired roof surfaces or planning a metal roofing upgrade.</p>\n304:          </div>\n305:          <div class=\"feature card-flat\">\n306:            <div class=\"feature-mark\">\n307:              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\"><path d=\"M5 7h14v5a5 5 0 0 1-5 5H5z\"/><path d=\"M5 12h14\"/></svg>\n308:            </div>\n309:            <h3>Gutters and inspections</h3>\n310:            <p>Gutter repairs, drainage checks, and roof inspections for homeowners who want a practical next step.</p>\n311:          </div>\n312:        </div>\n313:      </div>\n314:    </section>\n315:\n316:    <section class=\"section\" data-od-id=\"detail\">\n317:      <div class=\"container grid-1-2\">\n318:        <aside class=\"roof-visual square\">\n319:          <img src=\"assets/service-roof-detail.svg\" alt=\"Metal roof flashing and gutter detail\" />\n320:        </aside>\n321:        <div class=\"stack\">\n322:          <p class=\"eyebrow\">What gets checked</p>\n323:          <h2>A roofing visit should leave you with decisions, not guesswork.</h2>\n324:          <div>\n325:            <article class=\"service-card\">\n326:              <img src=\"assets/service-roof-detail.svg\" alt=\"\" />\n327:              <div>\n328:                <h3>Visible roof condition</h3>\n329:                <p style=\"margin: 6px 0 0; color: var(--muted);\">Surface wear, storm damage, rust points, failed flashing, and obvious leak risks are separated into repair priorities.</p>\n330:              </div>\n331:            </article>\n332:            <article class=\"service-card\">\n333:              <img src=\"assets/about-roofer-frame.svg\" alt=\"\" />\n334:              <div>\n335:                <h3>Access and safety notes</h3>\n336:                <p style=\"margin: 6px 0 0; color: var(--muted);\">The quote can account for roof pitch, access points, site constraints, and the practical sequence of the job.</p>\n337:              </div>\n338:            </article>\n339:            <article class=\"service-card\">\n340:              <img src=\"assets/proof-before-after.svg\" alt=\"\" />\n341:              <div>\n342:                <h3>Repair or restoration pathway</h3>\n343:                <p style=\"margin: 6px 0 0; color: var(--muted);\">You get a plain-language recommendation for what needs attention now and what can be planned later.</p>\n344:              </div>\n345:            </article>\n346:          </div>\n347:        </div>\n348:      </div>\n349:    </section>\n350:\n351:    <section class=\"section\" data-od-id=\"process\" id=\"process\">\n352:      <div class=\"container\">\n353:        <div style=\"max-width: 46ch; margin-bottom: 56px;\">\n354:          <p class=\"eyebrow\">How the quote works</p>\n355:          <h2>A straightforward path from first enquiry to roof plan.</h2>\n356:        </div>\n357:        <div class=\"grid-3\">\n358:          <article class=\"process-step\">\n359:            <span class=\"meta num\">01</span>\n360:            <h3>Send the roof concern</h3>\n361:            <p style=\"color: var(--muted);\">Share the suburb, roof type if known, and whether the issue is urgent, seasonal, or part of a planned upgrade.</p>\n362:          </article>\n363:          <article class=\"process-step\">\n364:            <span class=\"meta num\">02</span>\n365:            <h3>Inspect and scope</h3>\n366:            <p style=\"color: var(--muted);\">The visit focuses on the cause of the problem and the most sensible repair, restoration, or replacement pathway.</p>\n367:          </article>\n368:          <article class=\"process-step\">\n369:            <span class=\"meta num\">03</span>\n370:            <h3>Quote with next steps</h3>\n371:            <p style=\"color: var(--muted);\">You receive a clear quote request pathway and can ask what is urgent, optional, or best grouped together.</p>\n372:          </article>\n373:        </div>\n374:      </div>\n375:    </section>\n376:\n377:    <section class=\"section\" data-od-id=\"proof\">\n378:      <div class=\"container grid-2\">\n379:        <div class=\"stack\">\n380:          <p class=\"eyebrow\">Project clarity</p>\n381:          <h2>Before-and-after thinking, without the sales fog.</h2>\n382:          <p class=\"lead\">Roofing decisions can be hard to judge from the ground. A clean visual scope helps compare repair work, restoration, and longer-term upgrades without relying on vague promises.</p>\n383:          <div class=\"row\" style=\"flex-wrap: wrap;\">\n384:            <span class=\"pill\">Inspection led</span>\n385:            <span class=\"tag\">Repair scope</span>\n386:            <span class=\"tag\">Restoration pathway</span>\n387:          </div>\n388:        </div>\n389:        <figure class=\"roof-visual wide\">\n390:          <img src=\"assets/proof-before-after.svg\" alt=\"Before and after roof transformation concept\" />\n391:        </figure>\n392:      </div>\n393:    </section>\n394:\n395:    <section class=\"section\" data-od-id=\"enquiry\" id=\"enquiry\">\n396:      <div class=\"container grid-2-1\">\n397:        <div>\n398:          <p class=\"eyebrow\">Request an inspection or quote</p>\n399:          <h2>Tell RidgeLine what is happening on the roof.</h2>\n400:          <p class=\"lead\" style=\"margin-top: 16px;\">Use the form for non-urgent enquiries, or call if you would rather speak through the issue first.</p>\n401:          <form class=\"card\" style=\"margin-top: 32px;\" aria-label=\"Roofing enquiry form\">\n402:            <div class=\"form-grid\">\n403:              <div class=\"field\">\n404:                <label for=\"name\">Name</label>\n405:                <input class=\"input\" id=\"name\" name=\"name\" autocomplete=\"name\" />\n406:              </div>\n407:              <div class=\"field\">\n408:                <label for=\"phone\">Phone</label>\n409:                <input class=\"input\" id=\"phone\" name=\"phone\" autocomplete=\"tel\" />\n410:              </div>\n411:              <div class=\"field full\">\n412:                <label for=\"suburb\">Suburb</label>\n413:                <input class=\"input\" id=\"suburb\" name=\"suburb\" />\n414:              </div>\n415:              <div class=\"field full\">\n416:                <label for=\"service\">What do you need help with?</label>\n417:                <select class=\"select\" id=\"service\" name=\"service\">\n418:                  <option>Roof repair</option>\n419:                  <option>Roof restoration</option>\n420:                  <option>Metal roofing</option>\n421:                  <option>Gutter repair</option>\n422:                  <option>Roof inspection</option>\n423:                </select>\n424:              </div>\n425:              <div class=\"field full\">\n426:                <label for=\"message\">Briefly describe the roof concern</label>\n427:                <textarea class=\"textarea\" id=\"message\" name=\"message\"></textarea>\n428:              </div>\n429:            </div>\n430:            <button class=\"btn btn-primary\" type=\"submit\" style=\"margin-top: 20px;\">Send enquiry</button>\n431:          </form>\n432:        </div>\n433:        <aside class=\"card contact-panel\">\n434:          <p class=\"meta\">Prefer to call?</p>\n435:          <h3 style=\"margin-top: 12px;\">Speak with RidgeLine Roof Co.</h3>\n436:          <p style=\"color: var(--muted);\">For Brisbane and Gold Coast roofing enquiries, call the team and describe the roof issue, suburb, and preferred inspection timing.</p>\n437:          <a class=\"btn btn-secondary\" href=\"tel:0400000000\">0400 000 000</a>\n438:          <hr style=\"border: 0; border-top: 1px solid var(--border); margin: 28px 0;\" />\n439:          <p class=\"meta\">Service focus</p>\n440:          <p style=\"margin-bottom: 0;\">Roof repairs, roof restoration, metal roofing, gutter repairs, and roof inspections.</p>\n441:        </aside>\n442:      </div>\n443:    </section>\n444:\n445:    <section class=\"section\" data-od-id=\"faq\">\n446:      <div class=\"container\">\n447:        <div class=\"row-between\" style=\"margin-bottom: 24px;\">\n448:          <h2>Roofing questions homeowners ask first.</h2>\n449:        </div>\n450:        <article class=\"faq-row\">\n451:          <h3>Can a leak be repaired without restoring the whole roof?</h3>\n452:          <p style=\"margin: 0; color: var(--muted);\">Sometimes. The inspection should identify whether the issue is localised, tied to flashing or guttering, or part of broader surface wear.</p>\n453:        </article>\n454:        <article class=\"faq-row\">\n455:          <h3>What should I include in my enquiry?</h3>\n456:          <p style=\"margin: 0; color: var(--muted);\">Your suburb, roof material if known, where the issue appears, and whether water is entering the home. Photos can help when available.</p>\n457:        </article>\n458:        <article class=\"faq-row\">\n459:          <h3>Do you cover both Brisbane and the Gold Coast?</h3>\n460:          <p style=\"margin: 0; color: var(--muted);\">Yes. RidgeLine Roof Co. presents its service area as Brisbane and the Gold Coast.</p>\n461:        </article>\n462:      </div>\n463:    </section>\n464:  </main>\n465:\n466:  <footer class=\"pagefoot\" data-od-id=\"footer\">\n467:    <div class=\"container row-between\">\n468:      <span>© RidgeLine Roof Co.</span>\n469:      <span class=\"meta\">Roofing enquiries · Brisbane and Gold Coast · 0400 000 000</span>\n470:    </div>\n471:  </footer>\n472:\n473:  <a class=\"btn btn-primary mobile-call\" href=\"tel:0400000000\">Call 0400 000 000</a>\n474:</body>\n475:</html>\n","isError":false}

