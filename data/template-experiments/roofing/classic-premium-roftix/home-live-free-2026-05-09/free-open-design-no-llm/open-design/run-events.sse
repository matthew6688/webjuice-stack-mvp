id: 347
event: agent
data: {"type":"text_delta","delta":"Built `index.html` and local roofing visuals under `assets/`. The page uses only the supplied business facts, includes phone and enquiry CTAs, and avoids internal/unverified claims.\n\n<artifact identifier=\"ridgeline-roof-home\" type=\"text/html\" title=\"RidgeLine Roof Co. Home Page\">\n<!doctype html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>RidgeLine Roof Co. · Brisbane and Gold Coast roofing</title>\n  <style>\n    :root {\n      --bg: oklch(97% 0.012 80);\n      --surface: oklch(99% 0.005 80);\n      --fg: oklch(20% 0.02 60);\n      --muted: oklch(48% 0.015 60);\n      --border: oklch(89% 0.012 80);\n      --accent: oklch(58% 0.16 35);\n      --accent-soft: color-mix(in oklch, var(--accent) 14%, transparent);\n      --fg-soft: color-mix(in oklch, var(--fg) 6%, transparent);\n      --font-display: 'Iowan Old Style', 'Charter', Georgia, 'Times New Roman', serif;\n      --font-body: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;\n      --font-mono: ui-monospace, 'JetBrains Mono', 'SF Mono', Menlo, monospace;\n      --fs-h1: clamp(44px, 6vw, 76px);\n      --fs-h2: clamp(32px, 4vw, 48px);\n      --fs-h3: 22px;\n      --fs-lead: 19px;\n      --fs-body: 16px;\n      --fs-meta: 13px;\n      --gap-sm: 12px;\n      --gap-md: 20px;\n      --gap-lg: 32px;\n      --gap-xl: 56px;\n      --gap-2xl: 96px;\n      --container: 1160px;\n      --gutter: 32px;\n      --radius: 8px;\n      --radius-lg: 12px;\n    }\n    *, *::before, *::after { box-sizing: border-box; }\n    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }\n    body {\n      margin: 0;\n      background: var(--bg);\n      color: var(--fg);\n      font-family: var(--font-body);\n      font-size: var(--fs-body);\n      line-height: 1.55;\n      text-rendering: optimizeLegibility;\n      -webkit-font-smoothing: antialiased;\n    }\n    img, svg { display: block; max-width: 100%; }\n    a { color: inherit; text-decoration: none; }\n    button { font: inherit; cursor: pointer; }\n    p { text-wrap: pretty; }\n    h1, h2, h3, h4 { text-wrap: balance; }\n    .container { max-width: var(--container); margin-inline: auto; padding-inline: var(--gutter); }\n    .section { padding-block: clamp(56px, 8vw, var(--gap-2xl)); }\n    .section + .section { border-top: 1px solid var(--border); }\n    .stack { display: flex; flex-direction: column; }\n    .stack > * + * { margin-top: var(--gap-md); }\n    .row { display: flex; align-items: center; gap: var(--gap-md); }\n    .row-between { display: flex; align-items: center; justify-content: space-between; gap: var(--gap-md); }\n    .grid-2, .grid-3, .grid-2-1, .grid-1-2 { display: grid; gap: var(--gap-lg); }\n    .grid-2 { grid-template-columns: repeat(2, 1fr); }\n    .grid-3 { grid-template-columns: repeat(3, 1fr); }\n    .grid-2-1 { grid-template-columns: 2fr 1fr; gap: var(--gap-xl); align-items: start; }\n    .grid-1-2 { grid-template-columns: 1fr 2fr; gap: var(--gap-xl); align-items: start; }\n    h1, .h1 { font-family: var(--font-display); font-size: var(--fs-h1); line-height: 1.04; letter-spacing: -0.02em; margin: 0; }\n    h2, .h2 { font-family: var(--font-display); font-size: var(--fs-h2); line-height: 1.1; letter-spacing: -0.015em; margin: 0; }\n    h3, .h3 { font-family: var(--font-display); font-size: var(--fs-h3); font-weight: 600; line-height: 1.3; margin: 0; }\n    .lead { font-size: var(--fs-lead); line-height: 1.55; color: var(--muted); max-width: 60ch; margin: 0; }\n    .eyebrow {\n      font-family: var(--font-mono);\n      font-size: 12px;\n      letter-spacing: 0.08em;\n      text-transform: uppercase;\n      color: var(--accent);\n      margin: 0 0 var(--gap-md);\n    }\n    .meta, .num { font-family: var(--font-mono); font-size: var(--fs-meta); color: var(--muted); }\n    .num { font-variant-numeric: tabular-nums; }\n    .topnav {\n      position: sticky; top: 0; z-index: 10;\n      background: color-mix(in oklch, var(--bg) 92%, transparent);\n      backdrop-filter: blur(12px);\n      border-bottom: 1px solid var(--border);\n    }\n    .topnav-inner { display: flex; align-items: center; justify-content: space-between; padding-block: 14px; }\n    .logo { font-family: var(--font-display); font-size: 21px; font-weight: 650; }\n    .topnav nav { display: flex; gap: var(--gap-lg); }\n    .topnav nav a { font-size: 14px; color: var(--muted); }\n    .topnav nav a:hover { color: var(--fg); }\n    .btn {\n      display: inline-flex; align-items: center; justify-content: center; gap: 8px;\n      min-height: 44px;\n      padding: 11px 20px;\n      border-radius: var(--radius);\n      border: 1px solid transparent;\n      font-size: 15px;\n      font-weight: 600;\n      transition: transform 0.05s ease, background 0.15s ease, border-color 0.15s ease;\n    }\n    .btn:active { transform: translateY(1px); }\n    .btn-primary { background: var(--accent); color: var(--surface); border-color: var(--accent); }\n    .btn-primary:hover { background: color-mix(in oklch, var(--accent) 88%, black); }\n    .btn-secondary { background: transparent; color: var(--fg); border-color: var(--border); }\n    .btn-secondary:hover { border-color: var(--fg); }\n    .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 28px; }\n    .card-flat { background: transparent; border: 0; padding: 0; }\n    .feature .feature-mark {\n      width: 36px; height: 36px;\n      display: grid; place-items: center;\n      border: 1px solid var(--border);\n      border-radius: 10px;\n      color: var(--fg);\n      margin-bottom: var(--gap-md);\n    }\n    .feature .feature-mark svg { width: 18px; height: 18px; }\n    .feature h3 { margin-bottom: 6px; }\n    .feature p { margin: 0; color: var(--muted); font-size: 15px; }\n    .pill {\n      display: inline-flex; align-items: center; gap: 6px;\n      padding: 4px 10px;\n      background: var(--accent-soft);\n      color: var(--accent);\n      border-radius: 999px;\n      font-family: var(--font-mono);\n      font-size: 11px;\n      letter-spacing: 0.04em;\n      text-transform: uppercase;\n    }\n    .tag {\n      display: inline-flex; align-items: center;\n      padding: 4px 10px;\n      color: var(--muted);\n      border: 1px solid var(--border);\n      border-radius: 999px;\n      font-size: 12px;\n    }\n    .field { display: flex; flex-direction: column; gap: 6px; }\n    .field label { font-size: 13px; color: var(--muted); }\n    .input, .textarea, .select {\n      width: 100%;\n      padding: 11px 14px;\n      border: 1px solid var(--border);\n      border-radius: var(--radius);\n      background: var(--surface);\n      color: var(--fg);\n      font: inherit;\n      font-size: 15px;\n    }\n    .input:focus, .textarea:focus, .select:focus {\n      outline: 2px solid var(--accent-soft);\n      border-color: var(--accent);\n    }\n    .textarea { min-height: 112px; resize: vertical; line-height: 1.55; }\n    .hero { padding-block: clamp(74px, 10vw, 132px); }\n    .hero h1 { margin-bottom: var(--gap-md); }\n    .hero-cta { display: inline-flex; gap: var(--gap-sm); flex-wrap: wrap; }\n    .hero-split { display: grid; grid-template-columns: 0.92fr 1.08fr; gap: var(--gap-2xl); align-items: center; }\n    .roof-visual {\n      overflow: hidden;\n      border: 1px solid var(--border);\n      border-radius: var(--radius-lg);\n      background: var(--surface);\n    }\n    .roof-visual img { width: 100%; height: 100%; object-fit: cover; }\n    .roof-visual.hero-img { aspect-ratio: 16 / 11; }\n    .roof-visual.square { aspect-ratio: 1 / 1; }\n    .roof-visual.wide { aspect-ratio: 16 / 9; }\n    .service-list { display: flex; flex-wrap: wrap; gap: var(--gap-sm); margin-top: var(--gap-lg); }\n    .service-card {\n      display: grid;\n      grid-template-columns: 104px 1fr;\n      gap: var(--gap-md);\n      align-items: center;\n      padding: 16px 0;\n      border-top: 1px solid var(--border);\n    }\n    .service-card img { width: 104px; height: 78px; object-fit: cover; border-radius: var(--radius); border: 1px solid var(--border); }\n    .process-step { border-top: 1px solid var(--fg); padding-top: 20px; }\n    .process-step .meta { display: block; margin-bottom: 12px; }\n    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--gap-md); }\n    .form-grid .full { grid-column: 1 / -1; }\n    .contact-panel { position: sticky; top: 96px; }\n    .faq-row { display: grid; grid-template-columns: 0.8fr 1.2fr; gap: var(--gap-xl); padding: 24px 0; border-top: 1px solid var(--border); }\n    .pagefoot { padding-block: var(--gap-xl); color: var(--muted); font-size: 13px; border-top: 1px solid var(--border); }\n    .pagefoot .row-between { flex-wrap: wrap; }\n    .mobile-call { display: none; }\n    @media (max-width: 920px) {\n      .grid-2, .grid-3, .grid-2-1, .grid-1-2, .hero-split, .faq-row { grid-template-columns: 1fr; }\n      .topnav nav, .topnav .btn { display: none; }\n      .form-grid { grid-template-columns: 1fr; }\n      .contact-panel { position: static; }\n      .mobile-call {\n        display: flex;\n        position: fixed;\n        left: 16px; right: 16px; bottom: 16px;\n        z-index: 20;\n        box-shadow: 0 12px 30px color-mix(in oklch, var(--fg) 18%, transparent);\n      }\n      body { padding-bottom: 76px; }\n    }\n    @media (max-width: 560px) {\n      :root { --gutter: 20px; }\n      .service-card { grid-template-columns: 1fr; }\n      .service-card img { width: 100%; height: auto; aspect-ratio: 16 / 9; }\n      .hero-cta { display: flex; width: 100%; }\n      .hero-cta .btn { flex: 1 1 100%; }\n    }\n  </style>\n</head>\n<body>\n  <header class=\"topnav\" data-od-id=\"topnav\">\n    <div class=\"container topnav-inner\">\n      <a class=\"logo\" href=\"#top\" aria-label=\"RidgeLine Roof Co. home\">RidgeLine Roof Co.</a>\n      <nav aria-label=\"Primary navigation\">\n        <a href=\"#services\">Services</a>\n        <a href=\"#process\">Process</a>\n        <a href=\"#enquiry\">Enquiry</a>\n      </nav>\n      <a class=\"btn btn-secondary\" href=\"tel:0400000000\">Call 0400 000 000</a>\n    </div>\n  </header>\n\n  <main id=\"content\">\n    <section class=\"section hero\" data-od-id=\"hero\" id=\"top\">\n      <div class=\"container hero-split\">\n        <div>\n          <p class=\"eyebrow\">Roofing · Brisbane and Gold Coast</p>\n          <h1>Premium roof care for homes that need a clear plan.</h1>\n          <p class=\"lead\" style=\"margin-top: 20px;\">RidgeLine Roof Co. handles roof repairs, restoration, metal roofing, gutter repairs, and inspections with a calm, practical quote process.</p>\n          <div class=\"hero-cta\" style=\"margin-top: 28px;\">\n            <a class=\"btn btn-primary\" href=\"#enquiry\">Request an inspection or quote</a>\n            <a class=\"btn btn-secondary\" href=\"tel:0400000000\">Call 0400 000 000</a>\n          </div>\n          <div class=\"service-list\" aria-label=\"Service area\">\n            <span class=\"tag\">Brisbane</span>\n            <span class=\"tag\">Gold Coast</span>\n            <span class=\"tag\">Residential roofing</span>\n          </div>\n        </div>\n        <figure class=\"roof-visual hero-img\" aria-label=\"Premium roofline at blue hour\">\n          <img src=\"assets/hero-roof-blue-hour.svg\" alt=\"Premium home roofline at blue hour\" />\n        </figure>\n      </div>\n    </section>\n\n    <section class=\"section\" data-od-id=\"services\" id=\"services\">\n      <div class=\"container stack\" style=\"gap: 56px;\">\n        <div class=\"grid-2-1\">\n          <div>\n            <p class=\"eyebrow\">Roofing services</p>\n            <h2>Start with the roof issue, then get the right scope.</h2>\n          </div>\n          <p class=\"lead\">The goal is not to oversell a replacement. It is to separate urgent leaks, worn surfaces, gutter faults, and longer-term roof restoration needs.</p>\n        </div>\n        <div class=\"grid-3\">\n          <div class=\"feature card-flat\">\n            <div class=\"feature-mark\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\"><path d=\"M4 13 12 5l8 8\"/><path d=\"M7 12v7h10v-7\"/></svg>\n            </div>\n            <h3>Roof repairs</h3>\n            <p>Leak paths, flashing problems, damaged sheets, and small repair scopes explained before work begins.</p>\n          </div>\n          <div class=\"feature card-flat\">\n            <div class=\"feature-mark\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\"><path d=\"M5 18h14\"/><path d=\"M7 14 12 6l5 8\"/><path d=\"M9 14h6\"/></svg>\n            </div>\n            <h3>Restoration and metal roofing</h3>\n            <p>Clear options for restoring tired roof surfaces or planning a metal roofing upgrade.</p>\n          </div>\n          <div class=\"feature card-flat\">\n            <div class=\"feature-mark\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\"><path d=\"M5 7h14v5a5 5 0 0 1-5 5H5z\"/><path d=\"M5 12h14\"/></svg>\n            </div>\n            <h3>Gutters and inspections</h3>\n            <p>Gutter repairs, drainage checks, and roof inspections for homeowners who want a practical next step.</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" data-od-id=\"detail\">\n      <div class=\"container grid-1-2\">\n        <aside class=\"roof-visual square\">\n          <img src=\"assets/service-roof-detail.svg\" alt=\"Metal roof flashing and gutter detail\" />\n        </aside>\n        <div class=\"stack\">\n          <p class=\"eyebrow\">What gets checked</p>\n          <h2>A roofing visit should leave you with decisions, not guesswork.</h2>\n          <div>\n            <article class=\"service-card\">\n              <img src=\"assets/service-roof-detail.svg\" alt=\"\" />\n              <div>\n                <h3>Visible roof condition</h3>\n                <p style=\"margin: 6px 0 0; color: var(--muted);\">Surface wear, storm damage, rust points, failed flashing, and obvious leak risks are separated into repair priorities.</p>\n              </div>\n            </article>\n            <article class=\"service-card\">\n              <img src=\"assets/about-roofer-frame.svg\" alt=\"\" />\n              <div>\n                <h3>Access and safety notes</h3>\n                <p style=\"margin: 6px 0 0; color: var(--muted);\">The quote can account for roof pitch, access points, site constraints, and the practical sequence of the job.</p>\n              </div>\n            </article>\n            <article class=\"service-card\">\n              <img src=\"assets/proof-before-after.svg\" alt=\"\" />\n              <div>\n                <h3>Repair or restoration pathway</h3>\n                <p style=\"margin: 6px 0 0; color: var(--muted);\">You get a plain-language recommendation for what needs attention now and what can be planned later.</p>\n              </div>\n            </article>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" data-od-id=\"process\" id=\"process\">\n      <div class=\"container\">\n        <div style=\"max-width: 46ch; margin-bottom: 56px;\">\n          <p class=\"eyebrow\">How the quote works</p>\n          <h2>A straightforward path from first enquiry to roof plan.</h2>\n        </div>\n        <div class=\"grid-3\">\n          <article class=\"process-step\">\n            <span class=\"meta num\">01</span>\n            <h3>Send the roof concern</h3>\n            <p style=\"color: var(--muted);\">Share the suburb, roof type if known, and whether the issue is urgent, seasonal, or part of a planned upgrade.</p>\n          </article>\n          <article class=\"process-step\">\n            <span class=\"meta num\">02</span>\n            <h3>Inspect and scope</h3>\n            <p style=\"color: var(--muted);\">The visit focuses on the cause of the problem and the most sensible repair, restoration, or replacement pathway.</p>\n          </article>\n          <article class=\"process-step\">\n            <span class=\"meta num\">03</span>\n            <h3>Quote with next steps</h3>\n            <p style=\"color: var(--muted);\">You receive a clear quote request pathway and can ask what is urgent, optional, or best grouped together.</p>\n          </article>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" data-od-id=\"proof\">\n      <div class=\"container grid-2\">\n        <div class=\"stack\">\n          <p class=\"eyebrow\">Project clarity</p>\n          <h2>Before-and-after thinking, without the sales fog.</h2>\n          <p class=\"lead\">Roofing decisions can be hard to judge from the ground. A clean visual scope helps compare repair work, restoration, and longer-term upgrades without relying on vague promises.</p>\n          <div class=\"row\" style=\"flex-wrap: wrap;\">\n            <span class=\"pill\">Inspection led</span>\n            <span class=\"tag\">Repair scope</span>\n            <span class=\"tag\">Restoration pathway</span>\n          </div>\n        </div>\n        <figure class=\"roof-visual wide\">\n          <img src=\"assets/proof-before-after.svg\" alt=\"Before and after roof transformation concept\" />\n        </figure>\n      </div>\n    </section>\n\n    <section class=\"section\" data-od-id=\"enquiry\" id=\"enquiry\">\n      <div class=\"container grid-2-1\">\n        <div>\n          <p class=\"eyebrow\">Request an inspection or quote</p>\n          <h2>Tell RidgeLine what is happening on the roof.</h2>\n          <p class=\"lead\" style=\"margin-top: 16px;\">Use the form for non-urgent enquiries, or call if you would rather speak through the issue first.</p>\n          <form class=\"card\" style=\"margin-top: 32px;\" aria-label=\"Roofing enquiry form\">\n            <div class=\"form-grid\">\n              <div class=\"field\">\n                <label for=\"name\">Name</label>\n                <input class=\"input\" id=\"name\" name=\"name\" autocomplete=\"name\" />\n              </div>\n              <div class=\"field\">\n                <label for=\"phone\">Phone</label>\n                <input class=\"input\" id=\"phone\" name=\"phone\" autocomplete=\"tel\" />\n              </div>\n              <div class=\"field full\">\n                <label for=\"suburb\">Suburb</label>\n                <input class=\"input\" id=\"suburb\" name=\"suburb\" />\n              </div>\n              <div class=\"field full\">\n                <label for=\"service\">What do you need help with?</label>\n                <select class=\"select\" id=\"service\" name=\"service\">\n                  <option>Roof repair</option>\n                  <option>Roof restoration</option>\n                  <option>Metal roofing</option>\n                  <option>Gutter repair</option>\n                  <option>Roof inspection</option>\n                </select>\n              </div>\n              <div class=\"field full\">\n                <label for=\"message\">Briefly describe the roof concern</label>\n                <textarea class=\"textarea\" id=\"message\" name=\"message\"></textarea>\n              </div>\n            </div>\n            <button class=\"btn btn-primary\" type=\"submit\" style=\"margin-top: 20px;\">Send enquiry</button>\n          </form>\n        </div>\n        <aside class=\"card contact-panel\">\n          <p class=\"meta\">Prefer to call?</p>\n          <h3 style=\"margin-top: 12px;\">Speak with RidgeLine Roof Co.</h3>\n          <p style=\"color: var(--muted);\">For Brisbane and Gold Coast roofing enquiries, call the team and describe the roof issue, suburb, and preferred inspection timing.</p>\n          <a class=\"btn btn-secondary\" href=\"tel:0400000000\">0400 000 000</a>\n          <hr style=\"border: 0; border-top: 1px solid var(--border); margin: 28px 0;\" />\n          <p class=\"meta\">Service focus</p>\n          <p style=\"margin-bottom: 0;\">Roof repairs, roof restoration, metal roofing, gutter repairs, and roof inspections.</p>\n        </aside>\n      </div>\n    </section>\n\n    <section class=\"section\" data-od-id=\"faq\">\n      <div class=\"container\">\n        <div class=\"row-between\" style=\"margin-bottom: 24px;\">\n          <h2>Roofing questions homeowners ask first.</h2>\n        </div>\n        <article class=\"faq-row\">\n          <h3>Can a leak be repaired without restoring the whole roof?</h3>\n          <p style=\"margin: 0; color: var(--muted);\">Sometimes. The inspection should identify whether the issue is localised, tied to flashing or guttering, or part of broader surface wear.</p>\n        </article>\n        <article class=\"faq-row\">\n          <h3>What should I include in my enquiry?</h3>\n          <p style=\"margin: 0; color: var(--muted);\">Your suburb, roof material if known, where the issue appears, and whether water is entering the home. Photos can help when available.</p>\n        </article>\n        <article class=\"faq-row\">\n          <h3>Do you cover both Brisbane and the Gold Coast?</h3>\n          <p style=\"margin: 0; color: var(--muted);\">Yes. RidgeLine Roof Co. handles roofing enquiries across Brisbane and the Gold Coast.</p>\n        </article>\n      </div>\n    </section>\n  </main>\n\n  <footer class=\"pagefoot\" data-od-id=\"footer\">\n    <div class=\"container row-between\">\n      <span>© RidgeLine Roof Co.</span>\n      <span class=\"meta\">Roofing enquiries · Brisbane and Gold Coast · 0400 000 000</span>\n    </div>\n  </footer>\n\n  <a class=\"btn btn-secondary mobile-call\" href=\"tel:0400000000\">Call 0400 000 000</a>\n</body>\n</html>\n</artifact>"}

