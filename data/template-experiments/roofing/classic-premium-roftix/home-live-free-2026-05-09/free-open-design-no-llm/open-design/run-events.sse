data: {"type":"tool_result","toolUseId":"item_16","content":"246:  <header class=\"topnav\" data-od-id=\"topnav\">\n259:    <section class=\"section hero\" data-od-id=\"hero\" id=\"top\">\n281:    <section class=\"section\" data-od-id=\"services\" id=\"services\">\n316:    <section class=\"section\" data-od-id=\"detail\">\n351:    <section class=\"section\" data-od-id=\"process\" id=\"process\">\n377:    <section class=\"section\" data-od-id=\"proof\">\n395:    <section class=\"section\" data-od-id=\"enquiry\" id=\"enquiry\">\n445:    <section class=\"section\" data-od-id=\"faq\">\n466:  <footer class=\"pagefoot\" data-od-id=\"footer\">\n","isError":false}

