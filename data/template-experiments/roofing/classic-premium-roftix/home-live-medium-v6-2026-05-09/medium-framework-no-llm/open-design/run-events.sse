event: agent
data: {"type":"text_delta","delta":"Built `index.html` as the polished one-page RidgeLine Roof Co. concept with approved local imagery, quote form, phone CTAs, local SEO basics, and RoofingContractor JSON-LD.\n\n<artifact identifier=\"ridgeline-roof-co-home\" type=\"text/html\" title=\"RidgeLine Roof Co. Home Page\">\n<!doctype html>\n<html lang=\"en-AU\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>RidgeLine Roof Co. | Roofing Contractor Brisbane & Gold Coast</title>\n  <meta name=\"description\" content=\"RidgeLine Roof Co. provides roof repairs, restorations, metal roofing, gutter repairs and inspections across Brisbane and the Gold Coast.\" />\n  <meta name=\"review-provenance\" content=\"ai-reference-placeholder; replace with real Google or customer reviews before live\" />\n  <style>\n    :root {\n      --bg: oklch(97% 0.009 84);\n      --surface: oklch(100% 0 0);\n      --fg: oklch(18% 0.032 255);\n      --muted: oklch(47% 0.022 250);\n      --border: oklch(88% 0.012 88);\n      --accent: oklch(43% 0.12 155);\n      --navy: oklch(22% 0.06 255);\n      --charcoal: oklch(15% 0.025 250);\n      --warm: oklch(62% 0.145 52);\n      --accent-soft: color-mix(in oklch, var(--accent) 13%, transparent);\n      --navy-soft: color-mix(in oklch, var(--navy) 9%, transparent);\n      --fg-soft: color-mix(in oklch, var(--fg) 7%, transparent);\n      --font-display: 'Iowan Old Style', 'Charter', Georgia, 'Times New Roman', serif;\n      --font-body: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;\n      --font-mono: ui-monospace, 'SF Mono', Menlo, monospace;\n      --fs-h1: clamp(46px, 6.8vw, 92px);\n      --fs-h2: clamp(32px, 4vw, 56px);\n      --fs-h3: 22px;\n      --fs-lead: 19px;\n      --fs-body: 16px;\n      --fs-meta: 13px;\n      --gap-xs: 8px;\n      --gap-sm: 12px;\n      --gap-md: 20px;\n      --gap-lg: 32px;\n      --gap-xl: 56px;\n      --gap-2xl: 96px;\n      --container: 1180px;\n      --gutter: 32px;\n      --radius: 8px;\n      --radius-lg: 12px;\n    }\n\n    *, *::before, *::after { box-sizing: border-box; }\n    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }\n    body {\n      margin: 0;\n      background: var(--bg);\n      color: var(--fg);\n      font-family: var(--font-body);\n      font-size: var(--fs-body);\n      line-height: 1.55;\n      text-rendering: optimizeLegibility;\n      -webkit-font-smoothing: antialiased;\n    }\n    img, svg { display: block; max-width: 100%; }\n    a { color: inherit; text-decoration: none; }\n    button, input, textarea, select { font: inherit; }\n    p { text-wrap: pretty; }\n    h1, h2, h3, h4 { text-wrap: balance; }\n    .container { max-width: var(--container); margin-inline: auto; padding-inline: var(--gutter); }\n    .section { padding-block: clamp(58px, 8vw, var(--gap-2xl)); }\n    .section + .section { border-top: 1px solid var(--border); }\n    .stack { display: flex; flex-direction: column; }\n    .stack > * + * { margin-top: var(--gap-md); }\n    .row-between { display: flex; align-items: center; justify-content: space-between; gap: var(--gap-md); }\n    .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--gap-lg); }\n    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap-lg); }\n    .grid-2-1 { display: grid; grid-template-columns: 2fr 1fr; gap: var(--gap-xl); align-items: start; }\n    .grid-1-2 { display: grid; grid-template-columns: 1fr 2fr; gap: var(--gap-xl); align-items: start; }\n    .h1, h1 { font-family: var(--font-display); font-size: var(--fs-h1); line-height: 0.98; letter-spacing: -0.025em; margin: 0; }\n    .h2, h2 { font-family: var(--font-display); font-size: var(--fs-h2); line-height: 1.06; letter-spacing: -0.018em; margin: 0; }\n    .h3, h3 { font-family: var(--font-display); font-size: var(--fs-h3); font-weight: 600; line-height: 1.25; margin: 0; }\n    .lead { font-size: var(--fs-lead); line-height: 1.55; color: var(--muted); max-width: 60ch; margin: 0; }\n    .eyebrow {\n      font-family: var(--font-mono);\n      font-size: 12px;\n      letter-spacing: 0.08em;\n      text-transform: uppercase;\n      color: var(--accent);\n      margin: 0 0 var(--gap-md);\n    }\n    .meta { font-family: var(--font-mono); font-size: var(--fs-meta); color: var(--muted); }\n    .topnav {\n      position: fixed;\n      inset: 0 0 auto;\n      z-index: 20;\n      color: var(--surface);\n      background: color-mix(in oklch, var(--navy) 62%, transparent);\n      backdrop-filter: blur(16px);\n      border-bottom: 1px solid color-mix(in oklch, var(--surface) 20%, transparent);\n    }\n    .topnav-inner { display: flex; align-items: center; justify-content: space-between; padding-block: 15px; }\n    .logo { display: inline-flex; align-items: center; gap: 10px; font-family: var(--font-display); font-size: 21px; font-weight: 700; letter-spacing: -0.01em; }\n    .logo-mark { width: 30px; height: 30px; display: grid; place-items: center; border: 1px solid color-mix(in oklch, var(--surface) 45%, transparent); border-radius: 50%; }\n    .topnav nav { display: flex; align-items: center; gap: var(--gap-lg); }\n    .topnav nav a { color: color-mix(in oklch, var(--surface) 82%, transparent); font-size: 14px; }\n    .topnav nav a:hover { color: var(--surface); }\n    .btn {\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n      gap: 8px;\n      min-height: 46px;\n      padding: 12px 21px;\n      border-radius: var(--radius);\n      border: 1px solid transparent;\n      font-size: 15px;\n      font-weight: 700;\n      letter-spacing: -0.005em;\n      transition: transform 0.05s ease, background 0.15s ease, border-color 0.15s ease;\n    }\n    .btn:active { transform: translateY(1px); }\n    .btn-primary { background: var(--accent); color: var(--surface); border-color: var(--accent); }\n    .btn-primary:hover { background: color-mix(in oklch, var(--accent) 86%, black); }\n    .btn-secondary { background: color-mix(in oklch, var(--surface) 10%, transparent); color: var(--surface); border-color: color-mix(in oklch, var(--surface) 42%, transparent); }\n    .btn-secondary:hover { border-color: var(--surface); }\n    .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 28px; }\n    .card-rule { background: transparent; border: 0; border-top: 1px solid var(--fg); padding: 24px 0 0; border-radius: 0; }\n    .hero {\n      min-height: 760px;\n      padding: 132px 0 64px;\n      display: grid;\n      align-items: end;\n      color: var(--surface);\n      background:\n        linear-gradient(90deg, color-mix(in oklch, var(--navy) 92%, transparent) 0%, color-mix(in oklch, var(--navy) 70%, transparent) 42%, color-mix(in oklch, var(--navy) 18%, transparent) 100%),\n        url('assets/hero-family1-hero-premium-roof-at-blue-hour.png') center / cover no-repeat;\n    }\n    .hero-panel { max-width: 805px; }\n    .hero .lead { color: color-mix(in oklch, var(--surface) 78%, transparent); margin-top: 24px; }\n    .hero-cta { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 32px; }\n    .trust-strip {\n      display: grid;\n      grid-template-columns: repeat(3, 1fr);\n      gap: 1px;\n      margin-top: 56px;\n      max-width: 860px;\n      background: color-mix(in oklch, var(--surface) 22%, transparent);\n      border: 1px solid color-mix(in oklch, var(--surface) 22%, transparent);\n    }\n    .trust-strip div { padding: 18px 20px; background: color-mix(in oklch, var(--navy) 48%, transparent); }\n    .trust-strip strong { display: block; font-family: var(--font-display); font-size: 24px; line-height: 1.1; }\n    .trust-strip span { display: block; margin-top: 5px; color: color-mix(in oklch, var(--surface) 72%, transparent); font-size: 13px; }\n    .image-card { overflow: hidden; border-radius: var(--radius-lg); border: 1px solid var(--border); background: var(--surface); }\n    .image-card img { width: 100%; height: 100%; object-fit: cover; }\n    .service-card { display: grid; grid-template-rows: auto 1fr; overflow: hidden; padding: 0; }\n    .service-card .image-card { border: 0; border-radius: var(--radius-lg) var(--radius-lg) 0 0; aspect-ratio: 5 / 3; }\n    .service-card .body { padding: 24px; }\n    .service-card p { color: var(--muted); margin: 8px 0 0; }\n    .mini-list { display: grid; gap: 12px; margin: 28px 0 0; padding: 0; list-style: none; }\n    .mini-list li { display: flex; gap: 12px; color: var(--muted); }\n    .mini-list li::before { content: ''; width: 8px; height: 8px; margin-top: 8px; flex: 0 0 auto; border-radius: 50%; background: currentColor; opacity: 0.5; }\n    .proof-board {\n      background: var(--navy);\n      color: var(--surface);\n      border-radius: var(--radius-lg);\n      overflow: hidden;\n      display: grid;\n      grid-template-columns: 1.1fr 0.9fr;\n      min-height: 430px;\n    }\n    .proof-board img { width: 100%; height: 100%; object-fit: cover; }\n    .proof-copy { padding: clamp(30px, 5vw, 58px); align-self: center; }\n    .proof-copy .lead { color: color-mix(in oklch, var(--surface) 74%, transparent); }\n    .process-grid { counter-reset: step; }\n    .process-card { position: relative; min-height: 230px; }\n    .process-card::before {\n      counter-increment: step;\n      content: counter(step, decimal-leading-zero);\n      display: block;\n      margin-bottom: 44px;\n      font-family: var(--font-display);\n      font-size: 46px;\n      line-height: 1;\n      color: var(--navy);\n    }\n    .faq-item { padding: 22px 0; border-top: 1px solid var(--border); }\n    .faq-item h3 { font-size: 21px; }\n    .faq-item p { margin: 8px 0 0; color: var(--muted); }\n    .contact-panel { background: var(--charcoal); color: var(--surface); border: 0; }\n    .contact-panel .lead, .contact-panel .meta, .contact-panel label { color: color-mix(in oklch, var(--surface) 70%, transparent); }\n    .field { display: flex; flex-direction: column; gap: 6px; }\n    .field label { font-size: 13px; color: var(--muted); }\n    .input, .textarea, .select {\n      width: 100%;\n      padding: 12px 14px;\n      border: 1px solid color-mix(in oklch, var(--surface) 24%, transparent);\n      border-radius: var(--radius);\n      background: color-mix(in oklch, var(--surface) 8%, transparent);\n      color: var(--surface);\n      font: inherit;\n      font-size: 15px;\n    }\n    .input::placeholder, .textarea::placeholder { color: color-mix(in oklch, var(--surface) 48%, transparent); }\n    .input:focus, .textarea:focus, .select:focus { outline: 2px solid var(--accent-soft); border-color: var(--accent); }\n    .textarea { min-height: 112px; resize: vertical; line-height: 1.55; }\n    .contact-panel form { display: grid; gap: 14px; margin-top: 26px; }\n    .pagefoot { background: var(--charcoal); color: color-mix(in oklch, var(--surface) 68%, transparent); padding-block: var(--gap-xl); }\n    .pagefoot a:hover { color: var(--surface); }\n    .footer-grid { display: grid; grid-template-columns: 1.3fr 0.8fr 0.8fr 1fr; gap: var(--gap-lg); }\n    .footer-grid h3 { color: var(--surface); font-size: 18px; margin-bottom: 12px; }\n    .footer-grid p, .footer-grid li { margin: 0; color: color-mix(in oklch, var(--surface) 66%, transparent); font-size: 14px; }\n    .footer-grid ul { list-style: none; padding: 0; margin: 0; display: grid; gap: 8px; }\n    .mobile-call { display: none; position: fixed; left: 16px; right: 16px; bottom: 16px; z-index: 30; box-shadow: 0 18px 42px color-mix(in oklch, var(--fg) 28%, transparent); }\n    @media (max-width: 920px) {\n      :root { --gutter: 20px; }\n      .grid-2, .grid-3, .grid-2-1, .grid-1-2, .proof-board, .footer-grid { grid-template-columns: 1fr; }\n      .topnav nav { display: none; }\n      .topnav .btn { display: none; }\n      .hero { min-height: 720px; padding-top: 112px; }\n      .trust-strip { grid-template-columns: 1fr; }\n      .proof-board img { min-height: 280px; }\n      .mobile-call { display: inline-flex; }\n      body { padding-bottom: 82px; }\n    }\n  </style>\n  <script type=\"application/ld+json\">\n    {\n      \"@context\": \"https://schema.org\",\n      \"@type\": [\"LocalBusiness\", \"RoofingContractor\"],\n      \"name\": \"RidgeLine Roof Co.\",\n      \"telephone\": \"0400 000 000\",\n      \"url\": \"\",\n      \"image\": \"assets/hero-family1-hero-premium-roof-at-blue-hour.png\",\n      \"areaServed\": [\"Brisbane\", \"Gold Coast\"],\n      \"address\": {\n        \"@type\": \"PostalAddress\",\n        \"streetAddress\": \"Address available on request\",\n        \"addressLocality\": \"Brisbane\",\n        \"addressRegion\": \"QLD\",\n        \"addressCountry\": \"AU\"\n      },\n      \"hasMap\": \"https://www.google.com/maps/search/?api=1&query=Brisbane+roofing+contractor\",\n      \"description\": \"Local roofing contractor providing roof repairs, roof restoration, metal roofing, gutter repairs and roof inspections across Brisbane and the Gold Coast.\",\n      \"makesOffer\": [\n        { \"@type\": \"Offer\", \"itemOffered\": { \"@type\": \"Service\", \"name\": \"Roof repairs\" } },\n        { \"@type\": \"Offer\", \"itemOffered\": { \"@type\": \"Service\", \"name\": \"Roof restoration\" } },\n        { \"@type\": \"Offer\", \"itemOffered\": { \"@type\": \"Service\", \"name\": \"Metal roofing\" } },\n        { \"@type\": \"Offer\", \"itemOffered\": { \"@type\": \"Service\", \"name\": \"Gutter repairs\" } },\n        { \"@type\": \"Offer\", \"itemOffered\": { \"@type\": \"Service\", \"name\": \"Roof inspections\" } }\n      ]\n    }\n  </script>\n</head>\n<body>\n  <header class=\"topnav\" aria-label=\"Primary navigation\">\n    <div class=\"container topnav-inner\">\n      <a class=\"logo\" href=\"#top\" aria-label=\"RidgeLine Roof Co. home\">\n        <span class=\"logo-mark\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 24 24\" width=\"17\" height=\"17\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"><path d=\"M3 13.5 12 5l9 8.5\"/><path d=\"M6.5 11.8V19h11v-7.2\"/></svg>\n        </span>\n        RidgeLine Roof Co.\n      </a>\n      <nav aria-label=\"Page sections\">\n        <a href=\"#services\">Services</a>\n        <a href=\"#proof\">Our approach</a>\n        <a href=\"#process\">Process</a>\n        <a href=\"#contact\">Contact</a>\n      </nav>\n      <a class=\"btn btn-primary\" href=\"tel:0400000000\">Call 0400 000 000</a>\n    </div>\n  </header>\n\n  <main id=\"top\">\n    <section class=\"hero\" data-od-id=\"hero\">\n      <div class=\"container\">\n        <div class=\"hero-panel\">\n          <p class=\"eyebrow\">Roof repairs · restorations · inspections</p>\n          <h1>Premium roofing for Brisbane and Gold Coast homes</h1>\n          <p class=\"lead\">RidgeLine Roof Co. helps homeowners request careful roof repairs, restorations, metal roofing, gutter repairs and inspections without the guesswork.</p>\n          <div class=\"hero-cta\">\n            <a class=\"btn btn-primary\" href=\"#contact\">Request an inspection</a>\n            <a class=\"btn btn-secondary\" href=\"tel:0400000000\">Call 0400 000 000</a>\n          </div>\n          <div class=\"trust-strip\" aria-label=\"Service highlights\">\n            <div><strong>Roof-first advice</strong><span>Repair, restore or replace guidance based on visible roof condition.</span></div>\n            <div><strong>Local service area</strong><span>Brisbane and Gold Coast enquiry coverage.</span></div>\n            <div><strong>Clear quote path</strong><span>Phone or form request with photos, priorities and access notes.</span></div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"services\" data-od-id=\"services\">\n      <div class=\"container stack\" style=\"gap: 56px;\">\n        <div class=\"row-between\">\n          <div style=\"max-width: 48ch;\">\n            <p class=\"eyebrow\">Services</p>\n            <h2>Roofing work homeowners can request in one place</h2>\n          </div>\n          <p class=\"lead\">From isolated leaks to full restoration planning, the service mix is built around practical roof condition, weather exposure and long-term home presentation.</p>\n        </div>\n        <div class=\"grid-3\">\n          <article class=\"card service-card\">\n            <div class=\"image-card\"><img src=\"assets/serviceRepair-family1-service-roof-repair-flashing-detail.png\" alt=\"Close detail of roof flashing repair work on a tiled roof\" loading=\"lazy\"></div>\n            <div class=\"body\">\n              <h3>Roof repairs</h3>\n              <p>Leak investigation, flashing issues, cracked tiles, storm wear and targeted repair work before small problems spread.</p>\n            </div>\n          </article>\n          <article class=\"card service-card\">\n            <div class=\"image-card\"><img src=\"assets/serviceInstall-family1-service-roof-installation-detail.png\" alt=\"Roofing contractor installing materials on a residential roof frame\" loading=\"lazy\"></div>\n            <div class=\"body\">\n              <h3>Roof restoration</h3>\n              <p>Assessment-led restoration planning for tired roof surfaces, visible weathering and homes preparing for a cleaner street presence.</p>\n            </div>\n          </article>\n          <article class=\"card service-card\">\n            <div class=\"image-card\"><img src=\"assets/about-family1-about-roofer-working-roof-frame.png\" alt=\"Roofer working carefully on a residential roof structure\" loading=\"lazy\"></div>\n            <div class=\"body\">\n              <h3>Metal roofing</h3>\n              <p>Metal roof enquiries, installation planning and replacement conversations for homes needing a durable roof profile.</p>\n            </div>\n          </article>\n        </div>\n        <div class=\"grid-2\">\n          <div class=\"card card-rule\">\n            <h3>Gutter repairs</h3>\n            <p class=\"lead\" style=\"font-size: 16px; margin-top: 8px;\">Blocked, loose or damaged gutter sections can affect drainage and roof edges. Request an inspection when overflow or staining appears.</p>\n          </div>\n          <div class=\"card card-rule\">\n            <h3>Roof inspections</h3>\n            <p class=\"lead\" style=\"font-size: 16px; margin-top: 8px;\">A practical check for leaks, weather damage, maintenance needs or pre-sale preparation across Brisbane and Gold Coast properties.</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"proof\" data-od-id=\"proof\">\n      <div class=\"container\">\n        <div class=\"proof-board\">\n          <img src=\"assets/proof-family1-project-before-after-roof-transformation.png\" alt=\"Before and after style view of a residential roof transformation\" loading=\"lazy\">\n          <div class=\"proof-copy stack\">\n            <p class=\"eyebrow\">Workmanship cues</p>\n            <h2>Proof is shown through process, not unsupported claims</h2>\n            <p class=\"lead\">Every enquiry should move from roof condition to a clear recommendation: repair what is failing, restore what can be renewed, and discuss replacement when the roof needs a larger plan.</p>\n            <ul class=\"mini-list\">\n              <li>Visible roof areas, gutters, ridges and flashing are considered together.</li>\n              <li>Photo-supported quote requests help prioritise urgent leaks and storm wear.</li>\n              <li>Project examples should be replaced with real local work before publishing.</li>\n            </ul>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"process\" data-od-id=\"quote-process\">\n      <div class=\"container stack\" style=\"gap: 48px;\">\n        <div class=\"grid-1-2\">\n          <div>\n            <p class=\"eyebrow\">Quote process</p>\n            <h2>A straightforward path from roof concern to inspection request</h2>\n          </div>\n          <p class=\"lead\">Share the roof issue, include helpful details, and choose the best way to be contacted. For urgent leaks, use the phone CTA so the enquiry is clear from the start.</p>\n        </div>\n        <div class=\"grid-3 process-grid\">\n          <article class=\"card process-card\">\n            <h3>Tell us what you are seeing</h3>\n            <p class=\"lead\" style=\"font-size: 16px; margin-top: 8px;\">Leaks, cracked tiles, rust, loose gutters, storm damage or a roof that looks ready for restoration.</p>\n          </article>\n          <article class=\"card process-card\">\n            <h3>Share access and timing notes</h3>\n            <p class=\"lead\" style=\"font-size: 16px; margin-top: 8px;\">Add suburb, property type, roof access notes and whether the issue is urgent or planned maintenance.</p>\n          </article>\n          <article class=\"card process-card\">\n            <h3>Request a practical recommendation</h3>\n            <p class=\"lead\" style=\"font-size: 16px; margin-top: 8px;\">Ask for a repair, restoration, metal roofing, gutter repair or inspection quote based on the roof condition.</p>\n          </article>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"contact\" data-od-id=\"faq-contact-footer\">\n      <div class=\"container grid-2-1\">\n        <div>\n          <p class=\"eyebrow\">Common questions</p>\n          <h2>Helpful answers before you request a quote</h2>\n          <div style=\"margin-top: 34px;\">\n            <article class=\"faq-item\">\n              <h3>Can I request a roof inspection without knowing the exact issue?</h3>\n              <p>Yes. Describe what you can see, where it appears on the home and whether it changes during rain or wind.</p>\n            </article>\n            <article class=\"faq-item\">\n              <h3>Do you handle small roof repairs as well as restoration enquiries?</h3>\n              <p>Yes. The service list includes roof repairs, restoration, metal roofing, gutter repairs and inspections.</p>\n            </article>\n            <article class=\"faq-item\">\n              <h3>What should I include in the form?</h3>\n              <p>Your suburb, the roofing concern, access notes and preferred contact method. Photos can be requested during follow-up.</p>\n            </article>\n            <article class=\"faq-item\">\n              <h3>Which areas does this page cover?</h3>\n              <p>RidgeLine Roof Co. is positioned for roofing enquiries across Brisbane and the Gold Coast.</p>\n            </article>\n          </div>\n        </div>\n        <aside class=\"card contact-panel\" aria-label=\"Request a roof inspection form\">\n          <p class=\"eyebrow\">Request a quote</p>\n          <h2 style=\"font-size: clamp(30px, 3vw, 42px);\">Start with the roof concern</h2>\n          <p class=\"lead\" style=\"font-size: 16px; margin-top: 12px;\">Call <a href=\"tel:0400000000\">0400 000 000</a> or send the form details for a roof inspection or quote request.</p>\n          <form action=\"#\" method=\"post\">\n            <div class=\"field\">\n              <label for=\"name\">Name</label>\n              <input class=\"input\" id=\"name\" name=\"name\" autocomplete=\"name\" placeholder=\"Your name\">\n            </div>\n            <div class=\"field\">\n              <label for=\"phone\">Phone</label>\n              <input class=\"input\" id=\"phone\" name=\"phone\" autocomplete=\"tel\" placeholder=\"Best contact number\">\n            </div>\n            <div class=\"field\">\n              <label for=\"suburb\">Suburb</label>\n              <input class=\"input\" id=\"suburb\" name=\"suburb\" autocomplete=\"address-level2\" placeholder=\"Brisbane, Gold Coast or nearby\">\n            </div>\n            <div class=\"field\">\n              <label for=\"service\">Service</label>\n              <select class=\"select\" id=\"service\" name=\"service\">\n                <option>Roof repairs</option>\n                <option>Roof restoration</option>\n                <option>Metal roofing</option>\n                <option>Gutter repairs</option>\n                <option>Roof inspection</option>\n              </select>\n            </div>\n            <div class=\"field\">\n              <label for=\"message\">Roof concern</label>\n              <textarea class=\"textarea\" id=\"message\" name=\"message\" placeholder=\"Tell us what you can see, when it happens and any access notes.\"></textarea>\n            </div>\n            <button class=\"btn btn-primary\" type=\"submit\">Send inspection request</button>\n            <p class=\"meta\">Hours: standard business hours by enquiry. Directions: <a href=\"https://www.google.com/maps/search/?api=1&query=Brisbane+roofing+contractor\">Google Maps search</a>.</p>\n          </form>\n        </aside>\n      </div>\n    </section>\n  </main>\n\n  <footer class=\"pagefoot\" data-od-id=\"footer\">\n    <div class=\"container footer-grid\">\n      <div>\n        <h3>RidgeLine Roof Co.</h3>\n        <p>Local roofing contractor for Brisbane and Gold Coast homeowners requesting roof repairs, restoration, metal roofing, gutter repairs and inspections.</p>\n      </div>\n      <div>\n        <h3>Services</h3>\n        <ul>\n          <li><a href=\"#services\">Roof repairs</a></li>\n          <li><a href=\"#services\">Roof restoration</a></li>\n          <li><a href=\"#services\">Metal roofing</a></li>\n          <li><a href=\"#services\">Gutter repairs</a></li>\n        </ul>\n      </div>\n      <div>\n        <h3>Areas</h3>\n        <ul>\n          <li>Brisbane</li>\n          <li>Gold Coast</li>\n          <li>Nearby enquiries by request</li>\n        </ul>\n      </div>\n      <div>\n        <h3>Contact</h3>\n        <ul>\n          <li><a href=\"tel:0400000000\">0400 000 000</a></li>\n          <li>Email available on request</li>\n          <li><a href=\"https://www.google.com/maps/search/?api=1&query=Brisbane+roofing+contractor\">Directions search</a></li>\n        </ul>\n      </div>\n    </div>\n  </footer>\n\n  <a class=\"btn btn-primary mobile-call\" href=\"tel:0400000000\">Call RidgeLine Roof Co.</a>\n</body>\n</html>\n</artifact>"}

