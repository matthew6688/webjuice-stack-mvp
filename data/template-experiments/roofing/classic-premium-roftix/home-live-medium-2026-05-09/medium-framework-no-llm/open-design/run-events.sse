data: {"type":"text_delta","delta":"Got it — prototype home page is set; I need a few fast choices before building.\n\n<question-form id=\"discovery\" title=\"Quick brief — 30 seconds\">\n{\n  \"description\": \"I'll lock these in before building. Skip what doesn't apply — I'll fill defaults.\",\n  \"questions\": [\n    {\n      \"id\": \"platform\",\n      \"label\": \"Primary surface\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Desktop web\",\n        \"Responsive — all sizes\",\n        \"Mobile-first\"\n      ]\n    },\n    {\n      \"id\": \"audience\",\n      \"label\": \"Who is this for?\",\n      \"type\": \"text\",\n      \"placeholder\": \"e.g. Brisbane homeowners, premium residential clients, property managers\"\n    },\n    {\n      \"id\": \"tone\",\n      \"label\": \"Visual tone\",\n      \"type\": \"checkbox\",\n      \"maxSelections\": 2,\n      \"options\": [\n        \"Classic premium\",\n        \"Editorial / magazine\",\n        \"Modern minimal\",\n        \"Warm / approachable\",\n        \"Trade practical\",\n        \"Luxury / refined\"\n      ]\n    },\n    {\n      \"id\": \"brand\",\n      \"label\": \"Brand context\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Use the Classic Premium Roftix direction from the brief\",\n        \"Pick a direction for me\",\n        \"I have a brand spec — I'll share it\",\n        \"Match a reference site / screenshot — I'll attach it\"\n      ]\n    },\n    {\n      \"id\": \"conversion\",\n      \"label\": \"Preferred quote path emphasis\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Phone-first with supporting form\",\n        \"Form-first with phone backup\",\n        \"Balanced phone and form\"\n      ]\n    },\n    {\n      \"id\": \"scale\",\n      \"label\": \"Page density\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Polished medium-length home page\",\n        \"Compact screenshot-first page\",\n        \"Richer long-scroll page\"\n      ]\n    },\n    {\n      \"id\": \"constraints\",\n      \"label\": \"Anything else I should know?\",\n      \"type\": \"textarea\",\n      \"placeholder\": \"Copy preferences, things to avoid, specific suburb language, section emphasis…\"\n    }\n  ]\n}\n</question-form>"}

