---
import Layout from '../../../../layouts/AdminLayout.astro';
import { siteConfig } from '../../../../config/site';
import { loadPaidIntakeIndex, loadPaidIntakeRecord } from '../../../../../core/funnel/paid-intake-index.js';
import { allowedAdminActions, adminActionDefinition } from '../../../../../core/funnel/paid-intake-actions.js';

function discordThreadUrl(threadId) {
  return threadId ? `https://discord.com/channels/@me/${threadId}` : '';
}

export function getStaticPaths() {
  const index = loadPaidIntakeIndex();
  return index.records.map((record) => ({
    params: { clientSlug: record.clientSlug, orderId: record.orderId },
  }));
}

const { clientSlug, orderId } = Astro.params;
const loaded = loadPaidIntakeRecord({ clientSlug, orderId });
if (!loaded) return Astro.redirect('/admin/intakes');
const { record, summary, timeline, filePath, timelinePath } = loaded;
const actions = allowedAdminActions(record).map((action) => ({ action, definition: adminActionDefinition(action) })).filter((item) => item.definition);
const latestRevision = Array.isArray(record.revisions) ? record.revisions.at(-1) : null;
const officialFunnel = 'https://profitslocal.com';
const funnelParams = new URLSearchParams({
  order_id: summary.orderId,
  email: summary.customer.email || '',
  client_slug: summary.clientSlug,
  repo: summary.repo || '',
  preview_url: summary.previewUrl || '',
});
const projectLinks = [
  { label: 'Repo', href: summary.repo ? `https://github.com/${summary.repo}` : '' },
  { label: 'Dev preview', href: summary.previewUrl },
  { label: '线上站点', href: summary.liveUrl || (summary.customer.domain ? `https://${summary.customer.domain}` : '') },
  { label: 'Revise', href: `${officialFunnel}/revision?${funnelParams.toString()}` },
  { label: 'Approve', href: `${officialFunnel}/approve?${funnelParams.toString()}` },
  { label: 'Domain setup', href: `${officialFunnel}/domain-setup?${funnelParams.toString()}` },
  { label: 'Discord thread', href: summary.discordThreadUrl || discordThreadUrl(summary.discordThreadId) },
].filter((link) => link.href);
const capsulePaths = [
  ['Paid intake', filePath],
  ['Timeline', timelinePath],
  ['Case', summary.casePath],
  ['Website survey', summary.websiteSurveyPath],
  ['Build packet', summary.buildPacketPath],
].filter(([, value]) => value);
const operatorLinks = [
  ['Discord thread', summary.discordThreadUrl || discordThreadUrl(summary.discordThreadId)],
  ['Repo', summary.repo ? `https://github.com/${summary.repo}` : ''],
  ['Dev preview', summary.previewUrl || ''],
  ['线上站点', summary.liveUrl || (summary.customer.domain ? `https://${summary.customer.domain}` : '')],
  ['Latest workflow', summary.workflowSummary?.latestWorkflowUrl || ''],
].filter(([, href]) => href);
const operatorArtifacts = [
  ['Open Design manifest', summary.artifactSummary?.conceptManifestPath || ''],
  ['Production handoff', summary.artifactSummary?.productionHandoffPath || ''],
  ['Outreach pack', summary.artifactSummary?.outreachPackPath || ''],
  ['Outreach email dir', summary.artifactSummary?.outreachEmailDir || ''],
  ['Delivery QA', summary.artifactSummary?.deliveryQaPath || ''],
  ['Finance summary', summary.artifactSummary?.financeSummaryPath || ''],
  ['Domain request', summary.artifactSummary?.domainRequestPath || ''],
  ['Ops smoke evidence', summary.workflowSummary?.latestSmokePath || ''],
].filter(([, value]) => value);
const healthItems = [
  {
    label: 'Open Design',
    value: summary.artifactSummary?.openDesignPipelineLabel || (summary.artifactSummary?.openDesignBound ? 'Running' : 'Missing'),
    tone: summary.artifactSummary?.openDesignPipelineTone || (summary.artifactSummary?.openDesignBound ? 'working' : 'alert'),
  },
  {
    label: 'Delivery QA',
    value: summary.artifactSummary?.deliveryQaReady ? 'Pass' : 'Pending',
    tone: summary.artifactSummary?.deliveryQaReady ? 'ready' : 'warn',
  },
  {
    label: 'Outreach proof',
    value: summary.artifactSummary?.outreachAssetsReady ? 'Ready' : 'Pending',
    tone: summary.artifactSummary?.outreachAssetsReady ? 'ready' : 'warn',
  },
  {
    label: 'Domain',
    value: summary.artifactSummary?.domainStatus || '未开始',
    tone: summary.artifactSummary?.domainStatus === 'waiting_for_customer_dns' ? 'warn' : 'info',
  },
];
---

<Layout title={`${summary.customer.company || summary.clientSlug} - 项目工作台 - ${siteConfig.name}`} description="已付款项目详情与操作面板。" active="intakes">
  <section class="poster-section admin-section">
    <div class="admin-shell admin-detail-shell">
      <div class="admin-header">
        <div>
          <p class="eyebrow"><a href="/admin/intakes">内部运营</a> / 项目详情</p>
          <h1>{summary.customer.company || summary.clientSlug}</h1>
          <p class="lede">{summary.clientSlug} / {summary.orderId}</p>
        </div>
        <div class="admin-count">
          <strong>{summary.revisionCount}</strong>
          <span>已用修订 / 共 {summary.revisionLimit} 次</span>
        </div>
      </div>

      {Astro.url.searchParams.get('action') === 'queued' && (
        <div class="admin-notice">动作已经排队。GitHub Actions 处理完成后，下一次 deploy 会把最新状态刷新到后台。</div>
      )}

      <div class="admin-summary-strip admin-summary-strip-compact">
        <article class="admin-summary-tile admin-summary-primary">
          <span class="admin-summary-label">项目阶段</span>
          <strong>{summary.stageSummary?.label || '未知'}</strong>
          <p>{summary.nextActionSummary?.reason || '先看最新 workflow，再决定下一步怎么解阻塞。'}</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">当前里程碑</span>
          <strong>{summary.milestoneSummary?.currentLabel || '线索已收集'}</strong>
          <p>已完成 {summary.milestoneSummary?.completedCount || 0} / {summary.milestoneSummary?.total || 0}</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">记录状态</span>
          <strong>{summary.status.replaceAll('_', ' ')}</strong>
          <p>{summary.readinessStatus || '尚未检查 readiness'} · 更新于 {summary.updatedAt || 'N/A'}</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">客户</span>
          <strong>{summary.customer.email || '缺少邮箱'}</strong>
          <p>{summary.customer.domain || '缺少域名'} · {summary.leadRecipientEmail || '缺少 lead recipient'}</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">修订</span>
          <strong>{summary.revisionCount} / {summary.revisionLimit}</strong>
          <p>{latestRevision?.status || '还没有修订'} · {summary.firstVersionConfirmed ? 'v1 已确认' : 'v1 未确认'}</p>
        </article>
      </div>

      <div class="admin-detail-lead">
        <section class="admin-panel admin-detail-primary">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">控制中心</span>
              <h2>下一步该做什么</h2>
            </div>
          </div>
          <div class="admin-command-card">
            <div class="admin-command-main">
              <strong>{summary.nextActionSummary?.label || '先查看项目状态'}</strong>
              <p>{summary.nextActionSummary?.reason || '当前还没有建议动作。'}</p>
            </div>
            <code>{summary.nextActionSummary?.command || '打开 Discord thread，并检查 preview。'}</code>
          </div>
          <div class="admin-health-grid">
            {healthItems.map((item) => (
              <div class={`admin-health-card admin-health-${item.tone}`}>
                <span>{item.label}</span>
                <strong>{item.value}</strong>
              </div>
            ))}
          </div>
          <div class="admin-blocker-box">
            <div class="admin-blocker-head">
              <span class="eyebrow">阻塞项</span>
              <strong>{summary.blockerSummary?.count || 0}</strong>
            </div>
            {summary.blockerSummary?.count ? (
              <ul class="admin-list">
                {summary.blockerSummary.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            ) : (
              <p class="micro">当前没有记录阻塞项，这个项目可以继续往前推。</p>
            )}
          </div>
        </section>

        <aside class="admin-panel admin-action-rail">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">操作动作</span>
              <h2>推进这个项目</h2>
            </div>
          </div>
          <div class="admin-link-grid">
            {projectLinks.slice(0, 4).map((link) => (
              <a class="button secondary" href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
            ))}
          </div>
          {actions.map(({ action, definition }) => (
            <form method="post" action="/admin/action" class="admin-action-form">
              <input type="hidden" name="client_slug" value={summary.clientSlug} />
              <input type="hidden" name="order_id" value={summary.orderId} />
              <input type="hidden" name="action" value={action} />
              <input type="hidden" name="actor" value="profitslocal-admin" />
              {definition.needsNote && <textarea name="note" placeholder="填写客户或内部上下文备注（必填）" required></textarea>}
              {!definition.needsNote && <input name="note" placeholder="可选备注" />}
              <button class="button" type="submit">{definition.label}</button>
            </form>
          ))}
        </aside>
      </div>

      <div class="admin-detail-grid">
        <section class="admin-panel">
          <h2>里程碑时间线</h2>
          <ol class="admin-milestone-list">
            {(summary.milestoneSummary?.milestones || []).map((item) => (
              <li class={`admin-milestone-item ${item.complete ? 'is-complete' : ''} ${item.key === summary.milestoneSummary?.currentKey ? 'is-current' : ''}`}>
                <div class="admin-milestone-marker" aria-hidden="true"></div>
                <div>
                  <strong>{item.label}</strong>
                  <span>{item.key}</span>
                </div>
                <div>
                  <span>{item.complete ? '已完成' : '待完成'}</span>
                  <span>{item.at || '还没有时间戳'}</span>
                </div>
              </li>
            ))}
          </ol>
        </section>

        <section class="admin-panel">
          <h2>状态</h2>
          <mark class={`status-pill status-${summary.status}`}>{summary.status.replaceAll('_', ' ')}</mark>
          <dl>
            <div><dt>项目阶段</dt><dd>{summary.stageSummary?.label || '未知'}</dd></div>
            <div><dt>当前里程碑</dt><dd>{summary.milestoneSummary?.currentLabel || '线索已收集'}</dd></div>
            <div><dt>Readiness</dt><dd>{summary.readinessStatus || '还没有检查'}</dd></div>
            <div><dt>缺失项</dt><dd>{summary.missing.length ? summary.missing.join(', ') : '已就绪'}</dd></div>
            <div><dt>首版是否确认</dt><dd>{summary.firstVersionConfirmed ? '是' : '否'}</dd></div>
            <div><dt>最近更新</dt><dd>{summary.updatedAt}</dd></div>
          </dl>
        </section>

        <section class="admin-panel">
          <h2>客户信息</h2>
          <dl>
            <div><dt>邮箱</dt><dd>{summary.customer.email}</dd></div>
            <div><dt>电话</dt><dd>{summary.customer.phone || 'N/A'}</dd></div>
            <div><dt>域名</dt><dd>{summary.customer.domain || 'N/A'}</dd></div>
            <div><dt>线索接收邮箱</dt><dd>{summary.leadRecipientEmail || summary.customer.email || '缺失'}</dd></div>
          </dl>
        </section>

        <section class="admin-panel">
          <h2>Workflow / Job 状态</h2>
          <dl>
            <div><dt>最近时间线事件</dt><dd>{summary.artifactSummary?.latestTimeline?.type || 'N/A'}</dd></div>
            <div><dt>事件时间</dt><dd>{summary.artifactSummary?.latestTimeline?.at || 'N/A'}</dd></div>
            <div><dt>Case 状态</dt><dd>{summary.artifactSummary?.caseStatus || 'N/A'}</dd></div>
            <div><dt>Open Design 项目</dt><dd>{summary.artifactSummary?.openDesignProjectId || 'N/A'}</dd></div>
            <div><dt>Open Design run</dt><dd>{summary.artifactSummary?.openDesignLastRunId || 'N/A'}</dd></div>
            <div><dt>Open Design pipeline</dt><dd>{summary.artifactSummary?.openDesignPipelineLabel || 'N/A'}</dd></div>
            <div><dt>Open Design 状态</dt><dd>{summary.artifactSummary?.openDesignStatus || 'N/A'}</dd></div>
            <div><dt>完成模式</dt><dd>{summary.artifactSummary?.openDesignCompletionMode || 'N/A'}</dd></div>
            <div><dt>最近任务</dt><dd>{summary.artifactSummary?.latestTask?.id || 'N/A'}</dd></div>
            <div><dt>任务类型</dt><dd>{summary.artifactSummary?.latestTask?.kind || 'N/A'}</dd></div>
            <div><dt>任务状态</dt><dd>{summary.artifactSummary?.latestTask?.status || 'N/A'}</dd></div>
            <div><dt>最近 agent run</dt><dd>{summary.workflowSummary?.latestAgentRunId || 'N/A'}</dd></div>
            <div><dt>Agent run 状态</dt><dd>{summary.workflowSummary?.latestAgentRunState || 'N/A'}</dd></div>
            <div><dt>最近 workflow 类型</dt><dd>{summary.workflowSummary?.latestWorkflowKind || 'N/A'}</dd></div>
            <div><dt>Workflow run ID</dt><dd>{summary.workflowSummary?.latestWorkflowRunId || 'N/A'}</dd></div>
            <div><dt>Workflow 链接</dt><dd>{summary.workflowSummary?.latestWorkflowUrl ? <a href={summary.workflowSummary.latestWorkflowUrl} target="_blank" rel="noreferrer">打开 run</a> : 'N/A'}</dd></div>
            <div><dt>Workflow 证据</dt><dd><code>{summary.workflowSummary?.latestSmokePath || 'N/A'}</code></dd></div>
          </dl>
        </section>
      </div>

      <section class="admin-panel">
        <h2>Project Links</h2>
        <div class="admin-link-grid">
          {projectLinks.map((link) => (
            <a class="button secondary" href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
          ))}
          {!projectLinks.length && <p class="micro">还没有记录项目链接。</p>}
        </div>
        <dl class="admin-path-list">
          {capsulePaths.map(([label, value]) => (
            <div><dt>{label}</dt><dd><code>{value}</code></dd></div>
          ))}
        </dl>
      </section>

      <div class="admin-detail-grid lower">
        <section class="admin-panel">
          <h2>Operator Console</h2>
          <dl>
            <div><dt>Client slug</dt><dd>{summary.clientSlug}</dd></div>
            <div><dt>Order ID</dt><dd><code>{summary.orderId}</code></dd></div>
            <div><dt>Repo branch</dt><dd>{record.branch || 'dev'}</dd></div>
            <div><dt>Template</dt><dd>{record.template || 'unknown'}</dd></div>
            <div><dt>Website thread</dt><dd>{record.discord?.websiteTaskThreadId || 'N/A'}</dd></div>
            <div><dt>Revision policy</dt><dd>{record.revision?.policy?.description || `${summary.revisionLimit} included revisions`}</dd></div>
          </dl>
        </section>

        <section class="admin-panel">
          <h2>Operator Links</h2>
          <div class="admin-link-grid">
            {operatorLinks.map(([label, href]) => (
              <a class="button secondary" href={href} target="_blank" rel="noreferrer">{label}</a>
            ))}
          </div>
        </section>

        <section class="admin-panel">
          <h2>Operator Artifacts</h2>
          <dl class="admin-path-list">
            {operatorArtifacts.map(([label, value]) => (
              <div><dt>{label}</dt><dd><code>{value}</code></dd></div>
            ))}
          </dl>
        </section>
      </div>

      <div class="admin-detail-grid lower">
        <section class="admin-panel">
          <h2>Intake</h2>
          <dl>
            <div><dt>服务内容</dt><dd>{record.intake?.services || record.intake?.launchNotes || 'N/A'}</dd></div>
            <div><dt>主要动作</dt><dd>{record.intake?.primaryAction || 'N/A'}</dd></div>
            <div><dt>地址 / 服务范围</dt><dd>{record.intake?.address || summary.customer.domain || 'N/A'}</dd></div>
            <div><dt>参考资料</dt><dd>{record.intake?.references || record.intake?.referenceUrl || 'N/A'}</dd></div>
            <div><dt>备注</dt><dd>{record.intake?.notes || 'N/A'}</dd></div>
          </dl>
        </section>

        <section class="admin-panel">
          <h2>资产</h2>
          <ul class="admin-list">
            {(record.intake?.assets || []).map((asset) => (
              <li><a href={asset.secureUrl || asset.url} target="_blank" rel="noreferrer">{asset.filename || asset.publicId}</a><span>{asset.resourceType || 'asset'} / {asset.bytes || 0} bytes</span></li>
            ))}
            {!(record.intake?.assets || []).length && <li>这个记录上还没有 Cloudinary 资产。</li>}
          </ul>
        </section>

        <section class="admin-panel">
          <h2>修订</h2>
          {latestRevision ? (
            <dl>
              <div><dt>状态</dt><dd>{latestRevision.status}</dd></div>
              <div><dt>次数</dt><dd>{latestRevision.revisionNumber} / {summary.revisionLimit}</dd></div>
              <div><dt>修改要求</dt><dd>{latestRevision.requestedChanges}</dd></div>
              <div><dt>附件</dt><dd>{latestRevision.assets?.length || 0}</dd></div>
            </dl>
          ) : <p class="micro">还没有修订记录。</p>}
        </section>
      </div>

      <div class="admin-detail-grid lower">
        <section class="admin-panel">
          <h2>Outreach</h2>
          <dl>
            <div><dt>Pack 里的预览</dt><dd>{summary.artifactSummary?.outreachPreviewUrl || 'N/A'}</dd></div>
            <div><dt>证明点</dt><dd>{summary.artifactSummary?.outreachProofPoints ?? 0}</dd></div>
            <div><dt>素材是否就绪</dt><dd>{summary.artifactSummary?.outreachAssetsReady ? '是' : '否'}</dd></div>
            <div><dt>Pack JSON 路径</dt><dd><code>{summary.artifactSummary?.outreachPackPath || 'N/A'}</code></dd></div>
            <div><dt>Pack MD 路径</dt><dd><code>{summary.artifactSummary?.outreachMarkdownPath || 'N/A'}</code></dd></div>
          </dl>
        </section>

        <section class="admin-panel">
          <h2>Delivery QA</h2>
          <dl>
            <div><dt>是否可发 review</dt><dd>{summary.artifactSummary?.deliveryQaReady ? '是' : '否'}</dd></div>
            <div><dt>QA 报告</dt><dd>{summary.artifactSummary?.deliveryQaPath || 'N/A'}</dd></div>
          </dl>
        </section>

        <section class="admin-panel">
          <h2>ROI 快照</h2>
          <dl>
            <div><dt>收入</dt><dd>{summary.currency} {summary.artifactSummary?.financeSummary?.revenue ?? 0}</dd></div>
            <div><dt>成本</dt><dd>{summary.currency} {summary.artifactSummary?.financeSummary?.cost ?? 0}</dd></div>
            <div><dt>利润</dt><dd>{summary.currency} {summary.artifactSummary?.financeSummary?.profit ?? 0}</dd></div>
            <div><dt>事件数</dt><dd>{summary.artifactSummary?.financeSummary?.eventCount ?? 0}</dd></div>
            <div><dt>摘要路径</dt><dd><code>{summary.artifactSummary?.financeSummaryPath || 'N/A'}</code></dd></div>
          </dl>
        </section>
      </div>

      <section class="admin-panel admin-timeline">
        <h2>时间线</h2>
        <ol>
          {timeline.slice().reverse().slice(0, 12).map((event) => (
            <li>
              <strong>{event.type || event.action || 'event'}</strong>
              <span>{event.createdAt || event.submittedAt || ''}</span>
              {event.note && <p>{event.note}</p>}
            </li>
          ))}
        </ol>
      </section>
    </div>
  </section>
</Layout>
