---
import Layout from '../../layouts/AdminLayout.astro';
import fs from 'fs';
import path from 'path';
import { deriveLocale, nowInLocale } from '../../../core/leads/locale.js';
import { readDetailedAudit } from '../../../core/funnel/lead-thread-helpers.js';

const uiVersion = 'local-style-2026-05-08';

const entitiesDir = path.join(process.cwd(), 'data', 'leads', 'entities');
const entities = fs.existsSync(entitiesDir)
  ? fs.readdirSync(entitiesDir).filter((f) => f.endsWith('.json')).map((f) => JSON.parse(fs.readFileSync(path.join(entitiesDir, f), 'utf8')))
  : [];
const graded = entities.filter((e) => e.grade?.investment_level);

function fmtDaysAgo(iso) {
  if (!iso) return null;
  const ms = Date.now() - new Date(iso).getTime();
  if (!Number.isFinite(ms) || ms < 0) return null;
  const d = Math.floor(ms / 86400000);
  return d < 1 ? 'today' : `${d}d`;
}
function discordUrl(threadId) { return threadId ? `https://discord.com/channels/@me/${threadId}` : ''; }

function row(e) {
  const audit = readDetailedAudit(e.entityKey)?.detailed_audit;
  const locale = deriveLocale(e);
  const s = e.signals || {};
  return {
    entityKey: e.entityKey,
    name: e.latest?.name || '—',
    niche: e.latest?.niche || null,
    city: e.latest?.city || null,
    grade: e.grade?.investment_level,
    tier: e.grade?.product_tier,
    phase: e.phase || null,
    sub_status: e.sub_status,
    audit_score: audit?.audit_score ?? null,
    audit_decision: audit?.decision ?? null,
    rating: e.latest?.rating,
    reviews: e.latest?.review_count,
    last_contact_at: e.last_contact_at,
    last_reply_class: e.last_reply_class,
    signals: { sent: s.sent ?? 0, opened: s.opened ?? 0, clicked: s.clicked ?? 0, replied: s.replied ?? 0 },
    locale_now: nowInLocale(locale),
    discord_thread_id: e.discord_thread_id,
  };
}

// Action-first grouping: things that need Matthew's attention come first.
const allRows = graded.map(row);
const groups = [
  {
    key: 'needs_human',
    label: '需要你介入',
    tone: 'urgent',
    rationale: '回复不明确或 AI 拿不准 — 优先处理',
    rows: allRows.filter((r) => r.phase === 'needs-human'),
  },
  {
    key: 'replied',
    label: '客户已回',
    tone: 'replied',
    rationale: '已分类，Discord thread 有 draft 等 ✅',
    rows: allRows.filter((r) => r.phase === 'replied' || r.phase === 'proposal-sent'),
  },
  {
    key: 'outreach_active',
    label: '外发中',
    tone: 'active',
    rationale: '已发，等回信 (≤ 21 天)',
    rows: allRows.filter((r) => r.phase === 'outreach-active'),
  },
  {
    key: 'awaiting',
    label: '就绪 — 等首封',
    tone: 'awaiting',
    rationale: 'AI 已起草 / 准备好，等你 ✅ 发出',
    rows: allRows.filter((r) => r.phase === 'awaiting' || (!r.phase && (r.grade === 'A' || r.grade === 'B'))),
  },
  {
    key: 'batch_c',
    label: 'C 批量池',
    tone: 'batch',
    rationale: '模板邮件批发，不开 Discord thread',
    rows: allRows.filter((r) => r.grade === 'C' && r.phase !== 'archived'),
  },
  {
    key: 'archived',
    label: '归档',
    tone: 'archived',
    rationale: 'D 自动 / 拒绝 / 长期沉默',
    rows: allRows.filter((r) => r.phase === 'archived' || r.grade === 'D'),
    collapsed: true,
  },
];

const counts = {
  total: graded.length,
  needs: groups.find((g) => g.key === 'needs_human').rows.length,
  replied: groups.find((g) => g.key === 'replied').rows.length,
  active: groups.find((g) => g.key === 'outreach_active').rows.length,
  awaiting: groups.find((g) => g.key === 'awaiting').rows.length,
};

const lastRefreshed = new Date().toISOString();
---
<Layout title="V2 Leads — Discord-driven" active="leads">
  <section class="poster-section admin-section" data-ui-version={uiVersion}>
    <div class="admin-shell">
      <div class="admin-header">
        <div>
          <p class="eyebrow">V2 Leads · Discord-driven</p>
          <h1>Lead 看板</h1>
          <p class="lede">日常推进在 Discord 完成。这里只用来扫一眼"现在该处理谁"——按紧急度排序，最需要你介入的在最上。</p>
        </div>
        <div class="admin-count">
          <strong>{counts.total}</strong>
          <span>Graded leads</span>
        </div>
      </div>

      <div class="v2-attention-strip">
        <a class={`v2-attention-cell ${counts.needs > 0 ? 'v2-attention-hot' : ''}`} href="#needs_human">
          <span class="v2-attention-num">{counts.needs}</span>
          <span class="v2-attention-label">需介入</span>
        </a>
        <a class={`v2-attention-cell ${counts.replied > 0 ? 'v2-attention-warm' : ''}`} href="#replied">
          <span class="v2-attention-num">{counts.replied}</span>
          <span class="v2-attention-label">已回信</span>
        </a>
        <a class="v2-attention-cell" href="#outreach_active">
          <span class="v2-attention-num">{counts.active}</span>
          <span class="v2-attention-label">外发中</span>
        </a>
        <a class="v2-attention-cell" href="#awaiting">
          <span class="v2-attention-num">{counts.awaiting}</span>
          <span class="v2-attention-label">就绪</span>
        </a>
      </div>

      {groups.map((group) => (
        <section class={`v2-group v2-group-${group.tone}`} id={group.key}>
          <header class="v2-group-head">
            <div class="v2-group-head-left">
              <h2 class="v2-group-title">{group.label}</h2>
              <span class="v2-group-count">{group.rows.length}</span>
            </div>
            <p class="v2-group-rationale">{group.rationale}</p>
          </header>
          {group.rows.length === 0 ? (
            <p class="v2-group-empty">— 此分组当前为空 —</p>
          ) : (
            <div class="v2-row-list">
              {group.rows.map((r) => (
                <div class="v2-row">
                  <div class="v2-row-main">
                    <a class="v2-row-name-link" href={`/admin/v2-leads/${r.entityKey}/`}>
                      <h3 class="v2-row-name">{r.name}</h3>
                    </a>
                    <div class="v2-row-meta">
                      <span class={`v2-grade-chip v2-grade-chip-${r.grade?.toLowerCase()}`}>{r.grade}{r.tier ? `/${r.tier}` : ''}</span>
                      {r.phase && <span class={`v2-phase-chip v2-phase-chip-${r.phase}`}>{r.phase}</span>}
                      {r.last_reply_class && <span class="v2-reply-tag">[{r.last_reply_class}]</span>}
                      {r.niche && <span class="v2-row-niche">{r.niche}</span>}
                      {r.city && <span class="v2-row-city">{r.city}</span>}
                    </div>
                  </div>
                  <div class="v2-row-stats">
                    {r.audit_score != null && (
                      <div class="v2-row-stat" title={r.audit_decision || ''}>
                        <span class="v2-row-stat-num">{r.audit_score}</span>
                        <span class="v2-row-stat-label">audit</span>
                      </div>
                    )}
                    {r.rating != null && (
                      <div class="v2-row-stat">
                        <span class="v2-row-stat-num">{r.rating}★</span>
                        <span class="v2-row-stat-label">{r.reviews ?? 0} reviews</span>
                      </div>
                    )}
                    {(r.signals.sent > 0 || r.signals.replied > 0) && (
                      <div class="v2-row-stat">
                        <span class="v2-row-stat-num v2-signals-row">
                          <span title="sent">📤{r.signals.sent}</span>
                          {r.signals.replied > 0 && <span title="replied">💬{r.signals.replied}</span>}
                        </span>
                        <span class="v2-row-stat-label">signals</span>
                      </div>
                    )}
                    {r.last_contact_at && (
                      <div class="v2-row-stat">
                        <span class="v2-row-stat-num">{fmtDaysAgo(r.last_contact_at)}</span>
                        <span class="v2-row-stat-label">since last</span>
                      </div>
                    )}
                  </div>
                  <div class="v2-row-aside">
                    {r.locale_now && <div class="v2-row-locale">{r.locale_now}</div>}
                    {r.discord_thread_id && (
                      <a class="v2-row-discord" href={discordUrl(r.discord_thread_id)} target="_blank" rel="noopener">→ Discord ↗</a>
                    )}
                  </div>
                </div>
              ))}
            </div>
          )}
        </section>
      ))}

      <footer class="admin-block-foot">
        <p>
          <span class="eyebrow-inline">Last refreshed</span>
          <code>{lastRefreshed}</code>
          ·
          <span class="eyebrow-inline">KPI</span>
          <a href="/admin/v2/">V2 Overview</a>
          ·
          <span class="eyebrow-inline">老 admin</span>
          <a href="/admin/queue">/admin/queue</a> ·
          <a href="/admin/leads">/admin/leads</a>
        </p>
      </footer>
    </div>
  </section>
</Layout>

<style is:global>
  /* === V2 Leads — action-first === */
  .eyebrow-inline {
    font-size: 10px; font-weight: 950; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--pl-muted);
  }
  .admin-block-foot {
    padding: 18px 24px;
    border-top: 2px solid var(--pl-line);
    background: color-mix(in srgb, white 50%, var(--pl-cream));
    font-size: 13px;
  }
  .admin-block-foot a { color: var(--pl-blue); text-decoration: none; border-bottom: 1px solid var(--pl-line); }
  .admin-block-foot a:hover { background: var(--pl-citrus); }
  .admin-block-foot code {
    font-family: ui-monospace, monospace; font-size: 12px;
    background: var(--pl-paper); border: 1px solid var(--pl-line); padding: 1px 6px;
  }

  /* Attention bar — clickable jump cells */
  .v2-attention-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 2px solid var(--pl-line);
    border-bottom: 2px solid var(--pl-line);
  }
  .v2-attention-cell {
    padding: 18px 24px;
    display: flex;
    align-items: baseline;
    gap: 16px;
    border-right: 2px solid var(--pl-line);
    background: var(--pl-paper);
    color: var(--pl-ink);
    text-decoration: none;
    transition: background 80ms;
  }
  .v2-attention-cell:last-child { border-right: 0; }
  .v2-attention-cell:hover { background: var(--pl-citrus); }
  .v2-attention-hot { background: color-mix(in srgb, var(--pl-coral) 16%, var(--pl-paper)); }
  .v2-attention-hot:hover { background: var(--pl-coral); color: white; }
  .v2-attention-warm { background: color-mix(in srgb, var(--pl-citrus) 32%, var(--pl-paper)); }
  .v2-attention-num {
    font-family: var(--pl-display);
    font-size: 42px;
    font-weight: 700;
    line-height: 1;
  }
  .v2-attention-label {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  /* Group sections */
  .v2-group {
    border-bottom: 2px solid var(--pl-line);
  }
  .v2-group:last-of-type { border-bottom: 0; }
  .v2-group-head {
    padding: 16px 24px 12px;
    display: grid;
    grid-template-columns: minmax(0, auto) 1fr;
    gap: 18px;
    align-items: baseline;
    border-bottom: 1px solid color-mix(in srgb, var(--pl-line) 25%, transparent);
  }
  .v2-group-head-left { display: flex; gap: 12px; align-items: baseline; }
  .v2-group-title {
    margin: 0;
    font-family: var(--pl-display);
    font-size: 24px;
    font-weight: 700;
  }
  .v2-group-count {
    font-family: var(--pl-display);
    font-size: 18px;
    color: var(--pl-muted);
  }
  .v2-group-rationale {
    margin: 0;
    text-align: right;
    font-size: 12.5px;
    color: var(--pl-muted);
    line-height: 1.4;
  }
  .v2-group-urgent .v2-group-head {
    background: color-mix(in srgb, var(--pl-coral) 14%, var(--pl-paper));
    border-bottom-color: var(--pl-coral);
  }
  .v2-group-replied .v2-group-head {
    background: color-mix(in srgb, var(--pl-citrus) 24%, var(--pl-paper));
  }
  .v2-group-active .v2-group-head {
    background: color-mix(in srgb, var(--pl-sky) 16%, var(--pl-paper));
  }
  .v2-group-awaiting .v2-group-head {
    background: color-mix(in srgb, var(--pl-mint) 18%, var(--pl-paper));
  }
  .v2-group-archived .v2-group-head {
    background: color-mix(in srgb, var(--pl-muted) 8%, var(--pl-paper));
  }
  .v2-group-empty {
    margin: 0;
    padding: 18px 24px;
    color: var(--pl-muted);
    font-style: italic;
    font-size: 13px;
  }

  /* Row layout — dense + scannable */
  .v2-row-list { background: var(--pl-paper); }
  .v2-row {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 1.4fr) auto;
    gap: 18px;
    padding: 14px 24px;
    border-bottom: 1px solid color-mix(in srgb, var(--pl-line) 12%, transparent);
    color: var(--pl-ink);
    align-items: center;
    transition: background 80ms;
  }
  .v2-row:last-child { border-bottom: 0; }
  .v2-row:hover { background: color-mix(in srgb, var(--pl-citrus) 16%, var(--pl-paper)); }
  .v2-row-name-link {
    text-decoration: none;
    color: inherit;
    display: inline-block;
    border-bottom: 2px solid transparent;
  }
  .v2-row-name-link:hover { border-bottom-color: var(--pl-line); }
  .v2-row-name {
    margin: 0;
    font-family: var(--pl-display);
    font-size: 17px;
    font-weight: 700;
    line-height: 1.2;
  }
  .v2-row-meta {
    margin-top: 6px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
    font-size: 12px;
  }
  .v2-row-niche, .v2-row-city {
    color: var(--pl-muted);
    font-size: 12px;
  }
  .v2-row-niche::before { content: '· '; }
  .v2-row-city::before { content: '· '; }

  /* Chips inline in meta */
  .v2-grade-chip {
    display: inline-block;
    padding: 2px 9px;
    border: 1.5px solid var(--pl-line);
    font-family: var(--pl-display);
    font-size: 12px;
    font-weight: 700;
    background: var(--pl-paper);
    line-height: 1.3;
  }
  .v2-grade-chip-a { background: var(--pl-mint); }
  .v2-grade-chip-b { background: var(--pl-sky); }
  .v2-grade-chip-c { background: var(--pl-peach); }
  .v2-grade-chip-d { background: var(--pl-coral-soft); }
  .v2-phase-chip {
    display: inline-block;
    padding: 2px 8px;
    font-family: ui-monospace, monospace;
    font-size: 10.5px;
    font-weight: 700;
    border: 1px solid var(--pl-line);
    line-height: 1.4;
  }
  .v2-phase-chip-awaiting { background: var(--pl-citrus); }
  .v2-phase-chip-outreach-active { background: var(--pl-sky); }
  .v2-phase-chip-replied { background: var(--pl-lilac); }
  .v2-phase-chip-proposal-sent { background: color-mix(in srgb, var(--pl-lilac) 60%, var(--pl-blue)); color: white; }
  .v2-phase-chip-nurture { background: var(--pl-mint); }
  .v2-phase-chip-paid { background: var(--pl-green); color: white; }
  .v2-phase-chip-archived { background: color-mix(in srgb, var(--pl-muted) 30%, white); }
  .v2-phase-chip-needs-human { background: var(--pl-coral); color: white; }

  .v2-reply-tag {
    padding: 1px 6px;
    font-size: 10px;
    font-weight: 950;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--pl-coral);
    border: 1px solid var(--pl-coral);
  }

  /* Right: numeric stats inline */
  .v2-row-stats {
    display: flex;
    gap: 22px;
    align-items: baseline;
  }
  .v2-row-stat { display: flex; flex-direction: column; align-items: flex-start; gap: 1px; }
  .v2-row-stat-num {
    font-family: var(--pl-display);
    font-size: 18px;
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
  }
  .v2-row-stat-label {
    font-size: 9.5px;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pl-muted);
  }
  .v2-signals-row { display: flex; gap: 6px; font-family: ui-monospace, monospace; font-size: 14px; }

  /* Right-most: locale + Discord */
  .v2-row-aside {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
  }
  .v2-row-locale {
    font-family: ui-monospace, monospace;
    font-size: 11.5px;
    color: var(--pl-muted);
  }
  .v2-row-discord {
    display: inline-block;
    padding: 3px 10px;
    border: 1.5px solid var(--pl-line);
    background: var(--pl-lilac);
    color: var(--pl-ink);
    font-size: 11px;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
  }
  .v2-row-discord:hover { background: var(--pl-blue); color: white; }

  @media (max-width: 960px) {
    .v2-attention-strip { grid-template-columns: repeat(2, 1fr); }
    .v2-attention-cell:nth-child(2n) { border-right: 0; }
    .v2-attention-cell:nth-child(-n+2) { border-bottom: 2px solid var(--pl-line); }
    .v2-row {
      grid-template-columns: 1fr;
      gap: 10px;
    }
    .v2-row-stats { flex-wrap: wrap; gap: 14px; }
    .v2-row-aside { align-items: flex-start; flex-direction: row; gap: 12px; }
    .v2-group-head { grid-template-columns: 1fr; }
    .v2-group-rationale { text-align: left; }
  }
</style>
