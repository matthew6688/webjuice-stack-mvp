---
import Layout from '../../layouts/AdminLayout.astro';
import { siteConfig } from '../../config/site';
import { loadAdminSettingsIndex } from '../../../core/admin/settings-index.js';

const settings = loadAdminSettingsIndex();
---

<Layout title={`系统设置 - ${siteConfig.name}`} description="ProfitsLocal 运行配置与集成状态面板。" active="settings">
  <section class="poster-section admin-section">
    <div class="admin-shell">
      <div class="admin-header">
        <div>
          <p class="eyebrow">内部运营</p>
          <h1>系统设置</h1>
          <p class="lede">这里统一看第三方依赖、回调线路、密钥配置，以及业务运行真正依赖的那些开关。</p>
        </div>
        <div class="admin-count">
          <strong>{settings.counts.configured}</strong>
          <span>已配置项</span>
        </div>
      </div>

      <div class="admin-summary-strip admin-summary-strip-compact">
        <article class="admin-summary-tile admin-summary-primary">
          <span class="admin-summary-label">覆盖情况</span>
          <strong>{settings.counts.configured} / {settings.counts.total}</strong>
          <p>还有 {settings.counts.missing} 个必需配置缺失，{settings.counts.optional} 个可选项尚未设置。</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">必需缺失</span>
          <strong>{settings.counts.missing}</strong>
          <p>这里的缺项会直接影响支付、部署、Discord 路由或客户邮件。</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">部分完成</span>
          <strong>{settings.counts.partial}</strong>
          <p>用来标记只配置了一半、还没有真正闭环的集成。</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">可选项</span>
          <strong>{settings.counts.optional}</strong>
          <p>像备用抓取工具、后续 outreach provider 这种扩展都归在这里。</p>
        </article>
      </div>

      <div class="admin-finance-grid">
        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">阻塞</span>
              <h2>需要优先补配置</h2>
            </div>
          </div>
          <div class="admin-urgent-list">
            {settings.blockers.length ? settings.blockers.map((blocker) => (
              <article class="admin-urgent-card">
                <strong>{blocker.label}</strong>
                <span>{blocker.section}</span>
                <code>{blocker.reason}</code>
              </article>
            )) : <p class="micro">当前没有必需配置缺失。</p>}
          </div>
        </section>

        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">使用规则</span>
              <h2>这个页面负责什么</h2>
            </div>
          </div>
          <ul class="admin-list">
            <li><strong>密钥都做了脱敏</strong><span>这里只展示“有没有、是哪一套”，不会把真正的 secret 明文露出来。</span></li>
            <li><strong>事务邮件 vs 冷启动触达</strong><span>Resend 继续只做事务邮件。cold outreach 当前使用路线还是 Agentic Inbox 的人工/半自动流程。</span></li>
            <li><strong>后续切换路径</strong><span>Instantly 和 Smartlead 继续保持 planned，等 webhook ingest 和 reply-state sync 真正接上再启用。</span></li>
            <li><strong>真相源边界</strong><span>这里负责运行配置，不负责客户内容。项目状态仍然以 cases、forums 和 artifacts 为准。</span></li>
          </ul>
        </section>
      </div>

      <div class="admin-settings-grid">
        {settings.sections.map((section) => (
          <section class="admin-settings-panel">
            <div class="admin-finance-head">
              <div>
                <span class="eyebrow">{section.title}</span>
                <h2>{section.description}</h2>
              </div>
            </div>
            <ul class="admin-list">
              {section.items.map((item) => (
                <li>
                  <div class="admin-settings-line">
                    <strong>{item.label}</strong>
                    <mark class={`status-pill status-${item.status === 'configured' ? 'ready' : item.status === 'optional' ? 'info' : item.status === 'partial' ? 'warn' : 'alert'}`}>{item.statusLabel}</mark>
                  </div>
                  <span class="admin-mono">{item.display}</span>
                  <span>{item.reason}</span>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    </div>
  </section>
</Layout>
