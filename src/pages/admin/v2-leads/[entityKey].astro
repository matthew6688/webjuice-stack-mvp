---
import Layout from '../../../layouts/AdminLayout.astro';
import fs from 'fs';
import path from 'path';
import { deriveLocale, nowInLocale } from '../../../../core/leads/locale.js';
import { renderProfileCard } from '../../../../core/funnel/profile-card.js';
import { readDetailedAudit } from '../../../../core/funnel/lead-thread-helpers.js';
import { readManifest } from '../../../../core/leads/asset-manifest.js';

const uiVersion = 'local-style-2026-05-08';

export async function getStaticPaths() {
  const dir = path.join(process.cwd(), 'data', 'leads', 'entities');
  if (!fs.existsSync(dir)) return [];
  const entities = fs.readdirSync(dir)
    .filter((f) => f.endsWith('.json'))
    .map((f) => { try { return JSON.parse(fs.readFileSync(path.join(dir, f), 'utf8')); } catch { return null; } })
    .filter((e) => e && e.grade?.investment_level);
  return entities.map((entity) => ({ params: { entityKey: entity.entityKey }, props: { entity } }));
}

const { entity } = Astro.props;
const latest = entity.latest || {};
const grade = entity.grade || {};
const audit = readDetailedAudit(entity.entityKey)?.detailed_audit;
const locale = deriveLocale(entity);

function slugify(s) { return String(s || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, ''); }
const clientSlug = entity.promotedClientSlug || slugify(latest.name || '');

let manifest = null;
try { manifest = readManifest(clientSlug); } catch {}

const embedRaw = renderProfileCard(entity, { audit });
// Filter out placeholder fields ("—" / "(none)" / "未知") — they make the card look hollow
function isEmpty(val) {
  const s = String(val || '').trim();
  return s === '—' || s === '(none)' || s === 'NONE' || s === '0' || s === '' || s === '0 reviews';
}
const embed = {
  ...embedRaw,
  fields: embedRaw.fields.filter((f) => !isEmpty(f.value)),
};

const recentHistory = (entity.history || []).slice(-10).reverse();
const discordThreadUrl = entity.discord_thread_id ? `https://discord.com/channels/@me/${entity.discord_thread_id}` : null;
const lastRefreshed = new Date().toISOString();

// Audit / report artifacts deployed under /audit-reports/<entityKey>/
const reportBase = `/audit-reports/${entity.entityKey}`;
const reports = [];
const reportDir = path.join(process.cwd(), 'public', 'audit-reports', entity.entityKey);
if (fs.existsSync(path.join(reportDir, 'internal-audit-report.html'))) {
  reports.push({ id: 'internal', label: 'Internal Audit Report', url: `${reportBase}/internal-audit-report`, type: 'audit' });
}
if (fs.existsSync(path.join(reportDir, 'master.report.html'))) {
  reports.push({ id: 'master', label: 'Master Narrative (master.md HTML)', url: `${reportBase}/master.report.html`, type: 'narrative' });
}
if (fs.existsSync(path.join(reportDir, 'screenshots/desktop.png'))) {
  reports.push({ id: 'desktop', label: 'Desktop screenshot', url: `${reportBase}/screenshots/desktop.png`, type: 'screenshot' });
}
if (fs.existsSync(path.join(reportDir, 'screenshots/mobile.png'))) {
  reports.push({ id: 'mobile', label: 'Mobile screenshot', url: `${reportBase}/screenshots/mobile.png`, type: 'screenshot' });
}
if (fs.existsSync(path.join(reportDir, 'video/mobile-throttled.webm'))) {
  reports.push({ id: 'video', label: 'Mobile 4G walkthrough (webm)', url: `${reportBase}/video/mobile-throttled.webm`, type: 'video' });
}
const evidenceDir = path.join(reportDir, 'evidence');
const evidence = fs.existsSync(evidenceDir)
  ? fs.readdirSync(evidenceDir).filter((f) => f.endsWith('.png')).slice(0, 12).map((f) => ({
      label: f.replace(/^issue-/, '').replace(/\.png$/, '').replace(/-/g, ' '),
      url: `${reportBase}/evidence/${f}`,
    }))
  : [];
const fmtDaysAgo = (iso) => {
  if (!iso) return '—';
  const d = Math.floor((Date.now() - new Date(iso).getTime()) / 86400000);
  return d < 1 ? 'today' : `${d}d`;
};
---
<Layout title={`Lead: ${latest.name || entity.entityKey}`} active="leads">
  <section class="poster-section admin-section" data-ui-version={uiVersion}>
    <div class="admin-shell">
      <div class="admin-header">
        <div>
          <p class="eyebrow"><a href="/admin/v2-leads/" class="eyebrow-link">← V2 Leads</a></p>
          <h1>{latest.name || entity.entityKey}</h1>
          <p class="lede">{latest.address || '— 地址未识别 —'}</p>
        </div>
        <div class="v2-detail-status">
          <span class={`v2-grade-chip v2-grade-chip-${grade.investment_level?.toLowerCase()}`}>{grade.investment_level}{grade.product_tier ? `/${grade.product_tier}` : ''}</span>
          {entity.phase && <span class={`v2-phase-chip v2-phase-chip-${entity.phase}`}>{entity.phase}</span>}
          {entity.last_reply_class && <span class="v2-reply-tag">[{entity.last_reply_class}]</span>}
          {discordThreadUrl && (
            <a class="v2-discord-link" href={discordThreadUrl} target="_blank">→ Discord thread ↗</a>
          )}
          {entity.do_not_contact && <span class="v2-warn-chip">DO NOT CONTACT</span>}
        </div>
      </div>

      {reports.length > 0 && (
        <section class="v2-reports-strip">
          <header class="v2-reports-head">
            <p class="eyebrow">Reports & Evidence</p>
            <span class="v2-reports-count">{reports.length + evidence.length} 个内部资产</span>
          </header>
          <div class="v2-reports-grid">
            {reports.map((r) => (
              <a class={`v2-report-tile v2-report-tile-${r.type}`} href={r.url} target="_blank">
                <span class="v2-report-tile-type">
                  {r.type === 'audit' && '📊'}
                  {r.type === 'narrative' && '📄'}
                  {r.type === 'screenshot' && '🖼️'}
                  {r.type === 'video' && '🎥'}
                </span>
                <span class="v2-report-tile-label">{r.label}</span>
                <span class="v2-report-tile-cta">open ↗</span>
              </a>
            ))}
          </div>
          {evidence.length > 0 && (
            <details class="v2-evidence-fold">
              <summary><span class="eyebrow">Per-issue evidence ({evidence.length})</span></summary>
              <div class="v2-evidence-grid">
                {evidence.map((e) => (
                  <a class="v2-evidence-thumb" href={e.url} target="_blank">
                    <img src={e.url} alt={e.label} loading="lazy" />
                    <span class="v2-evidence-caption">{e.label}</span>
                  </a>
                ))}
              </div>
            </details>
          )}
        </section>
      )}

      <div class="v2-detail-layout">
        <!-- LEFT: Profile card (Discord-parity) -->
        <section class="v2-card-frame">
          <header class="v2-card-frame-head" style={`border-left: 8px solid #${embed.color.toString(16).padStart(6, '0')}`}>
            <p class="eyebrow">Profile card · Discord embed 同源</p>
            <p class="v2-card-frame-desc">14 字段中显示 {embed.fields.length} 个有数据 · {embed.fields.length === 14 ? '完整' : `还有 ${14 - embed.fields.length} 个字段未填`}</p>
          </header>
          <div class="v2-meta-grid">
            {embed.fields.map((f) => (
              <div class={`v2-meta-cell ${f.inline ? '' : 'v2-meta-cell-wide'}`}>
                <dt>{f.name}</dt>
                <dd>{f.value}</dd>
              </div>
            ))}
          </div>
          <footer class="v2-card-frame-foot">
            <code>{embed.footer?.text}</code>
            <span class="v2-card-frame-sep">·</span>
            <code>{embed.timestamp}</code>
          </footer>
        </section>

        <!-- RIGHT: Assets / History / CLI -->
        <aside class="v2-detail-aside">
          <section class="admin-block-mini">
            <header class="admin-block-mini-head">
              <p class="eyebrow">Assets</p>
              <span class="admin-block-mini-count">{manifest?.assets?.length || 0}</span>
            </header>
            {manifest?.assets?.length ? (
              <ul class="v2-asset-list">
                {manifest.assets.map((a) => (
                  <li class="v2-asset-row">
                    <div class="v2-asset-main">
                      <div class="v2-asset-label">{a.label}</div>
                      <div class="v2-asset-meta">
                        <code class="v2-asset-type">{a.type}</code>
                        <code class="v2-asset-path">{a.localPath}</code>
                      </div>
                    </div>
                    {a.cloudinaryUrl && <a class="v2-cdn-link" href={a.cloudinaryUrl} target="_blank">CDN ↗</a>}
                  </li>
                ))}
              </ul>
            ) : (
              <p class="v2-empty-inline">— 未注册 manifest，跑 <code>npm run leads:migrate-existing-assets</code></p>
            )}
          </section>

          <section class="admin-block-mini">
            <header class="admin-block-mini-head">
              <p class="eyebrow">Recent history</p>
              <span class="admin-block-mini-count">{recentHistory.length}</span>
            </header>
            {recentHistory.length ? (
              <ol class="v2-history">
                {recentHistory.map((h) => (
                  <li class="v2-history-row">
                    <time>{h.at?.slice(0, 19)}</time>
                    <div>
                      <strong>{h.event}</strong>
                      {h.from && h.to && <span class="v2-history-arrow"> {h.from} → {h.to}</span>}
                      {h.note && <p class="v2-history-note">{h.note}</p>}
                    </div>
                  </li>
                ))}
              </ol>
            ) : (
              <p class="v2-empty-inline">— 暂无 history —</p>
            )}
          </section>

          <section class="admin-block-mini admin-block-mini-muted">
            <header class="admin-block-mini-head">
              <p class="eyebrow">紧急 CLI</p>
            </header>
            <ul class="v2-cli-mini-list">
              <li><span>显示</span><code>npm run pl:show -- {entity.entityKey}</code></li>
              <li><span>Agent 上下文</span><code>npm run pl:context -- {entity.entityKey}</code></li>
              <li><span>归档</span><code>npm run pl:advance -- {entity.entityKey} --to archived --reason &lt;reason&gt;</code></li>
              <li><span>标记需介入</span><code>npm run pl:advance -- {entity.entityKey} --to needs-human</code></li>
            </ul>
          </section>
        </aside>
      </div>

      <footer class="admin-block-foot">
        <p>
          <span class="eyebrow-inline">Last refreshed</span>
          <code>{lastRefreshed}</code>
          ·
          <span class="eyebrow-inline">EntityKey</span>
          <code>{entity.entityKey}</code>
        </p>
      </footer>
    </div>
  </section>
</Layout>

<style is:global>
  .admin-block-foot {
    padding: 18px 24px;
    border-top: 2px solid var(--pl-line);
    background: color-mix(in srgb, white 50%, var(--pl-cream));
    font-size: 13px;
  }
  .admin-block-foot code {
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 12px;
    background: var(--pl-paper);
    border: 1px solid var(--pl-line);
    padding: 1px 6px;
  }
  .eyebrow-inline {
    font-size: 10px;
    font-weight: 950;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pl-muted);
  }
  .eyebrow-link {
    color: inherit;
    text-decoration: none;
    border-bottom: 2px solid var(--pl-line);
  }
  .eyebrow-link:hover { background: var(--pl-citrus); }

  /* Status pills in header */
  .v2-detail-status {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-self: end;
    justify-self: end;
  }
  .v2-grade-chip {
    display: inline-block;
    padding: 4px 12px;
    border: 2px solid var(--pl-line);
    font-family: var(--pl-display);
    font-size: 14px;
    font-weight: 700;
    background: var(--pl-paper);
  }
  .v2-grade-chip-a { background: var(--pl-mint); }
  .v2-grade-chip-b { background: var(--pl-sky); }
  .v2-grade-chip-c { background: var(--pl-peach); }
  .v2-grade-chip-d { background: var(--pl-coral-soft); }
  .v2-phase-chip {
    display: inline-block;
    padding: 4px 10px;
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 12px;
    font-weight: 700;
    border: 1px solid var(--pl-line);
  }
  .v2-phase-chip-awaiting { background: var(--pl-citrus); }
  .v2-phase-chip-outreach-active { background: var(--pl-sky); }
  .v2-phase-chip-replied { background: var(--pl-lilac); }
  .v2-phase-chip-proposal-sent { background: color-mix(in srgb, var(--pl-lilac) 60%, var(--pl-blue)); color: white; }
  .v2-phase-chip-nurture { background: var(--pl-mint); }
  .v2-phase-chip-paid { background: var(--pl-green); color: white; }
  .v2-phase-chip-archived { background: color-mix(in srgb, var(--pl-muted) 30%, white); }
  .v2-phase-chip-needs-human { background: var(--pl-coral); color: white; }
  .v2-reply-tag {
    padding: 4px 8px;
    font-size: 10px;
    font-weight: 950;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--pl-coral);
    border: 1px solid var(--pl-coral);
  }
  .v2-warn-chip {
    padding: 4px 10px;
    background: var(--pl-coral);
    color: white;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .v2-discord-link {
    display: inline-block;
    padding: 4px 12px;
    border: 2px solid var(--pl-line);
    background: var(--pl-lilac);
    color: var(--pl-ink);
    font-size: 12px;
    font-weight: 700;
    text-decoration: none;
  }
  .v2-discord-link:hover { background: var(--pl-blue); color: white; }

  /* Reports & Evidence strip — top of detail page */
  .v2-reports-strip {
    border-top: 2px solid var(--pl-line);
    border-bottom: 2px solid var(--pl-line);
    background: color-mix(in srgb, var(--pl-citrus) 12%, var(--pl-paper));
  }
  .v2-reports-head {
    padding: 14px 24px 8px;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
  }
  .v2-reports-head .eyebrow { margin: 0; }
  .v2-reports-count {
    font-family: var(--pl-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--pl-muted);
  }
  .v2-reports-grid {
    padding: 0 24px 16px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 12px;
  }
  .v2-report-tile {
    display: grid;
    grid-template-columns: 38px 1fr auto;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    background: white;
    border: 2px solid var(--pl-line);
    color: var(--pl-ink);
    text-decoration: none;
    transition: background 80ms;
  }
  .v2-report-tile:hover { background: var(--pl-citrus); }
  .v2-report-tile-type {
    font-size: 24px;
    line-height: 1;
    text-align: center;
  }
  .v2-report-tile-label {
    font-size: 13px;
    font-weight: 700;
    line-height: 1.3;
  }
  .v2-report-tile-cta {
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 11px;
    font-weight: 700;
    color: var(--pl-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .v2-report-tile-audit { border-color: var(--pl-coral); }
  .v2-report-tile-narrative { border-color: var(--pl-blue); }
  .v2-report-tile-screenshot { border-color: var(--pl-green); }
  .v2-report-tile-video { border-color: var(--pl-blue); border-style: dashed; }

  /* Evidence thumbnail gallery (collapsed) */
  .v2-evidence-fold {
    margin: 0 24px 16px;
    border-top: 1px solid color-mix(in srgb, var(--pl-line) 25%, transparent);
    padding-top: 12px;
  }
  .v2-evidence-fold summary {
    cursor: pointer;
    padding: 6px 0;
    list-style: none;
  }
  .v2-evidence-fold summary::-webkit-details-marker { display: none; }
  .v2-evidence-fold summary::before {
    content: '▸';
    margin-right: 6px;
    display: inline-block;
    transition: transform 120ms;
  }
  .v2-evidence-fold[open] summary::before { transform: rotate(90deg); }
  .v2-evidence-grid {
    margin-top: 12px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 10px;
  }
  .v2-evidence-thumb {
    display: block;
    border: 2px solid var(--pl-line);
    background: var(--pl-paper);
    text-decoration: none;
    color: var(--pl-ink);
  }
  .v2-evidence-thumb img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-bottom: 1px solid color-mix(in srgb, var(--pl-line) 30%, transparent);
  }
  .v2-evidence-thumb:hover { background: var(--pl-citrus); }
  .v2-evidence-caption {
    display: block;
    padding: 6px 8px;
    font-size: 10.5px;
    text-transform: capitalize;
    color: var(--pl-muted);
    line-height: 1.3;
  }

  /* Two-column layout */
  .v2-detail-layout {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
    gap: 0;
    border-top: 2px solid var(--pl-line);
  }

  /* Profile card frame (Discord-parity) */
  .v2-card-frame {
    border-right: 2px solid var(--pl-line);
    background: var(--pl-paper);
  }
  .v2-card-frame-head {
    padding: 22px 24px;
    border-bottom: 2px solid var(--pl-line);
  }
  .v2-card-frame-head .eyebrow { margin: 0 0 8px; }
  .v2-card-frame-head h2 {
    margin: 0;
    font-family: var(--pl-display);
    font-size: 24px;
    font-weight: 700;
    line-height: 1.2;
  }
  .v2-card-frame-desc {
    margin: 8px 0 0;
    font-size: 14px;
    color: var(--pl-muted);
  }
  .v2-meta-grid {
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
  }
  .v2-meta-cell {
    padding: 14px 20px;
    border-right: 1px solid color-mix(in srgb, var(--pl-line) 25%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--pl-line) 25%, transparent);
    min-height: 70px;
  }
  .v2-meta-cell:nth-child(2n) { border-right: 0; }
  .v2-meta-cell-wide {
    grid-column: 1 / -1;
    border-right: 0;
  }
  .v2-meta-cell dt {
    margin: 0;
    font-size: 10px;
    font-weight: 950;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pl-muted);
  }
  .v2-meta-cell dd {
    margin: 6px 0 0;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.4;
    white-space: pre-line;
    word-break: break-word;
  }
  .v2-card-frame-foot {
    padding: 12px 20px;
    background: color-mix(in srgb, white 30%, var(--pl-cream));
    font-size: 11px;
    color: var(--pl-muted);
  }
  .v2-card-frame-foot code {
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 11px;
    background: var(--pl-paper);
    border: 1px solid color-mix(in srgb, var(--pl-line) 25%, transparent);
    padding: 1px 5px;
  }
  .v2-card-frame-sep { margin: 0 6px; }

  /* Aside: assets/history/CLI */
  .v2-detail-aside { background: color-mix(in srgb, white 70%, var(--pl-cream)); }
  .admin-block-mini {
    padding: 16px 20px;
    border-bottom: 2px solid var(--pl-line);
  }
  .admin-block-mini:last-child { border-bottom: 0; }
  .admin-block-mini-muted { background: var(--pl-cream); }
  .admin-block-mini-head {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 10px;
  }
  .admin-block-mini-head .eyebrow { margin: 0; }
  .admin-block-mini-count {
    margin-left: auto;
    font-family: var(--pl-display);
    font-size: 18px;
    font-weight: 700;
  }

  .v2-asset-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid color-mix(in srgb, var(--pl-line) 25%, transparent);
  }
  .v2-asset-row {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 8px 0;
    border-bottom: 1px solid color-mix(in srgb, var(--pl-line) 15%, transparent);
  }
  .v2-asset-row:last-child { border-bottom: 0; }
  .v2-asset-main { flex: 1; min-width: 0; }
  .v2-asset-label { font-size: 13px; font-weight: 700; }
  .v2-asset-meta { display: flex; gap: 6px; margin-top: 3px; align-items: baseline; flex-wrap: wrap; }
  .v2-asset-type {
    font-family: ui-monospace, monospace;
    font-size: 10px;
    background: var(--pl-paper);
    border: 1px solid var(--pl-line);
    padding: 1px 6px;
    text-transform: lowercase;
  }
  .v2-asset-path {
    font-family: ui-monospace, monospace;
    font-size: 10.5px;
    color: var(--pl-muted);
    overflow-wrap: anywhere;
  }
  .v2-cdn-link {
    flex-shrink: 0;
    font-size: 11px;
    font-weight: 700;
    color: var(--pl-blue);
    text-decoration: none;
    border-bottom: 1px solid var(--pl-blue);
  }
  .v2-cdn-link:hover { background: var(--pl-citrus); }

  .v2-history {
    list-style: none;
    counter-reset: hist;
    margin: 0;
    padding: 0;
  }
  .v2-history-row {
    display: grid;
    grid-template-columns: 84px 1fr;
    gap: 10px;
    padding: 8px 0;
    border-bottom: 1px solid color-mix(in srgb, var(--pl-line) 15%, transparent);
    align-items: baseline;
    font-size: 12px;
  }
  .v2-history-row:last-child { border-bottom: 0; }
  .v2-history-row time {
    font-family: ui-monospace, monospace;
    font-size: 10.5px;
    color: var(--pl-muted);
  }
  .v2-history-row strong { font-size: 12.5px; }
  .v2-history-arrow {
    font-family: ui-monospace, monospace;
    color: var(--pl-blue);
  }
  .v2-history-note {
    margin: 4px 0 0;
    font-size: 11px;
    color: var(--pl-muted);
