---
import Layout from '../../layouts/AdminLayout.astro';
import { siteConfig } from '../../config/site';
import { LEAD_ADMIN_VIEWS, loadLeadOutreachIndex } from '../../../core/funnel/lead-outreach-index.js';
import { criteriaForLeadStage } from '../../../core/funnel/stage-config.js';
import { loadDiscoveryIndex } from '../../../core/leads/discovery-store.js';
import { loadEnrichmentGates, enrichmentGateLabel } from '../../../core/leads/enrichment-gate.js';
import { cheapAuditV2 } from '../../../core/scoring/cheap-audit-v2.js';

const index = loadLeadOutreachIndex();
const discoveryIndex = loadDiscoveryIndex();
const enrichmentGates = loadEnrichmentGates();
const discoveryPreview = (discoveryIndex.entities || []).slice(0, 12);

// V2 cheap-audit: score every discovery entity (Stage 1 only — no network),
// then sort to surface the strongest V2 candidates at the top of the page.
const v2Audited = (discoveryIndex.entities || []).map((entity) => {
  try {
    const audit = cheapAuditV2({ entity, sourceQuery: entity.latest?.sourceQuery });
    return { entity, audit };
  } catch {
    return { entity, audit: null };
  }
});
function v2ChipClass(action) {
  const a = String(action || '');
  if (a === 'audit_candidate') return 'chip-mint';
  if (a === 'starter_candidate') return 'chip-citrus';
  if (a === 'manual_review') return 'chip-sky';
  if (a === 'queued_for_enrichment') return 'chip-lilac';
  if (a === 'skip') return 'chip-coral';
  return '';
}
const v2TopCandidates = v2Audited
  .filter((row) => row.audit && ['audit_candidate', 'starter_candidate'].includes(row.audit.action))
  .sort((a, b) => (b.audit.final_score || 0) - (a.audit.final_score || 0))
  .slice(0, 20);
const v2Stats = v2Audited.reduce((acc, row) => {
  if (!row.audit) return acc;
  acc[row.audit.action] = (acc[row.audit.action] || 0) + 1;
  return acc;
}, {});
const recordsByStage = Object.fromEntries(index.pipelineStages.map((stage) => [
  stage.key,
  index.records.filter((record) => record.pipelineStage === stage.key),
]));
const priorityStages = ['needs_human', 'ready_for_mockup', 'researching', 'follow_up_due', 'replied', 'mockup_ready', 'draft_ready', 'new_lead'];
const activeStageKey = priorityStages.find((key) => recordsByStage[key]?.length) || index.pipelineStages.find((stage) => recordsByStage[stage.key]?.length)?.key || 'new_lead';
const savedViews = [
  ['all', LEAD_ADMIN_VIEWS.all.label],
  ['researching', LEAD_ADMIN_VIEWS.researching.label],
  ['needs_human', LEAD_ADMIN_VIEWS.needs_human.label],
  ['ready_for_mockup', LEAD_ADMIN_VIEWS.ready_for_mockup.label],
  ['mockup_ready', LEAD_ADMIN_VIEWS.mockup_ready.label],
  ['draft_ready', LEAD_ADMIN_VIEWS.draft_ready.label],
  ['follow_up_due', LEAD_ADMIN_VIEWS.follow_up_due.label],
  ['replied', LEAD_ADMIN_VIEWS.replied.label],
  ['skipped', LEAD_ADMIN_VIEWS.skipped.label],
];
const criteriaForStage = (stage) => criteriaForLeadStage(stage);
const criteriaSummary = (stage) => criteriaForStage(stage).join(' ');

const contactEmail = (record) => record.email || record.customerEmail || record.leadRecipientEmail || '';
const contactLine = (record) => [record.niche || record.leadFamilyId || '行业待补', record.city || record.address || record.domain || '地区待补'].filter(Boolean).join(' / ');
const locationLine = (record) => record.address || record.city || record.domain || '地区待补';
const servicesLine = (record) => Array.isArray(record.leadCoreServices) && record.leadCoreServices.length
  ? record.leadCoreServices.slice(0, 5).join('、')
  : record.niche || record.leadFamilyId || '服务待补';
const socialLine = (record) => Array.isArray(record.socialAccounts) && record.socialAccounts.length
  ? record.socialAccounts.map((account) => account.label || account.url).join('、')
  : '待补';
const contactChips = (record) => [
  contactEmail(record) ? { label: '邮箱', value: contactEmail(record), href: `mailto:${contactEmail(record)}` } : { label: '邮箱', value: '待补' },
  record.phone ? { label: '电话', value: record.phone, href: `tel:${record.phone.replace(/[^+\d]/g, '')}` } : { label: '电话', value: '待补' },
  (record.officialWebsiteUrl || record.websiteUrl) ? { label: '官网', value: '打开', href: record.officialWebsiteUrl || record.websiteUrl } : { label: '官网', value: '待补' },
  record.contactPageUrl ? { label: '联系页', value: '打开', href: record.contactPageUrl } : { label: '联系页', value: '待补' },
];
const publicOrPath = (publicUrl, localPath) => publicUrl || localPath || '';
const conceptAssetLinks = (record) => [
  record.conceptPublicPreviewUrl ? ['打开样稿', record.conceptPublicPreviewUrl] : null,
  record.conceptPublicAuditUrl ? ['质量审计', record.conceptPublicAuditUrl] : null,
  record.conceptPublicRunStateUrl ? ['运行状态', record.conceptPublicRunStateUrl] : null,
  record.openDesignRunRequestPath ? ['运行请求', record.openDesignRunRequestPath] : null,
  record.conceptManifestPath ? ['Manifest', record.conceptManifestPath] : null,
].filter(Boolean);
const decisionLabel = (value) => ({
  build_mockup: '可做 Mockup',
  human_review: '需人工判断',
  skip_or_monitor: '建议跳过/观察',
}[value] || '未判断');
const verdictLabel = (value) => ({
  clear_redesign_opportunity: '明确改版机会',
  moderate_redesign_opportunity: '可能有改版机会',
  weak_redesign_opportunity: '改版机会较弱',
}[value] || value || '已生成审计');
const auditSummaryLine = (record) => {
  if (record.currentSiteSalesDecision === 'skip_or_monitor') {
    return '当前官网基础较完整，只发现低影响问题。不要自动做 mockup；除非人工发现新的突破口，否则建议跳过或观察。';
  }
  return record.currentSiteAuditSummary || '';
};
const outreachHookLine = (record) => {
  if (record.currentSiteSalesDecision === 'skip_or_monitor') {
    return '没有足够强的触达切入点。不要用隐私链接或 OG 图片这类小问题当销售理由。';
  }
  return record.currentSiteOutreachHook || '';
};
const openDesignDirectionLine = (record) => {
  if (record.currentSiteSalesDecision === 'skip_or_monitor') {
    return '不要仅凭本次审计创建 redesign mockup。如人工批准，重点是保留现站优势，只做轻量信任与 SEO 卫生优化。';
  }
  return record.currentSiteOpenDesignDirection || '';
};
const impactFindings = (record) => Array.isArray(record.currentSiteAuditFindings)
  ? record.currentSiteAuditFindings.filter((finding) => finding.severity !== 'low')
  : [];
const auditIssueLines = (record) => {
  const findings = impactFindings(record);
  if (findings.length) {
    return findings.slice(0, 3).map((finding) => `${finding.title}: ${finding.evidence}`);
  }
  if (auditSummaryLine(record)) return [auditSummaryLine(record)];
  return (record.currentSiteAuditIssues || []).slice(0, 3);
};
const improvementLine = (record) => {
  if (record.currentSiteSalesDecision === 'skip_or_monitor') {
    return '没有值得拿来做销售切入点的中高影响问题；只适合补隐私链接、社交预览图这类低优先级卫生项。';
  }
  if (record.currentSitePriorityActions?.length) {
    return record.currentSitePriorityActions.slice(0, 3).map((action) => action.fix).join('；');
  }
  if (record.currentSiteImprovements?.length) return record.currentSiteImprovements.slice(0, 3).join('；');
  return '需要先完成 current-site audit。';
};
const openDesignInputLines = (record) => {
  const brief = record.openDesignBrief || {};
  return [
    ['业务', brief.business],
    ['行业/地区', [brief.industry, brief.location].filter(Boolean).join(' · ')],
    ['官网', brief.currentWebsite || record.officialWebsiteUrl || record.websiteUrl],
    ['联系页', brief.contactPage || record.contactPageUrl],
    ['社媒', brief.contactProfile?.socialAccounts?.length ? brief.contactProfile.socialAccounts.map((account) => `${account.label}: ${account.url}`).join('；') : '待补'],
    ['服务', Array.isArray(brief.services) && brief.services.length ? brief.services.join('、') : servicesLine(record)],
    ['Hero 角度', brief.heroAngle || record.outreachPrimaryProofPoint],
    ['Audit 重点', Array.isArray(brief.auditFocus) && brief.auditFocus.length ? brief.auditFocus.join('；') : '暂无'],
    ['Audit 结论', brief.salesDecision ? decisionLabel(brief.salesDecision) : record.currentSiteSalesDecision ? decisionLabel(record.currentSiteSalesDecision) : '暂无'],
    ['触达观察', brief.outreachHook || outreachHookLine(record) || '暂无'],
    ['Open Design 方向', brief.openDesignDirection || openDesignDirectionLine(record) || '暂无'],
    ['改进方向', Array.isArray(brief.improvements) && brief.improvements.length ? brief.improvements.join('；') : '暂无'],
    ['CTA', brief.primaryCta || record.leadPrimaryCta],
  ].filter(([, value]) => Boolean(value));
};
const channelLabel = (value) => ({
  sms_or_call: '短信/电话',
  email: '邮件',
  instagram_dm: 'Instagram DM',
  linkedin: 'LinkedIn',
  phone: '电话',
}[value] || value || '渠道待补');
const recordSearch = (record) => [
  record.clientSlug,
  record.company,
  record.niche,
  record.leadFamilyId,
  contactEmail(record),
  record.phone,
  record.websiteUrl,
  record.officialWebsiteUrl,
  record.pipelineLabel,
  record.nextAction?.label,
].filter(Boolean).join(' ').toLowerCase();
const artifactLabels = [
  ['profile', '档案'],
  ['research', '研究'],
  ['evidence', '证据'],
  ['currentSiteAudit', '现站审计'],
  ['templateMatch', '模板匹配'],
  ['copyBrief', '文案 Brief'],
  ['openDesignHandoff', '设计交接'],
  ['openDesignRun', '设计运行'],
  ['openDesignNativeFinish', 'Native 结束'],
  ['conceptQualityAudit', '质量审计'],
  ['mockup', 'Mockup'],
  ['proof', '素材'],
  ['draft', '草稿'],
  ['sent', '已发'],
  ['reply', '回复'],
  ['discord', 'Discord'],
];
const discoveryByKey = new Map((discoveryIndex.entities || []).map((entity) => [entity.entityKey, entity]));
const enrichmentGateFor = (record) => {
  const entityKey = record.discoveryStoreKey || (record.clientSlug || '').replace(/^discovery-/, '');
  return entityKey ? enrichmentGates.gates?.[entityKey] || { status: 'planned' } : null;
};
const crmSnapshot = (record) => {
  const gate = enrichmentGateFor(record);
  return [
    ['阶段', record.pipelineLabel],
    ['下一步', record.nextAction?.label],
    ['负责人动作', record.blockingReason || record.nextAction?.reason || '等待自动推进或人工确认。'],
    ['联系路径', [contactEmail(record) || '无邮箱', record.phone || '无电话', (record.officialWebsiteUrl || record.websiteUrl) ? '有官网' : '无官网'].join(' · ')],
    ['来源', record.discoveryStoreKey ? `Maps scraper · ${record.discoveryStoreKey}` : record.leadSourceType || record.source || '手动/客户侧'],
    ['成本关口', gate ? enrichmentGateLabel(gate.status || 'planned') : '不适用'],
    ['证明资产', record.assetsReady ? '样稿素材齐' : '素材未齐'],
    ['触达草稿', record.emailDraftReady ? '已生成' : '未生成'],
  ].filter(([, value]) => Boolean(value));
};
const discoveryCommandFor = (entity, action) => {
  if (!entity) return '';
  if (action === 'cheap_audit') return `npm run leads:audit-discovery-sites -- --entity-key ${entity.entityKey} --limit 1`;
  if (action === 'promote') return `npm run leads:promote-discovery-store -- --entity-key ${entity.entityKey} --limit 1`;
  if (action === 'manual_triage') return 'npm run leads:triage-discovery-manual -- --limit 8';
  if (action === 'outreach_brief') return 'npm run leads:build-discovery-outreach-briefs -- --limit 5';
  return '';
};
const discoveryActionsFor = (record) => {
  const entityKey = record.discoveryStoreKey || (record.clientSlug || '').replace(/^discovery-/, '');
  const entity = entityKey ? discoveryByKey.get(entityKey) : null;
  const isRawDiscoveryLead = Boolean(entity && (record.clientSlug || '').startsWith('discovery-'));
  if (!isRawDiscoveryLead) return [];
  if (entity.status === 'queued_for_audit') {
    return [{
      label: '建议命令：cheap audit',
      submitLabel: '记录决定：跑 audit',
      action: 'run_cheap_audit',
      command: discoveryCommandFor(entity, 'cheap_audit'),
      note: 'Discovery action: run cheap site audit before promote/skip decision.',
      tone: 'primary',
    }, {
      label: '跳过',
      submitLabel: '记录跳过',
      action: 'skip_lead',
      command: '',
      note: 'Discovery action: skipped before cheap audit.',
      tone: 'secondary',
    }];
  }
  if (entity.status === 'ready_for_outreach_brief') {
    return [{
      label: '建议命令：promote',
      submitLabel: '记录决定：promote',
      action: 'promote_discovery',
      command: discoveryCommandFor(entity, 'promote'),
      note: 'Discovery action: promote into lead pipeline.',
      tone: 'primary',
    }, {
      label: '重新检查',
      submitLabel: '记录重新检查',
      action: 'research_more',
      command: discoveryCommandFor(entity, 'outreach_brief'),
      note: 'Discovery action: rebuild/verify outreach brief before promote.',
      tone: 'secondary',
    }];
  }
  if (entity.status === 'manual_review') {
    return [{
      label: '保留人工判断',
      submitLabel: '保留人工判断',
      action: 'keep_manual_review',
      command: discoveryCommandFor(entity, 'manual_triage'),
      note: 'Discovery action: keep in manual review queue.',
      tone: 'secondary',
    }, {
      label: '建议命令：promote',
      submitLabel: '记录决定：promote',
      action: 'promote_discovery',
      command: discoveryCommandFor(entity, 'promote'),
      note: 'Discovery action: manually approved for promotion.',
      tone: 'primary',
    }, {
      label: '跳过',
      submitLabel: '记录跳过',
      action: 'skip_lead',
      command: '',
      note: 'Discovery action: manually skipped after review.',
      tone: 'secondary',
    }];
  }
  if (entity.status === 'queued_for_enrichment') {
    return [{
      label: '建议命令：生成 outreach brief',
      submitLabel: '记录决定：补 brief',
      action: 'build_outreach_brief',
      command: discoveryCommandFor(entity, 'outreach_brief'),
      note: 'Discovery action: build outreach brief for scraped lead.',
      tone: 'primary',
    }];
  }
  return [];
};
const leadPipelineUiVersion = 'local-style-2026-05-08';
---

<Layout title={`线索触达 - ${siteConfig.name}`} description="Cold outreach lead pipeline." active="leads">
  <section class="poster-section admin-section" data-ui-version={leadPipelineUiVersion}>
    <div class="admin-shell lead-admin-shell">
      <div class="admin-header">
        <div>
          <p class="eyebrow">线索触达</p>
          <h1>线索触达 Pipeline</h1>
          <p class="lede">新线索进来后自动研究。AI 有把握时只给两个结果：跳过，或可做 Mockup；不确定才进入需人工。每个判断都显示证据、工具轨迹和工作日志。</p>
        </div>
        <div class="admin-count">
          <strong>{index.counts.total}</strong>
          <span>线索</span>
        </div>
      </div>

      <div class="admin-summary-strip admin-summary-strip-compact">
        <article class="admin-summary-tile">
          <span class="admin-summary-label">Scraped 库</span>
          <strong>{discoveryIndex.totals?.entities || 0}</strong>
          <p>{discoveryIndex.totals?.needsAudit || 0} 个待 cheap audit，{discoveryIndex.totals?.promoted || 0} 个已 promote。</p>
        </article>
        <article class="admin-summary-tile admin-summary-primary">
          <span class="admin-summary-label">研究中</span>
          <strong>{index.counts.researching || 0}</strong>
          <p>新线索已入库，等待自动搜索、官网、地图、截图或 OCR。</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">需人工</span>
          <strong>{index.counts.needsHuman || 0}</strong>
          <p>AI 不确定，operator 看证据后记录批准、继续研究或跳过。</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">可做 Mockup</span>
          <strong>{index.counts.ready_for_mockup || 0}</strong>
          <p>已有联系方式和基本证据，等待人工批准进入 Mockup 队列。</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">Mockup 就绪</span>
          <strong>{index.counts.mockup_ready || 0}</strong>
          <p>预览和证明素材已具备，下一步生成或确认触达草稿。</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">待跟进</span>
          <strong>{index.counts.followUpDue || 0}</strong>
          <p>已发送且到了 follow-up 时间，优先处理。</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">已回复</span>
          <strong>{index.counts.replied || 0}</strong>
          <p>需要人工判断是否进入成交交接。</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">已跳过</span>
          <strong>{index.counts.skipped || 0}</strong>
          <p>没有明确突破口或不可触达的线索，保留原因和工作记录。</p>
        </article>
      </div>

      <section class="v2-sort-section">
        <div class="v2-sort-head">
          <div>
            <p class="eyebrow">V2 排序 · cheap-audit-v2</p>
            <h2>新算法 high-priority candidates</h2>
            <p class="v2-sort-meta">
              <span><strong class="num-mint">{v2Stats.audit_candidate || 0}</strong> audit_candidate</span>
              <span class="dot">·</span>
              <span><strong class="num-citrus">{v2Stats.starter_candidate || 0}</strong> starter</span>
              <span class="dot">·</span>
              <span><strong class="num-sky">{v2Stats.manual_review || 0}</strong> manual_review</span>
              <span class="dot">·</span>
              <span><strong class="num-coral">{v2Stats.skip || 0}</strong> skip</span>
              <span class="dot">·</span>
              <span class="muted">完整算法在 <a href="/admin/scoring" class="inline-link">/admin/scoring</a></span>
            </p>
          </div>
          <div class="v2-sort-count">Top {v2TopCandidates.length} / {v2Audited.length}</div>
        </div>
        <div class="admin-table-wrap">
          <table class="admin-table v2-sort-table">
            <thead>
              <tr>
                <th>商家</th>
                <th class="v2-sort-num-col">V2 final</th>
                <th>V2 决策</th>
                <th>V1 决策</th>
                <th>★ / 评论</th>
                <th>网站</th>
                <th>触发器</th>
              </tr>
            </thead>
            <tbody>
              {v2TopCandidates.map((row) => (
                <tr class="v2-sort-row">
                  <td>
                    <a href={`/admin/leads/${row.entity.entityKey}`} class="v2-lead-link">
                      <strong>{row.entity.latest?.name || row.entity.entityKey}</strong>
                      <span class="v2-lead-loc">{row.entity.latest?.city || row.entity.latest?.address?.split(',').pop()?.trim() || '—'}</span>
                    </a>
                  </td>
                  <td class="v2-sort-num">{row.audit.final_score}</td>
                  <td><span class={`chip ${v2ChipClass(row.audit.action)}`}>{row.audit.action.replace(/_/g, ' ')}</span></td>
                  <td><span class="v1-action">{row.entity.latest?.recommendedAction || '—'}</span></td>
                  <td class="v2-rating">★{row.entity.latest?.rating || '-'} <span class="muted">({row.entity.latest?.review_count || 0})</span></td>
                  <td><code class="v2-status">{row.entity.latest?.websiteStatus || 'unknown'}</code></td>
                  <td>{row.audit.fired_triggers.length > 0 ? <code class="v2-trig">{row.audit.fired_triggers[0]}</code> : <span class="muted">—</span>}</td>
                </tr>
              ))}
              {v2TopCandidates.length === 0 && (
                <tr><td colspan="7" class="v2-empty">暂无 V2 candidate 级别 lead。新 lead 进来或重跑 rescore 后会出现在这里。</td></tr>
              )}
            </tbody>
          </table>
        </div>
      </section>

      <div class="admin-toolbar" data-admin-toolbar>
        <div class="admin-toolbar-group">
          <span class="admin-toolbar-label">视图</span>
          <div class="admin-view-pills">
            {savedViews.map(([key, label], idx) => (
              <button type="button" class={`admin-view-pill ${idx === 0 ? 'is-active' : ''}`} data-admin-view={key}>{label}</button>
            ))}
          </div>
        </div>
        <div class="admin-toolbar-group admin-toolbar-right">
          <label class="admin-search">
            <span class="admin-toolbar-label">搜索</span>
            <input type="search" placeholder="客户、邮箱、行业、网站" data-admin-search />
          </label>
          <p class="micro" data-admin-visible-count>{index.records.length} 条可见</p>
        </div>
      </div>

      <div class="lead-pipeline" data-lead-pipeline>
        {index.pipelineStages.map((stage) => {
          const records = recordsByStage[stage.key] || [];
          const isActive = stage.key === activeStageKey;
          return (
            <section class={`lead-stage ${isActive ? 'is-active' : ''}`} data-stage-column={stage.key}>
              <button class="lead-stage-rail" type="button" data-stage-toggle={stage.key} aria-expanded={isActive ? 'true' : 'false'} title={`${stage.label}：${criteriaSummary(stage)}`} aria-label={`${stage.label}，进入标准：${criteriaSummary(stage)}`}>
                <span>{records.length}</span>
                <strong>{stage.label}</strong>
              </button>
              <div class="lead-stage-panel">
                <header class="lead-stage-head">
                  <div>
                    <span class="eyebrow">Pipeline</span>
                    <h2>{stage.label}</h2>
                    <details class="stage-criteria">
                      <summary>进入这个阶段的标准</summary>
                      <ul>
                        {criteriaForStage(stage).map((item) => <li>{item}</li>)}
                      </ul>
                    </details>
                  </div>
                  <strong>{records.length}</strong>
                </header>
                <div class="lead-card-list">
                  {records.length ? records.slice(0, 12).map((record, idx) => {
                    const discoveryActions = discoveryActionsFor(record);
                    return (
                    <article
                      class={`lead-card ${isActive && idx === 0 ? 'is-open' : ''}`}
                      data-lead-card
                      data-stage={record.pipelineStage}
                      data-search={recordSearch(record)}
                    >
                      <button class="lead-card-main" type="button" data-card-toggle>
                        <span class={`status-pill status-${record.pipelineTone}`}>{record.pipelineLabel}</span>
                        <strong>{record.company || record.clientSlug}</strong>
                        <span>{contactLine(record)}</span>
                        <span class="lead-card-contact">
                          {contactEmail(record) || '无邮箱'} · {record.phone || '无电话'} · {(record.officialWebsiteUrl || record.websiteUrl) ? '有网站' : '无网站'}
                        </span>
                        <em>{record.nextAction.label}</em>
                      </button>

                      <div class="lead-card-detail">
                        <section class="lead-profile-panel">
                          <div class="lead-contact-strip">
                            {contactChips(record).map((item) => item.href
                              ? <a href={item.href}><span>{item.label}</span><strong>{item.value}</strong></a>
                              : <span><span>{item.label}</span><strong>{item.value}</strong></span>)}
                          </div>
                          <dl class="lead-profile-facts">
                            <div><dt>服务</dt><dd>{servicesLine(record)}</dd></div>
                            <div><dt>社媒</dt><dd>{Array.isArray(record.socialAccounts) && record.socialAccounts.length
                              ? record.socialAccounts.map((account, accountIdx) => (
                                <>{accountIdx ? '、' : ''}<a href={account.url}>{account.label || account.url}</a></>
                              ))
                              : '待补'}</dd></div>
                            <div><dt>观察</dt><dd>{record.leadSpecificObservation || record.outreachPrimaryProofPoint || '还没有具体观察。需要继续研究。'}</dd></div>
                          </dl>
                        </section>

                        <section class="lead-crm-snapshot">
                          <div class="lead-section-head">
                            <h3>CRM 快照</h3>
                            <span>{record.clientSlug}</span>
                          </div>
                          <dl class="lead-crm-grid">
                            {crmSnapshot(record).map(([label, value]) => (
                              <div><dt>{label}</dt><dd>{value}</dd></div>
                            ))}
                          </dl>
                        </section>

                        <section class="lead-site-audit">
                          <div class="lead-section-head">
                            <h3>当前网站证据</h3>
                            {record.currentSiteAuditScore ? <span>{record.currentSiteAuditScore}分</span> : null}
                          </div>
                          {record.currentSiteAuditPath ? (
                            <>
                              <div class="lead-audit-links">
                                {(record.officialWebsiteUrl || record.websiteUrl) ? <a href={record.officialWebsiteUrl || record.websiteUrl}>打开官网</a> : null}
                                {record.contactPageUrl ? <a href={record.contactPageUrl}>联系页</a> : null}
                                {record.currentSitePublicScreenshotUrl ? <a href={record.currentSitePublicScreenshotUrl}>桌面截图</a> : null}
                                {record.currentSitePublicMobileScreenshotUrl ? <a href={record.currentSitePublicMobileScreenshotUrl}>手机截图</a> : null}
                                {record.currentSitePublicAuditUrl ? <a href={record.currentSitePublicAuditUrl}>审计报告</a> : null}
                                {record.currentSitePublicTextUrl ? <a href={record.currentSitePublicTextUrl}>网站原文</a> : null}
                                {record.currentSitePublicHtmlUrl ? <a href={record.currentSitePublicHtmlUrl}>HTML 快照</a> : null}
                              </div>
                              {(record.currentSitePublicScreenshotUrl || record.currentSitePublicMobileScreenshotUrl) ? (
                                <div class="lead-audit-shots">
                                  {record.currentSitePublicScreenshotUrl ? (
                                    <a href={record.currentSitePublicScreenshotUrl} aria-label="打开桌面截图">
                                      <img src={record.currentSitePublicScreenshotUrl} alt={`${record.company || record.clientSlug} 当前网站桌面截图`} loading="lazy" />
                                      <span>桌面</span>
                                    </a>
                                  ) : null}
                                  {record.currentSitePublicMobileScreenshotUrl ? (
                                    <a href={record.currentSitePublicMobileScreenshotUrl} aria-label="打开手机截图">
                                      <img src={record.currentSitePublicMobileScreenshotUrl} alt={`${record.company || record.clientSlug} 当前网站手机截图`} loading="lazy" />
                                      <span>手机</span>
                                    </a>
                                  ) : null}
                                </div>
                              ) : null}
                              <p><strong>{decisionLabel(record.currentSiteSalesDecision)} · {verdictLabel(record.currentSiteAuditVerdict)}</strong></p>
                              {auditSummaryLine(record) ? <p>{auditSummaryLine(record)}</p> : null}
                              <ul class="lead-compact-list">
                                {auditIssueLines(record).map((issue) => <li>{issue}</li>)}
                              </ul>
                              {outreachHookLine(record) ? (
                                <p class="micro"><strong>触达观察：</strong>{outreachHookLine(record)}</p>
                              ) : null}
                              <p class="micro">
                                报告：{publicOrPath(record.currentSitePublicAuditUrl, record.currentSiteAuditMdPath) ? <a href={publicOrPath(record.currentSitePublicAuditUrl, record.currentSiteAuditMdPath)}>{publicOrPath(record.currentSitePublicAuditUrl, record.currentSiteAuditMdPath)}</a> : '无'}
                                {' · '}
                                原文：{publicOrPath(record.currentSitePublicTextUrl, record.currentSiteTextPath) ? <a href={publicOrPath(record.currentSitePublicTextUrl, record.currentSiteTextPath)}>{publicOrPath(record.currentSitePublicTextUrl, record.currentSiteTextPath)}</a> : '无'}
                              </p>
                            </>
                          ) : (record.officialWebsiteUrl || record.websiteUrl) ? (
                            <p class="lead-warning">还没有保存当前网站截图、HTML/text 和 audit 报告。这个 lead 的判断需要先补 audit 才更可信。</p>
                          ) : (
                            <p class="lead-warning">没有官网可审计；本次判断主要来自图片/OCR、搜索记录、联系方式和服务清单。后续要把真实官网或联系页补进 profile。</p>
                          )}
                        </section>

                        {conceptAssetLinks(record).length ? (
                        <section class="lead-site-audit">
                          <div class="lead-section-head">
                            <h3>样稿资产</h3>
                            {Number.isFinite(record.conceptQualityAuditScore) ? <span>{record.conceptQualityAuditScore}分</span> : null}
                          </div>
                          <div class="lead-audit-links">
                            {conceptAssetLinks(record).map(([label, href]) => <a href={href}>{label}</a>)}
                          </div>
                          {record.openDesignBrief?.run ? (
                            <p class="micro">
                              Native：{record.openDesignBrief.run.nativeCleanFinish ? '已自然结束' : '待确认'}
                              {' · '}
                              Question form：{record.openDesignBrief.run.questionForms || 0}
                              {' · '}
                              Fallback：{record.openDesignRunRequestAllowFallback ? '允许' : '禁止'}
                            </p>
                          ) : null}
                        </section>
                        ) : null}

                        <section class="lead-handoff-brief">
                          <div class="lead-section-head">
                            <h3>下一步判断</h3>
                            <span>{record.aiAssessment.confidence}</span>
                          </div>
                          <div class="lead-decision-summary">
                            <div>
                              <strong>{record.aiAssessment.label}</strong>
                              <p>{record.customerOpportunitySummary || record.aiAssessment.reason || '还没有足够诊断。'}</p>
                            </div>
                            <div>
                              <strong>Open Design 方向</strong>
                              <p>{openDesignDirectionLine(record) || record.outreachSiteBrief || record.leadHeroAngle || '下一步需要先生成 site brief。'}</p>
                            </div>
                            <div>
                              <strong>可以改进的地方</strong>
                              <p>{improvementLine(record)}</p>
                            </div>
                            <div>
                              <strong>触达方向</strong>
                              <p>{record.leadPrimaryCta || 'CTA 待补'} · {channelLabel(record.outreachChannelRecommendation)} · 草稿需复写</p>
                            </div>
                          </div>
                          <details class="lead-open-design-input">
                            <summary>Open Design payload</summary>
                            <dl>
                              {openDesignInputLines(record).map(([label, value]) => (
                                <div><dt>{label}</dt><dd>{value}</dd></div>
                              ))}
                            </dl>
                          </details>
                        </section>

                        {discoveryActions.length ? (
                          <section class="lead-discovery-actions">
                            <div class="lead-section-head">
                              <h3>Scraped lead 操作</h3>
                              <span>{record.discoveryStoreKey || record.clientSlug}</span>
                            </div>
                            <p class="micro">这些按钮只记录 lead log / decision；命令需要人工或后台任务执行。</p>
                            <div class="lead-command-list">
                              {discoveryActions.map((action) => (
                                <div class="lead-command-card">
                                  <div>
                                    <strong>{action.label}</strong>
                                    {action.command ? <code>{action.command}</code> : <span>{action.note}</span>}
                                  </div>
                                  <form method="post" action="/admin/lead-note">
                                    <input type="hidden" name="client_slug" value={record.clientSlug} />
                                    <input type="hidden" name="order_id" value={record.orderId || ''} />
                                    <input type="hidden" name="company" value={record.company || ''} />
                                    <input type="hidden" name="actor" value="profitslocal-admin" />
                                    <input type="hidden" name="action" value={action.action} />
                                    <input type="hidden" name="note" value={`${action.note}${action.command ? ` Command: ${action.command}` : ''}`} />
                                    <button class={`button ${action.tone === 'primary' ? '' : 'secondary'}`} type="submit">{action.submitLabel || action.label}</button>
                                  </form>
                                </div>
                              ))}
                            </div>
                          </section>
                        ) : null}

                        {record.blockingReason || record.pipelineStage === 'skipped' ? (
                          <section class="lead-inline-warning">
                            {record.pipelineStage === 'skipped'
                              ? `跳过原因：${record.skipReason || record.blockingReason || '未记录原因'}`
                              : record.blockingReason}
                          </section>
                        ) : null}

                        <details class="lead-log-details">
                          <summary>工作日志（{record.actionLog.length} 条）</summary>
                          <ol class="lead-action-log">
                            {record.actionLog.length ? record.actionLog.map((entry) => (
                              <li>
                                <strong>{entry.label}</strong>
                                <span>{entry.detail || '已完成'}</span>
                                {entry.at ? <time>{entry.at}</time> : null}
                              </li>
                            )) : (
                              <li><strong>等待开始</strong><span>还没有可见的研究或触达记录。</span></li>
                            )}
                          </ol>
                        </details>

                        <details class="lead-tool-details">
                          <summary>工具与证据（{record.workTrace.length} 条输出）</summary>
                          <ol class="lead-tool-log">
                            {record.workTrace.map((entry) => (
                              <li>
                                <strong>{entry.tool}</strong>
                                <span>{entry.action}</span>
                                {entry.evidence ? entry.evidence.startsWith('http')
                                  ? <a href={entry.evidence}>{entry.evidence}</a>
                                  : <code>{entry.evidence}</code>
                                  : null}
                              </li>
                            ))}
                          </ol>
                        </details>

                        <details class="lead-proof-details">
                          <summary>状态证据：档案完整度 {record.profileCompleteness.percent}%{record.profileCompleteness.missing.length ? `，缺：${record.profileCompleteness.missing.join('、')}` : ''}</summary>
                          <div class="lead-proof-grid">
                            {artifactLabels.map(([key, label]) => (
                              <span class={record.artifactStatus[key] ? 'is-ready' : ''}>{label}</span>
                            ))}
                          </div>
                        </details>

                        {record.decisionActions.length ? (
                          <section>
                            <h3>人工决定</h3>
                            <p class="micro">这些按钮只记录决定和状态，不会直接生成 Mockup、发送邮件或运行外部工具。</p>
                            <div class="lead-decision-row">
                              {record.decisionActions.map((action) => (
                                <form method="post" action="/admin/lead-note">
                                  <input type="hidden" name="client_slug" value={record.clientSlug} />
                                  <input type="hidden" name="order_id" value={record.orderId || ''} />
                                  <input type="hidden" name="company" value={record.company || ''} />
                                  <input type="hidden" name="actor" value="profitslocal-admin" />
                                  <input type="hidden" name="action" value={action.action} />
                                  <input type="hidden" name="note" value={`${action.note}${record.blockingReason ? ` 原因：${record.blockingReason}` : ''}`} />
                                  <button class={`button ${action.tone === 'primary' ? '' : 'secondary'}`} type="submit">{action.label}</button>
                                </form>
                              ))}
                            </div>
                          </section>
                        ) : null}

                        <form method="post" action="/admin/lead-note" class="lead-note-form">
                          <input type="hidden" name="client_slug" value={record.clientSlug} />
                          <input type="hidden" name="order_id" value={record.orderId || ''} />
                          <input type="hidden" name="company" value={record.company || ''} />
                          <input type="hidden" name="actor" value="profitslocal-admin" />
                          <textarea name="note" rows="2" placeholder="补一条人工备注，比如电话结果、客户偏好、下一次联系角度" required></textarea>
                          <input type="date" name="next_follow_up_due" value={record.nextFollowUpDue || ''} />
                          <button class="button secondary" type="submit">保存备注</button>
                        </form>
                      </div>
                    </article>
                    );
                  }) : <p class="lead-empty">这一阶段暂时没有线索。</p>}
                </div>
              </div>
            </section>
          );
        })}
      </div>

      <details class="admin-audit-view">
        <summary>打开审计表格</summary>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>线索</th>
                <th>阶段</th>
                <th>联系方式</th>
                <th>下一步</th>
                <th>最近工作</th>
              </tr>
            </thead>
            <tbody>
              {index.records.map((record) => (
                <tr>
                  <td><strong>{record.company || record.clientSlug}</strong><span>{record.clientSlug}</span></td>
                  <td><mark class={`status-pill status-${record.pipelineTone}`}>{record.pipelineLabel}</mark></td>
                  <td>{contactEmail(record) || record.phone || record.officialWebsiteUrl || record.websiteUrl || '无联系方式'}</td>
                  <td><strong>{record.nextAction.label}</strong><span>{record.blockingReason || record.nextAction.reason}</span></td>
                  <td>{record.actionLog[0]?.label || '无记录'}<span>{record.actionLog[0]?.detail || ''}</span></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </details>

      <details class="admin-audit-view">
        <summary>打开 Maps scraper discovery 库（前 12 条）</summary>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>商家</th>
                <th>状态</th>
                <th>V1 分数</th>
                <th>V2 分数</th>
                <th>V2 决策</th>
                <th>官网状态</th>
                <th>下一步（V1）</th>
              </tr>
            </thead>
            <tbody>
              {discoveryPreview.map((entity) => {
                const audit = (() => {
                  try { return cheapAuditV2({ entity, sourceQuery: entity.latest?.sourceQuery }); } catch { return null; }
                })();
                return (
                  <tr>
                    <td>
                      <a href={`/admin/leads/${entity.entityKey}`} class="v2-lead-link">
                        <strong>{entity.latest?.name || entity.entityKey}</strong>
                        <span>{entity.latest?.city || entity.latest?.sourceQuery || entity.entityKey}</span>
                      </a>
                    </td>
                    <td><mark class="status-pill status-working">{entity.status}</mark></td>
                    <td>{entity.latest?.discoveryScore ?? '-'}</td>
                    <td class="v2-sort-num">{audit ? audit.final_score : '-'}</td>
                    <td>{audit ? <span class={`chip ${v2ChipClass(audit.action)}`}>{audit.action.replace(/_/g, ' ')}</span> : '—'}</td>
                    <td>{entity.latest?.websiteStatus || '-'}</td>
                    <td><strong>{entity.latest?.recommendedAction || '-'}</strong><span>{entity.promotedClientSlug ? `已进入 ${entity.promotedClientSlug}` : entity.latest?.website || entity.latest?.google_maps_url || '待补证据'}</span></td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </details>
    </div>
  </section>

  <script>
    const toolbar = document.querySelector('[data-admin-toolbar]');
    const pipeline = document.querySelector('[data-lead-pipeline]');
    const searchInput = toolbar?.querySelector('[data-admin-search]');
    const viewButtons = [...(toolbar?.querySelectorAll('[data-admin-view]') || [])];
    const cards = [...document.querySelectorAll('[data-lead-card]')];
    const visibleCount = toolbar?.querySelector('[data-admin-visible-count]');
    const params = new URLSearchParams(window.location.search);
    const initialQuery = params.get('q') || params.get('query') || params.get('search') || '';
    const initialView = params.get('view') || '';

    if (searchInput && initialQuery) searchInput.value = initialQuery;
    if (initialView && viewButtons.some((button) => button.dataset.adminView === initialView)) {
      viewButtons.forEach((button) => button.classList.toggle('is-active', button.dataset.adminView === initialView));
    }

    const activateStage = (stageKey) => {
      if (!stageKey) return;
      document.querySelectorAll('[data-stage-column]').forEach((column) => {
        const active = column.dataset.stageColumn === stageKey;
        column.classList.toggle('is-active', active);
        column.querySelector('[data-stage-toggle]')?.setAttribute('aria-expanded', active ? 'true' : 'false');
      });
    };

    document.querySelectorAll('[data-stage-toggle]').forEach((button) => {
      button.addEventListener('click', () => {
        activateStage(button.dataset.stageToggle);
      });
    });

    document.querySelectorAll('[data-card-toggle]').forEach((button) => {
      button.addEventListener('click', () => {
        const card = button.closest('[data-lead-card]');
        const column = card?.closest('[data-stage-column]');
        column?.querySelectorAll('[data-lead-card]').forEach((item) => item.classList.toggle('is-open', item === card && !item.classList.contains('is-open')));
      });
    });

    const applyFilters = () => {
      const query = (searchInput?.value || '').trim().toLowerCase();
      const activeView = viewButtons.find((button) => button.classList.contains('is-active'))?.dataset.adminView || 'all';
      let shown = 0;
      let firstVisibleCard = null;
      cards.forEach((card) => {
        const matchesQuery = !query || (card.dataset.search || '').includes(query);
        const matchesView = activeView === 'all' || card.dataset.stage === activeView;
        const visible = matchesQuery && matchesView;
        card.hidden = !visible;
        if (visible) {
          shown += 1;
          firstVisibleCard ||= card;
        }
      });
      if (visibleCount) visibleCount.textContent = `${shown} 条可见`;
      pipeline?.classList.toggle('is-filtering', activeView !== 'all' || Boolean(query));
      const activeColumn = document.querySelector('[data-stage-column].is-active');
      const activeColumnHasVisibleCard = Boolean(activeColumn?.querySelector('[data-lead-card]:not([hidden])'));
      if (firstVisibleCard && !activeColumnHasVisibleCard) {
        const nextStage = firstVisibleCard.dataset.stage;
        activateStage(nextStage);
      }
      if (firstVisibleCard && (query || activeView !== 'all')) {
        const nextColumn = firstVisibleCard.closest('[data-stage-column]');
        nextColumn?.querySelectorAll('[data-lead-card]').forEach((item) => {
          item.classList.toggle('is-open', item === firstVisibleCard);
        });
      }
    };

    viewButtons.forEach((button) => {
      button.addEventListener('click', () => {
        viewButtons.forEach((item) => item.classList.remove('is-active'));
        button.classList.add('is-active');
        applyFilters();
      });
    });

    searchInput?.addEventListener('input', applyFilters);
    applyFilters();
  </script>
</Layout>

