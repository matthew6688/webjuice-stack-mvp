---
import Layout from '../../layouts/AdminLayout.astro';
import { siteConfig } from '../../config/site';
import { LEAD_ADMIN_VIEWS, loadLeadOutreachIndex } from '../../../core/funnel/lead-outreach-index.js';

const index = loadLeadOutreachIndex();
const savedViews = [
  ['all', LEAD_ADMIN_VIEWS.all.label],
  ['demo_ready', LEAD_ADMIN_VIEWS.demo_ready.label],
  ['draft_ready', LEAD_ADMIN_VIEWS.draft_ready.label],
  ['outreach_sent', LEAD_ADMIN_VIEWS.outreach_sent.label],
  ['follow_up_due', LEAD_ADMIN_VIEWS.follow_up_due.label],
  ['follow_up_overdue', LEAD_ADMIN_VIEWS.follow_up_overdue.label],
  ['replied', LEAD_ADMIN_VIEWS.replied.label],
  ['replied_unprocessed', LEAD_ADMIN_VIEWS.replied_unprocessed.label],
  ['bounced', LEAD_ADMIN_VIEWS.bounced.label],
  ['paid', LEAD_ADMIN_VIEWS.paid.label],
  ['paid_handoff_pending', LEAD_ADMIN_VIEWS.paid_handoff_pending.label],
  ['missing_assets', LEAD_ADMIN_VIEWS.missing_assets.label],
  ['missing_email', LEAD_ADMIN_VIEWS.missing_email.label],
];
const urgent = index.records
  .filter((record) => record.blocker || ['paid', 'follow_up_due', 'follow_up_overdue', 'replied'].includes(record.stageKey))
  .sort((a, b) => urgencyScore(b) - urgencyScore(a))
  .slice(0, 8);

function urgencyScore(record) {
  let score = 0;
  if (record.stageKey === 'paid') score += 100;
  if (record.stageKey === 'follow_up_overdue') score += 90;
  if (record.stageKey === 'replied') score += 80;
  if (record.stageKey === 'follow_up_due') score += 60;
  if (record.blocker) score += 20;
  if (record.paymentStatus === 'paid' && !record.websiteTaskThreadId) score += 30;
  return score;
}
---

<Layout title={`Lead admin - ${siteConfig.name}`} description="Lead and cold outreach operations for ProfitsLocal." active="leads">
  <section class="poster-section admin-section">
    <div class="admin-shell">
      <div class="admin-header">
        <div>
          <p class="eyebrow">Internal ops</p>
          <h1>Leads & outreach</h1>
          <p class="lede">Track demo readiness, outreach drafts, and which prospects have already converted into paid projects.</p>
        </div>
        <div class="admin-count">
          <strong>{index.counts.total}</strong>
          <span>Lead records</span>
        </div>
      </div>

      <div class="admin-summary-strip admin-summary-strip-compact">
        <article class="admin-summary-tile admin-summary-primary">
          <span class="admin-summary-label">Demo ready</span>
          <strong>{index.counts.demoReady || 0}</strong>
          <p>Preview exists and proof assets are complete enough to start outreach.</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">Draft ready</span>
          <strong>{index.counts.draft_ready || 0}</strong>
          <p>Cold outreach draft exists. We can send manually or through the future agentic inbox flow.</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">Outreach sent</span>
          <strong>{index.counts.outreachSent || 0}</strong>
          <p>Live send has been recorded on the outreach artifact. Provider-specific reply and follow-up state can layer on top.</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">Follow-up due</span>
          <strong>{index.counts.followUpDue || 0}</strong>
          <p>These leads were sent already and still need a next-touch action recorded in the outreach workflow.</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">Follow-up overdue</span>
          <strong>{index.counts.followUpOverdue || 0}</strong>
          <p>These leads are past their recorded follow-up date and should be handled first.</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">Replied / bounced</span>
          <strong>{(index.counts.replied || 0) + (index.counts.bounced || 0)}</strong>
          <p>Reply and bounce state now land on the same lead truth source. Future providers should plug into this model, not replace it.</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">Replied needs review</span>
          <strong>{index.counts.repliedNeedsReview || 0}</strong>
          <p>Prospects replied, but they are not yet attached to a project workspace or paid flow.</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">Paid</span>
          <strong>{index.counts.paid || 0}</strong>
          <p>These leads should move into website-projects execution, not stay stuck in outreach.</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">Paid handoff pending</span>
          <strong>{index.counts.paidHandoffPending || 0}</strong>
          <p>Customer has paid, but the project workspace handoff is still missing or incomplete.</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">Blocked</span>
          <strong>{index.counts.blocked || 0}</strong>
          <p>Lead is missing either outreach assets, draft email, or a clear contact path.</p>
        </article>
      </div>

      <div class="admin-finance-grid">
        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">Needs Action</span>
              <h2>Lead queue</h2>
            </div>
          </div>
          <div class="admin-urgent-list">
            {urgent.length ? urgent.map((record) => (
              <article class="admin-urgent-card">
                <strong>{record.company || record.clientSlug}</strong>
                <span>{record.nextAction.label}</span>
                <code>{record.blocker || record.stageLabel}</code>
                <span class="micro">{record.email || record.customerEmail || record.leadRecipientEmail || 'no email'}</span>
                <span class="micro">{record.latestProviderEventType ? `${record.latestProviderEventType} · ${record.latestProviderEventAt || 'no timestamp'}` : 'no provider event yet'}</span>
              </article>
            )) : <p class="micro">No urgent lead blocker right now.</p>}
          </div>
        </section>

        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">Policy</span>
              <h2>What this page tracks</h2>
            </div>
          </div>
          <ul class="admin-list">
            <li><strong>Transactional email</strong><span>Stays on Resend. Not shown here as cold outreach send truth.</span></li>
            <li><strong>Cold outreach</strong><span>Current truth source is demo pack + draft artifact + normalized provider metadata written back to outreach email artifacts.</span></li>
            <li><strong>Current live path</strong><span>Agentic Inbox is the current cold outreach operator path. Instantly / Smartlead stay planned until webhook ingest is live.</span></li>
            <li><strong>Provider model</strong><span>Resend remains transactional only. Cold outreach can swap providers later without changing the admin truth model.</span></li>
            <li><strong>Lead notes</strong><span>Manual follow-up notes and next follow-up dates can be recorded here now, then reused when the lead becomes a paid project.</span></li>
            <li><strong>Forum visibility</strong><span>`website-leads` remains the Discord container; this page is the admin summary.</span></li>
            <li><strong>Settings source</strong><span>Use <a href="/admin/settings/">/admin/settings/</a> to see which outreach providers are configured, live, or still planned.</span></li>
          </ul>
        </section>
      </div>

      <div class="admin-toolbar" data-admin-toolbar>
        <div class="admin-toolbar-group">
          <span class="admin-toolbar-label">Saved views</span>
          <div class="admin-view-pills">
            {savedViews.map(([key, label], idx) => (
              <button type="button" class={`admin-view-pill ${idx === 0 ? 'is-active' : ''}`} data-admin-view={key}>{label}</button>
            ))}
          </div>
        </div>
        <div class="admin-toolbar-group admin-toolbar-right">
          <label class="admin-search">
            <span class="admin-toolbar-label">Search</span>
            <input type="search" placeholder="Client, email, domain" data-admin-search />
          </label>
          <p class="micro" data-admin-visible-count>{index.records.length} visible</p>
        </div>
      </div>

      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Lead</th>
              <th>Stage</th>
              <th>Demo proof</th>
              <th>Contact</th>
              <th>Discord / flow</th>
              <th>Next action</th>
            </tr>
          </thead>
          <tbody>
            {index.records.map((record) => (
              <tr
                data-client={record.clientSlug}
                data-company={record.company || ''}
                data-order-id={record.orderId || ''}
                data-domain={record.domain || ''}
                data-status={record.paymentStatus || ''}
                data-stage={record.stageKey}
                data-view-demo-ready={record.stageKey === 'demo_ready' ? 'true' : 'false'}
                data-view-draft-ready={record.emailDraftReady ? 'true' : 'false'}
                data-view-outreach-sent={record.outreachSent ? 'true' : 'false'}
                data-view-follow-up-due={record.stageKey === 'follow_up_due' ? 'true' : 'false'}
                data-view-follow-up-overdue={record.stageKey === 'follow_up_overdue' ? 'true' : 'false'}
                data-view-replied={record.stageKey === 'replied' ? 'true' : 'false'}
                data-view-replied-unprocessed={record.stageKey === 'replied' && !record.websiteTaskThreadId && record.paymentStatus !== 'paid' ? 'true' : 'false'}
                data-view-bounced={record.stageKey === 'bounced' ? 'true' : 'false'}
                data-view-paid={record.paymentStatus === 'paid' ? 'true' : 'false'}
                data-view-paid-handoff-pending={record.paymentStatus === 'paid' && !record.websiteTaskThreadId ? 'true' : 'false'}
                data-view-missing-assets={record.assetsReady ? 'false' : 'true'}
                data-view-missing-email={record.emailDraftReady ? 'false' : 'true'}
              >
                <td>
                  <strong>{record.company || record.clientSlug}</strong>
                  <span>{record.clientSlug}</span>
                  <span class="admin-mono">{record.orderId || 'no order yet'}</span>
                </td>
                <td>
                  <mark class={`status-pill status-${record.stageTone}`}>{record.stageLabel}</mark>
                  {record.outreachSent ? <mark class="status-pill status-ready">Sent</mark> : null}
                  {record.paymentStatus === 'paid' ? <mark class="status-pill status-ready">Paid</mark> : null}
                  <span>{record.caseStatus || record.paidIntakeStatus || 'lead only'}</span>
                </td>
                <td>
                  <div class="admin-health-pills">
                    <mark class={`status-pill ${record.previewUrl ? 'status-ready' : 'status-warn'}`}>Preview {record.previewUrl ? 'ready' : 'missing'}</mark>
                    <mark class={`status-pill ${record.assetsReady ? 'status-ready' : 'status-alert'}`}>Assets {record.assetsReady ? 'ready' : 'missing'}</mark>
                    <mark class={`status-pill ${record.emailDraftReady ? 'status-ready' : 'status-warn'}`}>Draft {record.emailDraftReady ? 'ready' : 'missing'}</mark>
                  </div>
                  <span>{record.previewUrl || 'No preview recorded'}</span>
                  <span>{record.proofPoints} proof point(s) · audit {record.auditVerdict || 'n/a'}{record.auditScore != null ? ` ${record.auditScore}` : ''}</span>
                </td>
                <td>
                  <span>{record.email || record.customerEmail || record.leadRecipientEmail || 'no email recorded'}</span>
                  <span>{record.phone || 'no phone recorded'}</span>
                  <span>{record.domain || 'no domain recorded'}</span>
                  <span>{record.websiteUrl || 'no website recorded'}</span>
                  <span>{record.latestEmailArtifact?.subject || 'no outreach draft subject'}</span>
                  <span>{record.outreachSentAt ? `sent ${record.outreachSentAt}` : 'send not recorded'}</span>
                  <span>{record.outreachProvider ? `${record.outreachProvider}${record.replyState === 'replied' ? ' · replied' : record.bounceState === 'bounced' ? ' · bounced' : ''}` : 'provider not recorded yet'}</span>
                  <span>{record.nextFollowUpDue ? `next follow-up ${record.nextFollowUpDue}` : 'next follow-up not recorded'}</span>
                  <span>{record.latestProviderEventType ? `latest event ${record.latestProviderEventType} at ${record.latestProviderEventAt || 'n/a'}` : 'latest provider event not recorded'}</span>
                  <span>{record.latestLeadNote?.note ? `latest note: ${record.latestLeadNote.note}` : 'no lead note yet'}</span>
                </td>
                <td>
                  <span>{record.salesWorkspaceName || 'website-leads forum not recorded'}</span>
                  <span>{record.salesThreadId || 'no lead thread id'}</span>
                  <span>{record.websiteTaskThreadId ? 'project workspace exists' : 'not yet in website-projects'}</span>
                </td>
                <td>
                  <strong>{record.nextAction.label}</strong>
                  <span>{record.nextAction.reason}</span>
                  <form method="post" action="/admin/lead-note" class="admin-action-form">
                    <input type="hidden" name="client_slug" value={record.clientSlug} />
                    <input type="hidden" name="order_id" value={record.orderId || ''} />
                    <input type="hidden" name="company" value={record.company || ''} />
                    <input type="hidden" name="actor" value="profitslocal-admin" />
                    <textarea name="note" rows="3" placeholder="Add follow-up note, call result, or special context." required></textarea>
                    <input type="date" name="next_follow_up_due" value={record.nextFollowUpDue || ''} />
                    <button class="button secondary" type="submit">Save lead note</button>
                  </form>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <script>
    const toolbar = document.querySelector('[data-admin-toolbar]');
    const searchInput = toolbar?.querySelector('[data-admin-search]');
    const viewButtons = [...(toolbar?.querySelectorAll('[data-admin-view]') || [])];
    const rows = [...document.querySelectorAll('tbody tr')];
    const visibleCount = toolbar?.querySelector('[data-admin-visible-count]');

    const applyFilters = () => {
      const query = (searchInput?.value || '').trim().toLowerCase();
      const activeView = viewButtons.find((button) => button.classList.contains('is-active'))?.dataset.adminView || 'all';
      let shown = 0;
      rows.forEach((row) => {
        const haystack = [
          row.dataset.client,
          row.dataset.company,
          row.dataset.orderId,
          row.dataset.domain,
        ].join(' ').toLowerCase();
        const matchesQuery = !query || haystack.includes(query);
        const matchesView = activeView === 'all'
          ? true
          : row.dataset[`view${activeView.split('_').map((part) => part.charAt(0).toUpperCase() + part.slice(1)).join('')}`] === 'true';
        const visible = matchesQuery && matchesView;
        row.hidden = !visible;
        if (visible) shown += 1;
      });
      if (visibleCount) visibleCount.textContent = `${shown} visible`;
    };

    viewButtons.forEach((button) => {
      button.addEventListener('click', () => {
        viewButtons.forEach((item) => item.classList.remove('is-active'));
        button.classList.add('is-active');
        applyFilters();
      });
    });

    searchInput?.addEventListener('input', applyFilters);
    applyFilters();
  </script>
</Layout>
