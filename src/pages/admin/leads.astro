    font-size: 13px; font-weight: 800;
    border-bottom: 1.5px solid rgba(23,25,28,0.1);
    vertical-align: middle;
  }
  .v2-sort-table tr:last-child td { border-bottom: 0; }
  .v2-sort-table tr:hover td { background: color-mix(in srgb, var(--pl-citrus) 10%, var(--pl-paper)); }

  .v2-lead-link {
    display: block;
    color: var(--pl-ink);
    text-decoration: none;
  }
  .v2-lead-link strong {
    display: block;
    font-family: var(--pl-display);
    font-size: 16px; font-weight: 950;
    line-height: 1.2;
  }
  .v2-lead-link span {
    display: block;
    font-size: 11.5px; color: var(--pl-muted); font-weight: 800;
    margin-top: 2px;
  }
  .v2-lead-loc { font-style: normal; }
  .v2-lead-link:hover strong { color: var(--pl-coral); text-decoration: underline; }

  .v2-sort-num {
    font-family: var(--pl-display);
    font-size: 22px; font-weight: 950;
    color: var(--pl-ink);
    width: 80px;
  }
