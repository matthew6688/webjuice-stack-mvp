---
import Layout from '../../../layouts/AdminLayout.astro';

const uiVersion = 'local-style-2026-05-08';
const API_BASE = import.meta.env.PUBLIC_SOP0_API_BASE || 'https://tasks.profitslocal.com';
const API_TOKEN = import.meta.env.PUBLIC_SOP0_API_TOKEN || '';
---

<Layout title="SOP-0 · 任务" active="tasks">
  <section class="poster-section admin-section" data-ui-version={uiVersion}>
    <div class="admin-shell tasks-shell">
      <div class="admin-header">
        <div>
          <p class="eyebrow">SOP-0 · 任务列表</p>
          <h1 id="page-title">任务</h1>
          <p class="lede" id="page-subtitle">所有发到 Discord 的任务都在这。Discord 是干活的现场，这页是跨设备查历史和详情用的。</p>
        </div>
        <div class="admin-count">
          <strong id="count-total">—</strong>
          <span>任务总数</span>
          <span class="micro-note" id="count-breakdown">加载中…</span>
        </div>
      </div>

      <!-- attention strip: status counts (mirrors v2-leads pattern) -->
      <div class="v2-attention-strip" id="attention-strip">
        <a class="v2-attention-cell" href="#" data-filter="human">
          <span class="v2-attention-num" id="cnt-human">—</span>
          <span class="v2-attention-label">等人处理</span>
        </a>
        <a class="v2-attention-cell" href="#" data-filter="running">
          <span class="v2-attention-num" id="cnt-running">—</span>
          <span class="v2-attention-label">处理中</span>
        </a>
        <a class="v2-attention-cell" href="#" data-filter="pending">
          <span class="v2-attention-num" id="cnt-pending">—</span>
          <span class="v2-attention-label">排队中</span>
        </a>
        <a class="v2-attention-cell" href="#" data-filter="failed">
          <span class="v2-attention-num" id="cnt-failed">—</span>
          <span class="v2-attention-label">失败</span>
        </a>
        <a class="v2-attention-cell" href="#" data-filter="done">
          <span class="v2-attention-num" id="cnt-done">—</span>
          <span class="v2-attention-label">已完成</span>
        </a>
      </div>

      <!-- list view -->
      <div id="list-view">
        <header class="admin-paper-section-head">
          <h2>所有任务</h2>
          <div class="filters-bar">
            <label>状态
              <select id="filter-status">
                <option value="">全部</option>
                <option value="pending">排队中</option>
                <option value="running">处理中</option>
                <option value="done">已完成</option>
                <option value="failed">失败</option>
                <option value="human">等人处理</option>
              </select>
            </label>
            <label>类型
              <select id="filter-kind">
                <option value="">全部</option>
                <option value="intake">批量采集</option>
                <option value="places-intake">Google Places 搜索</option>
                <option value="single-enrich">单条补全</option>
                <option value="enrich">批量补全</option>
                <option value="audit">审计</option>
                <option value="dedup">去重</option>
                <option value="photos">图片抓取</option>
                <option value="image-extract">图片识别</option>
                <option value="ops">运维</option>
              </select>
            </label>
            <label class="filter-toggle">
              <input type="checkbox" id="filter-archived" />
              包含已归档
            </label>
            <button class="admin-card-meta-action" id="refresh-btn">刷新</button>
            <span id="refresh-status" class="filter-status-line"></span>
          </div>
        </header>

        <div class="v2-row-list" id="task-rows">
          <p class="v2-group-empty">loading…</p>
        </div>
      </div>

      <!-- detail view -->
      <div id="detail-view" style="display:none">
        <header class="admin-paper-section-head">
          <h2 id="detail-title">任务</h2>
          <a href="#" id="back-to-list" class="admin-card-meta-action">← 返回列表</a>
        </header>
        <div id="detail-content">
          <p class="v2-group-empty">loading…</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script define:vars={{ API_BASE, API_TOKEN }}>
  const $ = (id) => document.getElementById(id);
  const escape = (s) => String(s ?? '').replace(/[&<>"]/g, (c) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;' }[c]));
  const fmtTime = (iso) => iso ? new Date(iso).toLocaleString('en-AU', { hour12: false, year: '2-digit', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' }).replace(',', '') : '—';
  const fmtDur = (ms) => ms == null ? '—' : ms < 1000 ? `${ms}ms` : `${(ms/1000).toFixed(1)}s`;
  const ago = (iso) => {
    if (!iso) return '—';
    const sec = Math.max(0, Math.floor((Date.now() - new Date(iso).getTime()) / 1000));
    if (sec < 60) return `${sec} 秒前`;
    if (sec < 3600) return `${Math.floor(sec/60)} 分钟前`;
    if (sec < 86400) return `${Math.floor(sec/3600)} 小时前`;
    return `${Math.floor(sec/86400)} 天前`;
  };

  const STATUS_ZH = {
    pending: '排队中',
    running: '处理中',
    done: '已完成',
    failed: '失败',
    human: '等人处理',
  };
  const KIND_ZH = {
    intake: '批量采集',
    'places-intake': 'Google Places 搜索',
    'single-enrich': '单条补全',
    enrich: '批量补全',
    audit: '审计',
    dedup: '去重',
    photos: '图片抓取',
    'image-extract': '图片识别',
    ops: '运维',
  };
  function statusChip(s) {
    return `<span class="chip chip-status-${s}">${STATUS_ZH[s] || s}</span>`;
  }
  function kindChip(k) {
    return `<span class="chip chip-kind-${k}">${KIND_ZH[k] || k}</span>`;
  }

  async function fetchJson(url) {
    const t0 = Date.now();
    const r = await fetch(url, {
      headers: API_TOKEN ? { 'Authorization': `Bearer ${API_TOKEN}` } : {},
    });
    if (!r.ok) throw new Error(`${r.status} ${r.statusText}`);
    const data = await r.json();
    return { data, ms: Date.now() - t0 };
  }

  let cachedTasks = [];

  async function loadList() {
    const status = $('filter-status').value;
    const kind = $('filter-kind').value;
    const archived = $('filter-archived').checked ? '1' : '0';
    const url = `${API_BASE}/api/tasks?status=${encodeURIComponent(status)}&kind=${encodeURIComponent(kind)}&archived=${archived}&limit=100`;
    $('refresh-status').textContent = '加载中…';
    try {
      const { data, ms } = await fetchJson(url);
      const tasks = [...(data.active || []), ...(data.archived || [])]
        .sort((a, b) => (b.created_at || '').localeCompare(a.created_at || ''));
      cachedTasks = tasks;
      renderList(tasks);
      renderStrip(tasks);
      $('refresh-status').textContent = `${tasks.length} 条 · ${ms}ms · 进行中 ${data.counts.active} / 已归档 ${data.counts.archived}`;
    } catch (err) {
      $('refresh-status').textContent = `出错: ${err.message}`;
      $('task-rows').innerHTML = `<p class="v2-group-empty admin-banner admin-banner-coral">读取失败: ${escape(err.message)}</p>`;
    }
  }

  function renderStrip(tasks) {
    const counts = { pending: 0, running: 0, done: 0, failed: 0, human: 0 };
    for (const t of tasks) if (counts[t.status] != null) counts[t.status] += 1;
    $('cnt-human').textContent = counts.human;
    $('cnt-running').textContent = counts.running;
    $('cnt-pending').textContent = counts.pending;
    $('cnt-failed').textContent = counts.failed;
    $('cnt-done').textContent = counts.done;
    $('count-total').textContent = tasks.length;
    $('count-breakdown').textContent = `处理中 ${counts.running} · 等人 ${counts.human} · 失败 ${counts.failed}`;
    // attention tone
    document.querySelectorAll('[data-filter]').forEach((el) => {
      const k = el.dataset.filter;
      el.classList.remove('v2-attention-hot', 'v2-attention-warm');
      if (k === 'human' && counts.human > 0) el.classList.add('v2-attention-hot');
      else if (k === 'failed' && counts.failed > 0) el.classList.add('v2-attention-warm');
      else if (k === 'running' && counts.running > 0) el.classList.add('v2-attention-warm');
    });
  }

  function renderList(tasks) {
    const tbody = $('task-rows');
    if (tasks.length === 0) {
      tbody.innerHTML = '<p class="v2-group-empty">— 没有符合条件的任务 —</p>';
      return;
    }
    tbody.innerHTML = tasks.map((t) => `
      <div class="v2-row task-row task-row-${t.status}${t.archived ? ' task-row-archived' : ''}">
        <div class="v2-row-main">
          <a class="v2-row-name-link" href="#${escape(t.task_id)}">
            <h3 class="v2-row-name">${escape(t.task_id)}${t.archived ? ' <span class="chip chip-muted">已归档</span>' : ''}</h3>
          </a>
          <div class="v2-row-meta">
            ${kindChip(t.kind)}
            ${statusChip(t.status)}
            ${t.cli ? `<code class="v2-stage-cli">${escape(t.cli)}${t.args?.length ? ' ' + escape(t.args.join(' ')) : ''}</code>` : ''}
            ${t.target_entity_key ? `<span class="v2-row-niche">${escape(t.target_entity_key)}</span>` : ''}
          </div>
        </div>
        <div class="v2-row-stats">
          <div class="v2-row-stat">
            <span class="v2-row-stat-num">${ago(t.created_at)}</span>
            <span class="v2-row-stat-label">创建</span>
          </div>
          ${t.duration_ms != null ? `
            <div class="v2-row-stat">
              <span class="v2-row-stat-num">${fmtDur(t.duration_ms)}</span>
              <span class="v2-row-stat-label">耗时 · exit ${t.exit_code ?? '—'}</span>
            </div>` : ''}
          <div class="v2-row-stat">
            <span class="v2-row-stat-num">${t.progress_count || 0}</span>
            <span class="v2-row-stat-label">步骤</span>
          </div>
        </div>
      </div>
    `).join('');
  }

  async function loadDetail(taskId) {
    $('list-view').style.display = 'none';
    $('detail-view').style.display = 'block';
    $('detail-title').textContent = `任务 ${taskId}`;
    $('detail-content').innerHTML = '<p class="v2-group-empty">加载中…</p>';
    try {
      const { data } = await fetchJson(`${API_BASE}/api/tasks/${encodeURIComponent(taskId)}`);
      const t = data.task;
      const threadId = t.discord?.thread_id || t.source?.thread_id;
      const threadLink = threadId
        ? `<a href="https://discord.com/channels/@me/${threadId}" target="_blank">Discord 帖子 ↗</a>`
        : '<span class="v2-row-niche">—</span>';
      const entityKey = t.target?.target_entity_key;
      const entityLink = entityKey
        ? `<a href="/admin/v2-leads/${escape(entityKey)}">${escape(entityKey)} ↗</a>`
        : '<span class="v2-row-niche">—</span>';
      const progressRows = (t.progress || []).map((p) => `
        <tr>
          <td class="dim mono">${escape((p.at || '').slice(11, 23))}</td>
          <td><span class="chip chip-muted">${escape(p.step)}</span></td>
          <td class="progress-detail-cell">${escape(p.detail || '')}</td>
        </tr>`).join('');
      $('detail-content').innerHTML = `
        <div class="admin-card-grid admin-card-grid-2">
          <div class="admin-card">
            <h3 class="admin-card-title">基本信息</h3>
            <div class="admin-card-body">
              <div class="kv"><span class="k">类型</span> ${kindChip(t.kind)}</div>
              <div class="kv"><span class="k">状态</span> ${statusChip(t.status)}</div>
              <div class="kv"><span class="k">创建时间</span><code>${escape(fmtTime(t.created_at))}</code></div>
              <div class="kv"><span class="k">更新时间</span><code>${escape(fmtTime(t.updated_at))}</code></div>
              <div class="kv"><span class="k">发起人</span><span>${escape(t.source?.author || '—')}</span></div>
            </div>
          </div>
          <div class="admin-card">
            <h3 class="admin-card-title">执行情况</h3>
            <div class="admin-card-body">
              <div class="kv"><span class="k">运行命令</span><code>${escape(t.target?.cli || '—')}${t.target?.args?.length ? ' ' + escape(t.target.args.join(' ')) : ''}</code></div>
              <div class="kv"><span class="k">耗时</span><span>${fmtDur(t.result?.duration_ms)}</span></div>
              <div class="kv"><span class="k">退出码</span><code>${t.result?.exit_code == null ? '—' : t.result.exit_code}</code></div>
              <div class="kv"><span class="k">关联客户</span><span>${entityLink}</span></div>
              <div class="kv"><span class="k">Discord</span><span>${threadLink}</span></div>
              ${t.error ? `<div class="kv"><span class="k">错误</span><span class="chip chip-coral">${escape(t.error)}</span></div>` : ''}
            </div>
          </div>
        </div>

        <header class="admin-paper-section-head"><h2>原始请求</h2></header>
        <div class="admin-banner admin-banner-mint">
          <span class="admin-banner-icon">📥</span>
          <div class="admin-banner-body"><p style="white-space:pre-wrap">${escape(t.input?.text || '(空)')}</p></div>
        </div>

        <header class="admin-paper-section-head"><h2>进度 · 共 ${(t.progress || []).length} 步</h2></header>
        <table class="admin-table progress-table">
          <thead><tr><th style="width:10ch">时间</th><th style="width:22ch">步骤</th><th>详情</th></tr></thead>
          <tbody>${progressRows || '<tr><td colspan="3" class="v2-group-empty">(无)</td></tr>'}</tbody>
        </table>
      `;
    } catch (err) {
      $('detail-content').innerHTML = `<p class="admin-banner admin-banner-coral">${escape(err.message)}</p>`;
    }
  }

  function routeFromHash() {
    const id = window.location.hash.slice(1);
    if (id) loadDetail(id);
    else {
      $('list-view').style.display = 'block';
      $('detail-view').style.display = 'none';
      $('page-title').textContent = '任务';
      loadList();
    }
  }

  // status filter from attention strip
  document.querySelectorAll('[data-filter]').forEach((el) => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      $('filter-status').value = el.dataset.filter;
      loadList();
    });
  });
  $('refresh-btn').addEventListener('click', loadList);
  $('filter-status').addEventListener('change', loadList);
  $('filter-kind').addEventListener('change', loadList);
  $('filter-archived').addEventListener('change', loadList);
  $('back-to-list').addEventListener('click', (e) => { e.preventDefault(); window.location.hash = ''; });
  window.addEventListener('hashchange', routeFromHash);
  routeFromHash();
</script>

<style>
  .tasks-shell { max-width: 1200px; }
  .tasks-shell .admin-count { min-width: 220px; flex-shrink: 0; }
  .tasks-shell .admin-count strong { font-size: 44px; line-height: 1; font-weight: 950; }
  .tasks-shell .admin-count .micro-note { display:block; margin-top:6px; font-size:11px; font-weight:700; color: var(--pl-muted); }

  /* Filters bar — sits in section-head */
  .filters-bar {
    display: flex; gap: 10px; align-items: center; flex-wrap: wrap;
    font-size: 12px;
  }
  .filters-bar label { display: inline-flex; align-items: center; gap: 6px; font-weight: 700; color: var(--pl-muted); }
  .filters-bar label.filter-toggle { font-weight: 600; }
  .filters-bar select {
    padding: 4px 10px;
    border: 2px solid var(--pl-line);
    background: var(--pl-paper);
    font: inherit; font-weight: 700;
  }
  .filter-status-line { color: var(--pl-muted); font-size: 11px; margin-left: 8px; }
  .admin-card-meta-action {
    display: inline-block; padding: 4px 12px;
    border: 2px solid var(--pl-line);
    background: var(--pl-citrus); color: var(--pl-ink);
    cursor: pointer; text-decoration: none;
    font: inherit; font-size: 12px; font-weight: 700;
    box-shadow: 2px 2px 0 var(--pl-line);
  }
  .admin-card-meta-action:hover { transform: translate(-1px, -1px); box-shadow: 3px 3px 0 var(--pl-line); }

  /* Status chips · use design tokens */
  .chip-status-pending { background: color-mix(in srgb, var(--pl-citrus) 30%, var(--pl-paper)); }
  .chip-status-running { background: color-mix(in srgb, var(--pl-sky) 28%, var(--pl-paper)); }
  .chip-status-done    { background: color-mix(in srgb, var(--pl-mint) 30%, var(--pl-paper)); }
  .chip-status-failed  { background: var(--pl-coral); color: white; }
  .chip-status-human   { background: color-mix(in srgb, var(--pl-citrus) 60%, var(--pl-paper)); }
  /* Kind chips · lilac family for variety, all light */
  .chip-kind-intake        { background: color-mix(in srgb, var(--pl-mint) 18%, var(--pl-paper)); }
  .chip-kind-single-enrich { background: color-mix(in srgb, var(--pl-coral) 18%, var(--pl-paper)); }
  .chip-kind-enrich        { background: color-mix(in srgb, var(--pl-sky) 18%, var(--pl-paper)); }
  .chip-kind-audit         { background: color-mix(in srgb, var(--pl-lilac) 22%, var(--pl-paper)); }
  .chip-kind-dedup         { background: color-mix(in srgb, var(--pl-citrus) 18%, var(--pl-paper)); }
  .chip-kind-photos        { background: color-mix(in srgb, var(--pl-mint) 22%, var(--pl-paper)); }
  .chip-kind-image-extract { background: color-mix(in srgb, var(--pl-coral) 14%, var(--pl-paper)); }
  .chip-kind-ops           { background: color-mix(in srgb, var(--pl-muted) 18%, var(--pl-paper)); }

  /* Task row hover */
  .task-row-archived { opacity: 0.55; }
  .task-row .v2-stage-cli { font-size: 11px; padding: 2px 8px; }

  /* Detail kv pairs */
  .kv { display: flex; gap: 12px; padding: 4px 0; border-bottom: 1px dashed rgba(23,25,28,0.12); font-size: 13px; }
  .kv .k { color: var(--pl-muted); min-width: 12ch; font-weight: 700; letter-spacing: 0.02em; }
  .kv code { background: var(--pl-paper); border: 1px solid var(--pl-line); padding: 1px 6px; font-size: 12px; }

  /* Progress table */
  .progress-table { font-size: 12.5px; }
  .progress-table td { vertical-align: top; padding: 6px 10px; border-bottom: 1px dashed rgba(23,25,28,0.1); }
  .progress-table .dim { color: var(--pl-muted); }
  .progress-table .mono { font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace; }
  .progress-table .progress-detail-cell { font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace; font-size: 11.5px; white-space: pre-wrap; max-width: 700px; word-break: break-word; }
</style>
