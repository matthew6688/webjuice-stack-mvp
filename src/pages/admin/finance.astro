---
import Layout from '../../layouts/AdminLayout.astro';
import { siteConfig } from '../../config/site';
import { formatMoney, readLedger, summarizeLedger } from '../../../core/finance/ledger.js';

const events = readLedger();
const summary = summarizeLedger(events);
const byClient = Object.entries(summary.byClient || {}).sort((a, b) => b[1] - a[1]);
const byProvider = Object.entries(summary.byProvider || {}).sort((a, b) => a[1] - b[1]);
const byCategory = Object.entries(summary.byCategory || {}).sort((a, b) => a[1] - b[1]);
---

<Layout title={`Admin finance - ${siteConfig.name}`} description="Finance and ROI view for ProfitsLocal ops." active="finance">
  <section class="poster-section admin-section">
    <div class="admin-shell">
      <div class="admin-header">
        <div>
          <p class="eyebrow">Internal ops</p>
          <h1>Finance</h1>
          <p class="lede">Read the business side of the pipeline: revenue, cost pressure, provider spend, and which clients are carrying the margin.</p>
        </div>
        <div class="admin-count">
          <strong>{summary.eventCount}</strong>
          <span>Ledger events</span>
        </div>
      </div>

      <div class="admin-summary-strip admin-summary-strip-compact">
        <article class="admin-summary-tile admin-summary-primary">
          <span class="admin-summary-label">Net position</span>
          <strong>{formatMoney(summary.profit || 0)}</strong>
          <p>{summary.profit > 0 ? 'The pipeline is currently profit positive.' : 'Margin needs attention before scaling spend.'}</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">Revenue events</span>
          <strong>{summary.revenueEventCount || 0}</strong>
          <p>Booked sales or revenue records currently tracked in the ledger.</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">Cost events</span>
          <strong>{summary.costEventCount || 0}</strong>
          <p>Spend lines across providers, tooling, and manual operating cost.</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">Dominant client</span>
          <strong>{byClient[0]?.[0] || 'N/A'}</strong>
          <p>{byClient[0] ? `${formatMoney(byClient[0][1])} contribution` : 'No client finance data yet.'}</p>
        </article>
      </div>

      <div class="admin-finance-grid">
        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">Snapshot</span>
              <h2>P&amp;L</h2>
            </div>
          </div>
          <div class="admin-finance-metrics">
            <div><span>Revenue</span><strong>{formatMoney(summary.revenue || 0)}</strong></div>
            <div><span>Cost</span><strong>{formatMoney(summary.cost || 0)}</strong></div>
            <div><span>Profit</span><strong>{formatMoney(summary.profit || 0)}</strong></div>
            <div><span>ROI</span><strong>{summary.roi == null ? 'N/A' : `${(summary.roi * 100).toFixed(1)}%`}</strong></div>
          </div>
          <div class="admin-finance-meta">
            <span>{summary.revenueEventCount || 0} revenue events</span>
            <span>{summary.costEventCount || 0} cost events</span>
          </div>
        </section>

        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">Clients</span>
              <h2>Top Profit</h2>
            </div>
          </div>
          <ul class="admin-list">
            {byClient.length ? byClient.map(([client, amount]) => (
              <li><strong>{client}</strong><span>{formatMoney(amount)}</span></li>
            )) : <li>No client finance data yet.</li>}
          </ul>
        </section>

        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">Providers</span>
              <h2>Spend</h2>
            </div>
          </div>
          <ul class="admin-list">
            {byProvider.length ? byProvider.map(([provider, amount]) => (
              <li><strong>{provider}</strong><span>{formatMoney(amount)}</span></li>
            )) : <li>No provider data yet.</li>}
          </ul>
        </section>
      </div>

      <div class="admin-finance-grid">
        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">Categories</span>
              <h2>Cost Mix</h2>
            </div>
          </div>
          <ul class="admin-list">
            {byCategory.length ? byCategory.map(([category, amount]) => (
              <li><strong>{category.replaceAll('_', ' ')}</strong><span>{formatMoney(amount)}</span></li>
            )) : <li>No category data yet.</li>}
          </ul>
        </section>

        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">Usage</span>
              <h2>Read This First</h2>
            </div>
          </div>
          <ul class="admin-list">
            <li><strong>Profit positive</strong><span>{summary.profit > 0 ? 'Yes' : 'No'}</span></li>
            <li><strong>Dominant spend</strong><span>{byProvider[0]?.[0] || 'N/A'}</span></li>
            <li><strong>Dominant client</strong><span>{byClient[0]?.[0] || 'N/A'}</span></li>
            <li><strong>Ledger path</strong><span><code>data/finance/ledger.jsonl</code></span></li>
          </ul>
        </section>
      </div>
    </div>
  </section>
</Layout>
