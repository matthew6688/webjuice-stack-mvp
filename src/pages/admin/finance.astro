---
import Layout from '../../layouts/AdminLayout.astro';
import { siteConfig } from '../../config/site';
import { formatMoney, readLedger, summarizeLedger } from '../../../core/finance/ledger.js';

const events = readLedger();
const summary = summarizeLedger(events);
const byClient = Object.entries(summary.byClient || {}).sort((a, b) => b[1] - a[1]);
const byProvider = Object.entries(summary.byProvider || {}).sort((a, b) => a[1] - b[1]);
const byCategory = Object.entries(summary.byCategory || {}).sort((a, b) => a[1] - b[1]);
---

<Layout title={`财务后台 - ${siteConfig.name}`} description="ProfitsLocal 收入、成本与 ROI 面板。" active="finance">
  <section class="poster-section admin-section">
    <div class="admin-shell">
      <div class="admin-header">
        <div>
          <p class="eyebrow">内部运营</p>
          <h1>财务</h1>
          <p class="lede">这里看业务的另一面：收入、成本、利润、供应商花费，以及哪些客户在支撑利润。</p>
        </div>
        <div class="admin-count">
          <strong>{summary.eventCount}</strong>
          <span>财务事件</span>
        </div>
      </div>

      <dl class="admin-meta-line admin-meta-line-wide">
        <div><dt>当前净额</dt><dd>{formatMoney(summary.profit || 0)}</dd></div>
        <div><dt>收入事件</dt><dd>{summary.revenueEventCount || 0}</dd></div>
        <div><dt>成本事件</dt><dd>{summary.costEventCount || 0}</dd></div>
        <div><dt>主要客户</dt><dd>{byClient[0]?.[0] || 'N/A'}</dd></div>
      </dl>

      <div class="admin-finance-grid">
        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">快照</span>
              <h2>损益总览</h2>
            </div>
          </div>
          <div class="admin-finance-metrics">
            <div><span>收入</span><strong>{formatMoney(summary.revenue || 0)}</strong></div>
            <div><span>成本</span><strong>{formatMoney(summary.cost || 0)}</strong></div>
            <div><span>利润</span><strong>{formatMoney(summary.profit || 0)}</strong></div>
            <div><span>ROI</span><strong>{summary.roi == null ? 'N/A' : `${(summary.roi * 100).toFixed(1)}%`}</strong></div>
          </div>
          <div class="admin-finance-meta">
            <span>{summary.revenueEventCount || 0} 条收入事件</span>
            <span>{summary.costEventCount || 0} 条成本事件</span>
          </div>
        </section>

        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">客户贡献</span>
              <h2>利润最高</h2>
            </div>
          </div>
          <ul class="admin-list">
            {byClient.length ? byClient.map(([client, amount]) => (
              <li><strong>{client}</strong><span>{formatMoney(amount)}</span></li>
            )) : <li>还没有客户级财务数据。</li>}
          </ul>
        </section>

        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">供应商花费</span>
              <h2>支出排行</h2>
            </div>
          </div>
          <ul class="admin-list">
            {byProvider.length ? byProvider.map(([provider, amount]) => (
              <li><strong>{provider}</strong><span>{formatMoney(amount)}</span></li>
            )) : <li>还没有供应商数据。</li>}
          </ul>
        </section>
      </div>

      <div class="admin-finance-grid">
        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">成本分类</span>
              <h2>花费结构</h2>
            </div>
          </div>
          <ul class="admin-list">
            {byCategory.length ? byCategory.map(([category, amount]) => (
              <li><strong>{category.replaceAll('_', ' ')}</strong><span>{formatMoney(amount)}</span></li>
            )) : <li>还没有分类数据。</li>}
          </ul>
        </section>

        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">读法提示</span>
              <h2>先看这几项</h2>
            </div>
          </div>
          <ul class="admin-list">
            <li><strong>利润为正</strong><span>{summary.profit > 0 ? '是' : '否'}</span></li>
            <li><strong>主要花费</strong><span>{byProvider[0]?.[0] || 'N/A'}</span></li>
            <li><strong>主要客户</strong><span>{byClient[0]?.[0] || 'N/A'}</span></li>
            <li><strong>账本路径</strong><span><code>data/finance/ledger.jsonl</code></span></li>
          </ul>
        </section>
      </div>
    </div>
  </section>
</Layout>
