---
import fs from 'fs';
import path from 'path';
import Layout from '../../../layouts/AdminLayout.astro';
import { cheapAuditV2 } from '../../../../core/scoring/cheap-audit-v2.js';

export async function getStaticPaths() {
  const entitiesDir = path.join(process.cwd(), 'data/leads/entities');
  if (!fs.existsSync(entitiesDir)) return [];
  return fs.readdirSync(entitiesDir)
    .filter((f) => f.endsWith('.json'))
    .map((f) => {
      try {
        const e = JSON.parse(fs.readFileSync(path.join(entitiesDir, f), 'utf8'));
        return { params: { slug: e.entityKey }, props: { entity: e } };
      } catch {
        return null;
      }
    })
    .filter(Boolean);
}

const { entity } = Astro.props;
const latest = entity.latest || {};
const audit = cheapAuditV2({ entity, sourceQuery: latest.sourceQuery });
const stage1Rules = audit.stage_1.rules;
const stage2Rules = audit.stage_2 ? audit.stage_2.rules : [];

const ratingDisplay = latest.rating || '-';
const reviewDisplay = latest.review_count || 0;
const addressDisplay = latest.address || latest.city || '地址未知';
const websiteStatus = latest.websiteStatus || 'unknown';
const auditJson = JSON.stringify(audit, null, 2);

function chipClass(action) {
  const a = String(action || '');
  if (a === 'audit_candidate') return 'chip-mint';
  if (a === 'starter_candidate') return 'chip-citrus';
  if (a === 'manual_review') return 'chip-sky';
  if (a === 'queued_for_enrichment') return 'chip-lilac';
  if (a === 'skip') return 'chip-coral';
  return '';
}

const actionLabel = audit.action.replace(/_/g, ' ');
const niche = (latest.niche || 'lead').toUpperCase();
const cityLabel = (latest.city || latest.address?.split(',').pop()?.trim() || '').toUpperCase();
---

<Layout title={`Lead · ${latest.name || entity.entityKey}`} active="leads">
  <section class="poster-section admin-section">
    <div class="admin-shell lead-admin-shell lead-detail-shell" data-ui-version="local-style-2026-05-08">
      <header class="admin-header">
        <div>
          <a href="/admin/leads" class="back-link">← 线索列表</a>
          <p class="eyebrow"><span>{niche}</span>{cityLabel && <><span> · </span><span>{cityLabel}</span></>}</p>
          <h1>{latest.name || entity.entityKey}</h1>
          <p class="lede">
            <span class="rating">★ {ratingDisplay}</span>
            <span class="reviews">{reviewDisplay} reviews</span>
            <span class="dot">·</span>
            <span class="addr">{addressDisplay}</span>
          </p>
          <div class="meta-tags">
            <span class={`chip ${chipClass(audit.action)}`}>{actionLabel}</span>
            <code class="status-code">{websiteStatus}</code>
            {latest.google_maps_url && <a href={latest.google_maps_url} class="map-link" target="_blank" rel="noopener">Google Maps ↗</a>}
          </div>
        </div>
        <div class="admin-count">
          <span>FINAL SCORE</span>
          <strong>{audit.final_score}</strong>
          <span class="micro-note">{audit.reason}</span>
        </div>
      </header>

      <div class="admin-summary-strip score-strip">
        <div class="admin-summary-tile dim-tile">
          <span>GBP quality</span>
          <strong>{audit.gbp_quality}</strong>
          <p>权重 40 · GBP 信号完整度</p>
          <div class="dim-bar"><div class="dim-fill gbp-fill" style={`width: ${audit.gbp_quality}%`}></div></div>
        </div>
        <div class={`admin-summary-tile dim-tile ${audit.redesign_need == null ? 'dim-empty' : ''}`}>
          <span>Redesign need</span>
          <strong>{audit.redesign_need == null ? '—' : audit.redesign_need}</strong>
          <p>权重 60 · 网站需 redesign 程度{audit.redesign_need == null && <span class="hint"> · 未抓站</span>}</p>
          <div class="dim-bar"><div class="dim-fill redesign-fill" style={`width: ${audit.redesign_need || 0}%`}></div></div>
        </div>
        <div class="admin-summary-tile dim-tile">
          <span>Formula</span>
          <strong class="formula-num">gbp × .4 + redesign × .6</strong>
          <p>= <b>{audit.final_score}</b></p>
          {audit.fired_triggers.length > 0 && (
            <p class="trigger-row">trigger: <code>{audit.fired_triggers.join(', ')}</code></p>
          )}
        </div>
      </div>

      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">Stage 1 · GBP triage</p>
            <h2>分项明细</h2>
          </div>
          <span class="admin-section-count">
            {audit.stage_1.earned_total} / {audit.stage_1.max_total} · 完整算法在
            <a href="/admin/scoring" class="inline-link">/admin/scoring</a>
          </span>
        </div>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr><th>规则</th><th>命中</th><th>得分</th><th>原因</th></tr>
            </thead>
            <tbody>
              {stage1Rules.map((r) => {
                return (
                  <tr class={r.hit ? 'hit-row' : 'miss-row'}>
                    <td><code>{r.id}</code></td>
                    <td>{r.hit ? <span class="check">✓</span> : <span class="x">✗</span>}</td>
                    <td class="num"><strong>{r.earned}</strong> / {r.max}</td>
                    <td class="rationale">{r.rationale}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </section>

      {audit.stage_2 && (
        <section class="admin-paper-section">
          <div class="admin-paper-section-head">
            <div>
              <p class="eyebrow">Stage 2 · Site quick-scan</p>
              <h2>网页规则明细</h2>
            </div>
            <span class="admin-section-count">{audit.stage_2.earned_total} / {audit.stage_2.max_total}</span>
          </div>
          <p class="fetch-meta">
            <span>fetched <code>{audit.stage_2.evidence.url}</code></span>
            <span class="dot">·</span>
            <span>{audit.stage_2.evidence.markdown_length} chars</span>
            <span class="dot">·</span>
            <span>{audit.stage_2.evidence.rules_evaluated}/{audit.stage_2.evidence.rules_evaluated + audit.stage_2.evidence.rules_skipped} rules evaluated</span>
          </p>
          <div class="admin-table-wrap">
            <table class="admin-table">
              <thead>
                <tr><th>规则</th><th>命中</th><th>得分</th><th>原因</th></tr>
              </thead>
              <tbody>
                {stage2Rules.map((r) => {
                  const cls = r.not_evaluated ? 'skip-row' : (r.hit ? 'hit-row' : 'miss-row');
                  return (
                    <tr class={cls}>
                      <td><code>{r.id}</code></td>
                      <td>
                        {r.not_evaluated ? <span class="dash">—</span> : (r.hit ? <span class="check">✓</span> : <span class="x">✗</span>)}
                      </td>
                      <td class="num"><strong>{r.earned}</strong> / {r.max}</td>
                      <td class="rationale">{r.rationale}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </section>
      )}

      {!audit.stage_2 && (
        <section class="admin-paper-section stage2-skipped">
          <div class="admin-paper-section-head">
            <div>
              <p class="eyebrow">Stage 2</p>
              <h2>未抓取网站</h2>
            </div>
          </div>
          <p>{websiteStatus === 'no_website' ? '无网站，按 starter 路径决策（不需要 redesign_need）' : '需要先 Tinyfish fetch homepage 后再跑 Stage 2'}</p>
        </section>
      )}

      <section class="admin-paper-section raw-section">
        <details>
          <summary>raw cheap-audit-v2 output</summary>
          <pre>{auditJson}</pre>
        </details>
      </section>
    </div>
  </section>
</Layout>

<style>
  /* most chrome inherited from global local-style-2026-05-08 */
  .lead-detail-shell .admin-header { gap: 24px; }
  .lead-detail-shell .admin-header h1 {
    font-family: var(--pl-display);
    font-size: clamp(32px, 3.6vw, 52px);
    font-weight: 950;
    line-height: 1.05;
    letter-spacing: 0;
    margin: 4px 0 0;
    max-width: 760px;
    word-break: normal;
    overflow-wrap: anywhere;
  }
  .back-link {
    display: inline-block;
    color: var(--pl-muted);
    font-size: 13px; font-weight: 850;
    text-decoration: none;
    margin-bottom: 8px;
  }
  .back-link:hover { color: var(--pl-coral); }
  .lead-detail-shell .admin-header .lede {
    display: flex; gap: 10px; flex-wrap: wrap; align-items: baseline;
    font-size: 16px; font-weight: 800;
  }
  .rating { font-weight: 950; color: var(--pl-coral); }
  .reviews { font-weight: 850; }
  .addr { color: var(--pl-muted); font-weight: 800; }
  .dot { color: rgba(23,25,28,0.3); font-weight: 800; }

  .meta-tags {
    margin-top: 14px;
    display: flex; gap: 10px; flex-wrap: wrap; align-items: center;
  }
  .status-code {
    background: var(--pl-paper);
    border: 2px solid var(--pl-line);
    color: var(--pl-ink);
    padding: 3px 10px;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 11px; font-weight: 850;
  }
  .map-link {
    color: var(--pl-blue);
    font-size: 12.5px; font-weight: 950;
    text-decoration: none;
  }
  .map-link:hover { text-decoration: underline; }

  .lead-detail-shell .admin-count {
    background: var(--pl-citrus);
    border: 2px solid var(--pl-line);
    padding: 16px 14px;
    text-align: center;
    min-width: 158px;
  }
  .lead-detail-shell .admin-count > span:first-child {
    display: block;
    font-size: 10.5px; font-weight: 950;
    letter-spacing: 0.1em;
    color: var(--pl-ink);
  }
  .lead-detail-shell .admin-count strong {
    display: block;
    margin: 6px 0;
    font-family: var(--pl-display);
    font-size: 60px; font-weight: 950;
    line-height: 1;
    color: var(--pl-ink);
  }
  .lead-detail-shell .admin-count .micro-note {
    display: block;
    font-size: 11px; font-weight: 850;
    color: var(--pl-ink);
    line-height: 1.35;
    max-width: 200px; margin: 4px auto 0;
  }

  .score-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-bottom: 2px solid var(--pl-line);
    background: color-mix(in srgb, white 42%, var(--pl-paper));
  }
  .dim-tile {
    padding: 22px 24px;
    border-right: 2px solid var(--pl-line);
    min-height: 138px;
  }
  .dim-tile:last-child { border-right: 0; }
  .dim-tile span:first-child {
    font-size: 11px; font-weight: 950;
    color: var(--pl-ink);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .dim-tile strong {
    display: block;
    margin: 8px 0;
    font-family: var(--pl-display);
    font-size: 44px; font-weight: 950;
    line-height: 1;
    color: var(--pl-ink);
  }
  .dim-tile .formula-num {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 14px;
    color: var(--pl-muted);
    line-height: 1.4;
    font-weight: 850;
  }
  .dim-tile p {
    margin: 0;
    font-size: 12px; font-weight: 850;
    color: var(--pl-muted);
    line-height: 1.4;
  }
  .dim-tile .trigger-row { margin-top: 8px; }
  .dim-tile .trigger-row code {
    background: var(--pl-mint);
    border: 1.5px solid var(--pl-line);
    color: var(--pl-ink);
    padding: 2px 8px;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 11px; font-weight: 950;
  }
  .dim-tile .hint { color: var(--pl-coral); font-weight: 950; }
  .dim-bar {
    margin-top: 10px;
    height: 8px;
    background: var(--pl-paper);
    border: 1.5px solid var(--pl-line);
    overflow: hidden;
  }
  .dim-fill { height: 100%; transition: width 0.4s ease; }
  .gbp-fill { background: var(--pl-blue); }
  .redesign-fill { background: var(--pl-coral); }
  .dim-empty .dim-bar .dim-fill { background: rgba(23,25,28,0.15); width: 0; }

  .lead-detail-shell .admin-paper-section {
    padding: 24px 30px;
    border-top: 2px solid var(--pl-line);
  }
  .lead-detail-shell .admin-paper-section h2 {
    font-family: var(--pl-display);
    font-size: clamp(26px, 2.4vw, 38px);
    font-weight: 950;
    line-height: 1.1;
    max-width: none;
    margin: 4px 0 0;
  }
  .lead-detail-shell .admin-section-count {
    font-size: 13px; font-weight: 850;
    color: var(--pl-muted);
  }
  .inline-link {
    color: var(--pl-coral);
    font-weight: 950;
    text-decoration: none;
  }
  .inline-link:hover { text-decoration: underline; }
  .fetch-meta {
    margin: 4px 0 14px;
    color: var(--pl-muted);
    font-size: 12.5px; font-weight: 800;
    display: flex; gap: 10px; flex-wrap: wrap;
  }
  .fetch-meta code {
    background: var(--pl-paper);
    border: 1.5px solid var(--pl-line);
    color: var(--pl-ink);
    padding: 1px 8px;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 11.5px; font-weight: 800;
  }

  /* table — sharp 2px border, citrus header band */
  .lead-detail-shell .admin-table {
    width: 100%; border-collapse: separate; border-spacing: 0;
    border: 2px solid var(--pl-line);
    background: var(--pl-paper);
  }
  .lead-detail-shell .admin-table th {
    position: static !important;
    text-align: left;
    padding: 12px 14px;
    font-size: 11px; font-weight: 950;
    color: var(--pl-ink);
    text-transform: uppercase; letter-spacing: 0.08em;
    background: color-mix(in srgb, var(--pl-citrus) 55%, var(--pl-paper));
    border-bottom: 2px solid var(--pl-line);
    box-shadow: none;
  }
  .lead-detail-shell .admin-table td {
    padding: 12px 14px;
    font-size: 13px; font-weight: 700;
    border-bottom: 1.5px solid rgba(23,25,28,0.12);
    vertical-align: top;
  }
  .lead-detail-shell .admin-table tr:last-child td { border-bottom: 0; }
  .lead-detail-shell .admin-table td.num {
    font-variant-numeric: tabular-nums;
    font-weight: 850;
  }
  .lead-detail-shell .admin-table td.num strong { font-family: var(--pl-display); font-size: 16px; font-weight: 950; }
  .lead-detail-shell .admin-table tr.hit-row td.num strong { color: var(--pl-green); }
  .lead-detail-shell .admin-table tr.miss-row td.num strong { color: var(--pl-muted); }
  .lead-detail-shell .admin-table tr.skip-row td { color: rgba(23,25,28,0.35); font-style: italic; }
  .lead-detail-shell .admin-table td.rationale { color: var(--pl-muted); font-weight: 800; }
  .lead-detail-shell .admin-table .check { color: var(--pl-green); font-weight: 950; font-size: 16px; }
  .lead-detail-shell .admin-table .x { color: rgba(23,25,28,0.3); font-weight: 950; font-size: 16px; }
  .lead-detail-shell .admin-table .dash { color: rgba(23,25,28,0.3); }
  .lead-detail-shell .admin-table code {
    background: var(--pl-cream);
    border: 1.5px solid var(--pl-line);
    color: var(--pl-ink);
    padding: 1px 8px;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 11.5px; font-weight: 800;
  }

  .chip {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 0;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 11px; font-weight: 950;
    letter-spacing: 0.02em;
    background: var(--pl-paper);
    color: var(--pl-ink);
    border: 2px solid var(--pl-line);
  }
  .chip-mint { background: var(--pl-mint); }
  .chip-citrus { background: var(--pl-citrus); }
  .chip-coral { background: var(--pl-coral); color: white; }
  .chip-sky { background: var(--pl-sky); }
  .chip-lilac { background: var(--pl-lilac); }

  .stage2-skipped p { color: var(--pl-muted); font-weight: 800; margin: 6px 0 0; }

  .raw-section details { padding: 0; }
  .raw-section summary {
    cursor: pointer;
    color: var(--pl-muted);
    font-size: 13px; font-weight: 850;
    padding: 8px 0;
  }
  .raw-section summary:hover { color: var(--pl-coral); }
  .raw-section pre {
    background: var(--pl-paper);
    border: 2px solid var(--pl-line);
    box-shadow: 4px 4px 0 var(--pl-line);
    padding: 14px 16px;
    font-size: 11.5px;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    max-height: 420px;
    overflow: auto;
    margin: 8px 0 0;
  }

  @media (max-width: 900px) {
    .score-strip { grid-template-columns: 1fr; }
    .dim-tile { border-right: 0; border-bottom: 2px solid var(--pl-line); }
    .dim-tile:last-child { border-bottom: 0; }
    .lead-detail-shell .admin-header { grid-template-columns: 1fr; }
  }
</style>
