---
import Layout from '../../layouts/AdminLayout.astro';
import { loadCheapAuditConfig } from '../../../core/scoring/cheap-audit-v2.js';

const config = loadCheapAuditConfig();
const stage1 = config.stages.stage_1_gbp_triage;
const stage2 = config.stages.stage_2_site_quick_scan;
const stage05 = config.stages.stage_0_5_enrichment_gate;
const totalRules = stage1.rules.length + stage2.rules.length;

function fmtRule(rule) {
  if (rule.deduct_tiers || rule.earn_tiers) {
    const tiers = rule.deduct_tiers || rule.earn_tiers;
    return tiers.map((t) => `${t.if} → +${t.earn}`).join(' / ');
  }
  if (rule.deduct_if) return `miss → -${rule.max} (max ${rule.max})`;
  if (rule.earn_if_missing) return `if missing → +${rule.earn_if_missing} redesign_need`;
  if (rule.earn_if_present) return `if present → +${rule.earn_if_present} redesign_need`;
  if (rule.earn_if_stale) return `if stale → +${rule.earn_if_stale}`;
  return `max ${rule.max}`;
}

function chipClass(action) {
  const a = String(action || '');
  if (a === 'audit_candidate') return 'chip-mint';
  if (a === 'starter_candidate') return 'chip-citrus';
  if (a === 'manual_review') return 'chip-sky';
  if (a === 'queued_for_enrichment') return 'chip-lilac';
  if (a === 'skip') return 'chip-coral';
  return '';
}
---

<Layout title="算法定义 — Cheap Audit V2" active="scoring">
  <section class="poster-section admin-section">
    <div class="admin-shell lead-admin-shell scoring-shell" data-ui-version="local-style-2026-05-08">
      <header class="admin-header">
        <div>
          <p class="eyebrow">算法定义</p>
          <h1>Cheap Audit V2</h1>
          <p class="lede">{config.purpose}</p>
          <p class="meta-line">
            <span>config <code>{config.version}</code></span>
            <span class="dot">·</span>
            <span>source <code>core/scoring/cheap-audit-config.json</code></span>
          </p>
        </div>
        <div class="admin-count">
          <span>规则数</span>
          <strong>{totalRules}</strong>
          <span class="micro-note">两段 + {config.hard_triggers.length} 个 hard trigger</span>
        </div>
      </header>

      <div class="philosophy-strip">
        <p class="eyebrow">设计哲学</p>
        <p>{config.philosophy}</p>
      </div>

      <section class="admin-paper-section flow-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">Lead 分流流程</p>
            <h2>从抓取到决策的完整路径</h2>
          </div>
          <span class="admin-section-count">5 个步骤 · 4 个 hard trigger · 4 档阈值</span>
        </div>

        <div class="flow-grid">
          <!-- Row 1: ENTRY -->
          <div class="flow-row">
            <div class="flow-row-label">入口</div>
            <div class="flow-entries">
              <div class="flow-entry">
                <div class="flow-entry-tag">maps_scraper</div>
                <div class="flow-entry-desc">Google Maps 抓取（主入口）</div>
              </div>
              <div class="flow-entry">
                <div class="flow-entry-tag">image-discovery</div>
                <div class="flow-entry-desc">图片识别商家</div>
              </div>
              <div class="flow-entry">
                <div class="flow-entry-tag">manual intake</div>
                <div class="flow-entry-desc">手工 / 转介绍</div>
              </div>
            </div>
          </div>
          <div class="flow-arrow-row">▼</div>

          <!-- Row 2: DISCOVERY STORE -->
          <div class="flow-step">
            <div class="flow-step-num">0</div>
            <div class="flow-step-body">
              <div class="flow-step-title">Discovery store</div>
              <div class="flow-step-desc">data/leads/entities/&lt;entity-key&gt;.json &nbsp;·&nbsp; 去重 + 历史轨迹</div>
            </div>
          </div>
          <div class="flow-arrow-row">▼</div>

          <!-- Row 3: STAGE 0.5 -->
          <div class="flow-step flow-step-conditional">
            <div class="flow-step-num">0.5</div>
            <div class="flow-step-body">
              <div class="flow-step-title">Enrichment-before-skip 门槛</div>
              <div class="flow-step-desc">联系方式不足 → 5 路 search 强制补全（Tinyfish / DDGS / Doko）→ 回到 Stage 1 重判</div>
              <div class="flow-step-meta">条件触发 · 仅 thin-contact 走</div>
            </div>
          </div>
          <div class="flow-arrow-row">▼</div>

          <!-- Row 4: STAGE 1 -->
          <div class="flow-step">
            <div class="flow-step-num">1</div>
            <div class="flow-step-body">
              <div class="flow-step-title">Stage 1 · GBP triage <span class="flow-step-badge">always</span></div>
              <div class="flow-step-desc">9 项规则 · 满分 100 · 仅读 maps payload · T0 零成本</div>
              <div class="flow-step-out">
                <span class="flow-out-fail">category 不匹配 → SKIP（hard）</span>
              </div>
            </div>
          </div>
          <div class="flow-arrow-row">▼</div>

          <!-- Row 5: BRANCH -->
          <div class="flow-branch">
            <div class="flow-branch-label">hasWebsite ?</div>
            <div class="flow-branch-arrows">
              <div class="flow-branch-arrow">no</div>
              <div class="flow-branch-arrow">yes</div>
            </div>
            <div class="flow-branch-paths">
              <div class="flow-step flow-step-no-site">
                <div class="flow-step-body">
                  <div class="flow-step-title">无网站路径</div>
                  <div class="flow-step-desc">联系方式可达 → <span class="chip chip-citrus">starter_candidate</span> · 不跑 Stage 2</div>
                </div>
              </div>
              <div class="flow-step">
                <div class="flow-step-num">2</div>
                <div class="flow-step-body">
                  <div class="flow-step-title">Stage 2 · Site quick-scan</div>
                  <div class="flow-step-desc">Tinyfish fetch 首页 → 10 项 redesign 启发式 · 满分 100 · T0</div>
                </div>
              </div>
            </div>
          </div>
          <div class="flow-arrow-row">▼</div>

          <!-- Row 6: HARD TRIGGERS -->
          <div class="flow-step flow-step-trigger">
            <div class="flow-step-num">★</div>
            <div class="flow-step-body">
              <div class="flow-step-title">Hard triggers 检查</div>
              <div class="flow-step-desc">4 条强制覆盖规则（无网站可达 → starter / HTTP+评论 ≥50 → audit / 评论 ≥100 ★≥4.5 抬升下限 / ...）</div>
            </div>
          </div>
          <div class="flow-arrow-row">▼</div>

          <!-- Row 7: FINAL DECISION -->
          <div class="flow-step">
            <div class="flow-step-num">3</div>
            <div class="flow-step-body">
              <div class="flow-step-title">Final score · 阈值映射</div>
              <div class="flow-step-desc"><code>final = gbp_quality × 0.4 + redesign_need × 0.6</code></div>
            </div>
          </div>
          <div class="flow-arrow-row">▼</div>

          <!-- Row 8: OUTCOMES -->
          <div class="flow-outcomes">
            <div class="flow-outcome">
              <span class="chip chip-mint">audit_candidate</span>
              <div class="flow-outcome-desc">≥ 70 · 进入 Block D 详细 audit</div>
            </div>
            <div class="flow-outcome">
              <span class="chip chip-citrus">starter_candidate</span>
              <div class="flow-outcome-desc">无网站 + 可达 · 易成交</div>
            </div>
            <div class="flow-outcome">
              <span class="chip chip-sky">manual_review</span>
              <div class="flow-outcome-desc">30-69 · 等 operator 看</div>
            </div>
            <div class="flow-outcome">
              <span class="chip chip-coral">skip</span>
              <div class="flow-outcome-desc">&lt; 30 · 不推进</div>
            </div>
          </div>
        </div>
      </section>

      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">Stage 0.5</p>
            <h2>Enrichment-before-skip 门槛</h2>
          </div>
        </div>
        <p class="section-lede">{stage05.description}</p>
        <div class="rule-grid two">
          <div class="rule-list">
            <p class="eyebrow accent-coral">触发 enrichment</p>
            <ul>
              {stage05.triggers_enrichment_if.map((t) => <li><code>{t}</code></li>)}
            </ul>
          </div>
          <div class="rule-list">
            <p class="eyebrow accent-muted">立即 skip</p>
            <ul>
              {stage05.skips_immediately_if.map((t) => <li><code>{t}</code></li>)}
            </ul>
          </div>
        </div>
      </section>

      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">Stage 1 · 满分 {stage1.max_score}</p>
            <h2>GBP triage</h2>
          </div>
          <span class="admin-section-count">{stage1.rules.length} 项</span>
        </div>
        <p class="section-lede">{stage1.description}</p>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr><th>规则</th><th>检测</th><th>满分</th><th>评分规则</th></tr>
            </thead>
            <tbody>
              {stage1.rules.map((r) => (
                <tr>
                  <td>
                    <code>{r.id}</code>
                    {r.is_hard_skip && <span class="chip chip-coral">hard-skip</span>}
                  </td>
                  <td>{r.check}</td>
                  <td class="num">{r.max}</td>
                  <td class="formula">{fmtRule(r)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">Stage 2 · 满分 {stage2.max_score}</p>
            <h2>Website quick scan</h2>
          </div>
          <span class="admin-section-count">{stage2.rules.length} 项</span>
        </div>
        <p class="section-lede">{stage2.description}</p>
        <p class="skip-note">⤳ skip when: <code>{stage2.skipped_when}</code></p>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr><th>规则</th><th>检测</th><th>满分</th><th>判定</th><th>意义</th></tr>
            </thead>
            <tbody>
              {stage2.rules.map((r) => (
                <tr>
                  <td><code>{r.id}</code></td>
                  <td>{r.check}</td>
                  <td class="num">{r.max}</td>
                  <td class="formula">{fmtRule(r)}</td>
                  <td class="rationale">{r.rationale}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">最终评分</p>
            <h2>Final score formula</h2>
          </div>
        </div>
        <p class="formula-line"><code>{config.scoring.formula}</code></p>
        <p class="rationale-line">{config.scoring.rationale}</p>
      </section>

      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">Hard triggers</p>
            <h2>强制覆盖阈值的规则</h2>
          </div>
          <span class="admin-section-count">{config.hard_triggers.length} 条</span>
        </div>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead><tr><th>触发条件</th><th>强制动作</th><th>原因</th></tr></thead>
            <tbody>
              {config.hard_triggers.map((t) => (
                <tr>
                  <td><code>{t.if}</code></td>
                  <td>
                    <span class={`chip ${chipClass(t.force_action || t.force_action_min)}`}>{t.force_action || t.force_action_min || '—'}</span>
                    {t.force_action_min && <span class="hint">lift floor</span>}
                  </td>
                  <td class="rationale">{t.rationale}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">阈值</p>
            <h2>Score → action 映射</h2>
          </div>
        </div>
        <div class="threshold-grid">
          {config.thresholds.map((t) => (
            <div class="threshold-card">
              <div class="threshold-min">≥ {t.min}</div>
              <div class={`chip ${chipClass(t.action)}`}>{t.action}</div>
              <p>{t.label}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">No-website 路径</p>
            <h2>Starter candidate 决策</h2>
          </div>
        </div>
        <p class="section-lede">{config.starter_candidate_path.description}</p>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead><tr><th>条件</th><th>动作</th><th>原因</th></tr></thead>
            <tbody>
              {config.starter_candidate_path.decision_rules.map((r) => (
                <tr>
                  <td><code>{r.if}</code></td>
                  <td><span class={`chip ${chipClass(r.action)}`}>{r.action}</span></td>
                  <td class="rationale">{r.rationale}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">显性化映射</p>
            <h2>这份算法在哪里可见</h2>
          </div>
        </div>
        <ul class="ui-map">
          {Object.entries(config.ui_visibility).map((entry) => (
            <li><code>{entry[0]}</code> → {entry[1]}</li>
          ))}
        </ul>
      </section>
    </div>
  </section>
</Layout>

<style>
  /* most chrome inherited from global local-style-2026-05-08 system */
  .scoring-shell .admin-header { gap: 18px; }

  /* ─── Flow diagram ─── */
  .flow-section { background: color-mix(in srgb, white 50%, var(--pl-paper)); }
  .flow-grid {
    display: flex; flex-direction: column; align-items: stretch;
    gap: 0; max-width: 920px; margin: 0 auto;
    padding: 14px 0 6px;
  }

  .flow-row { display: flex; flex-direction: column; gap: 8px; }
  .flow-row-label {
    font-size: 11px; font-weight: 950;
    color: var(--pl-muted);
    letter-spacing: 0.1em; text-transform: uppercase;
    text-align: center;
  }
  .flow-entries { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .flow-entry {
    border: 2px solid var(--pl-line);
    background: var(--pl-paper);
    padding: 12px 14px;
    box-shadow: 3px 3px 0 var(--pl-line);
  }
  .flow-entry-tag {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 12px; font-weight: 950;
    color: var(--pl-coral);
    margin-bottom: 4px;
  }
  .flow-entry-desc { font-size: 12px; font-weight: 800; color: var(--pl-ink); }

  .flow-arrow-row {
    text-align: center;
    font-size: 18px; font-weight: 950;
    color: var(--pl-line);
    line-height: 1;
    margin: 10px 0;
  }

  .flow-step {
    display: grid; grid-template-columns: 56px 1fr;
    gap: 0;
    border: 2px solid var(--pl-line);
    background: var(--pl-paper);
    box-shadow: 4px 4px 0 var(--pl-line);
  }
  .flow-step-num {
    background: var(--pl-line);
    color: var(--pl-paper);
    font-family: var(--pl-display);
    font-size: 28px; font-weight: 950;
    line-height: 1;
    display: flex; align-items: center; justify-content: center;
    padding: 16px 0;
  }
  .flow-step-body { padding: 14px 18px; }
  .flow-step-title {
    font-family: var(--pl-display);
    font-size: 18px; font-weight: 950;
    line-height: 1.2;
    margin-bottom: 6px;
    color: var(--pl-ink);
  }
  .flow-step-title .flow-step-badge {
    display: inline-block;
    background: var(--pl-citrus);
    border: 1.5px solid var(--pl-line);
    color: var(--pl-ink);
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 10.5px; font-weight: 950;
    padding: 1px 6px;
    margin-left: 8px;
    vertical-align: middle;
  }
  .flow-step-desc {
    font-size: 13px; font-weight: 800;
    line-height: 1.45;
    color: var(--pl-ink);
  }
  .flow-step-desc code {
    background: var(--pl-cream);
    border: 1.5px solid var(--pl-line);
    padding: 1px 6px;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 11.5px; font-weight: 850;
  }
  .flow-step-meta {
    margin-top: 6px;
    font-size: 11.5px; font-weight: 800;
    color: var(--pl-muted);
    font-style: italic;
  }
  .flow-step-out {
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1.5px dashed rgba(23,25,28,0.18);
  }
  .flow-out-fail {
    display: inline-block;
    font-size: 11.5px; font-weight: 850;
    color: var(--pl-coral);
  }

  .flow-step-conditional .flow-step-num { background: var(--pl-lilac); color: var(--pl-ink); }
  .flow-step-trigger .flow-step-num { background: var(--pl-coral); color: var(--pl-paper); }
  .flow-step-no-site .flow-step-num { display: none; }
  .flow-step-no-site { grid-template-columns: 1fr; }
  .flow-step-no-site .flow-step-body { padding: 14px 18px; }

  .flow-branch {
    display: grid;
    grid-template-rows: auto auto auto;
    gap: 8px;
  }
  .flow-branch-label {
    text-align: center;
    font-family: var(--pl-display);
    font-size: 17px; font-weight: 950;
    padding: 8px 14px;
    background: var(--pl-citrus);
    border: 2px solid var(--pl-line);
    box-shadow: 3px 3px 0 var(--pl-line);
    width: fit-content; margin: 0 auto;
  }
  .flow-branch-arrows {
    display: grid; grid-template-columns: 1fr 1fr;
    text-align: center;
  }
  .flow-branch-arrow {
    font-size: 13px; font-weight: 950;
    color: var(--pl-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    position: relative;
    padding-bottom: 22px;
  }
  .flow-branch-arrow::after {
    content: '▼';
    position: absolute;
    bottom: 0; left: 50%;
    transform: translateX(-50%);
    color: var(--pl-line);
    font-size: 16px;
  }
  .flow-branch-paths {
    display: grid; grid-template-columns: 1fr 1fr; gap: 12px;
  }

  .flow-outcomes {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 0;
    border: 2px solid var(--pl-line);
    background: var(--pl-paper);
  }
  .flow-outcome {
    padding: 14px 14px;
    border-right: 2px solid var(--pl-line);
    display: flex; flex-direction: column; gap: 8px; align-items: flex-start;
  }
  .flow-outcome:last-child { border-right: 0; }
  .flow-outcome-desc {
    font-size: 11.5px; font-weight: 850;
    color: var(--pl-muted);
    line-height: 1.4;
  }

  @media (max-width: 800px) {
    .flow-entries { grid-template-columns: 1fr; }
    .flow-branch-paths { grid-template-columns: 1fr; }
    .flow-outcomes { grid-template-columns: 1fr 1fr; }
    .flow-outcome { border-right: 0; border-bottom: 2px solid var(--pl-line); }
    .flow-outcome:nth-child(2n) { border-right: 0; }
    .flow-outcome:last-child, .flow-outcome:nth-last-child(2) { border-bottom: 0; }
  }
  /* ─── end flow ─── */

  .scoring-shell .admin-header .meta-line {
    margin-top: 14px;
    color: var(--pl-muted);
    font-size: 13px; font-weight: 800;
    display: flex; gap: 8px; flex-wrap: wrap;
  }
  .scoring-shell .meta-line .dot { color: rgba(23,25,28,0.3); }
  .scoring-shell .meta-line code {
    background: var(--pl-paper); border: 1.5px solid var(--pl-line);
    padding: 1px 8px; font-size: 12px;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-weight: 700;
  }
  .scoring-shell .admin-count strong {
    font-family: var(--pl-display);
    font-size: 44px; line-height: 1; font-weight: 950;
    margin: 4px 0;
  }
  .scoring-shell .admin-count .micro-note {
    display: block; margin-top: 6px;
    font-size: 11px; font-weight: 850;
    color: var(--pl-ink); opacity: 0.7;
  }

  .philosophy-strip {
    border-bottom: 2px solid var(--pl-line);
    background: var(--pl-peach);
    padding: 18px 30px;
  }
  .philosophy-strip p:last-child {
    margin: 6px 0 0;
    font-size: 15px; font-weight: 700;
    line-height: 1.55;
    max-width: 80ch;
  }

  .scoring-shell .admin-paper-section {
    padding: 22px 30px;
    border-top: 2px solid var(--pl-line);
  }
  .scoring-shell .admin-paper-section-head h2 {
    font-family: var(--pl-display);
    font-size: clamp(26px, 2.4vw, 38px);
    font-weight: 950;
    letter-spacing: 0;
    line-height: 1.1;
    max-width: none;
    margin: 4px 0 0;
  }
  .section-lede {
    color: var(--pl-ink);
    font-weight: 800;
    margin: 6px 0 16px;
    max-width: 80ch;
    line-height: 1.45;
    font-size: 14.5px;
  }
  .skip-note {
    color: var(--pl-muted);
    margin: -8px 0 14px;
    font-weight: 800; font-size: 13px;
  }

  .scoring-shell .admin-table {
    width: 100%; border-collapse: separate; border-spacing: 0;
    border: 2px solid var(--pl-line);
    background: var(--pl-paper);
  }
  .scoring-shell .admin-table th {
    position: static !important;
