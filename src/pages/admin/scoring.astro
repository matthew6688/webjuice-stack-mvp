---
import Layout from '../../layouts/AdminLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

// V2 entity snapshot (read entity store at build time for live status block)
const repoRoot = process.cwd();
const entitiesDir = path.join(repoRoot, 'data/leads/entities');
const detailedDir = path.join(repoRoot, 'data/v2/fixtures/detailed-audit');
const batchesDir = path.join(repoRoot, 'data/v2/pipeline-batches');

let entityCount = 0;
let gradeCounts = { A: 0, B: 0, C: 0, D: 0, ungraded: 0 };
let withDiscordThread = 0;
let detailedAudits = 0;
let batchCount = 0;

try {
  if (fs.existsSync(entitiesDir)) {
    const files = fs.readdirSync(entitiesDir).filter((f) => f.endsWith('.json'));
    entityCount = files.length;
    for (const f of files) {
      try {
        const e = JSON.parse(fs.readFileSync(path.join(entitiesDir, f), 'utf8'));
        const g = e.grade?.investment_level;
        if (g && gradeCounts[g] !== undefined) gradeCounts[g] += 1;
        else gradeCounts.ungraded += 1;
        if (e.discord_thread_id) withDiscordThread += 1;
      } catch {}
    }
  }
  if (fs.existsSync(detailedDir)) {
    detailedAudits = fs.readdirSync(detailedDir).filter((f) => f.endsWith('.json') && !f.startsWith('ledger-')).length;
  }
  if (fs.existsSync(batchesDir)) {
    batchCount = fs.readdirSync(batchesDir).filter((f) => f.endsWith('.json')).length;
  }
} catch {}

// 16 SOP catalog — single source of truth for what we have / what's coming
const sopCatalog = {
  lifecycle: {
    title: '🔵 Lifecycle Process SOPs',
    subtitle: '按业务阶段 · 每段 Discord channel 对应一个',
    items: [
      { id: 'SOP-1',  zh: '客户发现 Intake & Discovery',     status: '🟡 调研笔记中', href: '/admin/scoring/sop-1',    trigger: 'gosom Docker / image / search keywords', channel: '#lead-discovery-runs' },
      { id: 'SOP-2',  zh: '筛选 + 审计 Screening & Audit',   status: '✅ 有了 (本次润色)',  href: '/admin/scoring/sop-2',    trigger: 'cheap-audit-v2 + detailed audit + grade',  channel: '#lead-discovery-runs → #website-leads' },
      { id: 'SOP-3',  zh: 'Open Design 网站预制',             status: '⚪ 待写',         href: null,                       trigger: 'A 必做 / B 排完 A 做 / C 有意向也做',     channel: '#website-projects' },
      { id: 'SOP-4',  zh: '销售对接 Sales Engagement',       status: '⚪ 待写',         href: null,                       trigger: 'A/B/C lead 进入对接 → 多触点 outreach', channel: '#website-leads' },
      { id: 'SOP-5',  zh: '交付维护 Delivery & Maintenance', status: '⚪ 待写',         href: null,                       trigger: '客户付费',                              channel: '#paid-websites' },
    ],
  },
  artifact: {
    title: '🟡 Per-Lead Artifact SOPs',
    subtitle: '每客户独立的源真理资产 · 跨所有阶段不变',
    items: [
      { id: 'SOP-ART-1', zh: 'Master.md 维护协议',          status: '⚪ 待写', href: null, trigger: '所有下游素材的 source of truth' },
      { id: 'SOP-ART-2', zh: 'Internal Audit Report 协议',  status: '⚪ 待写', href: null, trigger: '11 sub-audit + 6 dim + 39 规则' },
      { id: 'SOP-ART-3', zh: '客户 Profile / Contact ID',   status: '⚪ 待写', href: null, trigger: '多触点：GMB / contact-us / social / phone / email' },
    ],
  },
  crossCutting: {
    title: '🟢 Cross-cutting Method / Infra SOPs',
    subtitle: '不绑定任何阶段 · 所有阶段都必须遵守',
    items: [
      { id: 'SOP-X-Discord',     zh: 'Discord 4-channel 架构 + 协议', status: '🔴 立刻写', href: null, trigger: '覆盖整个销售流程的载体' },
      { id: 'SOP-X-Pricing',     zh: '改价格协议',                    status: '🔴 立刻写', href: null, trigger: '改价漏点的纪律修正' },
      { id: 'SOP-X-Deploy',      zh: '前端部署验证协议',              status: '🔴 立刻写', href: null, trigger: '我刚 burned 的纪律' },
      { id: 'SOP-X-PhaseTrans',  zh: 'V2 phase 状态机',               status: '⚪ 待写',   href: null, trigger: '8 phase × setEntityPhase 谁负责' },
      { id: 'SOP-X-CronOps',     zh: 'Hermes cron 运维',              status: '⚪ 待写',   href: null, trigger: 'reply-poll / daily-tick / ttl 健康' },
      { id: 'SOP-X-CostLedger',  zh: '预算护栏 + 成本纪律',           status: '🟡 已有 doc',href: null, trigger: 'COST_DISCIPLINE 提为 SOP' },
      { id: 'SOP-X-Autoresearch',zh: 'Autoresearch 优化方法论',       status: '🟡 已有 doc',href: null, trigger: '自我优化循环 (Karpathy-style)' },
      { id: 'SOP-X-Backup',      zh: '备份 / 密钥轮换',               status: '⚪ 待写',   href: null, trigger: 'Discord bot / PSI / CF API key' },
    ],
  },
};

const sopTotal = sopCatalog.lifecycle.items.length + sopCatalog.artifact.items.length + sopCatalog.crossCutting.items.length;
const sopReady = [...sopCatalog.lifecycle.items, ...sopCatalog.artifact.items, ...sopCatalog.crossCutting.items]
  .filter((s) => s.status.startsWith('✅')).length;
const sopInProgress = [...sopCatalog.lifecycle.items, ...sopCatalog.artifact.items, ...sopCatalog.crossCutting.items]
  .filter((s) => s.status.includes('🟡')).length;
const sopUrgent = [...sopCatalog.lifecycle.items, ...sopCatalog.artifact.items, ...sopCatalog.crossCutting.items]
  .filter((s) => s.status.includes('🔴')).length;
---

<Layout title="SOP 总览 · 销售流水线" active="scoring">
  <section class="poster-section admin-section">
    <div class="admin-shell sop-shell" data-ui-version="local-style-2026-05-08">
      <header class="admin-header">
        <div>
          <p class="eyebrow">SOP 总览 · BUSINESS PIPELINE</p>
          <h1>ProfitsLocal 销售流水线总览</h1>
          <p class="zh-en-sub"><span>End-to-end Sales Pipeline</span></p>
          <p class="lede">从抓客户到成交付费交付——我们的整个销售流水线一页看清。每段流程都有独立 SOP；横切的资产 / 操作纪律有自己的 SOP。</p>

          <div class="usp-banner">
            <span class="usp-banner-icon">🎯</span>
            <div class="usp-banner-body">
              <strong>我们的差异化 / Our USP</strong>
              <p>「先做好网站，再去对接客户」<br/><em>Pre-build the website, then pitch — not the other way around.</em></p>
              <p class="usp-banner-note">这决定了我们的销售流程拓扑：A/B/C 都可能预制网站，A 优先，B 算力允许，C 看意向。</p>
            </div>
          </div>
        </div>

        <div class="admin-count">
          <span>SOP 总数</span>
          <strong>{sopTotal}</strong>
          <span class="micro-note">{sopReady} ready · {sopInProgress} in progress · {sopUrgent} urgent · 其余待写</span>
        </div>
      </header>

      <nav class="sop-tabs" aria-label="SOP navigation">
        <a href="/admin/scoring" class="sop-tab sop-tab--active" aria-current="page">
          <span class="sop-tab-id">📊 概览</span>
          <span class="sop-tab-zh">销售流水线总览</span>
          <span class="sop-tab-en">Overview</span>
        </a>
        <a href="/admin/scoring/sop-1" class="sop-tab">
          <span class="sop-tab-id">🎣 SOP-1</span>
          <span class="sop-tab-zh">客户发现</span>
          <span class="sop-tab-en">Intake & Discovery</span>
        </a>
        <a href="/admin/scoring/sop-2" class="sop-tab">
          <span class="sop-tab-id">🔍 SOP-2</span>
          <span class="sop-tab-zh">筛选 + 审计</span>
          <span class="sop-tab-en">Screening & Audit</span>
        </a>
      </nav>

      <!-- ─── SECTION 1 · USP 三分支销售漏斗 ────────────────────────────── -->
      <section class="admin-paper-section funnel-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">销售流水线 · 三分支模型</p>
            <h2>从发现到付费 · 完整漏斗 <span class="en-sub">Pipeline · Discovery → Pre-build → Sales → Pay</span></h2>
          </div>
          <span class="admin-section-count">5 段主流程 + USP 双路径</span>
        </div>

        <div class="funnel-grid">
          <!-- Row 1: Discovery -->
          <div class="funnel-step">
            <div class="funnel-step-num">1</div>
            <div class="funnel-step-body">
              <h3>客户发现 / Discovery</h3>
              <p>gosom Docker scraper (主) · image lead · 关键词 search</p>
              <p class="funnel-step-meta">→ entity 入库 · SOP-1</p>
            </div>
          </div>
          <div class="funnel-arrow">▼</div>

          <!-- Row 2: Screening -->
          <div class="funnel-step">
            <div class="funnel-step-num">2</div>
            <div class="funnel-step-body">
              <h3>筛选 + 审计 / Screening</h3>
              <p>cheap-audit-v2 → detailed audit → 评级 A/B/C/D</p>
              <p class="funnel-step-meta">→ entity.grade · SOP-2</p>
            </div>
          </div>
          <div class="funnel-arrow">▼</div>

          <!-- Row 3: USP branch -->
          <div class="funnel-branch">
            <div class="funnel-branch-label">分流 · USP 三分支</div>
            <div class="funnel-branch-cols">
              <div class="funnel-branch-col grade-a">
                <div class="grade-chip">A</div>
                <strong>必做网站，优先</strong>
                <p>OD 立刻预制 → 销售带网站对接</p>
              </div>
              <div class="funnel-branch-col grade-b">
                <div class="grade-chip">B</div>
                <strong>也做网站</strong>
                <p>A 排完算力允许 → OD 跟做 → 销售带网站对接</p>
              </div>
              <div class="funnel-branch-col grade-c">
                <div class="grade-chip">C</div>
                <strong>先问意向</strong>
                <p>销售先对接 → 有意向 → OD 反向建</p>
                <p class="grade-note">没意向 → 归档（niche 数据库备用）</p>
              </div>
              <div class="funnel-branch-col grade-d">
                <div class="grade-chip">D</div>
                <strong>跳过</strong>
                <p>不投入 (hard-skip)</p>
              </div>
            </div>
          </div>
          <div class="funnel-arrow">▼</div>

          <!-- Row 4: OD build -->
          <div class="funnel-step">
            <div class="funnel-step-num">3</div>
            <div class="funnel-step-body">
              <h3>Open Design 网站预制</h3>
              <p>基于 master.md + audit report，针对性建 demo 网站</p>
              <p class="funnel-step-meta">→ clients/&lt;slug&gt;/v2/ · SOP-3</p>
            </div>
          </div>
          <div class="funnel-arrow">▼</div>

          <!-- Row 5: Sales -->
          <div class="funnel-step">
            <div class="funnel-step-num">4</div>
            <div class="funnel-step-body">
              <h3>销售对接 / Sales Engagement</h3>
              <p>多触点 outreach: contact-us 表单 · GMB · social · phone · email</p>
              <p class="funnel-step-meta">→ #website-leads thread · SOP-4 · 自动化销售框架</p>
            </div>
          </div>
          <div class="funnel-arrow">▼</div>

          <!-- Row 6: Pay & Deliver -->
          <div class="funnel-step funnel-step-end">
            <div class="funnel-step-num">5</div>
            <div class="funnel-step-body">
              <h3>客户决定 → 付费 → 交付维护</h3>
              <p>客户看 demo 决定 → Stripe → bootstrap repo → CF Pages → 持续维护</p>
              <p class="funnel-step-meta">→ #paid-websites · SOP-5</p>
            </div>
          </div>
        </div>

        <div class="contact-id-note">
          <p class="eyebrow accent-coral">📇 客户 Contact Identity (横跨所有阶段)</p>
          <p>每个 entity 在我们这边维护多触点 ID：<strong>GMB / Google Maps URL</strong> · <strong>网站 Contact Us 页 URL</strong> · <strong>社交账号</strong> (FB / IG / LinkedIn) · <strong>Phone / Email</strong>。SOP-4 销售对接时按触点优先级跨渠道触达 → 单一渠道死 ≠ lead 死。详见 <strong>SOP-ART-3 客户 Profile</strong>（待写）。</p>
        </div>
      </section>

      <!-- ─── SECTION 2 · Discord 4-channel lifecycle (summary) ──────────── -->
      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">Discord 4 频道 · 客户走过的 4 段路</p>
            <h2>4-channel Lifecycle <span class="en-sub">Each channel = each lead lifecycle stage</span></h2>
          </div>
          <span class="admin-section-count">详情见 SOP-X-Discord (待写)</span>
        </div>

        <div class="channel-mini-grid">
          <div class="channel-mini channel-mini-0">
            <div class="channel-mini-stage">阶段 1 · 发现</div>
            <code>#lead-discovery-runs</code>
            <p>1 batch = 1 thread · SOP-1 + SOP-2</p>
          </div>
          <div class="channel-mini-arrow">→</div>
          <div class="channel-mini channel-mini-1">
            <div class="channel-mini-stage">阶段 2 · 销售</div>
            <code>#website-leads</code>
            <p>1 A/B/C lead = 1 thread · SOP-4</p>
          </div>
          <div class="channel-mini-arrow">→</div>
          <div class="channel-mini channel-mini-2">
            <div class="channel-mini-stage">阶段 3 · Demo</div>
            <code>#website-projects</code>
            <p>1 demo 制作 = 1 thread · SOP-3</p>
          </div>
          <div class="channel-mini-arrow">→</div>
          <div class="channel-mini channel-mini-3">
            <div class="channel-mini-stage">阶段 4 · 付费</div>
            <code>#paid-websites</code>
            <p>1 付费客户 = 1 thread · SOP-5</p>
          </div>
        </div>
      </section>

      <!-- ─── SECTION 3 · 16-SOP Matrix ──────────────────────────────────── -->
      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">SOP 矩阵 · 全部 {sopTotal} 项</p>
            <h2>当前状态总览 <span class="en-sub">All SOPs by layer + current status</span></h2>
          </div>
          <span class="admin-section-count">{sopUrgent} 🔴 紧急 · {sopInProgress} 🟡 进行中 · {sopReady} ✅ 完成</span>
        </div>

        {Object.entries(sopCatalog).map(([key, group]) => (
          <div class="sop-layer">
            <div class="sop-layer-head">
              <h3>{group.title}</h3>
              <p class="sop-layer-sub">{group.subtitle}</p>
            </div>
            <div class="admin-table-wrap">
              <table class="admin-table sop-matrix-table">
                <thead><tr><th>编号</th><th>名称</th><th>状态</th><th>触发条件 / 范围</th><th>页面</th></tr></thead>
                <tbody>
                  {group.items.map((s) => (
                    <tr>
                      <td><code>{s.id}</code></td>
                      <td><strong>{s.zh}</strong></td>
                      <td>{s.status}</td>
                      <td class="rationale">{s.trigger}{s.channel && <span class="channel-pill"> · {s.channel}</span>}</td>
                      <td>{s.href ? <a href={s.href} class="sop-link">打开 →</a> : <span class="sop-link-na">—</span>}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        ))}
      </section>

      <!-- ─── SECTION 4 · Business Snapshot ──────────────────────────────── -->
      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">业务现状 · LIVE SNAPSHOT</p>
            <h2>当前数据快照 <span class="en-sub">As of {new Date().toISOString().slice(0, 16).replace('T', ' ')}</span></h2>
          </div>
          <span class="admin-section-count">build-time 读取 · 不实时</span>
        </div>

        <div class="snapshot-grid">
          <div class="snapshot-card">
            <p class="eyebrow">总 entity</p>
            <strong>{entityCount}</strong>
            <p class="snapshot-detail">{detailedAudits} 已 detailed audit</p>
          </div>
          <div class="snapshot-card">
            <p class="eyebrow">Grade 分布</p>
            <div class="snapshot-grade-row">
              <span><b>A</b> {gradeCounts.A}</span>
              <span><b>B</b> {gradeCounts.B}</span>
              <span><b>C</b> {gradeCounts.C}</span>
              <span><b>D</b> {gradeCounts.D}</span>
            </div>
            <p class="snapshot-detail">{gradeCounts.ungraded} 未评级</p>
          </div>
          <div class="snapshot-card">
            <p class="eyebrow">Discord thread</p>
            <strong>{withDiscordThread}</strong>
            <p class="snapshot-detail">A/B graduated to #website-leads</p>
          </div>
          <div class="snapshot-card">
            <p class="eyebrow">历史 batch</p>
            <strong>{batchCount}</strong>
            <p class="snapshot-detail">pipeline-batches 累计</p>
          </div>
        </div>
      </section>

      <!-- ─── SECTION 5 · Maintenance protocol ───────────────────────────── -->
      <section class="admin-paper-section sop2-maintenance">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">SOP 维护协议</p>
            <h2>改流程 = 改 doc + 改 admin 页 (paired)</h2>
          </div>
        </div>
        <p class="section-lede">每个 SOP 都同时有：</p>
        <ul class="maintenance-list">
          <li><strong>1 个 admin 页面</strong> (macro overview, 给操作员看大局) — <code>/admin/scoring/&lt;sop-id&gt;</code></li>
          <li><strong>1 个详细文档</strong> (source of truth, 给 AI / 工程师 / 新人看细节) — <code>docs/SOP_&lt;id&gt;_*.md</code></li>
          <li><strong>1 份调研笔记</strong> (建立 SOP 前的现状摸底) — <code>data/qa/sop-investigations/&lt;sop-id&gt;.md</code></li>
        </ul>
        <p class="note-line">流程变动 → <strong>必须同时改 admin 页 + 详细文档</strong>。所有代码、master.md frontmatter、客户报告都从这里衍生。Decision records 加 REVISED 注释，不删历史。</p>

        <p class="section-lede" style="margin-top:18px"><strong>4-step 工作流 (建 SOP 必须走完)</strong></p>
        <ol class="maintenance-list">
          <li><strong>Step 1 · 现状调研</strong> — 读相关代码 / commit / 跑 happy path → 写 investigation note</li>
          <li><strong>Step 2 · Review</strong> — Matthew 确认我没把现状搞错</li>
          <li><strong>Step 3 · 写 SOP v0.1</strong> — 中文为主 + 英文对照 · 目的 / 步骤 / 容易忽略的点 / 维护规则</li>
          <li><strong>Step 4 · 验证</strong> — astro build → push → GH Actions success → browser verify live URL + screenshot</li>
        </ol>
      </section>
    </div>
  </section>
</Layout>

<style>
  .sop-shell { max-width: 1080px; }
  .sop-shell .admin-header h1 { font-size: 30px; line-height: 1.15; }
  .zh-en-sub { color: var(--pl-muted); font-size: 13px; margin: 2px 0 8px; font-style: italic; }
  .en-sub { display: inline-block; margin-left: 8px; font-family: Georgia, serif; font-style: italic; font-size: 13px; font-weight: 400; color: var(--pl-muted); }

  /* USP banner */
  .usp-banner {
    display: flex; gap: 16px; align-items: flex-start;
    margin: 14px 0 6px;
    padding: 14px 18px;
    border: 2px solid var(--pl-line);
    background: color-mix(in srgb, var(--pl-coral) 14%, var(--pl-paper));
    box-shadow: 4px 4px 0 var(--pl-line);
    max-width: 720px;
  }
  .usp-banner-icon { font-size: 26px; line-height: 1; padding-top: 2px; }
  .usp-banner-body strong { font-family: Georgia, serif; font-size: 16px; }
  .usp-banner-body p { margin: 4px 0 0; font-size: 14px; line-height: 1.55; }
  .usp-banner-body em { color: var(--pl-muted); font-size: 13px; }
  .usp-banner-note { font-size: 12.5px; color: var(--pl-muted); }

  /* Tab strip (reused) */
  .sop-tabs { display: flex; gap: 0; margin: 18px 0 22px; border-bottom: 2px solid var(--pl-line); }
  .sop-tab {
    display: flex; flex-direction: column; gap: 2px;
    padding: 12px 22px;
    background: color-mix(in srgb, var(--pl-paper) 50%, transparent);
    border: 2px solid var(--pl-line); border-bottom: none;
    margin-right: 6px; margin-bottom: -2px;
    text-decoration: none; color: var(--pl-muted);
    min-width: 220px;
  }
  .sop-tab:hover { background: color-mix(in srgb, var(--pl-citrus) 12%, var(--pl-paper)); color: var(--pl-ink); }
  .sop-tab--active {
    background: var(--pl-paper); color: var(--pl-ink);
    box-shadow: 3px -3px 0 var(--pl-line);
    transform: translateY(-2px); border-bottom: 2px solid var(--pl-paper);
  }
  .sop-tab-id { font-family: ui-monospace, monospace; font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--pl-coral); }
  .sop-tab-zh { font-family: Georgia, serif; font-size: 16px; font-weight: 700; line-height: 1.15; }
