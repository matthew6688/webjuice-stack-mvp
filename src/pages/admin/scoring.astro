---
import Layout from '../../layouts/AdminLayout.astro';
import { loadCheapAuditConfig } from '../../../core/scoring/cheap-audit-v2.js';
import {
  INVESTMENT_LEVEL_TABLE,
  PRODUCT_TIER_TABLE,
  ADDON_TABLE,
  HARD_SKIP_DEFINITIONS,
} from '../../../core/scoring/lead-grading.js';

const config = loadCheapAuditConfig();
const stage1 = config.stages.stage_1_gbp_triage;
const stage2 = config.stages.stage_2_site_quick_scan;
const stage05 = config.stages.stage_0_5_enrichment_gate;
const totalRules = stage1.rules.length + stage2.rules.length;

// Stage 2 detailed-audit sub-audits (11 modules that run in parallel during
// run-audit-pipeline `--all-audit-candidates` per lead). See
// docs/SOP_2_LEAD_DISCOVERY_PIPELINE.md §2 (Stage 2 Step A).
const detailedAuditSubAudits = [
  { id: '2a', name: 'site fetch', module: 'core/audit/site-fetch-full.js (Playwright)', tool: 'Playwright headless chromium', tier: 'T0 local', outputs: 'rawHtml + mobileHtml + screenshots/{desktop,mobile}.png' },
  { id: '2b', name: 'tech_stack', module: 'core/audit/tech-stack-detector.js', tool: 'wapalyzer-style regex', tier: 'T0', outputs: 'tech_stack {platform, frameworks, analytics, pixels}' },
  { id: '2c', name: 'form_audit', module: 'core/audit/form-audit.js', tool: 'Playwright 真 submit 测试', tier: 'T0', outputs: 'form_audit {submittable, fields, redirect_url}' },
  { id: '2d', name: 'image_optimization', module: 'core/audit/image-optimization.js', tool: 'rawHtml 解析', tier: 'T0', outputs: 'image_optimization {weights, formats, lazy_load}' },
  { id: '2e', name: 'trust_signals', module: 'core/audit/trust-signals/index.js', tool: 'rawHtml + heuristics', tier: 'T0', outputs: 'trust_signals {social_proof, certifications, badges}' },
  { id: '2f', name: 'third_party_weight', module: 'core/audit/third-party-weight.js', tool: 'Playwright request interceptor', tier: 'T0', outputs: 'third_party_weight {blocked_mb, scripts}' },
  { id: '2g', name: 'sitemap_analysis', module: 'core/audit/sitemap-analyzer.js', tool: 'HTTP fetch /sitemap.xml + /robots.txt', tier: 'T0', outputs: 'sitemap_analysis {total_urls, has_sitemap, has_robots}' },
  { id: '2h', name: 'ai_geo', module: 'core/audit/ai-geo-checks.js', tool: 'rawHtml + markdown analysis', tier: 'T0', outputs: 'ai_geo {LLMS.txt, JSON-LD, AI-search ready}' },
  { id: '2i', name: 'pagespeed (PSI)', module: 'core/audit/pagespeed-insights.js', tool: 'Google PSI API (free 25k/day)', tier: 'T2 free', outputs: 'pagespeed {LCP, FCP, CWV, INP, TTFB + Lighthouse mobile+desktop}', critical: true },
  { id: '2j', name: 'domain_history', module: 'core/audit/domain-history.js', tool: 'WHOIS API', tier: 'T2', outputs: 'domain_history {age_years, registrar, expiry}' },
  { id: '2k', name: 'activity', module: 'core/audit/activity-audit.js', tool: 'rawHtml + GBP signals', tier: 'T0', outputs: 'activity {last_update, blog_freshness, gbp_post_recency}' },
];

// 4 Discord channels in V2 lead lifecycle
const channels = [
  { id: '#lead-discovery-runs',  channel_id: '1503513633756283070', type: 'forum (type 15)', unit: '1 batch task = 1 thread', audience: '你 + AI agent (运营监督)', purpose: 'discovery + audit batch progress', sop: 'SOP-2 (this)' },
  { id: '#website-leads',        channel_id: '1501187038706401290', type: 'forum (type 15)', unit: '1 A/B lead = 1 thread',  audience: '销售人员',          purpose: 'per-lead CRM + outreach 对话',          sop: 'SOP-3 (待写)' },
  { id: '#website-projects',     channel_id: '1501945763650080899', type: 'forum (type 15)', unit: '1 demo 候选 = 1 thread',  audience: '设计 + 客户',      purpose: 'demo/proposal 制作追踪',                sop: 'SOP-4 (待写)' },
  { id: '#paid-websites',        channel_id: '1503529874336383137', type: 'forum (type 15)', unit: '1 paid customer = 1 thread', audience: '交付 + ongoing', purpose: '付费客户生产部署 + 维护',              sop: 'SOP-5 (待写)' },
];

// 5 stages of the V2 batch pipeline
const stages = [
  {
    n: 0, name: 'Discovery', cli: 'pl:scrape-docker (待建)', cost: 'T0 local (gosom Docker)',
    desc: 'gosom Web API 抓 Google Maps → CSV → upsertDiscoveryRun → entity store',
    outputs: ['data/leads/entities/<key>.json × N', 'discovery-events.jsonl', 'queues.json'],
    ui_signal: '/admin/v2-queue discovery funnel +N',
  },
  {
    n: 0.5, name: 'Enrichment', cli: '(自动, conditional)', cost: 'T0 (Tinyfish/DDGS free)',
    desc: '仅 queued_for_enrichment lead 触发 — 5 路并行 search (FB/IG/LinkedIn/3rd-party reviews)',
    outputs: ['data/v2/fixtures/enrichment/<key>.json'],
    ui_signal: '(无直接 UI, 回流到 rescore)',
    conditional: true,
  },
  {
    n: 1, name: 'Rescore', cli: 'npm run rescore-v2-cli -- --niche <X>', cost: 'T0 (本地脚本 + Tinyfish quick-scan)',
    desc: 'cheap-audit-v2 跑 GBP triage + site quick-scan → 输出 5 种 action',
    outputs: ['data/v2/fixtures/rescore/<niche>-<ts>.json'],
    ui_signal: '本页 Outcome 分布 (audit / starter / manual / skip)',
  },
  {
    n: 2, name: 'Audit + Visual + Grade + Reviews + Report', cli: 'npm run leads:run-pipeline -- --all-audit-candidates --with-reviews --refetch', cost: 'T0 Playwright + T2 PSI free + T1 claude_cli',
    desc: '11 sub-audits (含 PSI/domain/form) → 6-dim 39-rule scoring → visual audit (claude_cli) → gradeLead → A/B 自动 graduate to #website-leads → build internal report',
    outputs: ['detailed-audit/<key>.json', 'visual-autoresearch/.../<key>.json', 'reviews/<key>.json (A/B)', 'clients/<slug>/v2/internal-audit-report.html + evidence/ + video/', 'entity.grade + entity.discord_thread_id (A/B)'],
    ui_signal: '/admin/v2-leads grade 分布 + Discord per-lead thread',
  },
  {
    n: 3, name: 'Master MD', cli: 'npm run leads:build-master-md -- --all-with-detailed', cost: 'T0',
    desc: '销售素材源头 — YAML frontmatter + 中文销售叙述',
    outputs: ['clients/<slug>/v2/master.md'],
    ui_signal: '/admin/v2-leads/[entityKey] Reports & Evidence strip',
  },
  {
    n: 4, name: 'Entity ↔ Artifact Linkage (F5)', cli: 'pl:entity-link-reports --batch-id <id> (待建)', cost: 'T0',
    desc: '把 HTML / master.md / public URL 显式写进 entity.audit_reports.internal',
    outputs: ['entity.audit_reports.internal {html_path, public_url, master_md, audit_version, built_at}', 'entity.batch_id'],
    ui_signal: 'admin per-lead detail 显示 audit version + batch_id',
  },
];

// Investment level chip class
function levelChipClass(level) {
  const m = { A: 'chip-mint', B: 'chip-citrus', C: 'chip-sky', D: 'chip-coral' };
  return m[level] || 'chip-muted';
}
function tierChipClass(tier) {
  const m = { T1: 'chip-mint', T2: 'chip-citrus', T3: 'chip-lilac' };
  return m[tier] || 'chip-muted';
}

function fmtRule(rule) {
  if (rule.deduct_tiers || rule.earn_tiers) {
    const tiers = rule.deduct_tiers || rule.earn_tiers;
    return tiers.map((t) => `${t.if} → +${t.earn}`).join(' / ');
  }
  if (rule.deduct_if) return `miss → -${rule.max} (max ${rule.max})`;
  if (rule.earn_if_missing) return `if missing → +${rule.earn_if_missing} redesign_need`;
  if (rule.earn_if_present) return `if present → +${rule.earn_if_present} redesign_need`;
  if (rule.earn_if_stale) return `if stale → +${rule.earn_if_stale}`;
  return `max ${rule.max}`;
}

function chipClass(action) {
  const a = String(action || '');
  if (a === 'audit_candidate') return 'chip-mint';
  if (a === 'starter_candidate') return 'chip-citrus';
  if (a === 'manual_review') return 'chip-sky';
  if (a === 'queued_for_enrichment') return 'chip-lilac';
  if (a === 'skip') return 'chip-coral';
  return '';
}
---

<Layout title="SOP-2 · V2 Lead Pipeline" active="scoring">
  <section class="poster-section admin-section">
    <div class="admin-shell lead-admin-shell scoring-shell" data-ui-version="local-style-2026-05-08">
      <header class="admin-header">
        <div>
          <p class="eyebrow">SOP-2 概览 (macro view)</p>
          <h1>V2 Lead Pipeline · Discovery → Audit → Graduation</h1>
          <p class="lede">从一个搜索 query 到 A/B 客户进入销售 thread 的完整流程。本页是 macro overview（看大局）；细节看 <a href="https://github.com/matthewkiata/google-map-website/blob/main/docs/SOP_2_LEAD_DISCOVERY_PIPELINE.md" target="_blank" rel="noopener"><code>docs/SOP_2_LEAD_DISCOVERY_PIPELINE.md</code></a>。</p>
          <p class="meta-line">
            <span>cheap-audit config <code>{config.version}</code></span>
            <span class="dot">·</span>
            <span>pipeline source <code>docs/SOP_2_LEAD_DISCOVERY_PIPELINE.md</code></span>
          </p>
        </div>
        <div class="admin-count">
          <span>Pipeline</span>
          <strong>5 stages</strong>
          <span class="micro-note">4 channels · {totalRules} cheap-audit rules · {detailedAuditSubAudits.length} detailed sub-audits</span>
        </div>
      </header>

      <div class="sop2-banner">
        <div class="sop2-banner-icon">⚠</div>
        <div class="sop2-banner-body">
          <strong>Source of truth</strong>: 这个页面（macro overview）和 <code>docs/SOP_2_LEAD_DISCOVERY_PIPELINE.md</code> 是 V2 lead pipeline 的唯一权威。
          <br/>任何流程变动 — <strong>必须同时改这两处</strong>。代码、admin UI、master.md frontmatter 都从这里衍生。
        </div>
      </div>

      <div class="philosophy-strip">
        <p class="eyebrow">设计哲学 (cheap-audit-v2)</p>
        <p>{config.philosophy}</p>
      </div>

      <!-- ─── 4-Channel Discord Lifecycle ─────────────────────────────────── -->
      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">Discord 4-channel 架构</p>
            <h2>Lead 生命周期分 4 段，每段一个 Discord channel</h2>
          </div>
          <span class="admin-section-count">{channels.length} channels · graduation 串连</span>
        </div>
        <p class="section-lede">每段 cadence / audience / SLA 不同。SOP-2 范围 = 前 2 段 (discovery-runs + website-leads) + 它们之间的 graduation 机制。</p>
        <div class="channel-flow">
          {channels.map((c, i) => (
            <>
              <div class={`channel-card channel-${i}`}>
                <div class="channel-name"><code>{c.id}</code></div>
                <div class="channel-unit">{c.unit}</div>
                <div class="channel-purpose">{c.purpose}</div>
                <div class="channel-meta">
                  <span>受众: <strong>{c.audience}</strong></span>
                  <span>{c.type}</span>
                  <span>{c.sop}</span>
                </div>
              </div>
              {i < channels.length - 1 && (
                <div class="channel-arrow">
                  <span class="channel-arrow-label">
                    {i === 0 ? 'A/B grade 自动 graduate' : i === 1 ? '客户想看 demo' : '客户付费'}
                  </span>
                  <span class="channel-arrow-glyph">▼</span>
                </div>
              )}
            </>
          ))}
        </div>
      </section>

      <!-- ─── 5-Stage Pipeline Overview ───────────────────────────────────── -->
      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">SOP-2 流水线</p>
            <h2>5 个 stage · 从 entity 入库到 audit report 落地</h2>
          </div>
          <span class="admin-section-count">{stages.length} stages (含 0.5 conditional)</span>
        </div>
        <div class="stage-grid">
          {stages.map((s) => (
            <div class={`stage-card ${s.conditional ? 'stage-conditional' : ''}`}>
              <div class="stage-num">
                Stage {s.n}
                {s.conditional && <span class="stage-cond-badge">conditional</span>}
              </div>
              <div class="stage-name">{s.name}</div>
              <div class="stage-desc">{s.desc}</div>
              <div class="stage-meta">
                <div><span class="stage-meta-label">CLI</span> <code>{s.cli}</code></div>
                <div><span class="stage-meta-label">Cost</span> <span class="chip chip-muted">{s.cost}</span></div>
                <div>
                  <span class="stage-meta-label">Output</span>
                  <ul class="stage-outputs">
                    {s.outputs.map((o) => <li><code>{o}</code></li>)}
                  </ul>
                </div>
                <div><span class="stage-meta-label">UI signal</span> {s.ui_signal}</div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- ─── Investment Level × Product Tier Matrix ──────────────────────── -->
      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">销售矩阵</p>
            <h2>Investment Level × Product Tier · 决定销售物料 + 报价</h2>
          </div>
          <span class="admin-section-count">A/B/C/D × T1/T2/T3 · V2 pricing locked 2026-05-11</span>
        </div>
        <p class="section-lede">Stage 2 跑完，每个 audit_candidate 拿一个 <strong>investment level</strong>（销售投入度）+ <strong>product tier</strong>（报价档位）。匹配 profitslocal.com homepage live pricing。</p>

        <h3 class="subhead">Investment Level (A/B/C/D)</h3>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead><tr><th>Level</th><th>标签</th><th>触发条件</th><th>销售动作</th></tr></thead>
            <tbody>
              {INVESTMENT_LEVEL_TABLE.map((lv) => (
                <tr>
                  <td><span class={`chip ${levelChipClass(lv.level)}`}>{lv.level}</span></td>
                  <td><strong>{lv.label}</strong></td>
                  <td class="rationale">{lv.criteria}</td>
                  <td class="rationale">{lv.action}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h3 class="subhead">Product Tier (T1/T2/T3) — V2 productized pricing</h3>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead><tr><th>Tier</th><th>标签</th><th>触发信号</th><th>报价</th><th>包含</th></tr></thead>
            <tbody>
              {PRODUCT_TIER_TABLE.map((t) => (
                <tr>
                  <td><span class={`chip ${tierChipClass(t.tier)}`}>{t.tier}</span></td>
                  <td><strong>{t.label}</strong></td>
                  <td class="rationale">{t.signals}</td>
                  <td><strong class="price">{t.pricing}</strong></td>
                  <td class="rationale">{t.includes}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h3 class="subhead">Add-on (任何 tier)</h3>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead><tr><th>Add-on</th><th>报价</th><th>适用</th></tr></thead>
            <tbody>
              {ADDON_TABLE.map((a) => (
                <tr>
                  <td><strong>{a.label}</strong></td>
                  <td><strong class="price">{a.pricing}</strong></td>
                  <td class="rationale">{a.applies_to}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <p class="note-line"><strong>价格 source of truth</strong>: profitslocal.com homepage (live) + <code>docs/v2/SCALING_AND_PRICING.md</code> (锁定 2026-05-11)。代码 <code>core/scoring/lead-grading.js</code> 的 PRODUCT_TIER_TABLE 已对齐。改价格 = 改这 3 处 + 重 generate 所有 master.md。</p>
      </section>

      <!-- ─── Stage 2 Detailed Audit Sub-Audits ───────────────────────────── -->
      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">Stage 2 内部</p>
            <h2>Detailed audit 跑的 11 个 sub-audit</h2>
          </div>
          <span class="admin-section-count">{detailedAuditSubAudits.length} 个并行 / per lead</span>
        </div>
        <p class="section-lede">每个 audit_candidate 经过 <code>run-audit-pipeline</code> 时，<code>siteFetchFull</code> 一次 Playwright 访问内并行跑这 11 个模块，结果拼成 <code>fetchPayload</code> 喂给 <code>detailedAudit</code> 打 6-dim × 39-rule 分数。</p>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead><tr><th>Sub</th><th>名称</th><th>模块</th><th>Tool</th><th>Tier</th><th>关键输出字段</th></tr></thead>
            <tbody>
              {detailedAuditSubAudits.map((s) => (
                <tr class={s.critical ? 'sub-critical' : ''}>
                  <td><code>{s.id}</code>{s.critical && <span class="chip chip-coral">critical</span>}</td>
                  <td><strong>{s.name}</strong></td>
                  <td><code>{s.module}</code></td>
                  <td class="rationale">{s.tool}</td>
                  <td><span class="chip chip-muted">{s.tier}</span></td>
                  <td class="rationale"><code>{s.outputs}</code></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="note-line"><strong>注意 2i pagespeed</strong>: 历史上 <code>PAGESPEED_API_KEY</code> 缺失导致所有 lead LCP/CWV = 0；2026-05-11 已修复。<strong>容易忽略的点</strong>: 见 SOP-2 文档 §6。</p>
      </section>

      <!-- ─── HARD-SKIP Definitions ────────────────────────────────────────── -->
      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">Grade D 触发</p>
            <h2>Hard-skip 条件（命中即 D 级，不投入）</h2>
          </div>
          <span class="admin-section-count">{HARD_SKIP_DEFINITIONS.length} 条</span>
        </div>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead><tr><th>ID</th><th>原因</th></tr></thead>
            <tbody>
              {HARD_SKIP_DEFINITIONS.map((h) => (
                <tr>
                  <td><code>{h.id}</code></td>
                  <td class="rationale">{h.reason}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- ─── Existing detail sections (cheap-audit-v2 rule reference) below -->
      <div class="cheap-audit-divider">
        <p class="eyebrow">↓ 下面是 cheap-audit-v2 详细规则参考（Stage 1）</p>
      </div>

      <section class="admin-paper-section flow-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">Lead 分流流程</p>
            <h2>从抓取到决策的完整路径</h2>
          </div>
          <span class="admin-section-count">5 个步骤 · 4 个 hard trigger · 4 档阈值</span>
        </div>

        <div class="flow-grid">
          <!-- Row 1: ENTRY -->
          <div class="flow-row">
            <div class="flow-row-label">入口</div>
            <div class="flow-entries">
              <div class="flow-entry">
                <div class="flow-entry-tag">maps_scraper</div>
                <div class="flow-entry-desc">Google Maps 抓取（主入口）</div>
              </div>
              <div class="flow-entry">
                <div class="flow-entry-tag">image-discovery</div>
                <div class="flow-entry-desc">图片识别商家</div>
              </div>
              <div class="flow-entry">
                <div class="flow-entry-tag">manual intake</div>
                <div class="flow-entry-desc">手工 / 转介绍</div>
              </div>
            </div>
          </div>
          <div class="flow-arrow-row">▼</div>

          <!-- Row 2: DISCOVERY STORE -->
          <div class="flow-step">
            <div class="flow-step-num">0</div>
            <div class="flow-step-body">
              <div class="flow-step-title">Discovery store</div>
              <div class="flow-step-desc">data/leads/entities/&lt;entity-key&gt;.json &nbsp;·&nbsp; 去重 + 历史轨迹</div>
            </div>
          </div>
          <div class="flow-arrow-row">▼</div>

          <!-- Row 3: STAGE 0.5 -->
          <div class="flow-step flow-step-conditional">
            <div class="flow-step-num">0.5</div>
            <div class="flow-step-body">
              <div class="flow-step-title">Enrichment-before-skip 门槛</div>
              <div class="flow-step-desc">联系方式不足 → 5 路 search 强制补全（Tinyfish / DDGS / Doko）→ 回到 Stage 1 重判</div>
              <div class="flow-step-meta">条件触发 · 仅 thin-contact 走</div>
            </div>
          </div>
          <div class="flow-arrow-row">▼</div>

          <!-- Row 4: STAGE 1 -->
          <div class="flow-step">
            <div class="flow-step-num">1</div>
            <div class="flow-step-body">
              <div class="flow-step-title">Stage 1 · GBP triage <span class="flow-step-badge">always</span></div>
              <div class="flow-step-desc">9 项规则 · 满分 100 · 仅读 maps payload · T0 零成本</div>
              <div class="flow-step-out">
                <span class="flow-out-fail">category 不匹配 → SKIP（hard）</span>
              </div>
            </div>
          </div>
          <div class="flow-arrow-row">▼</div>

          <!-- Row 5: BRANCH -->
          <div class="flow-branch">
            <div class="flow-branch-label">hasWebsite ?</div>
            <div class="flow-branch-arrows">
              <div class="flow-branch-arrow">no</div>
              <div class="flow-branch-arrow">yes</div>
            </div>
            <div class="flow-branch-paths">
              <div class="flow-step flow-step-no-site">
                <div class="flow-step-body">
                  <div class="flow-step-title">无网站路径</div>
                  <div class="flow-step-desc">联系方式可达 → <span class="chip chip-citrus">starter_candidate</span> · 不跑 Stage 2</div>
                </div>
              </div>
              <div class="flow-step">
                <div class="flow-step-num">2</div>
                <div class="flow-step-body">
                  <div class="flow-step-title">Stage 2 · Site quick-scan</div>
