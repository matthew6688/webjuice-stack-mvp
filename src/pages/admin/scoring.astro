---
import Layout from '../../layouts/AdminLayout.astro';
import { loadCheapAuditConfig } from '../../../core/scoring/cheap-audit-v2.js';

const config = loadCheapAuditConfig();

// V2 cheap-audit-config has stages.stage_1_gbp_triage.rules and stage_2_site_quick_scan.rules
const stage1 = config.stages.stage_1_gbp_triage;
const stage2 = config.stages.stage_2_site_quick_scan;
const stage05 = config.stages.stage_0_5_enrichment_gate;

function fmtRule(rule) {
  if (rule.deduct_tiers || rule.earn_tiers) {
    const tiers = rule.deduct_tiers || rule.earn_tiers;
    return tiers.map((t) => `${t.if} → +${t.earn}`).join(' / ');
  }
  if (rule.deduct_if) return `miss → -${rule.max} (max ${rule.max})`;
  if (rule.earn_if_missing) return `if missing → +${rule.earn_if_missing} redesign_need`;
  if (rule.earn_if_present) return `if present → +${rule.earn_if_present} redesign_need`;
  if (rule.earn_if_stale) return `if stale → +${rule.earn_if_stale}`;
  return `max ${rule.max}`;
}
---

<Layout title="算法定义 — Cheap Audit V2" active="settings">
  <main class="page">
    <header class="page-header">
      <a href="/admin" class="breadcrumb">总览</a>
      <h1>算法定义 — Cheap Audit V2</h1>
      <p class="meta">
        Config version: <code>{config.version}</code> &nbsp;·&nbsp;
        Source: <code>core/scoring/cheap-audit-config.json</code>
      </p>
      <p class="lead">{config.purpose}</p>
      <p class="lead philosophy">{config.philosophy}</p>
    </header>

    <section class="card">
      <h2>Stage 0.5 — Enrichment-before-skip 门槛</h2>
      <p>{stage05.description}</p>
      <h3>触发 enrichment 的情况</h3>
      <ul>
        {stage05.triggers_enrichment_if.map((t) => <li><code>{t}</code></li>)}
      </ul>
      <h3>立即 skip 的情况</h3>
      <ul>
        {stage05.skips_immediately_if.map((t) => <li><code>{t}</code></li>)}
      </ul>
    </section>

    <section class="card">
      <h2>Stage 1 — GBP triage</h2>
      <p>{stage1.description}</p>
      <p class="meta">满分: <strong>{stage1.max_score}</strong></p>
      <table>
        <thead>
          <tr>
            <th>规则 ID</th>
            <th>检测</th>
            <th>满分</th>
            <th>评分规则</th>
          </tr>
        </thead>
        <tbody>
          {stage1.rules.map((r) => (
            <tr>
              <td><code>{r.id}</code>{r.is_hard_skip && <span class="hard-skip"> ⚠ hard-skip</span>}</td>
              <td>{r.check}</td>
              <td>{r.max}</td>
              <td><span class="rule-formula">{fmtRule(r)}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="card">
      <h2>Stage 2 — Website quick scan</h2>
      <p>{stage2.description}</p>
      <p class="meta">满分: <strong>{stage2.max_score}</strong>  &nbsp;·&nbsp;  跳过条件: <code>{stage2.skipped_when}</code></p>
      <table>
        <thead>
          <tr>
            <th>规则 ID</th>
            <th>检测</th>
            <th>满分</th>
            <th>判定</th>
            <th>意义</th>
          </tr>
        </thead>
        <tbody>
          {stage2.rules.map((r) => (
            <tr>
              <td><code>{r.id}</code></td>
              <td>{r.check}</td>
              <td>{r.max}</td>
              <td><span class="rule-formula">{fmtRule(r)}</span></td>
              <td><span class="rationale">{r.rationale}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="card">
      <h2>最终评分</h2>
      <p class="formula">final_score = <code>{config.scoring.formula}</code></p>
      <p class="rationale">{config.scoring.rationale}</p>
    </section>

    <section class="card">
      <h2>Hard triggers（强制覆盖阈值的规则）</h2>
      <table>
        <thead><tr><th>触发条件</th><th>强制动作</th><th>原因</th></tr></thead>
        <tbody>
          {config.hard_triggers.map((t) => (
            <tr>
              <td><code>{t.if}</code></td>
              <td><span class="action">{t.force_action || t.force_action_min || '—'}</span>{t.force_action_min && <small> (lift floor)</small>}</td>
              <td>{t.rationale}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="card">
      <h2>阈值</h2>
      <table>
        <thead><tr><th>分数 ≥</th><th>动作</th><th>说明</th></tr></thead>
        <tbody>
          {config.thresholds.map((t) => (
            <tr><td>{t.min}</td><td><span class="action">{t.action}</span></td><td>{t.label}</td></tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="card">
      <h2>No-website starter 决策路径</h2>
      <p>{config.starter_candidate_path.description}</p>
      <table>
        <thead><tr><th>条件</th><th>动作</th><th>原因</th></tr></thead>
        <tbody>
          {config.starter_candidate_path.decision_rules.map((r) => (
            <tr><td><code>{r.if}</code></td><td><span class="action">{r.action}</span></td><td>{r.rationale}</td></tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="card meta-section">
      <h2>UI 显性化映射</h2>
      <ul>
        {Object.entries(config.ui_visibility).map(([k, v]) => (
          <li><code>{k}</code> &nbsp;→&nbsp; {v}</li>
        ))}
      </ul>
    </section>
  </main>
</Layout>

<style>
  .page { max-width: 1100px; margin: 2rem auto; padding: 0 1.5rem; font-family: ui-sans-serif, system-ui, sans-serif; color: #1a1a1a; }
  .page-header { margin-bottom: 2rem; }
  .breadcrumb { color: #666; text-decoration: none; }
  .breadcrumb:hover { color: #000; }
  h1 { margin: 0.4rem 0; font-size: 1.7rem; }
  .meta { color: #666; font-size: 0.9rem; margin: 0.3rem 0; }
  .lead { font-size: 0.95rem; line-height: 1.5; color: #333; max-width: 80ch; }
  .lead.philosophy { background: #fff7e6; border-left: 3px solid #f0a500; padding: 0.6rem 0.9rem; margin-top: 0.6rem; }
  .card { background: #fff; border: 1px solid #e5e5e5; border-radius: 6px; padding: 1.2rem 1.4rem; margin-bottom: 1.2rem; }
  .card h2 { margin-top: 0; font-size: 1.2rem; }
  .card h3 { font-size: 1rem; margin-top: 1rem; margin-bottom: 0.4rem; }
  table { width: 100%; border-collapse: collapse; font-size: 0.88rem; margin-top: 0.6rem; }
  th, td { text-align: left; padding: 0.45rem 0.6rem; border-bottom: 1px solid #f0f0f0; vertical-align: top; }
  th { background: #fafafa; font-weight: 600; color: #444; }
  code { background: #f5f5f5; padding: 0.1rem 0.35rem; border-radius: 3px; font-size: 0.85em; }
  .rule-formula { color: #444; font-family: ui-monospace, monospace; font-size: 0.8rem; }
  .rationale { color: #666; font-size: 0.85rem; }
  .formula { font-size: 1rem; }
  .action { font-family: ui-monospace, monospace; padding: 0.1rem 0.4rem; background: #eef5ff; border-radius: 3px; color: #1a4f9c; }
  .hard-skip { color: #c00; font-size: 0.8rem; font-weight: 600; }
  .meta-section { background: #fafafa; }
  ul { padding-left: 1.4rem; }
  li { margin-bottom: 0.3rem; }
</style>
