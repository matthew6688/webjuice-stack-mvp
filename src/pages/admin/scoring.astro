  .sop-channel-pill {
    color: var(--pl-muted);
    font-size: 11px;
  }
  .text-muted { color: var(--pl-muted); font-style: italic; }

  /* Snapshot card oversized number */
  .snapshot-big {
    font-family: Georgia, serif;
