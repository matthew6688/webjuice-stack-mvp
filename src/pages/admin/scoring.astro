---
import Layout from '../../layouts/AdminLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

// V2 entity snapshot (read entity store at build time for live status block)
const repoRoot = process.cwd();
const entitiesDir = path.join(repoRoot, 'data/leads/entities');
const detailedDir = path.join(repoRoot, 'data/v2/fixtures/detailed-audit');
const batchesDir = path.join(repoRoot, 'data/v2/pipeline-batches');

let entityCount = 0;
let gradeCounts = { A: 0, B: 0, C: 0, D: 0, ungraded: 0 };
let withDiscordThread = 0;
let detailedAudits = 0;
let batchCount = 0;

try {
  if (fs.existsSync(entitiesDir)) {
    const files = fs.readdirSync(entitiesDir).filter((f) => f.endsWith('.json'));
    entityCount = files.length;
    for (const f of files) {
      try {
        const e = JSON.parse(fs.readFileSync(path.join(entitiesDir, f), 'utf8'));
        const g = e.grade?.investment_level;
        if (g && gradeCounts[g] !== undefined) gradeCounts[g] += 1;
        else gradeCounts.ungraded += 1;
        if (e.discord_thread_id) withDiscordThread += 1;
      } catch {}
    }
  }
  if (fs.existsSync(detailedDir)) {
    detailedAudits = fs.readdirSync(detailedDir).filter((f) => f.endsWith('.json') && !f.startsWith('ledger-')).length;
  }
  if (fs.existsSync(batchesDir)) {
    batchCount = fs.readdirSync(batchesDir).filter((f) => f.endsWith('.json')).length;
  }
} catch {}

// 16 SOP catalog — single source of truth for what we have / what's coming
const sopCatalog = {
  lifecycle: {
    title: '🔵 Lifecycle Process SOPs',
    subtitle: '按业务阶段 · 每段 Discord channel 对应一个',
    items: [
      { id: 'SOP-1',  zh: '客户发现 Intake & Discovery',     status: '🟡 调研笔记中', href: '/admin/scoring/sop-1',    trigger: 'gosom Docker / image / search keywords', channel: '#lead-discovery-runs' },
      { id: 'SOP-2',  zh: '筛选 + 审计 Screening & Audit',   status: '✅ 有了 (本次润色)',  href: '/admin/scoring/sop-2',    trigger: 'cheap-audit-v2 + detailed audit + grade',  channel: '#lead-discovery-runs → #website-leads' },
      { id: 'SOP-3',  zh: 'Open Design 网站预制',             status: '⚪ 待写',         href: null,                       trigger: 'A 必做 / B 排完 A 做 / C 有意向也做',     channel: '#website-projects' },
      { id: 'SOP-4',  zh: '销售对接 Sales Engagement',       status: '⚪ 待写',         href: null,                       trigger: 'A/B/C lead 进入对接 → 多触点 outreach', channel: '#website-leads' },
      { id: 'SOP-5',  zh: '交付维护 Delivery & Maintenance', status: '⚪ 待写',         href: null,                       trigger: '客户付费',                              channel: '#paid-websites' },
    ],
  },
  artifact: {
    title: '🟡 Per-Lead Artifact SOPs',
    subtitle: '每客户独立的源真理资产 · 跨所有阶段不变',
    items: [
      { id: 'SOP-ART-1', zh: 'Master.md 维护协议',          status: '⚪ 待写', href: null, trigger: '所有下游素材的 source of truth' },
      { id: 'SOP-ART-2', zh: 'Internal Audit Report 协议',  status: '⚪ 待写', href: null, trigger: '11 sub-audit + 6 dim + 39 规则' },
      { id: 'SOP-ART-3', zh: '客户 Profile / Contact ID',   status: '⚪ 待写', href: null, trigger: '多触点：GMB / contact-us / social / phone / email' },
    ],
  },
  crossCutting: {
    title: '🟢 Cross-cutting Method / Infra SOPs',
    subtitle: '不绑定任何阶段 · 所有阶段都必须遵守',
    items: [
      { id: 'SOP-X-Tooling',     zh: '第三方工具矩阵 + Quota',         status: '✅ v1.0',   href: '/admin/scoring/sop-x-tooling', trigger: '20+ 工具 · tier + 计费 + fail-over' },
      { id: 'SOP-X-Health',      zh: 'ops:health-check + Discord 警报', status: '✅ v1.0',   href: null, trigger: '9 项周期检查 · 失败推 Discord webhook' },
      { id: 'SOP-X-Handoff',     zh: 'SOP-1 → SOP-2 数据交接合约',      status: '✅ v1.0',   href: null, trigger: 'entity schema 每字段解读' },
      { id: 'SOP-X-Discord',     zh: 'Discord 4-channel 架构 + 协议', status: '🔴 立刻写', href: null, trigger: '覆盖整个销售流程的载体' },
      { id: 'SOP-X-Pricing',     zh: '改价格协议',                    status: '🔴 立刻写', href: null, trigger: '改价漏点的纪律修正' },
      { id: 'SOP-X-Deploy',      zh: '前端部署验证协议',              status: '🔴 立刻写', href: null, trigger: '我刚 burned 的纪律' },
      { id: 'SOP-X-PhaseTrans',  zh: 'V2 phase 状态机',               status: '⚪ 待写',   href: null, trigger: '8 phase × setEntityPhase 谁负责' },
      { id: 'SOP-X-CronOps',     zh: 'Hermes cron 运维',              status: '⚪ 待写',   href: null, trigger: 'reply-poll / daily-tick / ttl 健康' },
      { id: 'SOP-X-CostLedger',  zh: '预算护栏 + 成本纪律',           status: '🟡 已有 doc',href: null, trigger: 'COST_DISCIPLINE 提为 SOP' },
      { id: 'SOP-X-Autoresearch',zh: 'Autoresearch 优化方法论',       status: '🟡 已有 doc',href: null, trigger: '自我优化循环 (Karpathy-style)' },
      { id: 'SOP-X-Backup',      zh: '备份 / 密钥轮换',               status: '⚪ 待写',   href: null, trigger: 'Discord bot / PSI / CF API key' },
    ],
  },
};

const sopTotal = sopCatalog.lifecycle.items.length + sopCatalog.artifact.items.length + sopCatalog.crossCutting.items.length;
const sopReady = [...sopCatalog.lifecycle.items, ...sopCatalog.artifact.items, ...sopCatalog.crossCutting.items]
  .filter((s) => s.status.startsWith('✅')).length;
const sopInProgress = [...sopCatalog.lifecycle.items, ...sopCatalog.artifact.items, ...sopCatalog.crossCutting.items]
  .filter((s) => s.status.includes('🟡')).length;
const sopUrgent = [...sopCatalog.lifecycle.items, ...sopCatalog.artifact.items, ...sopCatalog.crossCutting.items]
  .filter((s) => s.status.includes('🔴')).length;
---

<Layout title="SOP 总览 · 销售流水线" active="scoring">
  <section class="poster-section admin-section sop-page">
    <nav class="sop-tabs sop-tabs--global" aria-label="SOP navigation">
      <a href="/admin/scoring" class="sop-tab sop-tab--active" aria-current="page">
        <span class="sop-tab-id">📊 概览</span>
        <span class="sop-tab-zh">销售流水线总览</span>
        <span class="sop-tab-en">Overview</span>
      </a>
      <a href="/admin/scoring/sop-1" class="sop-tab">
        <span class="sop-tab-id">🎣 SOP-1</span>
        <span class="sop-tab-zh">客户发现</span>
        <span class="sop-tab-en">Intake & Discovery</span>
      </a>
      <a href="/admin/scoring/sop-2" class="sop-tab">
        <span class="sop-tab-id">🔍 SOP-2</span>
        <span class="sop-tab-zh">筛选 + 审计</span>
        <span class="sop-tab-en">Screening & Audit</span>
      </a>
    </nav>
    <div class="admin-shell lead-admin-shell scoring-shell sop-shell" data-ui-version="local-style-2026-05-08">
      <header class="admin-header">
        <div>
          <p class="eyebrow">SOP 总览 · BUSINESS PIPELINE</p>
          <h1>ProfitsLocal 销售流水线总览</h1>
          <p class="zh-en-sub"><span>End-to-end Sales Pipeline</span>　·　<span class="micro">从抓客户到付费交付的完整流水线</span></p>
          <p class="lede">每段流程都有独立 SOP；横切的资产 / 操作纪律有自己的 SOP。点 tab 切到具体 SOP 看细节。</p>
          <div class="sop2-doc-link-row">
            <a href="/admin/scoring/sop-overview-doc" class="sop2-doc-link-btn">
              <span class="sop2-doc-link-icon">📘</span>
              <span class="sop2-doc-link-text">
                <strong>SOP 总览详细文档 / source of truth</strong>
                <span class="sop2-doc-link-sub"><code>docs/SOP_OVERVIEW.md</code> · 16 SOP 矩阵 + 维护协议 + 同步规则</span>
              </span>
              <span class="sop2-doc-link-arrow">→</span>
            </a>
          </div>
          <p class="admin-page-meta">
            <span class="admin-page-version">v1.0</span>
            <span class="dot">·</span>
            <span class="admin-page-updated">最近更新 2026-05-12</span>
            <span class="dot">·</span>
            <span>16 SOPs · 3 layers · 4 channels</span>
          </p>
          <div class="admin-code-sync-banner is-synced">
            <span>✓</span>
            <div>
              <strong>页面与代码同步</strong> — Overview 内容 (USP 三分支 / 4-channel / SOP 矩阵) 均反映当前代码状态。<br/>
              <em>规则：未上代码的想法只能进 TODO，不能在此页声称已就绪。</em>
            </div>
          </div>
        </div>

        <div class="admin-count">
          <span>SOP 总数</span>
          <strong>{sopTotal}</strong>
          <span class="micro-note">{sopReady} ready · {sopInProgress} in progress · {sopUrgent} urgent · 其余待写</span>
        </div>
      </header>

      <!-- ─── USP banner (now its own section after header) ──────────── -->
      <div class="admin-banner admin-banner-coral">
        <span class="admin-banner-icon">🎯</span>
        <div class="admin-banner-body">
          <strong>我们的差异化 / Our USP</strong>
          <p>「先做好网站，再去对接客户」<br/><em>Pre-build the website, then pitch — not the other way around.</em></p>
          <p>这决定了我们的销售流程拓扑：A/B/C 都可能预制网站，A 优先，B 算力允许，C 看意向。</p>
        </div>
      </div>

      <!-- ─── SECTION 1 · 销售流水线 5 个 macro 阶段 (SOP-2 stage-grid pattern) -->
      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">销售流水线 · 5 个 macro 阶段</p>
            <h2>从抓客户到付费交付 · 完整流水线 <span class="en-sub">5 stages: Discovery → Screening → Pre-build → Sales → Pay</span></h2>
          </div>
          <span class="admin-section-count">5 个 macro 阶段 + USP 三分支分流</span>
        </div>
        <p class="section-lede">从外面抓客户进数据库 → 筛选审计评级 → A/B/C 都可能预制网站（USP 三分支） → 销售带网站去对接 → 客户决定付费 → 交付维护。每个阶段对应一份 SOP。</p>

        <div class="stage-grid">
          <div class="stage-card">
            <div class="stage-num">第 1 步</div>
            <div class="stage-name">客户发现<span class="stage-en">Discovery</span></div>
            <div class="stage-desc">
              <p class="stage-desc-zh">从外面找客户：gosom Docker scraper (主入口) · image lead 单 lead 入 · 关键词 search（多 search 引擎）。</p>
              <p class="stage-desc-en"><span class="lang-tag">EN</span> 3 entries: gosom Docker / image / keyword search → entity store</p>
            </div>
            <div class="stage-meta">
              <div><span class="stage-meta-label">SOP</span> <a href="/admin/scoring/sop-1">SOP-1 (调研中)</a></div>
              <div><span class="stage-meta-label">Channel</span> <code>#lead-discovery-runs</code></div>
              <div><span class="stage-meta-label">产出</span> <code>data/leads/entities/&lt;key&gt;.json</code></div>
            </div>
          </div>

          <div class="stage-card">
            <div class="stage-num">第 2 步</div>
            <div class="stage-name">筛选 + 审计<span class="stage-en">Screening & Audit</span></div>
            <div class="stage-desc">
              <p class="stage-desc-zh">先 cheap-audit-v2 19 规则粗筛 → audit_candidate 走 detailed audit (11 sub-audit 含 PSI/domain/form) + visual audit → 6 维 39 规则评级 → A/B/C/D。</p>
              <p class="stage-desc-en"><span class="lang-tag">EN</span> cheap-audit → detailed audit → visual → gradeLead → A/B/C/D + T1/T2/T3</p>
            </div>
            <div class="stage-meta">
              <div><span class="stage-meta-label">SOP</span> <a href="/admin/scoring/sop-2">SOP-2 (有了)</a></div>
              <div><span class="stage-meta-label">Channel</span> <code>#lead-discovery-runs</code> → <code>#website-leads</code></div>
              <div><span class="stage-meta-label">产出</span> <code>entity.grade</code> + <code>internal-audit-report.html</code></div>
            </div>
          </div>

          <div class="stage-card stage-conditional">
            <div class="stage-num">USP 三分支<span class="stage-cond-badge">grade 决定</span></div>
            <div class="stage-name">是否预制网站<span class="stage-en">Pre-build website?</span></div>
            <div class="stage-desc">
              <p class="stage-desc-zh"><strong>A</strong> 必做（优先）· <strong>B</strong> 也做（A 排完算力允许）· <strong>C</strong> 看意向（销售先聊，有意 → 反向建）· <strong>D</strong> 跳过。<br/>这是我们的差异化 — 拿着网站去对接 prospect，而不是嘴上推销空气。</p>
            </div>
            <div class="stage-meta">
              <div><span class="stage-meta-label">A</span> <span class="chip chip-mint">必做</span> OD 立刻预制 → 销售带网站对接</div>
              <div><span class="stage-meta-label">B</span> <span class="chip chip-citrus">也做</span> A 排完算力允许 → OD 跟做</div>
              <div><span class="stage-meta-label">C</span> <span class="chip chip-sky">看意向</span> 销售先对接 · 有意 → OD 反向建 · 没意 → 归档</div>
              <div><span class="stage-meta-label">D</span> <span class="chip chip-muted">跳过</span> 不投入 (hard-skip)</div>
            </div>
          </div>

          <div class="stage-card">
            <div class="stage-num">第 3 步</div>
            <div class="stage-name">Open Design 网站预制<span class="stage-en">Pre-built Website</span></div>
            <div class="stage-desc">
              <p class="stage-desc-zh">基于 master.md + audit report，针对性建 demo 网站（新站 / redesign）。需要自动化让单客户成本可控。</p>
              <p class="stage-desc-en"><span class="lang-tag">EN</span> Open Design → demo URL → clients/&lt;slug&gt;/v2/</p>
            </div>
            <div class="stage-meta">
              <div><span class="stage-meta-label">SOP</span> SOP-3 (待写)</div>
              <div><span class="stage-meta-label">Channel</span> <code>#website-projects</code></div>
              <div><span class="stage-meta-label">输入</span> master.md + audit report</div>
            </div>
          </div>

          <div class="stage-card">
            <div class="stage-num">第 4 步</div>
            <div class="stage-name">销售对接<span class="stage-en">Sales Engagement</span></div>
            <div class="stage-desc">
              <p class="stage-desc-zh">A/B/C 客户进入 per-lead Discord thread。多触点 outreach：contact-us 表单 / GMB / social handles / phone / email。自动化 sequence 是 scale 核心。</p>
              <p class="stage-desc-en"><span class="lang-tag">EN</span> Multi-touch outreach + auto sequence + reply handling</p>
            </div>
            <div class="stage-meta">
              <div><span class="stage-meta-label">SOP</span> SOP-4 (待写)</div>
              <div><span class="stage-meta-label">Channel</span> <code>#website-leads</code></div>
              <div><span class="stage-meta-label">触点</span> contact-us · GMB · social · phone · email</div>
            </div>
          </div>

          <div class="stage-card">
            <div class="stage-num">第 5 步</div>
            <div class="stage-name">付费 → 交付 → 维护<span class="stage-en">Pay → Deliver → Maintain</span></div>
            <div class="stage-desc">
              <p class="stage-desc-zh">客户看 demo 决定 → Stripe checkout → bootstrap client repo → CF Pages 部署 → 域名 setup → ongoing 维护（revision / 内容 / SEO）。</p>
              <p class="stage-desc-en"><span class="lang-tag">EN</span> Stripe → bootstrap → CF Pages → domain → maintain</p>
            </div>
            <div class="stage-meta">
              <div><span class="stage-meta-label">SOP</span> SOP-5 (待写)</div>
              <div><span class="stage-meta-label">Channel</span> <code>#paid-websites</code></div>
              <div><span class="stage-meta-label">产出</span> live website + 客户长期关系</div>
            </div>
          </div>
        </div>
      </section>

      <!-- ─── SECTION 2 · Discord 4-channel lifecycle (channel-flow pattern) -->
      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">Discord 频道架构 · 客户走过的 4 段路</p>
            <h2>4 channels · 4 段生命周期 <span class="en-sub">Each Discord channel = one lead lifecycle stage</span></h2>
          </div>
          <span class="admin-section-count">客户级别上升时"毕业"到下一段</span>
        </div>
        <p class="section-lede">每段的 <strong>节奏</strong> · <strong>受众</strong> · <strong>关注点</strong> 都不同，所以分 4 个频道而不是一个。详情见 SOP-X-Discord (待写)。</p>

        <div class="channel-flow">
          <div class="channel-card channel-0">
            <div class="channel-stage">阶段 1 · 客户发现批次</div>
            <div class="channel-zh">线索发现 + 审计 batch</div>
            <div class="channel-name"><code>#lead-discovery-runs</code></div>
            <div class="channel-unit">1 batch task = 1 thread</div>
            <div class="channel-purpose">看每批"抓 + 筛 + 审"进度 · 监控 ops</div>
            <div class="channel-meta">
              <span>👁 受众：<strong>你 + AI 监督</strong></span>
              <span>📄 文档：SOP-1 + SOP-2</span>
            </div>
          </div>
          <div class="channel-arrow">
            <span class="channel-arrow-label">当客户分级 A/B/C → 自动"毕业"到下一段</span>
            <span class="channel-arrow-glyph">▼</span>
          </div>

          <div class="channel-card channel-1">
            <div class="channel-stage">阶段 2 · 高质量销售线索</div>
            <div class="channel-zh">per-lead 销售对话</div>
            <div class="channel-name"><code>#website-leads</code></div>
            <div class="channel-unit">1 A/B/C 客户 = 1 thread</div>
            <div class="channel-purpose">每个潜在客户单独跟进 · 多触点 outreach + 沟通记录</div>
            <div class="channel-meta">
              <span>👁 受众：<strong>销售人员</strong></span>
              <span>📄 文档：SOP-4 (待写)</span>
            </div>
          </div>
          <div class="channel-arrow">
            <span class="channel-arrow-label">客户表示有意 / OD 建好 demo → 进 demo 制作</span>
            <span class="channel-arrow-glyph">▼</span>
          </div>

          <div class="channel-card channel-2">
            <div class="channel-stage">阶段 3 · 网站方案 / Demo</div>
            <div class="channel-zh">demo 制作 + revision</div>
            <div class="channel-name"><code>#website-projects</code></div>
            <div class="channel-unit">1 demo 制作 = 1 thread</div>
            <div class="channel-purpose">给客户看的新站 demo / 改版 demo 制作 · Open Design 流程</div>
            <div class="channel-meta">
              <span>👁 受众：<strong>设计 + 客户</strong></span>
              <span>📄 文档：SOP-3 (待写)</span>
            </div>
          </div>
          <div class="channel-arrow">
            <span class="channel-arrow-label">客户付费 → 进生产</span>
            <span class="channel-arrow-glyph">▼</span>
          </div>

          <div class="channel-card channel-3">
            <div class="channel-stage">阶段 4 · 付费客户</div>
            <div class="channel-zh">交付 + 长期维护</div>
            <div class="channel-name"><code>#paid-websites</code></div>
            <div class="channel-unit">1 付费客户 = 1 thread</div>
            <div class="channel-purpose">客户付费后的部署 + ongoing 维护 / 修订 / SEO</div>
            <div class="channel-meta">
              <span>👁 受众：<strong>交付 + 客服</strong></span>
              <span>📄 文档：SOP-5 (待写)</span>
            </div>
          </div>
        </div>

        <p class="admin-note-line"><strong>📇 客户 Contact Identity</strong> (横跨 4 channel 不变的 artifact) — 每个 entity 维护多触点 ID：GMB / 网站 Contact Us 页 / 社交账号 (FB/IG/LinkedIn) / Phone / Email。SOP-4 销售按触点优先级跨渠道触达 → 单一渠道死 ≠ lead 死。详见 <strong>SOP-ART-3</strong>（待写）。</p>
      </section>

      <!-- ─── SECTION 3 · 16-SOP Matrix ──────────────────────────────────── -->
      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">SOP 矩阵 · 全部 {sopTotal} 项</p>
            <h2>当前状态总览 <span class="en-sub">All SOPs by layer + current status</span></h2>
          </div>
          <span class="admin-section-count">{sopUrgent} 🔴 紧急 · {sopInProgress} 🟡 进行中 · {sopReady} ✅ 完成</span>
        </div>

        {Object.entries(sopCatalog).map(([key, group]) => (
          <div class="sop-layer">
            <h3 class="admin-subhead">{group.title}</h3>
            <p class="admin-subhead-note">{group.subtitle}</p>
            <div class="admin-table-wrap">
              <table class="admin-table">
                <thead><tr><th>编号</th><th>名称</th><th>状态</th><th>触发条件 / 范围</th><th>页面</th></tr></thead>
                <tbody>
                  {group.items.map((s) => (
                    <tr>
                      <td><code>{s.id}</code></td>
                      <td><strong>{s.zh}</strong></td>
                      <td>{s.status}</td>
                      <td>{s.trigger}{s.channel && <span class="sop-channel-pill"> · {s.channel}</span>}</td>
                      <td>{s.href ? <a href={s.href} class="admin-back-link" style="padding:3px 10px;font-size:11px;">打开 →</a> : <span class="text-muted">—</span>}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        ))}
      </section>

      <!-- ─── SECTION 4 · Business Snapshot ──────────────────────────────── -->
      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">业务现状 · LIVE SNAPSHOT</p>
            <h2>当前数据快照 <span class="en-sub">As of {new Date().toISOString().slice(0, 16).replace('T', ' ')}</span></h2>
          </div>
          <span class="admin-section-count">build-time 读取 · 不实时</span>
        </div>

        <div class="admin-card-grid admin-card-grid-4">
          <div class="admin-card">
            <p class="eyebrow">总 entity</p>
            <p class="snapshot-big">{entityCount}</p>
            <p class="admin-card-meta">{detailedAudits} 已 detailed audit</p>
          </div>
          <div class="admin-card">
            <p class="eyebrow">Grade 分布</p>
            <p class="snapshot-grade-row">
              <span><b>A</b> {gradeCounts.A}</span>
              <span><b>B</b> {gradeCounts.B}</span>
              <span><b>C</b> {gradeCounts.C}</span>
              <span><b>D</b> {gradeCounts.D}</span>
            </p>
            <p class="admin-card-meta">{gradeCounts.ungraded} 未评级</p>
          </div>
          <div class="admin-card">
            <p class="eyebrow">Discord thread</p>
            <p class="snapshot-big">{withDiscordThread}</p>
            <p class="admin-card-meta">A/B graduated to #website-leads</p>
          </div>
          <div class="admin-card">
            <p class="eyebrow">历史 batch</p>
            <p class="snapshot-big">{batchCount}</p>
            <p class="admin-card-meta">pipeline-batches 累计</p>
          </div>
        </div>
      </section>

      <!-- ─── SECTION 5 · Maintenance protocol ───────────────────────────── -->
      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">SOP 维护协议</p>
            <h2>改流程 = 改 doc + 改 admin 页 (paired)</h2>
          </div>
        </div>
        <div class="admin-banner admin-banner-lilac">
          <span class="admin-banner-icon">📋</span>
          <div class="admin-banner-body">
            <strong>每个 SOP 同时有 3 个产物</strong>
            <p>1 个 admin 页面 (macro · 给操作员) · 1 个详细文档 (source of truth · 给 AI/工程师) · 1 份调研笔记 (建 SOP 前的现状摸底)</p>
          </div>
        </div>

        <h3 class="admin-subhead">4-step 工作流 (建 SOP 必须走完)</h3>
        <ul class="admin-marker-list">
          <li><strong>Step 1 · 现状调研</strong> — 读相关代码 / commit / 跑 happy path → 写 investigation note</li>
          <li><strong>Step 2 · Review</strong> — Matthew 确认现状没搞错</li>
          <li><strong>Step 3 · 写 SOP v0.1</strong> — 中文主 + 英文对照 · 目的 / 步骤 / 容易忽略的点 / 维护规则</li>
          <li><strong>Step 4 · 验证</strong> — astro build → push → GH Actions success → browser verify live + screenshot</li>
        </ul>

        <p class="admin-note-line"><strong>📘 Design System</strong>：所有 admin 页面遵守 <code>docs/ADMIN_DESIGN_SYSTEM.md</code> · 不允许 per-page 自造视觉模式 · 改 design system → 同时改 doc + admin-design-system.css + 截图验证</p>
      </section>
    </div>
  </section>
</Layout>

