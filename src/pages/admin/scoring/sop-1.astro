---
import Layout from '../../../layouts/AdminLayout.astro';
import fs from 'node:fs';
import path from 'node:path';
import { activeChannels, plannedChannels } from '../../../../core/leads/intake-channels.js';

// SOP-1 入口注册表 · 单一真相 · 改这一个 JSON 全站同步
// data/sop1/intake-channels.json
const channels = activeChannels();
const planned = plannedChannels();

// Pick a real entity sample for the handoff payload viz (prefer one with grade + multi-field)
let sampleEntity = null;
try {
  const dir = path.join(process.cwd(), 'data/leads/entities');
  const candidates = fs.readdirSync(dir).filter((f) => f.startsWith('place_') && f.endsWith('.json'));
  // Prefer one with grade.investment_level set; fall back to any
  for (const f of candidates) {
    try {
      const e = JSON.parse(fs.readFileSync(path.join(dir, f), 'utf8'));
      if (e.grade?.investment_level && !sampleEntity) sampleEntity = e;
      if (sampleEntity) break;
    } catch {}
  }
  if (!sampleEntity && candidates.length > 0) {
    sampleEntity = JSON.parse(fs.readFileSync(path.join(dir, candidates[0]), 'utf8'));
  }
} catch {}
---

<Layout title="SOP-1 · 客户发现 + Dedup + Enrichment" active="scoring">
  <section class="poster-section admin-section sop-page">
    <nav class="sop-tabs sop-tabs--global" aria-label="SOP navigation">
      <a href="/admin/scoring" class="sop-tab">
        <span class="sop-tab-id">📊 概览</span>
        <span class="sop-tab-zh">销售流水线总览</span>
        <span class="sop-tab-en">Overview</span>
      </a>
      <a href="/admin/scoring/sop-0" class="sop-tab">
        <span class="sop-tab-id">🚪 SOP-0</span>
        <span class="sop-tab-zh">统一入口</span>
        <span class="sop-tab-en">Task System</span>
      </a>
      <a href="/admin/scoring/sop-1" class="sop-tab sop-tab--active" aria-current="page">
        <span class="sop-tab-id">🎣 SOP-1</span>
        <span class="sop-tab-zh">客户发现</span>
        <span class="sop-tab-en">Intake & Discovery</span>
      </a>
      <a href="/admin/scoring/sop-2" class="sop-tab">
        <span class="sop-tab-id">🔍 SOP-2</span>
        <span class="sop-tab-zh">筛选 + 审计</span>
        <span class="sop-tab-en">Screening & Audit</span>
      </a>
    </nav>
    <div class="admin-shell lead-admin-shell scoring-shell sop-shell" data-ui-version="local-style-2026-05-08">
      <header class="admin-header">
        <div>
          <p class="eyebrow">SOP-1 · 把新商家找进来、去重、补联系方式</p>
          <h1>客户发现 · 把新商家找进来并整理干净</h1>
          <p class="zh-en-sub"><span>找进来 · 去重 · 补联系方式（Intake · Dedup · Enrichment）</span>　·　<span class="micro">"找一批新店 + 重复的合并掉 + 电话官网都补齐"</span></p>
          <p class="lede">SOP-1 交给下一站（SOP-2 筛选+审计）的承诺：每家商家都<strong>去过重 + 联系方式补到位</strong>。SOP-2 拿到就能直接做网站审计，不用再帮忙查电话、判重复。</p>

          <div class="sop2-doc-link-row">
            <a href="/admin/scoring/sop-1-doc" class="sop2-doc-link-btn">
              <span class="sop2-doc-link-icon">📘</span>
              <span class="sop2-doc-link-text">
                <strong>SOP-1 详细文档 v1.0（给工程师看）</strong>
                <span class="sop2-doc-link-sub">完整技术细节、踩坑记录、工具清单 · <code>docs/SOP_1_INTAKE_DISCOVERY.md</code></span>
              </span>
              <span class="sop2-doc-link-arrow">→</span>
            </a>
          </div>
          <div class="sop2-doc-link-row">
            <a href="/admin/scoring/sop-handoff-doc" class="sop2-doc-link-btn">
              <span class="sop2-doc-link-icon">📑</span>
              <span class="sop2-doc-link-text">
                <strong>SOP-1 → SOP-2 交接清单（Handoff Contract）</strong>
                <span class="sop2-doc-link-sub">交给下一站的商家档案到底要包含哪些字段、哪些必填</span>
              </span>
              <span class="sop2-doc-link-arrow">→</span>
            </a>
          </div>
          <div class="sop2-doc-link-row">
            <a href="/admin/scoring/sop-x-dedup-doc" class="sop2-doc-link-btn">
              <span class="sop2-doc-link-icon">🧬</span>
              <span class="sop2-doc-link-text">
                <strong>去重规则详解（SOP-X-Dedup）</strong>
                <span class="sop2-doc-link-sub">3 个判重信号怎么用、撞库后怎么合并、人工复核界面在哪</span>
              </span>
              <span class="sop2-doc-link-arrow">→</span>
            </a>
          </div>

          <p class="admin-page-meta">
            <span class="admin-page-version">v1.0</span>
            <span class="dot">·</span>
            <span class="admin-page-updated">最近更新 2026-05-12</span>
            <span class="dot">·</span>
            <span>4 步流程 · 2 个入口 · 单线 intake → dedup → enrich → handoff</span>
          </p>
          <div class="admin-code-sync-banner is-synced">
            <span>✓</span>
            <div>
              <strong>这页只讲什么</strong>：只讲 SOP-1（找进来 + 去重 + 补联系方式 + 交接给 SOP-2）。网站审计、商家分级、Discord 开 thread 归 <a href="/admin/scoring/sop-2">SOP-2</a>；商家档案完整字段定义看 <a href="/admin/scoring/sop-handoff-doc">SOP-X-Handoff</a>；各种工具的成本/配额看 <a href="/admin/scoring/sop-x-tooling">SOP-X-Tooling</a>。<br/>
              <strong>页面 ↔ 代码已同步</strong>（C5-Phase-A+B+C 完成 2026-05-12）— SOP-1 交接承诺端到端跑通：
              <code>isThinContact()</code> 判断器（看商家是不是缺联系方式，源码在 <code>core/leads/thin-contact.js</code>）+
              <code>enrichment_status</code>（补全状态标签）自动写入 +
              <code>isEnrichmentReady()</code> 排队闸门（决定能不能进 SOP-2 队列）+
              <code>pl:run-enrichment-batch</code> 命令行工具（实测 6/6 条路都跑通、$0 成本）+
              <code>pl:pipeline-batch-step --finalize</code> 自动触发 <code>pl:dedup-audit</code>（批次跑完自动去重）+
              cheap-audit-v2 兜底链注释。<br/>
              <strong>还没做</strong> — G-11 抓取兜底链路 · G-6.1 图片自动 OCR 识别 · G-18 把定时任务接到 Hermes 调度。
            </div>
          </div>
        </div>
        <div class="admin-count">
          <span>当前状态</span>
          <strong>✅ v1.0</strong>
          <span class="micro-note">4 步流程已跑通 · 出口商家<br/>全部去过重 + 联系方式补到位</span>
        </div>
      </header>

      <!-- ─── SOP-1 流程图 (只画自己的 4 步) ────────────────────────────── -->
      <section class="admin-paper-section flow-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">SOP-1 流程</p>
            <h2>从抓商家到交给 SOP-2，一共 4 步</h2>
          </div>
          <span class="admin-section-count">{channels.length} 个入口 · 4 步流程（建档 → 去重 → 补联系方式 → 交接）</span>
        </div>

        <div class="flow-grid">
          {/* ENTRIES · 从 data/sop1/intake-channels.json 动态渲染 · 新增入口改那个 JSON 即可 */}
          <div class="flow-row">
            <div class="flow-row-label">从哪进来</div>
            <div class="flow-entries">
              {channels.map((ch) => (
                <div
                  class="flow-entry"
                  title={`CLI: ${ch.cli} · 触发: ${ch.trigger_example}${ch.known_issue ? '\n⚠ 已知问题: ' + ch.known_issue : ''}`}
                  style={ch.status === 'active-but-broken' ? 'border-color: #d97706; background: rgba(217, 119, 6, 0.06)' : ''}
                >
                  <div class="flow-entry-tag">
                    <span style="margin-right: 0.3em">{ch.icon}</span>{ch.name_zh}
                    {ch.status === 'active-but-broken' && <span style="margin-left: 0.5em; font-size: 0.8em; color: #d97706">⚠ 待修</span>}
                  </div>
                  <div class="flow-entry-desc">{ch.primary_use}</div>
                  <div class="flow-entry-meta" style="font-size: 0.75em; opacity: 0.6; margin-top: 0.25em">
                    <code>{ch.cli}</code>
                  </div>
                  {ch.known_issue && (
                    <div class="flow-entry-issue" style="font-size: 0.75em; color: #92400e; margin-top: 0.4em; padding: 0.3em 0.5em; background: rgba(217,119,6,0.08); border-left: 2px solid #d97706; border-radius: 3px">
                      <strong>⚠ </strong>{ch.known_issue.split(' · ')[0]}
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
          {planned.length > 0 && (
            <div class="flow-row" style="opacity: 0.55">
              <div class="flow-row-label">待加入</div>
              <div class="flow-entries">
                {planned.map((ch) => (
                  <div class="flow-entry">
                    <div class="flow-entry-tag">{ch.name_zh}</div>
                    <div class="flow-entry-desc" style="font-size: 0.85em">{ch.rationale}</div>
                    <div class="flow-entry-meta" style="font-size: 0.7em; opacity: 0.7">{ch.status}</div>
                  </div>
                ))}
              </div>
            </div>
          )}
          <div class="flow-arrow-row">▼</div>

          <!-- STEP 1: DISCOVERY WRITE -->
          <div class="flow-step">
            <div class="flow-step-num">1</div>
            <div class="flow-step-body">
              <div class="flow-step-title">建档：把找到的商家写进系统 <span class="flow-step-badge">每条都跑</span></div>
              <div class="flow-step-desc">在 <code>data/leads/entities/&lt;entityKey&gt;.json</code> 落一份档案 · 字段格式统一化 · 打上批次号（<code>batch_id</code>）和搜索词（<code>sourceQuery</code>）</div>
              <div class="flow-step-meta">如果 Google 店铺 ID（<code>place_id</code>）已经入过库 → 直接合并到原档案（<code>mergeLeadIntoEntity</code>）</div>
            </div>
          </div>
          <div class="flow-arrow-row">▼</div>

          <!-- STEP 2: DEDUP -->
          <div class="flow-step">
            <div class="flow-step-num">2</div>
            <div class="flow-step-body">
              <div class="flow-step-title">去重：查有没有重复商家 <span class="flow-step-badge">每条都跑</span></div>
              <div class="flow-step-desc">3 个判重信号：Google 店铺 ID（<code>place_id</code>）· 电话号（<code>phoneDigits</code>，归一后 10 位）· 官网域名（<code>websiteDomain</code>，去掉 www. 取根域）。电话或域名撞上 → 进人工复核队列。</div>
              <div class="flow-step-out">
                <span class="flow-out-fail">疑似重复 → 去 <a href="/admin/v2-leads/dedup-review">/admin/v2-leads/dedup-review</a> 人工判定</span>
              </div>
            </div>
          </div>
          <div class="flow-arrow-row">▼</div>

          <!-- STEP 3: ENRICHMENT (single-line · no branch) -->
          <div class="flow-step">
            <div class="flow-step-num">3</div>
            <div class="flow-step-body">
              <div class="flow-step-title">补联系方式：到处搜电话和官网 <span class="flow-step-badge">每条都跑</span></div>
              <div class="flow-step-desc">5 个搜索通道：官网、Facebook、Instagram、LinkedIn、第三方目录（hipages、yelp 等）</div>
              <div class="flow-step-meta">把找到的填进 <code>contact_identity</code>。出口三态：<code>complete</code>（有 phone OR website）/ <code>partial</code>（跑了但没拿到联系方式但有 social 等其他证据）/ <code>unenrichable</code>（所有 route 都失败）</div>
              <div class="flow-step-meta" style="opacity:0.7">⚠ Places API 补全（行业分类 / 店面图 / E.164 phone / 营业时间）属于 <strong>SOP-2 回流</strong>（grade ≥ B 后由 SOP-2 调）· 不在 SOP-1 主链 · 见 <a href="/admin/scoring/sop-2">SOP-2</a></div>
            </div>
          </div>
          <div class="flow-arrow-row">▼</div>

          <!-- STEP 4: HANDOFF -->
          <div class="flow-step admin-flow-step--handoff">
            <div class="flow-step-num">4</div>
            <div class="flow-step-body">
              <div class="flow-step-title">交接：把商家送进 SOP-2 队列</div>
              <div class="flow-step-desc">写入补全状态（<code>enrichment_status</code>） · 商家档案落到 <code>queues/cheap-site-audit.json</code> · 等 SOP-2 来拉取</div>
              <div class="flow-step-meta">出口承诺：已去过重 + 联系方式补到位（或者明确标了"查不到联系方式"）</div>
            </div>
          </div>
        </div>
      </section>

      <!-- ─── Handoff Payload Sample (annotated) ──────────────────────── -->
      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">交给 SOP-2 的商家档案长什么样</p>
            <h2>SOP-2 拿到的字段（带注释的样本）</h2>
          </div>
          <span class="admin-section-count">完整字段定义见交接清单文档</span>
        </div>
        <p class="section-lede">下面是一个真实商家档案的节选（只挑了关键字段）。<strong>每行后面写清：SOP-1 怎么填进去 + SOP-2 拿来干嘛用</strong>。这是双方的约定本身，不是数据导出 — SOP-2 拿到的就是这个结构。</p>

        {sampleEntity && (
          <div class="admin-payload-card">
            <div class="admin-payload-line"><span class="admin-payload-key">entityKey</span><span class="admin-payload-val">"{sampleEntity.entityKey}"</span><span class="admin-payload-note">SOP-1 给商家发的唯一身份证号 · 后续所有引用都用这个</span></div>

            <div class="admin-payload-section">identifiers · 判重用的几个信号</div>
            <div class="admin-payload-line"><span class="admin-payload-key">  place_id</span><span class="admin-payload-val">"{sampleEntity.identifiers?.place_id?.slice(0, 36) || ''}..."</span><span class="admin-payload-note">Google 店铺 ID · 判重首选信号</span></div>
            <div class="admin-payload-line"><span class="admin-payload-key">  phoneDigits</span><span class="admin-payload-val">"{sampleEntity.identifiers?.phoneDigits || ''}"</span><span class="admin-payload-note">判重次选 · 电话归一化后留最后 10 位</span></div>
            <div class="admin-payload-line"><span class="admin-payload-key">  websiteDomain</span><span class="admin-payload-val">"{sampleEntity.identifiers?.websiteDomain || ''}"</span><span class="admin-payload-note">判重次选 · 官网去掉 www. 留根域名</span></div>

            <div class="admin-payload-section">latest · SOP-2 主要会读的字段</div>
            <div class="admin-payload-line"><span class="admin-payload-key">  name</span><span class="admin-payload-val">"{sampleEntity.latest?.name || ''}"</span><span class="admin-payload-note">SOP-2 客户档案（master.md）的标题</span></div>
            <div class="admin-payload-line"><span class="admin-payload-key">  niche</span><span class="admin-payload-val">"{sampleEntity.latest?.niche || ''}"</span><span class="admin-payload-note">行业 · SOP-2 根据这个挑专属审计规则</span></div>
            <div class="admin-payload-line"><span class="admin-payload-key">  city</span><span class="admin-payload-val">"{sampleEntity.latest?.city || ''}"</span><span class="admin-payload-note">城市 · SOP-2 用来搜评论、算行业匹配分</span></div>
            <div class="admin-payload-line"><span class="admin-payload-key">  phone</span><span class="admin-payload-val">"{sampleEntity.latest?.phone || ''}"</span><span class="admin-payload-note">⭐ SOP-1 补全后填 · 或标"查不到"（unenrichable）</span></div>
            <div class="admin-payload-line"><span class="admin-payload-key">  website</span><span class="admin-payload-val">"{sampleEntity.latest?.website || ''}"</span><span class="admin-payload-note">⭐ 同上 · 这是 SOP-2 做网站审计的入口</span></div>
            <div class="admin-payload-line"><span class="admin-payload-key">  sourceQuery</span><span class="admin-payload-val">"{sampleEntity.latest?.sourceQuery || ''}"</span><span class="admin-payload-note">当初的搜索词 · SOP-1 强制 = 批次查询 · 用来追溯</span></div>
            <div class="admin-payload-line"><span class="admin-payload-key">  batch_id</span><span class="admin-payload-val">"{sampleEntity.latest?.batch_id || ''}"</span><span class="admin-payload-note">批次号 · SOP-1 打上 · SOP-2 可以按批次过滤</span></div>

            <div class="admin-payload-section">enrichment_status · SOP-1 出口的核心承诺</div>
            <div class="admin-payload-line"><span class="admin-payload-key">enrichment_status</span><span class="admin-payload-val">"{sampleEntity.enrichment_status || '(待 SOP-1 填；当前样本是历史商家)'}"</span><span class="admin-payload-note">complete（补到位）/ partial（部分）/ unenrichable（查不到）</span></div>

            <div class="admin-payload-section">SOP-2 回填的字段（SOP-1 不读这些）</div>
            <div class="admin-payload-line"><span class="admin-payload-key">grade</span><span class="admin-payload-val">{sampleEntity.grade ? `{ investment_level: "${sampleEntity.grade.investment_level}", product_tier: "${sampleEntity.grade.product_tier || ''}" }` : 'null'}</span><span class="admin-payload-note">商家分级 · SOP-2 评完之后写回</span></div>
            <div class="admin-payload-line"><span class="admin-payload-key">discord_thread_id</span><span class="admin-payload-val">"{sampleEntity.discord_thread_id || ''}"</span><span class="admin-payload-note">Discord 客户档案 thread · 评级 A/B 自动开后写回</span></div>

            <p class="admin-payload-source">↑ 真实商家样本：<code>{sampleEntity.entityKey}</code></p>
          </div>
        )}

        {!sampleEntity && (
          <p class="admin-note-line">⚠ 当前商家档案库为空，渲染不出样本。完整字段定义见 <a href="/admin/scoring/sop-handoff-doc">SOP-X-Handoff §2</a>。</p>
        )}
      </section>

      <!-- ─── 链接到详细文档 + admin operations -->
      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">深入了解</p>
            <h2>看更多细节 · 实际操作</h2>
          </div>
        </div>
        <div class="admin-card-grid admin-card-grid-3">
          <div class="admin-card">
            <p class="eyebrow">详细文档（给工程师看）</p>
            <p><a href="/admin/scoring/sop-1-doc">SOP-1 v1.0 详细文档</a></p>
            <p class="admin-card-meta">技术细节、字段命名差异、批次号怎么传、8 条踩坑记录、工具落地状态</p>
          </div>
          <div class="admin-card">
            <p class="eyebrow">操作员界面</p>
            <p><a href="/admin/v2-leads/dedup-review">疑似重复复核</a> · <a href="/admin/v2-leads/niches">按行业浏览商家</a></p>
            <p class="admin-card-meta">人工判定疑似重复的商家 · 按行业分组看 · 为加项推荐做准备</p>
          </div>
          <div class="admin-card">
            <p class="eyebrow">命令行工具</p>
            <p><code>pl:scrape-docker</code> · <code>pl:ingest-image</code> · <code>pl:places-enrich</code> · <code>pl:dedup-audit</code> · <code>pl:rebuild-niche-shards</code></p>
            <p class="admin-card-meta">分别对应：抓 Google Maps · 图片建档 · Places 补全 · 去重复核 · 重建行业分组。完整列表见 <a href="/admin/scoring/sop-1-doc">详细文档 §9</a></p>
          </div>
        </div>
      </section>
    </div>
  </section>
</Layout>

<!-- No per-page <style> · all classes live in admin-design-system.css (v1.2+) -->
