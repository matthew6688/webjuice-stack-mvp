---
import Layout from '../../../layouts/AdminLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

// Pick a real entity sample for the handoff payload viz (prefer one with grade + multi-field)
let sampleEntity = null;
try {
  const dir = path.join(process.cwd(), 'data/leads/entities');
  const candidates = fs.readdirSync(dir).filter((f) => f.startsWith('place_') && f.endsWith('.json'));
  // Prefer one with grade.investment_level set; fall back to any
  for (const f of candidates) {
    try {
      const e = JSON.parse(fs.readFileSync(path.join(dir, f), 'utf8'));
      if (e.grade?.investment_level && !sampleEntity) sampleEntity = e;
      if (sampleEntity) break;
    } catch {}
  }
  if (!sampleEntity && candidates.length > 0) {
    sampleEntity = JSON.parse(fs.readFileSync(path.join(dir, candidates[0]), 'utf8'));
  }
} catch {}
---

<Layout title="SOP-1 · 客户发现 + Dedup + Enrichment" active="scoring">
  <section class="poster-section admin-section sop-page">
    <nav class="sop-tabs sop-tabs--global" aria-label="SOP navigation">
      <a href="/admin/scoring" class="sop-tab">
        <span class="sop-tab-id">📊 概览</span>
        <span class="sop-tab-zh">销售流水线总览</span>
        <span class="sop-tab-en">Overview</span>
      </a>
      <a href="/admin/scoring/sop-1" class="sop-tab sop-tab--active" aria-current="page">
        <span class="sop-tab-id">🎣 SOP-1</span>
        <span class="sop-tab-zh">客户发现</span>
        <span class="sop-tab-en">Intake & Discovery</span>
      </a>
      <a href="/admin/scoring/sop-2" class="sop-tab">
        <span class="sop-tab-id">🔍 SOP-2</span>
        <span class="sop-tab-zh">筛选 + 审计</span>
        <span class="sop-tab-en">Screening & Audit</span>
      </a>
    </nav>
    <div class="admin-shell lead-admin-shell scoring-shell sop-shell">
      <header class="admin-header">
        <div>
          <p class="eyebrow">SOP-1 · 客户发现 + 去重 + 增强</p>
          <h1>客户发现 / Intake</h1>
          <p class="zh-en-sub"><span>Intake · Dedup · Enrichment</span>　·　<span class="micro">"我们找进来 + 整理干净 + 联系方式补全"</span></p>
          <p class="lede">SOP-1 出口承诺给 SOP-2：每个 entity 都 <strong>dedup-clean + enrichment-complete</strong>。 SOP-2 拿到就能直接 audit，不用再做联系方式补全 / 去重判定。</p>

          <div class="sop2-doc-link-row">
            <a href="/admin/scoring/sop-1-doc" class="sop2-doc-link-btn">
              <span class="sop2-doc-link-icon">📘</span>
              <span class="sop2-doc-link-text">
                <strong>SOP-1 详细文档 v1.0</strong>
                <span class="sop2-doc-link-sub">完整技术细节 / gotchas / 工具 · <code>docs/SOP_1_INTAKE_DISCOVERY.md</code></span>
              </span>
              <span class="sop2-doc-link-arrow">→</span>
            </a>
            <a href="/admin/scoring/sop-handoff-doc" class="sop2-doc-link-btn">
              <span class="sop2-doc-link-icon">📑</span>
              <span class="sop2-doc-link-text">
                <strong>SOP-1 → SOP-2 Handoff Contract</strong>
                <span class="sop2-doc-link-sub">entity schema 全字段定义 + 必填校验</span>
              </span>
              <span class="sop2-doc-link-arrow">→</span>
            </a>
            <a href="/admin/scoring/sop-x-dedup-doc" class="sop2-doc-link-btn">
              <span class="sop2-doc-link-icon">🧬</span>
              <span class="sop2-doc-link-text">
                <strong>Dedup 协议详解 (SOP-X-Dedup)</strong>
                <span class="sop2-doc-link-sub">3-key 规则 + 合并语义 + operator UI</span>
              </span>
              <span class="sop2-doc-link-arrow">→</span>
            </a>
          </div>

          <p class="admin-page-meta">
            <span class="admin-page-version">v1.0</span>
            <span class="dot">·</span>
            <span class="admin-page-updated">最近更新 2026-05-12</span>
            <span class="dot">·</span>
            <span>4 步 · 2 入口 · enrichment 2 路</span>
          </p>
          <div class="admin-code-sync-banner is-stale">
            <span>⚠</span>
            <div>
              <strong>本页范围</strong>：仅 SOP-1（Discovery + Dedup + Enrichment + Handoff）。audit / grade / thread 归 <a href="/admin/scoring/sop-2">SOP-2</a>；entity schema 全字段归 <a href="/admin/scoring/sop-handoff-doc">SOP-X-Handoff</a>；工具计费归 <a href="/admin/scoring/sop-x-tooling">SOP-X-Tooling</a>。<br/>
              <strong>⚠ 文档承诺 vs 代码落地差距</strong>（待 C5 修复）—
              <code>enrichment_status</code> 字段 / <code>contact_identity</code> 字段 / <code>isThinContact</code> predicate 在代码中尚未实现；
              <code>buildDiscoveryQueues</code> 没加 enrichment gate；
              <code>pl:pipeline-batch-step --finalize</code> 没自动 hook <code>dedup-audit</code>；
              gosom fallback chain（G-11）未建。<br/>
              <strong>已落地</strong> — G-1/G-2/G-3/G-6/G-7 CLI + dedup detector + niche cohort + place_id auto-merge。
            </div>
          </div>
        </div>
        <div class="admin-count">
          <span>当前状态</span>
          <strong>✅ v1.0</strong>
          <span class="micro-note">4 步 pipeline · dedup-clean<br/>enrichment-complete</span>
        </div>
      </header>

      <!-- ─── SOP-1 流程图 (只画自己的 4 步) ────────────────────────────── -->
      <section class="admin-paper-section flow-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">SOP-1 流程</p>
            <h2>从抓取到 SOP-2 交付的 4 步</h2>
          </div>
          <span class="admin-section-count">2 入口 · 4 步骤 · 1 决策点</span>
        </div>

        <div class="flow-grid">
          <!-- ENTRIES -->
          <div class="flow-row">
            <div class="flow-row-label">入口</div>
            <div class="flow-entries">
              <div class="flow-entry">
                <div class="flow-entry-tag">gosom Docker</div>
                <div class="flow-entry-desc">Google Maps 主流量</div>
              </div>
              <div class="flow-entry">
                <div class="flow-entry-tag">image-lead V2</div>
                <div class="flow-entry-desc">网上找到名片 / 店面图</div>
              </div>
            </div>
          </div>
          <div class="flow-arrow-row">▼</div>

          <!-- STEP 1: DISCOVERY WRITE -->
          <div class="flow-step">
            <div class="flow-step-num">1</div>
            <div class="flow-step-body">
              <div class="flow-step-title">Discovery 写入 <span class="flow-step-badge">always</span></div>
              <div class="flow-step-desc"><code>data/leads/entities/&lt;entityKey&gt;.json</code> · normalize 字段 · stamp <code>batch_id</code> + <code>sourceQuery</code></div>
              <div class="flow-step-meta">place_id 撞库 → 这里自动 <code>mergeLeadIntoEntity</code></div>
            </div>
          </div>
          <div class="flow-arrow-row">▼</div>

          <!-- STEP 2: DEDUP -->
          <div class="flow-step">
            <div class="flow-step-num">2</div>
            <div class="flow-step-body">
              <div class="flow-step-title">Dedup 检测 <span class="flow-step-badge">always</span></div>
              <div class="flow-step-desc">3 把钥匙：<code>place_id</code> · <code>phoneDigits</code> · <code>websiteDomain</code>。phone / domain 撞 → 入 review 队列。</div>
              <div class="flow-step-out">
                <span class="flow-out-fail">嫌疑 → <a href="/admin/v2-leads/dedup-review">/admin/v2-leads/dedup-review</a></span>
              </div>
            </div>
          </div>
          <div class="flow-arrow-row">▼</div>

          <!-- DECISION: thin-contact? -->
          <div class="admin-flow-decision-row">
            <div class="admin-flow-decision-diamond">thin-contact?<br/><span class="admin-flow-decision-sub"><code>!phone && !website</code></span></div>
          </div>

          <!-- STEP 3a + 3b -->
          <div class="admin-flow-branch-row">
            <div class="admin-flow-branch admin-flow-branch--yes">
              <div class="admin-flow-branch-label">是</div>
              <div class="flow-step flow-step-conditional">
                <div class="flow-step-num">3a</div>
                <div class="flow-step-body">
                  <div class="flow-step-title">Contact enrichment</div>
                  <div class="flow-step-desc">5 路 search：官方 URL / FB / IG / LinkedIn / 3rd-party (hipages, yelp, ...)</div>
                  <div class="flow-step-meta">补 <code>contact_identity</code>。失败 → <code>enrichment_status: 'unenrichable'</code></div>
                </div>
              </div>
            </div>
            <div class="admin-flow-branch admin-flow-branch--no">
              <div class="admin-flow-branch-label">否</div>
              <div class="flow-step flow-step-conditional">
                <div class="flow-step-num">3b</div>
                <div class="flow-step-body">
                  <div class="flow-step-title">Places enrichment <span class="flow-step-badge">grade ≥ B</span></div>
                  <div class="flow-step-desc"><code>pl:places-enrich</code> · types[] / photos / E.164 phone / verified hours</div>
                  <div class="flow-step-meta">月度配额 11K calls hard cap · 见 <a href="/admin/scoring/sop-x-tooling">Tooling §2</a></div>
                </div>
              </div>
            </div>
          </div>
          <div class="flow-arrow-row">▼</div>

          <!-- STEP 4: HANDOFF -->
          <div class="flow-step admin-flow-step--handoff">
            <div class="flow-step-num">4</div>
            <div class="flow-step-body">
              <div class="flow-step-title">Handoff → SOP-2</div>
              <div class="flow-step-desc"><code>enrichment_status</code> 写入 · entity 落到 <code>queues/cheap-site-audit.json</code> · 等 SOP-2 拉取</div>
              <div class="flow-step-meta">承诺：dedup-clean + enrichment-complete (或 unenrichable flag)</div>
            </div>
          </div>
        </div>
      </section>

      <!-- ─── Handoff Payload Sample (annotated) ──────────────────────── -->
      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">SOP-1 → SOP-2 Handoff Payload</p>
            <h2>这就是 SOP-2 拿到的字段（注释版）</h2>
          </div>
          <span class="admin-section-count">完整 schema 见 Handoff Contract</span>
        </div>
        <p class="section-lede">这是真实 entity 的样本（节选关键字段）。<strong>每个字段后面注释说明：SOP-1 怎么填 + SOP-2 怎么用</strong>。这是合约本身，不是数据 dump — SOP-2 拿到的就是这套结构。</p>

        {sampleEntity && (
          <div class="admin-payload-card">
            <div class="admin-payload-line"><span class="admin-payload-key">entityKey</span><span class="admin-payload-val">"{sampleEntity.entityKey}"</span><span class="admin-payload-note">SOP-1 生成的主键 · SOP-2 用作所有引用</span></div>

            <div class="admin-payload-section">identifiers · 多键匹配（dedup 核心）</div>
            <div class="admin-payload-line"><span class="admin-payload-key">  place_id</span><span class="admin-payload-val">"{sampleEntity.identifiers?.place_id?.slice(0, 36) || ''}..."</span><span class="admin-payload-note">SOP-1 dedup primary key</span></div>
            <div class="admin-payload-line"><span class="admin-payload-key">  phoneDigits</span><span class="admin-payload-val">"{sampleEntity.identifiers?.phoneDigits || ''}"</span><span class="admin-payload-note">dedup secondary · 后 10 位归一化</span></div>
            <div class="admin-payload-line"><span class="admin-payload-key">  websiteDomain</span><span class="admin-payload-val">"{sampleEntity.identifiers?.websiteDomain || ''}"</span><span class="admin-payload-note">dedup secondary · 去 www. + 根域名</span></div>

            <div class="admin-payload-section">latest · SOP-2 主要消费</div>
            <div class="admin-payload-line"><span class="admin-payload-key">  name</span><span class="admin-payload-val">"{sampleEntity.latest?.name || ''}"</span><span class="admin-payload-note">SOP-2 master.md 标题</span></div>
            <div class="admin-payload-line"><span class="admin-payload-key">  niche</span><span class="admin-payload-val">"{sampleEntity.latest?.niche || ''}"</span><span class="admin-payload-note">SOP-2 触发 niche-specific 规则</span></div>
            <div class="admin-payload-line"><span class="admin-payload-key">  city</span><span class="admin-payload-val">"{sampleEntity.latest?.city || ''}"</span><span class="admin-payload-note">SOP-2 评论搜索 / niche-match scoring</span></div>
            <div class="admin-payload-line"><span class="admin-payload-key">  phone</span><span class="admin-payload-val">"{sampleEntity.latest?.phone || ''}"</span><span class="admin-payload-note">⭐ SOP-1 enrichment 后填或标 unenrichable</span></div>
            <div class="admin-payload-line"><span class="admin-payload-key">  website</span><span class="admin-payload-val">"{sampleEntity.latest?.website || ''}"</span><span class="admin-payload-note">⭐ 同上 · SOP-2 audit 入口</span></div>
            <div class="admin-payload-line"><span class="admin-payload-key">  sourceQuery</span><span class="admin-payload-val">"{sampleEntity.latest?.sourceQuery || ''}"</span><span class="admin-payload-note">SOP-1 bridge 强制 = run.query · 追溯 batch</span></div>
            <div class="admin-payload-line"><span class="admin-payload-key">  batch_id</span><span class="admin-payload-val">"{sampleEntity.latest?.batch_id || ''}"</span><span class="admin-payload-note">SOP-1 stamp · SOP-2 可 filter 本批</span></div>

            <div class="admin-payload-section">enrichment_status · SOP-1 出口承诺</div>
            <div class="admin-payload-line"><span class="admin-payload-key">enrichment_status</span><span class="admin-payload-val">"{sampleEntity.enrichment_status || '(待 SOP-1 填; 当前样本属于历史 entity)'}"</span><span class="admin-payload-note">complete / partial / unenrichable</span></div>

            <div class="admin-payload-section">SOP-2 写入字段（SOP-1 不读这些）</div>
            <div class="admin-payload-line"><span class="admin-payload-key">grade</span><span class="admin-payload-val">{sampleEntity.grade ? `{ investment_level: "${sampleEntity.grade.investment_level}", product_tier: "${sampleEntity.grade.product_tier || ''}" }` : 'null'}</span><span class="admin-payload-note">SOP-2 gradeLead 后回填</span></div>
            <div class="admin-payload-line"><span class="admin-payload-key">discord_thread_id</span><span class="admin-payload-val">"{sampleEntity.discord_thread_id || ''}"</span><span class="admin-payload-note">A/B 自动开 thread 后回填</span></div>

            <p class="admin-payload-source">↑ 真实 entity 样本：<code>{sampleEntity.entityKey}</code></p>
          </div>
        )}

        {!sampleEntity && (
          <p class="admin-note-line">⚠ 当前 entity store 为空，无法渲染样本。完整字段定义见 <a href="/admin/scoring/sop-handoff-doc">SOP-X-Handoff §2</a>。</p>
        )}
      </section>

      <!-- ─── 链接到详细文档 + admin operations -->
      <section class="admin-paper-section">
        <div class="admin-paper-section-head">
          <div>
            <p class="eyebrow">深入了解</p>
            <h2>看更多细节 · 跑操作</h2>
          </div>
        </div>
        <div class="admin-card-grid admin-card-grid-3">
          <div class="admin-card">
            <p class="eyebrow">详细文档</p>
            <p><a href="/admin/scoring/sop-1-doc">SOP-1 v1.0 详细文档</a></p>
            <p class="admin-card-meta">技术细节 / 字段命名差异 / batch_id 传播 / 8 条 gotchas / 工具实施状态</p>
          </div>
          <div class="admin-card">
            <p class="eyebrow">Operator UI</p>
            <p><a href="/admin/v2-leads/dedup-review">Dedup Review</a> · <a href="/admin/v2-leads/niches">Niche Cohorts</a></p>
            <p class="admin-card-meta">嫌疑撞库决策 · niche 分组浏览 · upsell 准备</p>
          </div>
          <div class="admin-card">
            <p class="eyebrow">CLI</p>
            <p><code>pl:scrape-docker</code> · <code>pl:ingest-image</code> · <code>pl:places-enrich</code> · <code>pl:dedup-audit</code> · <code>pl:rebuild-niche-shards</code></p>
            <p class="admin-card-meta">完整列表见 <a href="/admin/scoring/sop-1-doc">SOP-1 详细文档 §9</a></p>
          </div>
        </div>
      </section>
    </div>
  </section>
</Layout>

<!-- No per-page <style> · all classes live in admin-design-system.css (v1.2+) -->
