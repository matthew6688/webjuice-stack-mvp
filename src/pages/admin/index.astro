---
import Layout from '../../layouts/AdminLayout.astro';
import { siteConfig } from '../../config/site';
import { loadPaidIntakeIndex } from '../../../core/funnel/paid-intake-index.js';
import { loadLeadOutreachIndex } from '../../../core/funnel/lead-outreach-index.js';

const index = loadPaidIntakeIndex();
const leadIndex = loadLeadOutreachIndex();
const stageCounts = index.records.reduce((acc, record) => {
  const key = record.stageSummary?.key || 'unknown';
  acc[key] = (acc[key] || 0) + 1;
  return acc;
}, {});
const odCounts = index.records.reduce((acc, record) => {
  const key = record.artifactSummary?.openDesignPipelineState || 'not_started';
  acc[key] = (acc[key] || 0) + 1;
  return acc;
}, {});
const urgentQueue = index.records
  .filter((record) => record.blockerSummary?.blocking || record.status === 'revision_requested' || record.artifactSummary?.domainStatus === 'waiting_for_customer_dns')
  .map((record) => ({
    ...record,
    urgencyScore:
      (record.status === 'revision_requested' ? 100 : 0)
      + (record.artifactSummary?.domainStatus === 'waiting_for_customer_dns' ? 80 : 0)
      + ((record.blockerSummary?.count || 0) * 10)
      + (record.stageSummary?.key === 'review_ready' ? 15 : 0),
  }))
  .sort((a, b) => b.urgencyScore - a.urgencyScore)
  .slice(0, 5);
const reviewReady = index.records.filter((record) => record.stageSummary?.key === 'review_ready').slice(0, 5);
const leadUrgentQueue = leadIndex.prospectRecords
  .filter((record) => ['follow_up_overdue', 'replied', 'paid'].includes(record.stageKey) || record.blocker)
  .map((record) => ({
    ...record,
    urgencyScore:
      (record.stageKey === 'paid' ? 100 : 0)
      + (record.stageKey === 'follow_up_overdue' ? 90 : 0)
      + (record.stageKey === 'replied' ? 80 : 0)
      + (record.blocker ? 20 : 0)
      + (record.paymentStatus === 'paid' && !record.websiteTaskThreadId ? 30 : 0),
  }))
  .sort((a, b) => b.urgencyScore - a.urgencyScore)
  .slice(0, 5);

const stageLabels = {
  intake: '收单',
  intake_blocked: '收单阻塞',
  website_ready: '网站资料就绪',
  open_design: 'Open Design 进行中',
  port_to_dev: '已同步到开发分支',
  building: '构建中',
  review_ready: '待发 review',
  revision: '修订中',
  launch_ready: '待上线',
  live: '已上线',
};
---

<Layout title={`后台总览 - ${siteConfig.name}`} description="ProfitsLocal 内部运营总览。" active="overview">
  <section class="poster-section admin-section">
    <div class="admin-shell">
      <div class="admin-header">
        <div>
          <p class="eyebrow">内部运营</p>
          <h1>后台总览</h1>
          <p class="lede">先看今天该推进哪些线索、哪些项目卡住了，再决定先处理哪一条线。</p>
        </div>
        <div class="admin-count">
          <strong>{index.counts.total}</strong>
          <span>项目</span>
        </div>
      </div>

      <div class="admin-summary-strip">
        <article class="admin-summary-tile admin-summary-primary">
          <span class="admin-summary-label">今天先动</span>
          <strong>{urgentQueue.length + leadUrgentQueue.length}</strong>
          <p>{leadUrgentQueue.length} 条线索，{urgentQueue.length} 个项目。</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">待发 review</span>
          <strong>{stageCounts.review_ready || 0}</strong>
          <p>最接近发客户 review 的项目。</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">跟进过期</span>
          <strong>{leadIndex.prospectCounts.followUpOverdue || 0}</strong>
          <p>今天应该先补的外联动作。</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">OD 需输入</span>
          <strong>{odCounts.needs_input || 0}</strong>
          <p>{odCounts.failed || 0} 个失败，{odCounts.running || 0} 个仍在运行。</p>
        </article>
      </div>

      <div class="admin-overview-hero admin-overview-paper">
        <section class="admin-overview-card admin-overview-primary">
          <span class="eyebrow">总览说明</span>
          <h2>这里只做分流，不做细看。</h2>
          <p class="micro">先决定今天该跟进线索、推进项目，还是去处理 Open Design / DNS 阻塞。细节再进入对应页面。</p>
          <div class="admin-note-stack">
            <p class="micro">线索、项目、财务、设置各管一类事，不在这里混在一起。</p>
          </div>
        </section>

        <section class="admin-overview-card">
          <span class="eyebrow">项目概况</span>
          <ul class="admin-list admin-list-tight">
            <li><strong>待发 review</strong><span>{stageCounts.review_ready || 0}</span></li>
            <li><strong>修订中</strong><span>{stageCounts.revision || 0}</span></li>
            <li><strong>等待 DNS</strong><span>{index.records.filter((record) => record.artifactSummary?.domainStatus === 'waiting_for_customer_dns').length}</span></li>
            <li><strong>OD 运行中</strong><span>{odCounts.running || 0}</span></li>
            <li><strong>OD 需输入</strong><span>{odCounts.needs_input || 0}</span></li>
          </ul>
        </section>

        <section class="admin-overview-card">
          <span class="eyebrow">线索概况</span>
          <ul class="admin-list admin-list-tight">
            <li><strong>草稿已就绪</strong><span>{leadIndex.prospectCounts.draft_ready || 0}</span></li>
            <li><strong>已发送</strong><span>{leadIndex.prospectCounts.outreachSent || 0}</span></li>
            <li><strong>已回复待看</strong><span>{leadIndex.prospectCounts.repliedNeedsReview || 0}</span></li>
            <li><strong>跟进过期</strong><span>{leadIndex.prospectCounts.followUpOverdue || 0}</span></li>
            <li><strong>付款待交接</strong><span>{leadIndex.customerCounts.paidHandoffPending || 0}</span></li>
          </ul>
        </section>

        <section class="admin-overview-card">
          <span class="eyebrow">常用入口</span>
          <ul class="admin-list admin-list-links">
            <li><a class="admin-inline-link" href="/admin/leads">打开线索面板</a><span>看 outreach / reply / follow-up</span></li>
            <li><a class="admin-inline-link" href="/admin/intakes">打开项目面板</a><span>看 review / revision / DNS / OD</span></li>
            <li><a class="admin-inline-link" href="/admin/finance">打开财务面板</a><span>单独看收入、成本、利润</span></li>
            <li><a class="admin-inline-link" href="/admin/queue">打开行动队列</a><span>只看现在先做什么</span></li>
            <li><a class="admin-inline-link" href="/admin/settings">打开系统设置</a><span>看集成和环境覆盖</span></li>
          </ul>
        </section>
      </div>

      <div class="admin-finance-grid">
        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">线索行动</span>
              <h2>收件箱与跟进</h2>
            </div>
          </div>
          <div class="admin-urgent-list">
            {leadUrgentQueue.length ? leadUrgentQueue.map((record) => (
              <a class="admin-urgent-card" href="/admin/leads">
                <strong>{record.company || record.clientSlug}</strong>
                <span>{record.nextAction.label}</span>
                <code>{record.blocker || record.stageLabel}</code>
                <span class="micro">{record.email || record.customerEmail || record.leadRecipientEmail || '没有记录邮箱'}</span>
              </a>
            )) : <p class="micro">当前没有特别紧急的线索。</p>}
          </div>
        </section>

        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">项目行动</span>
              <h2>现在先做</h2>
            </div>
          </div>
          <div class="admin-urgent-list">
            {urgentQueue.length ? urgentQueue.map((record) => (
              <a class="admin-urgent-card" href={`/admin/intakes/${record.clientSlug}/${record.orderId}`}>
                <strong>{record.customer.company || record.clientSlug}</strong>
                <span>{record.nextActionSummary?.label || '查看项目'}</span>
                <code>{record.blockerSummary?.primary || record.artifactSummary?.domainStatus || record.status}</code>
              </a>
            )) : <p class="micro">当前没有特别紧急的项目。</p>}
          </div>
        </section>

        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">下一批可发</span>
              <h2>准备发给客户</h2>
            </div>
          </div>
          <ul class="admin-list">
            {reviewReady.length ? reviewReady.map((record) => (
              <li>
                <a class="admin-record-link" href={`/admin/intakes/${record.clientSlug}/${record.orderId}`}>
                  <strong>{record.customer.company || record.clientSlug}</strong>
                </a>
                <span>{record.nextActionSummary?.label || '发送客户 review'}</span>
                <span>{record.previewUrl || record.artifactSummary?.outreachPreviewUrl || '还没有记录 preview'}</span>
              </li>
            )) : <li>目前还没有已经准备好发 review 的项目。</li>}
          </ul>
        </section>

        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">阶段分布</span>
              <h2>工作现在堆在哪</h2>
            </div>
          </div>
          <ul class="admin-list">
            {Object.entries(stageCounts).sort((a, b) => b[1] - a[1]).map(([stage, count]) => (
              <li><strong>{stageLabels[stage] || stage.replaceAll('_', ' ')}</strong><span>{count} 个项目</span></li>
            ))}
          </ul>
        </section>
      </div>
    </div>
  </section>
</Layout>
