---
import Layout from '../../layouts/AdminLayout.astro';
import { siteConfig } from '../../config/site';
import { loadPaidIntakeIndex } from '../../../core/funnel/paid-intake-index.js';
import { loadLeadOutreachIndex } from '../../../core/funnel/lead-outreach-index.js';
import { formatMoney, readLedger, summarizeLedger } from '../../../core/finance/ledger.js';

const index = loadPaidIntakeIndex();
const leadIndex = loadLeadOutreachIndex();
const financeOverview = summarizeLedger(readLedger());
const stageCounts = index.records.reduce((acc, record) => {
  const key = record.stageSummary?.key || 'unknown';
  acc[key] = (acc[key] || 0) + 1;
  return acc;
}, {});
const odCounts = index.records.reduce((acc, record) => {
  const key = record.artifactSummary?.openDesignPipelineState || 'not_started';
  acc[key] = (acc[key] || 0) + 1;
  return acc;
}, {});
const urgentQueue = index.records
  .filter((record) => record.blockerSummary?.blocking || record.status === 'revision_requested' || record.artifactSummary?.domainStatus === 'waiting_for_customer_dns')
  .map((record) => ({
    ...record,
    urgencyScore:
      (record.status === 'revision_requested' ? 100 : 0)
      + (record.artifactSummary?.domainStatus === 'waiting_for_customer_dns' ? 80 : 0)
      + ((record.blockerSummary?.count || 0) * 10)
      + (record.stageSummary?.key === 'review_ready' ? 15 : 0),
  }))
  .sort((a, b) => b.urgencyScore - a.urgencyScore)
  .slice(0, 5);
const reviewReady = index.records.filter((record) => record.stageSummary?.key === 'review_ready').slice(0, 5);
const leadUrgentQueue = leadIndex.records
  .filter((record) => ['follow_up_overdue', 'replied', 'paid'].includes(record.stageKey) || record.blocker)
  .map((record) => ({
    ...record,
    urgencyScore:
      (record.stageKey === 'paid' ? 100 : 0)
      + (record.stageKey === 'follow_up_overdue' ? 90 : 0)
      + (record.stageKey === 'replied' ? 80 : 0)
      + (record.blocker ? 20 : 0)
      + (record.paymentStatus === 'paid' && !record.websiteTaskThreadId ? 30 : 0),
  }))
  .sort((a, b) => b.urgencyScore - a.urgencyScore)
  .slice(0, 5);
---

<Layout title={`Admin overview - ${siteConfig.name}`} description="Internal admin overview for ProfitsLocal ops." active="overview">
  <section class="poster-section admin-section">
    <div class="admin-shell">
      <div class="admin-header">
        <div>
          <p class="eyebrow">Internal ops</p>
          <h1>Admin overview</h1>
          <p class="lede">One place to scan delivery, money, blockers, and the next move across active website projects.</p>
        </div>
        <div class="admin-count">
          <strong>{index.counts.total}</strong>
          <span>Projects</span>
        </div>
      </div>

      <div class="admin-summary-strip">
        <article class="admin-summary-tile admin-summary-primary">
          <span class="admin-summary-label">Pipeline health</span>
          <strong>{index.counts.total}</strong>
          <p>{urgentQueue.length} project(s) need attention now. {reviewReady.length} are closest to customer review.</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">Review ready</span>
          <strong>{stageCounts.review_ready || 0}</strong>
          <p>Projects that are structurally closest to sending review links.</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">Waiting DNS</span>
          <strong>{index.records.filter((record) => record.artifactSummary?.domainStatus === 'waiting_for_customer_dns').length}</strong>
          <p>Customer-owned domain work that can stall launch if it is not nudged.</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">OD needs input</span>
          <strong>{odCounts.needs_input || 0}</strong>
          <p>{odCounts.failed || 0} project(s) are failed; {odCounts.running || 0} are still actively running.</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">Lead follow-up</span>
          <strong>{leadIndex.counts.followUpOverdue || 0}</strong>
          <p>{leadIndex.counts.repliedNeedsReview || 0} replied lead(s) still need operator review.</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">Margin pulse</span>
          <strong>{financeOverview.profit > 0 ? 'Positive' : 'Watch'}</strong>
          <p>{formatMoney(financeOverview.profit || 0)} net after {financeOverview.eventCount || 0} recorded finance events.</p>
        </article>
      </div>

      <div class="admin-overview-hero">
        <section class="admin-overview-card admin-overview-primary">
          <span class="eyebrow">Business pulse</span>
          <h2>Run the website pipeline from one calm surface.</h2>
          <p class="micro">This page is the first scan: revenue context, urgent work, and which projects can move forward without more digging.</p>
          <div class="admin-finance-metrics">
            <div><span>Revenue</span><strong>{formatMoney(financeOverview.revenue || 0)}</strong></div>
            <div><span>Cost</span><strong>{formatMoney(financeOverview.cost || 0)}</strong></div>
            <div><span>Profit</span><strong>{formatMoney(financeOverview.profit || 0)}</strong></div>
            <div><span>ROI</span><strong>{financeOverview.roi == null ? 'N/A' : `${(financeOverview.roi * 100).toFixed(1)}%`}</strong></div>
          </div>
        </section>

        <section class="admin-overview-card">
          <span class="eyebrow">Pipeline mix</span>
          <div class="admin-overview-kpis">
            <div><span>Review ready</span><strong>{stageCounts.review_ready || 0}</strong></div>
            <div><span>Revisions</span><strong>{stageCounts.revision || 0}</strong></div>
            <div><span>Live</span><strong>{stageCounts.live || 0}</strong></div>
            <div><span>Waiting DNS</span><strong>{index.records.filter((record) => record.artifactSummary?.domainStatus === 'waiting_for_customer_dns').length}</strong></div>
            <div><span>OD running</span><strong>{odCounts.running || 0}</strong></div>
            <div><span>OD needs input</span><strong>{odCounts.needs_input || 0}</strong></div>
          </div>
        </section>

        <section class="admin-overview-card">
          <span class="eyebrow">Lead pulse</span>
          <div class="admin-overview-kpis">
            <div><span>Draft ready</span><strong>{leadIndex.counts.draft_ready || 0}</strong></div>
            <div><span>Outreach sent</span><strong>{leadIndex.counts.outreachSent || 0}</strong></div>
            <div><span>Reply review</span><strong>{leadIndex.counts.repliedNeedsReview || 0}</strong></div>
            <div><span>Overdue</span><strong>{leadIndex.counts.followUpOverdue || 0}</strong></div>
            <div><span>Paid handoff</span><strong>{leadIndex.counts.paidHandoffPending || 0}</strong></div>
            <div><span>Blocked leads</span><strong>{leadIndex.counts.blocked || 0}</strong></div>
          </div>
        </section>

        <section class="admin-overview-card">
          <span class="eyebrow">Operator links</span>
          <div class="admin-link-grid">
            <a class="button secondary" href="/admin/leads">Open leads board</a>
            <a class="button secondary" href="/admin/intakes">Open intake board</a>
            <a class="button secondary" href="/admin/finance">Open finance view</a>
            <a class="button secondary" href="/admin/queue">Open action queue</a>
            <a class="button secondary" href="/admin/settings">Open settings</a>
          </div>
          <div class="admin-note-stack">
            <p class="micro">Use <strong>Leads</strong> for demo/outreach readiness, <strong>Intakes</strong> to audit paid projects, <strong>Queue</strong> to push the next action, and <strong>Finance</strong> to check whether the funnel is still healthy.</p>
          </div>
        </section>
      </div>

      <div class="admin-finance-grid">
        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">Lead action</span>
              <h2>Inbox & follow-up</h2>
            </div>
          </div>
          <div class="admin-urgent-list">
            {leadUrgentQueue.length ? leadUrgentQueue.map((record) => (
              <a class="admin-urgent-card" href="/admin/leads">
                <strong>{record.company || record.clientSlug}</strong>
                <span>{record.nextAction.label}</span>
                <code>{record.blocker || record.stageLabel}</code>
                <span class="micro">{record.email || record.customerEmail || record.leadRecipientEmail || 'no email recorded'}</span>
              </a>
            )) : <p class="micro">No urgent lead right now.</p>}
          </div>
        </section>

        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">Needs Action</span>
              <h2>Now</h2>
            </div>
          </div>
          <div class="admin-urgent-list">
            {urgentQueue.length ? urgentQueue.map((record) => (
              <a class="admin-urgent-card" href={`/admin/intakes/${record.clientSlug}/${record.orderId}`}>
                <strong>{record.customer.company || record.clientSlug}</strong>
                <span>{record.nextActionSummary?.label || 'Review project'}</span>
                <code>{record.blockerSummary?.primary || record.artifactSummary?.domainStatus || record.status}</code>
              </a>
            )) : <p class="micro">No urgent project right now.</p>}
          </div>
        </section>

        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">Ready To Review</span>
              <h2>Next Customer Sends</h2>
            </div>
          </div>
          <ul class="admin-list">
            {reviewReady.length ? reviewReady.map((record) => (
              <li>
                <a class="admin-record-link" href={`/admin/intakes/${record.clientSlug}/${record.orderId}`}>
                  <strong>{record.customer.company || record.clientSlug}</strong>
                </a>
                <span>{record.nextActionSummary?.label || 'Send customer review'}</span>
                <span>{record.previewUrl || record.artifactSummary?.outreachPreviewUrl || 'No preview recorded'}</span>
              </li>
            )) : <li>No project is review-ready yet.</li>}
          </ul>
        </section>

        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">Stage Mix</span>
              <h2>Where Work Sits</h2>
            </div>
          </div>
          <ul class="admin-list">
            {Object.entries(stageCounts).sort((a, b) => b[1] - a[1]).map(([stage, count]) => (
              <li><strong>{stage.replaceAll('_', ' ')}</strong><span>{count} project(s)</span></li>
            ))}
          </ul>
        </section>
      </div>
    </div>
  </section>
</Layout>
