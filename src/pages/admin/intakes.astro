---
import Layout from '../../layouts/AdminLayout.astro';
import { siteConfig } from '../../config/site';
import { ADMIN_VIEWS, loadPaidIntakeIndex } from '../../../core/funnel/paid-intake-index.js';
import { formatMoney, readLedger, summarizeLedger } from '../../../core/finance/ledger.js';

const index = loadPaidIntakeIndex();
const financeOverview = summarizeLedger(readLedger());
const statusOrder = [
  'intake_ready_for_review',
  'intake_needs_more_info',
  'intake_needs_generation_confirmation',
  'paid_intake_pending_preview',
  'revision_requested',
  'revision_over_limit',
];
const counts = statusOrder
  .filter((status) => index.counts[status])
  .map((status) => ({ status, count: index.counts[status] }));
const dashboardSummary = {
  reviewReady: index.records.filter((record) => record.stageSummary?.key === 'review_ready').length,
  revisionsPending: index.records.filter((record) => record.status === 'revision_requested').length,
  waitingDns: index.records.filter((record) => record.artifactSummary?.domainStatus === 'waiting_for_customer_dns').length,
  profitableProjects: index.records.filter((record) => (record.artifactSummary?.financeSummary?.profit ?? 0) > 0).length,
};
const pipelineStages = [
  ['intake', '收单'],
  ['website_ready', '网站资料就绪'],
  ['open_design', 'Open Design'],
  ['port_to_dev', '同步到开发分支'],
  ['building', '构建中'],
  ['review_ready', '待发 review'],
  ['revision', '修订中'],
  ['launch_ready', '待上线'],
  ['live', '已上线'],
];
const pipelineColumns = pipelineStages.map(([key, label]) => ({
  key,
  label,
  records: index.records.filter((record) => record.stageSummary?.key === key).slice(0, 4),
  total: index.records.filter((record) => record.stageSummary?.key === key).length,
}));
const urgentQueue = index.records
  .filter((record) => record.blockerSummary?.blocking || record.status === 'revision_requested' || record.artifactSummary?.domainStatus === 'waiting_for_customer_dns')
  .map((record) => ({
    ...record,
    urgencyScore:
      (record.status === 'revision_requested' ? 100 : 0)
      + (record.artifactSummary?.domainStatus === 'waiting_for_customer_dns' ? 80 : 0)
      + ((record.blockerSummary?.count || 0) * 10)
      + (record.stageSummary?.key === 'review_ready' ? 15 : 0),
  }))
  .sort((a, b) => b.urgencyScore - a.urgencyScore)
  .slice(0, 6);
const topClientsByProfit = Object.entries(financeOverview.byClient || {})
  .sort((a, b) => b[1] - a[1])
  .slice(0, 5);
const topProvidersBySpend = Object.entries(financeOverview.byProvider || {})
  .sort((a, b) => a[1] - b[1])
  .slice(0, 5);
const savedViews = [
  ['all', ADMIN_VIEWS.all.label],
  ['review_ready', ADMIN_VIEWS.review_ready.label],
  ['revision_pending', ADMIN_VIEWS.revision_pending.label],
  ['waiting_dns', ADMIN_VIEWS.waiting_dns.label],
  ['missing_open_design', ADMIN_VIEWS.missing_open_design.label],
  ['qa_blocked', ADMIN_VIEWS.qa_blocked.label],
];
---

<Layout title={`项目后台 - ${siteConfig.name}`} description="ProfitsLocal 已付款项目与交付状态面板。" active="intakes">
  <section class="poster-section admin-section">
    <div class="admin-shell">
      <div class="admin-header">
        <div>
          <p class="eyebrow">内部运营</p>
          <h1>项目队列</h1>
          <p class="lede">这里看正式项目：缺了什么、卡在哪、是否能发 review、修订压力和 DNS 阻塞。</p>
        </div>
        <div class="admin-count">
          <strong>{index.counts.total}</strong>
          <span>项目</span>
        </div>
      </div>
      <div class="admin-stat-grid">
        {counts.map((item) => (
          <div class="admin-stat">
            <span>{item.status.replaceAll('_', ' ')}</span>
            <strong>{item.count}</strong>
          </div>
        ))}
      </div>
      <div class="admin-stat-grid">
        <div class="admin-stat">
          <span>待发 review</span>
          <strong>{dashboardSummary.reviewReady}</strong>
        </div>
        <div class="admin-stat">
          <span>修订待处理</span>
          <strong>{dashboardSummary.revisionsPending}</strong>
        </div>
        <div class="admin-stat">
          <span>等待 DNS</span>
          <strong>{dashboardSummary.waitingDns}</strong>
        </div>
        <div class="admin-stat">
          <span>利润为正</span>
          <strong>{dashboardSummary.profitableProjects}</strong>
        </div>
      </div>
      <div class="admin-summary-strip admin-summary-strip-compact">
        <article class="admin-summary-tile admin-summary-primary">
          <span class="admin-summary-label">队列状态</span>
          <strong>{dashboardSummary.reviewReady > 0 ? '可以推进' : '继续建设'}</strong>
          <p>{dashboardSummary.reviewReady} 个项目已经接近发 review，另有 {dashboardSummary.revisionsPending} 个项目还在等修订处理。</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">Open Design</span>
          <strong>{index.records.filter((record) => record.artifactSummary?.openDesignBound).length}</strong>
          <p>还有 {index.records.filter((record) => !record.artifactSummary?.openDesignBound).length} 个项目缺少绑定好的概念源。</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">Delivery QA</span>
          <strong>{index.records.filter((record) => record.artifactSummary?.deliveryQaReady).length}</strong>
          <p>还有 {index.records.filter((record) => !record.artifactSummary?.deliveryQaReady).length} 个项目在发客户 review 前仍被 QA 卡住。</p>
        </article>
        <article class="admin-summary-tile">
          <span class="admin-summary-label">财务脉搏</span>
          <strong>{formatMoney(financeOverview.profit || 0)}</strong>
          <p>当前净额来自 {financeOverview.eventCount || 0} 条财务事件，先用它判断这条业务线是否健康。</p>
        </article>
      </div>
      <div class="admin-finance-grid">
        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">财务总览</span>
              <h2>经营快照</h2>
            </div>
          </div>
          <div class="admin-finance-metrics">
            <div><span>收入</span><strong>{formatMoney(financeOverview.revenue || 0)}</strong></div>
            <div><span>成本</span><strong>{formatMoney(financeOverview.cost || 0)}</strong></div>
            <div><span>利润</span><strong>{formatMoney(financeOverview.profit || 0)}</strong></div>
            <div><span>ROI</span><strong>{financeOverview.roi == null ? 'N/A' : `${(financeOverview.roi * 100).toFixed(1)}%`}</strong></div>
          </div>
          <div class="admin-finance-meta">
            <span>{financeOverview.eventCount || 0} 条财务事件</span>
            <span>{financeOverview.revenueEventCount || 0} 条收入</span>
            <span>{financeOverview.costEventCount || 0} 条成本</span>
          </div>
        </section>

        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">优先行动</span>
              <h2>现在先做</h2>
            </div>
          </div>
          <div class="admin-urgent-list">
            {urgentQueue.length ? urgentQueue.map((record) => (
              <a class="admin-urgent-card" href={`/admin/intakes/${record.clientSlug}/${record.orderId}`}>
                <strong>{record.customer.company || record.clientSlug}</strong>
                <span>{record.nextActionSummary?.label || '查看项目'}</span>
                <code>{record.blockerSummary?.primary || record.artifactSummary?.domainStatus || record.status}</code>
              </a>
            )) : <p class="micro">当前没有特别紧急的项目。</p>}
          </div>
        </section>

        <section class="admin-finance-panel">
          <div class="admin-finance-head">
            <div>
              <span class="eyebrow">贡献排行</span>
              <h2>利润 / 花费</h2>
            </div>
          </div>
          <div class="admin-split-lists">
            <div>
              <span class="admin-toolbar-label">利润最高客户</span>
              <ul class="admin-list">
                {topClientsByProfit.length ? topClientsByProfit.map(([client, amount]) => (
                  <li><strong>{client}</strong><span>{formatMoney(amount)}</span></li>
                )) : <li>还没有财务数据。</li>}
              </ul>
            </div>
            <div>
              <span class="admin-toolbar-label">花费最高供应商</span>
              <ul class="admin-list">
                {topProvidersBySpend.length ? topProvidersBySpend.map(([provider, amount]) => (
                  <li><strong>{provider}</strong><span>{formatMoney(amount)}</span></li>
                )) : <li>还没有供应商数据。</li>}
              </ul>
            </div>
          </div>
        </section>
      </div>
      <div class="admin-toolbar" data-admin-toolbar>
        <div class="admin-toolbar-group">
          <span class="admin-toolbar-label">快速筛选</span>
          <div class="admin-view-pills">
            {savedViews.map(([key, label], index) => (
              <button type="button" class={`admin-view-pill ${index === 0 ? 'is-active' : ''}`} data-admin-view={key}>{label}</button>
            ))}
          </div>
        </div>
        <div class="admin-toolbar-group admin-toolbar-right">
          <label class="admin-search">
            <span class="admin-toolbar-label">搜索</span>
            <input type="search" placeholder="客户、订单、域名" data-admin-search />
          </label>
          <p class="micro" data-admin-visible-count>{index.records.length} 条可见</p>
        </div>
      </div>
      <div class="admin-pipeline" data-admin-pipeline>
        {pipelineColumns.map((column) => (
          <section class="admin-pipeline-column" data-stage-column={column.key}>
            <header>
              <span>{column.label}</span>
              <strong>{column.total}</strong>
            </header>
            <div class="admin-pipeline-list">
              {column.records.length ? column.records.map((record) => (
                <a class="admin-pipeline-card" href={`/admin/intakes/${record.clientSlug}/${record.orderId}`}>
                  <strong>{record.customer.company || record.clientSlug}</strong>
                  <span>{record.nextActionSummary?.label || '查看项目'}</span>
                  <code>{record.orderId}</code>
                </a>
              )) : <p class="micro">这一列暂时没有项目。</p>}
            </div>
          </section>
        ))}
      </div>
      <div class="admin-mobile-records">
        {index.records.map((record) => (
          <article
            class="admin-mobile-record"
            data-client={record.clientSlug}
            data-company={record.customer.company || ''}
            data-order-id={record.orderId}
            data-domain={record.customer.domain || ''}
            data-status={record.status}
            data-stage={record.stageSummary?.key || ''}
            data-view-review-ready={record.stageSummary?.key === 'review_ready' ? 'true' : 'false'}
            data-view-revision-pending={record.status === 'revision_requested' ? 'true' : 'false'}
            data-view-waiting-dns={record.artifactSummary?.domainStatus === 'waiting_for_customer_dns' ? 'true' : 'false'}
            data-view-missing-open-design={record.artifactSummary?.openDesignBound ? 'false' : 'true'}
            data-view-qa-blocked={record.artifactSummary?.deliveryQaReady ? 'false' : 'true'}
          >
            <div class="admin-mobile-record-head">
              <div>
                <a class="admin-record-link" href={`/admin/intakes/${record.clientSlug}/${record.orderId}`}>
                  <strong>{record.customer.company || record.clientSlug}</strong>
                </a>
                <span class="admin-mono">{record.orderId}</span>
              </div>
              <a class="admin-open" href={`/admin/intakes/${record.clientSlug}/${record.orderId}`}>查看</a>
            </div>
            <div class="admin-health-pills">
              <mark class={`status-pill status-${record.stageSummary?.tone || 'info'}`}>{record.stageSummary?.label || '未知'}</mark>
              <mark class={`status-pill status-${record.status}`}>{record.status.replaceAll('_', ' ')}</mark>
            </div>
            <p class="micro">里程碑：{record.milestoneSummary?.currentLabel || '线索已收集'} · {record.milestoneSummary?.completedCount || 0}/{record.milestoneSummary?.total || 0}</p>
            <p class="micro">{record.nextActionSummary?.label || '查看'} · {record.nextActionSummary?.reason || '还没有记录推荐动作。'}</p>
            <div class="admin-mobile-record-grid">
              <div><span class="admin-toolbar-label">健康度</span><p>OD {record.artifactSummary?.openDesignBound ? '已就绪' : '缺失'} · QA {record.artifactSummary?.deliveryQaReady ? '通过' : '待完成'} · 域名 {record.artifactSummary?.domainStatus || '无'}</p></div>
              <div><span class="admin-toolbar-label">商务</span><p>{record.customer.email || '没有邮箱'} · {record.customer.domain || '没有域名'}</p></div>
              <div><span class="admin-toolbar-label">使用量</span><p>{record.assetCount} 资产 · {record.revisionCount}/{record.revisionLimit} 次修订 · {formatMoney(record.artifactSummary?.financeSummary?.profit ?? 0, record.currency || 'USD')}</p></div>
              <div><span class="admin-toolbar-label">风险</span><p>{record.blockerSummary?.primary || (record.missing.length ? record.missing.join(', ') : '当前没有明显阻塞')}</p></div>
            </div>
          </article>
        ))}
      </div>
      <div class="admin-table-wrap">
        <div class="admin-table-guide admin-table-guide-intakes" aria-hidden="true">
          <span>客户</span>
          <span>流程</span>
          <span>健康度</span>
          <span>商务</span>
          <span>使用量</span>
          <span>风险</span>
          <span>下一步动作</span>
          <span>查看</span>
        </div>
        <table class="admin-table">
          <thead>
            <tr>
              <th>客户</th>
              <th>流程</th>
              <th>健康度</th>
              <th>商务</th>
              <th>使用量</th>
              <th>风险</th>
              <th>下一步动作</th>
              <th>查看</th>
            </tr>
          </thead>
          <tbody>
            {index.records.map((record) => (
              <tr
                data-client={record.clientSlug}
                data-company={record.customer.company || ''}
                data-order-id={record.orderId}
                data-domain={record.customer.domain || ''}
                data-status={record.status}
                data-stage={record.stageSummary?.key || ''}
                data-view-review-ready={record.stageSummary?.key === 'review_ready' ? 'true' : 'false'}
                data-view-revision-pending={record.status === 'revision_requested' ? 'true' : 'false'}
                data-view-waiting-dns={record.artifactSummary?.domainStatus === 'waiting_for_customer_dns' ? 'true' : 'false'}
                data-view-missing-open-design={record.artifactSummary?.openDesignBound ? 'false' : 'true'}
                data-view-qa-blocked={record.artifactSummary?.deliveryQaReady ? 'false' : 'true'}
              >
                <td>
                  <a class="admin-record-link" href={`/admin/intakes/${record.clientSlug}/${record.orderId}`}>
                    <strong>{record.customer.company || record.clientSlug}</strong>
                  </a>
                  <span>{record.clientSlug}</span>
                  <span class="admin-mono">{record.orderId}</span>
                </td>
                <td>
                  <mark class={`status-pill status-${record.stageSummary?.tone || 'info'}`}>{record.stageSummary?.label || '未知'}</mark>
                  <mark class={`status-pill status-${record.status}`}>{record.status.replaceAll('_', ' ')}</mark>
                  <span><strong>里程碑：</strong>{record.milestoneSummary?.currentLabel || '线索已收集'}</span>
                  <span>{record.milestoneSummary?.completedCount || 0} / {record.milestoneSummary?.total || 0} 已完成</span>
                  <span>{record.readinessStatus.replaceAll('_', ' ') || '还没有记录 readiness'}</span>
                  <span>{record.artifactSummary?.latestTimeline?.type || '还没有最近事件'}</span>
                </td>
                <td>
                  <div class="admin-health-pills">
                    <mark class={`status-pill ${
                      record.artifactSummary?.openDesignPipelineTone === 'ready'
                        ? 'status-ready'
                        : record.artifactSummary?.openDesignPipelineTone === 'warn'
                          ? 'status-warn'
                          : record.artifactSummary?.openDesignPipelineTone === 'alert'
                            ? 'status-alert'
                            : (record.artifactSummary?.openDesignBound ? 'status-working' : 'status-alert')
                    }`}>
                      OD {record.artifactSummary?.openDesignPipelineLabel || (record.artifactSummary?.openDesignBound ? '运行中' : '缺失')}
                    </mark>
                    <mark class={`status-pill ${record.artifactSummary?.deliveryQaReady ? 'status-ready' : 'status-warn'}`}>QA {record.artifactSummary?.deliveryQaReady ? '通过' : '待完成'}</mark>
                    <mark class={`status-pill ${record.artifactSummary?.outreachAssetsReady ? 'status-ready' : 'status-warn'}`}>交付素材 {record.artifactSummary?.outreachAssetsReady ? '已齐' : '待补'}</mark>
                    <mark class="status-pill status-info">域名 {record.artifactSummary?.domainStatus || '无'}</mark>
                  </div>
                  <span>OD run {record.artifactSummary?.openDesignLastRunId || 'n/a'} · {record.artifactSummary?.openDesignStatus || 'not-started'} · {record.artifactSummary?.openDesignCompletionMode || '等待 native 结束'}</span>
                </td>
                <td>
                  <span>{record.customer.email || '没有邮箱'}</span>
                  <span>线索路由：{record.leadRecipientEmail || record.customer.email || '缺失'}</span>
                  <span>{record.customer.domain || '没有域名'}</span>
                </td>
                <td>
                  <span>{record.assetCount} 个资产</span>
                  <span>{record.fileCount} 个文件</span>
                  <span>{record.revisionCount} / {record.revisionLimit} 次修订</span>
                  <span>ROI: {formatMoney(record.artifactSummary?.financeSummary?.profit ?? 0, record.currency || 'USD')}</span>
                </td>
                <td>
                  {record.blockerSummary?.count ? (
                    <div class="admin-risk-stack">
                      <strong>{record.blockerSummary.primary}</strong>
                      <span>{record.blockerSummary.count} 个阻塞</span>
                    </div>
                  ) : (
                    <span class="admin-ready">当前没有明显阻塞</span>
                  )}
                  {record.missing.length ? <span class="admin-missing">{record.missing.join(', ')}</span> : null}
                </td>
                <td>
                  <strong>{record.nextActionSummary?.label || '查看'}</strong>
                  <span>{record.nextActionSummary?.reason || ''}</span>
                  <span class="micro">{record.milestoneSummary?.currentKey || 'lead_collected'}</span>
                </td>
                <td><a class="admin-open" href={`/admin/intakes/${record.clientSlug}/${record.orderId}`}>查看</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="micro">页面在构建时从 <code>data/paid-intakes</code> 生成，repo 里的 JSON 仍然是最终真相源。</p>
    </div>
  </section>
</Layout>

<script>
  const toolbar = document.querySelector('[data-admin-toolbar]');
  if (toolbar) {
    const tableRows = Array.from(document.querySelectorAll('tbody tr'));
    const mobileCards = Array.from(document.querySelectorAll('.admin-mobile-record'));
    const records = [...tableRows, ...mobileCards];
    const pills = Array.from(toolbar.querySelectorAll('[data-admin-view]'));
    const search = toolbar.querySelector('[data-admin-search]');
    const visibleCount = toolbar.querySelector('[data-admin-visible-count]');
    let activeView = 'all';
    const viewDatasetKey = {
      all: null,
      review_ready: 'viewReviewReady',
      revision_pending: 'viewRevisionPending',
      waiting_dns: 'viewWaitingDns',
      missing_open_design: 'viewMissingOpenDesign',
      qa_blocked: 'viewQaBlocked',
    };

    const applyFilters = () => {
      const query = (search?.value || '').trim().toLowerCase();
      let visibleRows = 0;
      let visibleCards = 0;
      records.forEach((record) => {
        const key = viewDatasetKey[activeView];
        const viewMatch = !key || record.dataset[key] === 'true';
        const haystack = [record.dataset.client, record.dataset.company, record.dataset.orderId, record.dataset.domain, record.dataset.status, record.dataset.stage]
          .filter(Boolean)
          .join(' ')
          .toLowerCase();
        const searchMatch = !query || haystack.includes(query);
        const show = viewMatch && searchMatch;
        record.hidden = !show;
        if (show && tableRows.includes(record)) visibleRows += 1;
        if (show && mobileCards.includes(record)) visibleCards += 1;
      });
      const normalizedVisible = window.innerWidth <= 760 ? visibleCards : visibleRows;
      if (visibleCount) visibleCount.textContent = `${normalizedVisible} 条可见`;
    };

    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        activeView = pill.dataset.adminView || 'all';
        pills.forEach((candidate) => candidate.classList.toggle('is-active', candidate === pill));
        applyFilters();
      });
    });
    search?.addEventListener('input', applyFilters);
    applyFilters();
  }
</script>
