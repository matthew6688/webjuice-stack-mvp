---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../config/site';
---

<Layout title={`Send a brief - ${siteConfig.name}`} description="Send profitslocal your business details and request a free website preview.">
  <section class="poster-section">
    <div class="contact-frame">
      <div class="contact-intro">
        <p class="eyebrow">Send a brief</p>
        <h1>Get a free website <em>preview.</em></h1>
        <p class="lede">Send the business details, and we will build a first preview before asking you to pay.</p>
        <p class="micro" style="margin-top: 22px;">You do not need a polished brief. A Google Business link, current website, menu, service list, or a few reference sites are enough to start.</p>
      </div>
      <form class="contact-form" id="contact-form" novalidate>
        <div class="field">
          <label for="name">Your name <span class="req">Required</span></label>
          <input id="name" name="name" autocomplete="name" placeholder="Jane Smith" required />
        </div>
        <div class="field">
          <label for="email">Email address <span class="req">Required</span></label>
          <input id="email" name="email" type="email" autocomplete="email" placeholder="jane@business.com" required />
        </div>
        <div class="field">
          <label for="company">Business name</label>
          <input id="company" name="company" autocomplete="organization" placeholder="Your local business" />
        </div>
        <div class="field">
          <label for="phone">Phone</label>
          <input id="phone" name="phone" autocomplete="tel" placeholder="+1 555 0123" />
        </div>
        <div class="field">
          <label for="website">Current website</label>
          <input id="website" name="website" type="url" placeholder="https://example.com" />
        </div>
        <div class="field">
          <label for="googleBusiness">Google Business link</label>
          <input id="googleBusiness" name="googleBusiness" type="url" placeholder="Google Maps or Business Profile URL" />
        </div>
        <div class="field full">
          <label for="message">What should the page say? <span class="req">Required</span></label>
          <textarea id="message" name="message" placeholder="Tell us what you sell, what customers ask for, your best menu items or services, pages you need, offers to highlight, competitors, websites you like, and anything to avoid." required></textarea>
        </div>
        <div class="field full file-field">
          <label for="files">Upload logo, photos, menu PDF, or reference files</label>
          <input id="files" name="files" type="file" multiple accept="image/*,.pdf,.doc,.docx,.txt,.md,.csv,.zip" />
          <p class="field-hint">Optional, up to 8 files. Send logo files, product photos, menus, service PDFs, screenshots, or visual references.</p>
        </div>
        <div class="form-actions">
          <button class="submit-button" type="submit">Request a free preview</button>
          <p id="form-status" class="form-status">We will review the details and reply with next steps.</p>
        </div>
      </form>
    </div>
  </section>

  <script>
    const supportEmail = 'support@profitslocal.com';
    const form = document.getElementById('contact-form');
    const status = document.getElementById('form-status');

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const controls = Array.from(form.querySelectorAll('input, textarea'));
      const invalid = controls.find((control) => !control.checkValidity());

      if (invalid) {
        invalid.focus();
        if (status) {
          status.textContent = 'Please complete the required fields so we can review the business.';
          status.className = 'form-status error';
        }
        return;
      }

      if (status) {
        status.textContent = 'Sending your brief...';
        status.className = 'form-status';
      }

      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          body: new FormData(form),
        });

        if (!response.ok) throw new Error('Failed to send');
        window.location.href = '/thank-you';
      } catch {
        if (status) {
          status.textContent = `Something went wrong. Please email ${supportEmail} or try again.`;
          status.className = 'form-status error';
        }
      }
    });
  </script>
</Layout>
