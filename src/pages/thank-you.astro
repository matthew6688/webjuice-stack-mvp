---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../config/site';
---

<Layout title={`Thank you - ${siteConfig.name}`} description="profitslocal brief received">
  <section class="poster-section">
    <div class="thank-frame">
      <p class="eyebrow" id="thank-eyebrow">Brief received</p>
      <h1 id="thank-title">We will review the business and build the first preview <em>free.</em></h1>
      <p class="lede" id="thank-lede">Thanks for sending the details. We will look at the business, the links you shared, and what customers need to know before preparing the website preview.</p>

      <div id="thank-proof-list"></div>

      <div class="next-grid">
        <article class="next-step">
          <h3 id="step-one-title">1. We review the details</h3>
          <p id="step-one-copy">We look at the Google Business Profile, current website, photos, menus, services, reviews, competitors, and your notes.</p>
        </article>
        <article class="next-step">
          <h3 id="step-two-title">2. We build the preview</h3>
          <p id="step-two-copy">You see a real website preview before paying for revisions, launch, or ongoing updates.</p>
        </article>
        <article class="next-step">
          <h3 id="step-three-title">3. You decide after seeing it</h3>
          <p id="step-three-copy">If it feels right, choose a plan. If it needs changes, tell us what matters.</p>
        </article>
      </div>

      <div style="display: flex; gap: 14px; flex-wrap: wrap; margin-top: 34px;">
        <a class="button" href="/">Back to homepage</a>
        <a class="button secondary" href={`mailto:${siteConfig.email}`}>Email support</a>
      </div>
    </div>
  </section>

  <script>
    const params = new URLSearchParams(window.location.search);
    const sessionId = params.get('session_id') || '';
    const orderId = params.get('order') || '';
    const clientSlug = params.get('client_slug') || '';
    const tier = params.get('tier') || '';
    const isPaid = Boolean(sessionId);

    if (isPaid) {
      setText('thank-eyebrow', 'Payment received');
      setHtml('thank-title', 'Your checkout is complete.');
      setText('thank-lede', 'Thanks for moving forward. Stripe confirmed the checkout, and our delivery workflow will prepare the next review step.');
      setText('step-one-title', '1. We confirm the order');
      setText('step-one-copy', 'The payment event is routed into our delivery queue with your checkout details and package.');
      setText('step-two-title', '2. We prepare the next preview');
      setText('step-two-copy', 'If you checked out from a preview link, the site moves into the review and launch workflow.');
      setText('step-three-title', '3. We send review steps');
      setText('step-three-copy', 'You will receive the review link, revision link, and any domain setup instructions by email.');
    }

    const proofs = [];
    if (orderId) proofs.push(['Order ID', orderId]);
    if (sessionId) proofs.push(['Stripe session', sessionId]);
    if (isPaid && clientSlug) proofs.push(['Project', `${clientSlug}${tier ? ` / ${tier}` : ''}`]);

    const proofList = document.getElementById('thank-proof-list');
    if (proofList && proofs.length) {
      proofList.innerHTML = proofs.map(([label, value], index) => (
        `<p class="proof" style="max-width: 620px; margin-top: ${index === 0 ? '28px' : '14px'};"><b>${escapeHtml(label)}</b>${escapeHtml(value)}</p>`
      )).join('');
    }

    function setText(id, value) {
      const element = document.getElementById(id);
      if (element) element.textContent = value;
    }

    function setHtml(id, value) {
      const element = document.getElementById(id);
      if (element) element.innerHTML = value;
    }

    function escapeHtml(value) {
      return String(value).replace(/[&<>"']/g, (char) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#039;',
      }[char]));
    }
  </script>
</Layout>
