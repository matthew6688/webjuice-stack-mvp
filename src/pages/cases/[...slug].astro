---
import Layout from '../../layouts/Layout.astro';
import { siteConfig } from '../../config/site';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const cases = await getCollection('cases');
  return cases.map(c => ({
    params: { slug: c.id.replace(/\.md$/, '') },
    props: { caseStudy: c },
  }));
}

const { caseStudy } = Astro.props;
const { Content } = await render(caseStudy);
---

<Layout title={`${caseStudy.data.title} - ${siteConfig.name}`} description={caseStudy.data.description}>
  <section class="poster-section">
    <article class="article-frame">
      <header>
        <p class="eyebrow">{caseStudy.data.client} · {caseStudy.data.industry}</p>
        <h1>{caseStudy.data.title}</h1>
        <p class="lede">{caseStudy.data.description}</p>
      </header>

      {caseStudy.data.results.length > 0 && (
        <div class="next-grid">
          {caseStudy.data.results.map(result => (
            <div class="next-step">
              <h3>Proof point</h3>
              <p>{result}</p>
            </div>
          ))}
        </div>
      )}

      <div class="content-body">
        <Content />
      </div>
    </article>
  </section>
</Layout>
