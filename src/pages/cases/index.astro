---
import Layout from '../../layouts/Layout.astro';
import { siteConfig } from '../../config/site';
import { getCollection } from 'astro:content';

const cases = await getCollection('cases', ({ data }) => !data.draft);
const sorted = cases.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const entrySlug = (id: string) => id.replace(/\.md$/, '');
---

<Layout title={`Cases - ${siteConfig.name}`} description="Example local-business website previews and launch workflows.">
  <section class="poster-section">
    <div class="listing-frame">
      <p class="eyebrow">Cases</p>
      <h1>Website previews built from real business details.</h1>
      <p class="lede">Examples of the research, preview, revision, launch, and domain handoff workflow behind profitslocal projects.</p>

      <div class="listing-grid">
        {sorted.map(c => (
          <a href={`/cases/${entrySlug(c.id)}`} class="listing-card">
            <p class="eyebrow">{c.data.industry}</p>
            <h3>{c.data.title}</h3>
            <p>{c.data.description}</p>
            {c.data.results.length > 0 && (
              <ul>
                {c.data.results.map(r => <li>{r}</li>)}
              </ul>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
