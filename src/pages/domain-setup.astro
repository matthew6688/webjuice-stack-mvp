---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../config/site';
---

<Layout title={`Domain setup - ${siteConfig.name}`} description="Choose and start a ProfitsLocal launch domain route.">
  <section class="poster-section">
    <div class="contact-frame intake-frame revision-frame">
      <div class="contact-intro">
        <p class="eyebrow">Domain launch</p>
        <h1>Choose the public address.</h1>
        <p class="lede">ProfitsLocal subdomains are fastest because we handle DNS. Customer-owned domains need one DNS change, and root domains need a quick safety check before we switch live traffic.</p>
        <p class="micro" style="margin-top: 22px;"><a href="/domain-help">Read the domain guide</a> if you already have a live website, business email, or existing DNS records.</p>
        <div class="domain-route-grid">
          <article class="domain-route-card">
            <span>Fastest</span>
            <h2>Free ProfitsLocal subdomain</h2>
            <p>Best when you want the site live quickly and do not want to touch DNS yourself.</p>
            <ul>
              <li>Example: <strong>dark-shepherd.profitslocal.com</strong></li>
              <li>We create and attach the domain</li>
              <li>No customer DNS step</li>
            </ul>
          </article>
          <article class="domain-route-card">
            <span>Low risk</span>
            <h2>Your subdomain</h2>
            <p>Best when your current root domain or email setup must stay untouched.</p>
            <ul>
              <li>Example: <strong>menu.yourbusiness.com</strong></li>
              <li>You add one CNAME record</li>
              <li>Existing main site stays safe</li>
            </ul>
          </article>
          <article class="domain-route-card">
            <span>Full replacement</span>
            <h2>Your root domain</h2>
            <p>Best when this new site should replace the current public homepage.</p>
            <ul>
              <li>Example: <strong>yourbusiness.com</strong></li>
              <li>We audit DNS and email first</li>
              <li>Safer after a quick operator review</li>
            </ul>
          </article>
        </div>
      </div>
      <form class="contact-form" id="domain-form" data-funnel-context-form novalidate>
        <input type="hidden" name="project" value="" />
        <div class="field">
          <label for="order_id">Order ID <span class="req">Required</span></label>
          <input id="order_id" name="order_id" required autocomplete="off" />
        </div>
        <div class="field">
          <label for="email">Checkout email <span class="req">Required</span></label>
          <input id="email" name="email" required type="email" autocomplete="email" />
        </div>
        <div class="field full">
          <label for="client_slug">Project slug <span class="req">Required</span></label>
          <input id="client_slug" name="client_slug" required />
        </div>
        <div class="field full">
          <label for="domain">Domain or subdomain</label>
          <input id="domain" name="domain" autocomplete="off" />
          <p id="domain-hint" class="field-hint">Leave blank to use the fastest free ProfitsLocal subdomain.</p>
        </div>
        <div class="field full policy-field">
          <label>Launch route</label>
          <label class="check-row"><input type="radio" name="route" value="profitslocal" checked /> Free ProfitsLocal subdomain</label>
          <label class="check-row"><input type="radio" name="route" value="subdomain" /> My own subdomain</label>
          <label class="check-row"><input type="radio" name="route" value="root" /> My root domain</label>
          <p id="route-help" class="field-hint">Fastest route. We create the public address for you and email the final link.</p>
        </div>
        <div class="form-actions">
          <button class="submit-button" type="submit">Start domain setup</button>
          <p id="domain-status" class="form-status">We will attach this request to your order.</p>
        </div>
      </form>
      <div class="domain-next-steps">
        <h2>What happens after you submit</h2>
        <ol>
          <li>We match the request to your order using order ID, email, and client slug.</li>
          <li>For a ProfitsLocal subdomain, we handle the domain attach step and send back the live URL.</li>
          <li>For your own subdomain, we reply with the exact CNAME target and confirm once DNS resolves.</li>
          <li>For a root domain, we first review DNS and email risk before changing anything live.</li>
        </ol>
      </div>
    </div>
  </section>

  <script>
    const params = new URLSearchParams(window.location.search);
    const form = document.getElementById('domain-form');
    const status = document.getElementById('domain-status');
    const domainField = form?.elements.namedItem('domain');
    const routeHelp = document.getElementById('route-help');
    const domainHint = document.getElementById('domain-hint');
    const routeInputs = Array.from(form?.querySelectorAll('input[name="route"]') || []);
    window.ProfitsLocalFunnel?.fillForm(form);
    for (const key of ['order_id', 'session_id', 'email', 'client_slug', 'domain', 'preferred_domain']) {
      const value = params.get(key);
      const fieldName = key === 'session_id' ? 'order_id' : key === 'preferred_domain' ? 'domain' : key;
      const field = form?.elements.namedItem(fieldName);
      if (value && field instanceof HTMLInputElement) field.value = value;
    }
    const clientField = form?.elements.namedItem('client_slug');
    const projectField = form?.elements.namedItem('project');
    if (clientField instanceof HTMLInputElement && projectField instanceof HTMLInputElement && clientField.value) {
      projectField.value = `${clientField.value}-live`;
    }

    const applyRouteState = () => {
      const selected = routeInputs.find((input) => input.checked)?.value || 'profitslocal';
      if (!(domainField instanceof HTMLInputElement)) return;
      if (selected === 'profitslocal') {
        domainField.placeholder = 'Leave blank for a free ProfitsLocal subdomain';
        domainField.value = '';
        if (domainHint) domainHint.textContent = 'We will assign and attach the fastest free ProfitsLocal subdomain.';
        if (routeHelp) routeHelp.textContent = 'Fastest route. We create the public address for you and email the final link.';
      } else if (selected === 'subdomain') {
        domainField.placeholder = 'Example: menu.yourbusiness.com';
        if (domainHint) domainHint.textContent = 'Use a subdomain when your current website or email must stay untouched.';
        if (routeHelp) routeHelp.textContent = 'You add one CNAME record. We confirm when Cloudflare Pages is attached.';
      } else {
        domainField.placeholder = 'Example: yourbusiness.com';
        if (domainHint) domainHint.textContent = 'Use the root domain only when this new site should replace the current public homepage.';
        if (routeHelp) routeHelp.textContent = 'We review DNS and business email risk first, then confirm the safest cutover.';
      }
    };

    const currentDomain = params.get('domain') || params.get('preferred_domain') || '';
    if (currentDomain && routeInputs.length) {
      const selected = currentDomain.split('.').length <= 2 ? 'root' : 'subdomain';
      routeInputs.forEach((input) => {
        input.checked = input.value === selected;
      });
    }
    routeInputs.forEach((input) => input.addEventListener('change', applyRouteState));
    applyRouteState();

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const invalid = Array.from(form.querySelectorAll('input')).find((control) => !control.checkValidity());
      if (invalid) {
        invalid.focus();
        if (status) {
          status.textContent = 'Please enter the order ID, email, and project slug.';
          status.className = 'form-status error';
        }
        return;
      }
      if (status) {
        status.textContent = 'Starting domain setup...';
        status.className = 'form-status';
      }
      const payload = Object.fromEntries(new FormData(form).entries());
      if (!payload.project && payload.client_slug) payload.project = `${payload.client_slug}-live`;
      try {
        const response = await fetch('/api/domain-request', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const result = await response.json();
        if (!response.ok || !result.success) throw new Error(result.error || 'Domain setup failed.');
        status.textContent = result.route?.message || 'Domain request queued. We will email status updates.';
        status.className = 'form-status success';
      } catch (error) {
        if (status) {
          status.textContent = error instanceof Error ? error.message : 'Domain setup failed.';
          status.className = 'form-status error';
        }
      }
    });
  </script>
</Layout>
