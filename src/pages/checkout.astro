---
import Layout from '../layouts/Layout.astro';
import { getPricing } from '../config/pricing';
import { siteConfig } from '../config/site';

const pricing = getPricing('restaurant');
const tierData = pricing.tiers.map((tier) => ({
  id: tier.id,
  name: tier.name,
  summaryName: tier.id === 'yearly_maintenance' ? 'Yearly maintenance' : tier.name,
  price: tier.price,
  suffix: tier.id === 'yearly_maintenance' ? '/year' : '',
  eyebrow: tier.id === 'one_time' ? 'Most direct' : tier.id === 'yearly_maintenance' ? 'Maintenance plan' : 'Add-on',
  description: tier.description,
  features: tier.features,
}));
---

<Layout title={`Checkout - ${siteConfig.name}`} description="Choose a profitslocal package and pay securely through Stripe.">
  <section class="poster-section checkout-page">
    <div class="checkout-frame">
      <div class="checkout-hero">
        <div>
          <p class="eyebrow">Secure Stripe checkout</p>
          <h1>Select your next step.</h1>
          <p class="lede">Choose a package, confirm the business details, and continue to Stripe. Fixed pricing covers one-page local business websites with structured async intake.</p>
          <div class="checkout-jump-row">
            <a href="#pricing">Pricing</a>
            <a href="#faq">FAQ</a>
            <a href="/contact">Ask first</a>
          </div>
        </div>
        <div class="checkout-context" id="checkout-context">
          <p class="eyebrow">Preview status</p>
          <p class="context-copy" id="context-copy">No preview link detected yet. We will record the order as a paid intake and ask for the details needed before first-version work starts.</p>
          <a class="context-link hidden" id="context-preview" href="#" target="_blank" rel="noreferrer">Open preview</a>
        </div>
      </div>

      <div class="checkout-tier-grid" id="pricing" aria-label="Package options">
        {pricing.tiers.map((tier) => (
          <button
            class="checkout-tier"
            type="button"
            data-tier={tier.id}
            aria-pressed="false"
          >
            <span class="tier-eyebrow">{tier.id === 'one_time' ? 'Most direct' : tier.id === 'yearly_maintenance' ? 'Maintenance plan' : 'Add-on'}</span>
            <strong>{tier.name}</strong>
            <b>${tier.price}{tier.id === 'yearly_maintenance' ? '/year' : ''}</b>
            <small>{tier.id === 'one_time' ? 'One-page + 3 revisions' : tier.id === 'yearly_maintenance' ? 'One-page + 12 updates/year' : 'For in-scope edits'}</small>
          </button>
        ))}
      </div>

      <section class="checkout-faq" id="faq" aria-labelledby="checkout-faq-title">
        <div>
          <p class="eyebrow">Quick answers</p>
          <h2 id="checkout-faq-title">What happens after you claim it?</h2>
        </div>
        <div class="checkout-faq-list">
          <article>
            <h3>Is this tied to my preview?</h3>
            <p>Yes. Preview links carry the client slug, repo, template, campaign, and preview URL into this checkout and into Stripe metadata.</p>
          </article>
          <article>
            <h3>Can I ask for changes?</h3>
            <p>The one-time package includes 3 revision rounds. Extra in-scope revision rounds are $100 after the included quota is used.</p>
          </article>
          <article>
            <h3>What domain can I use?</h3>
            <p>You can use a free ProfitsLocal subdomain, your own subdomain, or your root domain after DNS review.</p>
          </article>
        </div>
      </section>

      <div class="checkout-workspace">
        <aside class="selected-package" aria-live="polite">
          <p class="eyebrow">Selected package</p>
          <h2 id="selected-name">One-time website</h2>
          <div class="price" id="selected-price">$399</div>
          <p id="selected-description">For businesses that want to launch the preview site and make a few changes first.</p>
          <ul id="selected-features"></ul>
        </aside>

        <form class="checkout-form" id="checkout-form" data-funnel-context-form novalidate>
          <input type="hidden" name="tier" value="one_time" />
          <input type="hidden" name="client_slug" value="" />
          <input type="hidden" name="repo" value="" />
          <input type="hidden" name="template" value="webjuice-restaurant" />
          <input type="hidden" name="preview_url" value="" />
          <input type="hidden" name="campaign_id" value="profitslocal-main" />
          <input type="hidden" name="brief_id" value="" />
          <input type="hidden" name="auto_run_agent" value="false" />
          <input type="hidden" name="amount" value="" />
          <input type="hidden" name="currency" value="USD" />
          <input type="hidden" name="first_landing_url" value="" />
          <input type="hidden" name="last_landing_url" value="" />
          <input type="hidden" name="referrer" value="" />
          <input type="hidden" name="last_referrer" value="" />
          <input type="hidden" name="first_seen_at" value="" />
          <input type="hidden" name="last_seen_at" value="" />
          <input type="hidden" name="utm_source" value="" />
          <input type="hidden" name="utm_medium" value="" />
          <input type="hidden" name="utm_campaign" value="" />
          <input type="hidden" name="utm_term" value="" />
          <input type="hidden" name="utm_content" value="" />
          <input type="hidden" name="gclid" value="" />
          <input type="hidden" name="fbclid" value="" />
          <input type="hidden" name="msclkid" value="" />
          <input type="hidden" name="ttclid" value="" />
          <input type="hidden" name="twclid" value="" />
          <input type="hidden" name="li_fat_id" value="" />
          <input type="hidden" name="gbraid" value="" />
          <input type="hidden" name="wbraid" value="" />
          <input type="hidden" name="source" value="" />
          <input type="hidden" name="ref" value="" />

          <div class="field">
            <label for="business_name">Business name <span class="req">Required</span></label>
            <input id="business_name" name="business_name" autocomplete="organization" placeholder="Your local business" required />
          </div>
          <div class="field">
            <label for="email">Email address <span class="req">Required</span></label>
            <input id="email" name="email" type="email" autocomplete="email" placeholder="jane@business.com" required />
          </div>
          <div class="field">
            <label for="phone">Phone</label>
            <input id="phone" name="phone" autocomplete="tel" placeholder="+1 555 0123" />
          </div>
          <div class="field">
            <label for="preferred_domain">Preferred domain</label>
            <input id="preferred_domain" name="preferred_domain" placeholder="example.com or example.profitslocal.com" />
          </div>
          <div class="field full hidden" id="parent-order-field">
            <label for="parent_order_id">Original order ID <span class="req">Required</span></label>
            <input id="parent_order_id" name="parent_order_id" placeholder="cs_live_..." />
          </div>
          <div class="field full">
            <label for="launch_notes">Launch notes or requested changes</label>
            <textarea id="launch_notes" name="launch_notes" placeholder="Tell us what should happen after payment. Include launch timing, domain notes, or anything we should preserve. Multi-page/custom builds are quoted separately."></textarea>
          </div>
          <div class="field full policy-field">
            <label>Package boundary</label>
            <p class="field-hint">This checkout is for a one-page local business website. Revisions are changes to the current version, not a full redesign or new project. Before first-version generation starts, the order is refundable; after the first version is generated, it is non-refundable.</p>
          </div>
          <div class="field full file-field">
            <label for="checkout-files">Upload logo, photos, PDF, or reference files</label>
            <input id="checkout-files" name="files" type="file" multiple accept="image/*,.pdf,.doc,.docx,.txt,.md,.csv,.zip" />
            <p class="field-hint">Optional, up to 8 files. Attach the assets we should use after payment: logo, product photos, menu PDF, service list, screenshots, or visual references.</p>
          </div>
          <div class="form-actions">
            <button class="submit-button" type="submit">Continue to Stripe</button>
            <p id="checkout-status" class="form-status">Secure payment opens on Stripe.</p>
          </div>
        </form>
      </div>
    </div>
  </section>

  <script define:vars={{ tiers: tierData }}>
    const params = new URLSearchParams(window.location.search);
    const form = document.getElementById('checkout-form');
    const status = document.getElementById('checkout-status');
    const tierButtons = Array.from(document.querySelectorAll('.checkout-tier'));
    const selectedName = document.getElementById('selected-name');
    const selectedPrice = document.getElementById('selected-price');
    const selectedDescription = document.getElementById('selected-description');
    const selectedFeatures = document.getElementById('selected-features');
    const parentOrderField = document.getElementById('parent-order-field');
    const parentOrderInput = document.getElementById('parent_order_id');
    const contextCopy = document.getElementById('context-copy');
    const contextPreview = document.getElementById('context-preview');
    const validTierIds = new Set(tiers.map((tier) => tier.id));
    const contextKeys = [
      'client_slug',
      'repo',
      'template',
      'preview_url',
      'campaign_id',
      'brief_id',
      'business_name',
      'amount',
      'currency',
      'email',
      'phone',
      'preferred_domain',
      'parent_order_id',
      'first_landing_url',
      'last_landing_url',
      'referrer',
      'last_referrer',
      'first_seen_at',
      'last_seen_at',
      'utm_source',
      'utm_medium',
      'utm_campaign',
      'utm_term',
      'utm_content',
      'gclid',
      'fbclid',
      'msclkid',
      'ttclid',
      'twclid',
      'li_fat_id',
      'gbraid',
      'wbraid',
      'source',
      'ref',
    ];

    hydrateFromUrl();
    const storedContext = window.ProfitsLocalFunnel?.fillForm(form) || {};
    selectTier(validTierIds.has(params.get('tier')) ? params.get('tier') : 'one_time', false);

    tierButtons.forEach((button) => {
      button.addEventListener('click', () => {
        selectTier(button.dataset.tier || 'one_time', true);
      });
    });

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const controls = Array.from(form.querySelectorAll('input, textarea'));
      const invalid = controls.find((control) => control instanceof HTMLInputElement || control instanceof HTMLTextAreaElement ? !control.checkValidity() : false);

      if (invalid) {
        invalid.focus();
        if (status) {
          status.textContent = 'Please complete the required fields before opening Stripe.';
          status.className = 'form-status error';
        }
        return;
      }

      if (status) {
        status.textContent = 'Opening Stripe Checkout...';
        status.className = 'form-status';
      }

      try {
        const response = await fetch('/api/create-checkout-session', {
          method: 'POST',
          body: new FormData(form),
        });
        const result = await response.json();
        if (!response.ok || !result.url) throw new Error(result.error || 'Checkout failed');
        window.location.href = result.url;
      } catch (error) {
        if (status) {
          status.textContent = error instanceof Error ? error.message : 'Checkout failed. Please try again.';
          status.className = 'form-status error';
        }
      }
    });

    function hydrateFromUrl() {
      const mappings = {
        client_slug: 'client_slug',
        repo: 'repo',
        template: 'template',
        preview_url: 'preview_url',
        campaign_id: 'campaign_id',
        brief_id: 'brief_id',
        business_name: 'business_name',
        email: 'email',
        phone: 'phone',
        domain: 'preferred_domain',
        launch_notes: 'launch_notes',
        parent_order_id: 'parent_order_id',
      };
      contextKeys.forEach((key) => {
        if (!mappings[key]) mappings[key] = key;
      });

      for (const [paramName, fieldName] of Object.entries(mappings)) {
        const value = params.get(paramName);
        const field = form?.elements.namedItem(fieldName);
        if (value && (field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement)) {
          field.value = value || field.value;
        }
      }

      const previewUrl = params.get('preview_url') || storedContext.preview_url || '';
      const clientSlug = params.get('client_slug') || storedContext.client_slug || '';
      const repo = params.get('repo') || storedContext.repo || '';
      const hasPreviewContext = Boolean(clientSlug && repo && previewUrl);
      const autoRunField = form?.elements.namedItem('auto_run_agent');
      if (autoRunField instanceof HTMLInputElement) autoRunField.value = hasPreviewContext ? 'true' : 'false';

      if (previewUrl && contextPreview instanceof HTMLAnchorElement) {
        contextPreview.href = previewUrl;
        contextPreview.classList.remove('hidden');
      }
      if (contextCopy) {
        contextCopy.textContent = hasPreviewContext
          ? 'Preview link detected. Your checkout will stay tied to this project and route into the delivery workflow.'
          : 'No preview link detected yet. We will record the order as a paid intake and ask for the details needed before first-version work starts.';
      }
    }

    function selectTier(tierId, updateUrl) {
      const tier = tiers.find((item) => item.id === tierId) || tiers[0];
      const tierField = form?.elements.namedItem('tier');
      if (tierField instanceof HTMLInputElement) tierField.value = tier.id;

      tierButtons.forEach((button) => {
        const active = button.dataset.tier === tier.id;
        button.classList.toggle('is-active', active);
        button.setAttribute('aria-pressed', active ? 'true' : 'false');
      });

      if (selectedName) selectedName.textContent = tier.summaryName || tier.name;
      if (selectedPrice) selectedPrice.textContent = `$${tier.price}${tier.suffix}`;
      if (selectedDescription) selectedDescription.textContent = tier.description;
      if (selectedFeatures) {
        selectedFeatures.innerHTML = tier.features.map((feature) => `<li>${escapeHtml(feature)}</li>`).join('');
      }

      const isExtraRevision = tier.id === 'extra_revision';
      parentOrderField?.classList.toggle('hidden', !isExtraRevision);
      if (parentOrderInput instanceof HTMLInputElement) {
        parentOrderInput.required = isExtraRevision;
      }

      if (updateUrl) {
        const next = new URL(window.location.href);
        next.searchParams.set('tier', tier.id);
        window.history.replaceState({}, '', next);
      }
    }

    function escapeHtml(value) {
      return String(value).replace(/[&<>"']/g, (char) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#039;',
      }[char]));
    }
  </script>
</Layout>
