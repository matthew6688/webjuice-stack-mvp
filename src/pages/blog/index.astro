---
import Layout from '../../layouts/Layout.astro';
import { siteConfig } from '../../config/site';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const entrySlug = (id: string) => id.replace(/\.md$/, '');
---

<Layout title={`Blog - ${siteConfig.name}`} description="Plain notes for local businesses reviewing or improving a website.">
  <section class="poster-section">
    <div class="listing-frame">
      <p class="eyebrow">Blog</p>
      <h1>Notes for local businesses reviewing a website.</h1>
      <p class="lede">Short guides on what a local homepage needs, what to check before paying, and how to make a site easier for customers to trust.</p>

      <div class="listing-grid">
        {sorted.map(post => (
          <a href={`/blog/${entrySlug(post.id)}`} class="listing-card">
            <p class="eyebrow">{post.data.tags[0] || 'Website strategy'}</p>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <p class="micro">{post.data.author} · {post.data.pubDate.toLocaleDateString()}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
