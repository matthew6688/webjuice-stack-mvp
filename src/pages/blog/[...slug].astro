---
import Layout from '../../layouts/Layout.astro';
import { siteConfig } from '../../config/site';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} - ${siteConfig.name}`} description={post.data.description}>
  <section class="poster-section">
    <article class="article-frame">
      <header>
        <p class="eyebrow">{post.data.author} · {post.data.pubDate.toLocaleDateString()}</p>
        <h1>{post.data.title}</h1>
        <p class="lede">{post.data.description}</p>
        {post.data.tags?.length > 0 && (
          <p class="micro" style="margin-top: 20px;">{post.data.tags.join(' / ')}</p>
        )}
      </header>

      <div class="content-body">
        <Content />
      </div>
    </article>
  </section>
</Layout>
