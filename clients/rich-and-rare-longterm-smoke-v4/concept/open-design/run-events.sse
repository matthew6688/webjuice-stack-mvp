data: {"type":"tool_result","toolUseId":"item_17","content":"              \n\n              <div class=\"menu-item-title\">Woodfired Bone Marrow (15cm)</div>\n              <div class=\"menu-item-description\">Served with pangrattato, chives and wagyu fat ciabatta</div>\n\n              \n                <div class=\"menu-item-price-bottom\">\n                  \n                    <span class=\"currency-sign\">$</span>33 \n                  \n                </div>\n              \n\n              \n\n            </div>\n          \n            <div class=\"menu-item\">\n              \n                <span class=\"menu-item-price-top\">\n                  \n                    <span class=\"currency-sign\">$</span>38 \n                  \n                </span>\n              \n\n              <div class=\"menu-item-title\">Wagyu Kabayaki Skewer</div>\n              <div class=\"menu-item-description\">MB8–9 Stone Axe tri tip, served with burnt onion aioli, R&R kabayaki glaze & fried curry leaves</div>\n\n              \n                <div class=\"menu-item-price-bottom\">\n                  \n                    <span class=\"currency-sign\">$</span>38 \n                  \n                </div>\n              \n\n              \n\n            </div>\n          \n            <div class=\"menu-item\">\n              \n                <span class=\"menu-item-price-top\">\n                  \n                    <span class=\"currency-sign\">$</span>30 \n                  \n                </span>\n              \n\n              <div class=\"menu-item-title\">Homemade Pork Sausage</div>\n              <div class=\"menu-item-description\">Mozzarella cheese, Calabrian chilli and Brazilian spices. Served with black garlic purée, paprika aioli and chimichurri</div>\n\n              \n                <div class=\"menu-item-price-bottom\">\n                  \n                    <span class=\"currency-sign\">$</span>30 \n                  \n                </div>\n              \n\n              \n\n            </div>\n          \n            <div class=\"menu-item\">\n              \n                <span class=\"menu-item-price-top\">\n                  \n                    <span class=\"currency-sign\">$</span>22 \n                  \n                </span>\n              \n\n              <div class=\"menu-item-title\">Burrata (GF, VE)</div>\n              <div class=\"menu-item-description\">Pink peppercorn oil, black flake salt</div>\n\n              \n                <div class=\"menu-item-price-bottom\">\n                  \n                    <span class=\"currency-sign\">$</span>22 \n                  \n                </div>\n              \n\n              \n\n            </div>\n          \n            <div class=\"menu-item\">\n              \n                <span class=\"menu-item-price-top\">\n                  \n                    <span class=\"currency-sign\">$</span>20 \n                  \n                </span>\n              \n\n              <div class=\"menu-item-title\">Jamón Ibérico (GF, DF)</div>\n              <div class=\"menu-item-description\">EVOO</div>\n\n              \n                <div class=\"menu-item-price-bottom\">\n                  \n                    <span class=\"currency-sign\">$</span>20 \n                  \n                </div>\n              \n\n              \n\n            </div>\n          \n        </div>\n\n      </div>\n      \n\n    </div>\n  \n  </div>\n\n\n\n</div> <!-- END .menu-wrapper -->\n</div></div></div><div class=\"fe-block fe-block-93241f384c4a0880ffec\"><div class=\"sqs-block website-component-block sqs-block-website-component sqs-block-html html-block\" data-block-css=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.html/dc098d38-1f28-4adf-bbcb-6a5089a56458_517/website.components.html.styles.css&quot;]\" data-block-scripts=\"[&quot;https://definitions.sqspcdn.com/website-component-definitio