ings.html:1689:                          <use xlink:href=\"#facebook-unauth-icon\" width=\"110\" height=\"110\"></use>\nsource/bookings.html:1702:                href=\"https://www.sevenrooms.com/explore/richandrarerestaurant/reservations/create/search?venues=richandrarerestaurant,pompetteau,darkshepherd,yamasgreekdrink,stilts,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant\"\nsource/bookings.html:1745:  data-section-theme=\"black\"\nsource/bookings.html:1764:    black'\nsource/bookings.html:1819:                                                                                                                        &quot;sectionTheme&quot;: &quot;black&quot;,\nsource/bookings.html:2265:  alt=\"Black background with the white stylized initials R R R\"\nsource/bookings.html:2313:  overflow: hidden;-webkit-mask-image: -webkit-radial-gradient(white, black);clip-path: none;-webkit-clip-path: none;\nsource/bookings.html:2421:  alt=\"A circular badge with a blue watercolor background, displaying the text 'Winner Awards for Excellence 2025' in white, with 'Winner' written in script font.\"\nsource/bookings.html:2469:  overflow: hidden;-webkit-mask-image: -webkit-radial-gradient(white, black);clip-path: none;-webkit-clip-path: none;\nsource/bookings.html:2625:  overflow: hidden;-webkit-mask-image: -webkit-radial-gradient(white, black);clip-path: none;-webkit-clip-path: none;\nsource/bookings.html:2650:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p style=\"text-align:center;white-space:pre-wrap;\" class=\"\">Rich flavours. Rare cuts. Real service.</p></div>\nsource/bookings.html:2734:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><div class=\"sqsrte-scaled-text-container\"><span class=\"sqsrte-scaled-text\"><h1 style=\"text-align:center;white-space:pre-wrap;\">STEAK AND SEAFOOD RESTAURANT, WEST VILLAGE</h1></span></div></div>\nsource/bookings.html:2829:      href=\"https://www.sevenrooms.com/explore/richandrarerestaurant/reservations/create/search?venues=richandrarerestaurant,pompetteau,darkshepherd,yamasgreekdrink,stilts,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant\" \nsource/bookings.html:2850:      href=\"https://www.sevenrooms.com/explore/richandrarerestaurant/reservations/create/search?venues=richandrarerestaurant,pompetteau,darkshepherd,yamasgreekdrink,stilts,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant\" \nsource/bookings.html:2924:  data-section-theme=\"dark\"\nsource/bookings.html:3390:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p style=\"text-align:center;white-space:pre-wrap;\" class=\"\">Rich &amp; Rare offers premium fare without pretension. Open your collar, order a whisky and settle in to enjoy succulent, dry-aged steak and freshly caught seafood, nestled in the heart of Brisbane’s vibrant West Village precinct.</p></div>\nsource/bookings.html:3485:      href=\"/menus\" \nsource/bookings.html:3506:      href=\"/menus\" \nsource/bookings.html:3637:  alt=\"Person squeezing lemon over a seafood dish with lobster, fish, and shellfish, with glasses of white wine on a marble table.\"\nsource/bookings.html:3685:  overflow: hidden;-webkit-mask-image: -webkit-radial-gradient(white, black);clip-path: none;-webkit-clip-path: none;\nsource/bookings.html:3793:  alt=\"A dinner plate with a cooked steak topped with brown gravy, a small green pitcher, a salad in a white bowl, a white dish with cooked stuffed chicken breasts, and a glass of red wine on a marble table.\"\nsource/bookings.html:3841:  overflow: hidden;-webkit-mask-image: -webkit-radial-gradient(white, black);clip-path: none;-webkit-clip-path: none;\nsource/bookings.html:3949:  alt=\"Oysters on the half shell with green garnish and orange roe, served on a bed of ice on a white platter.\"\nsource/bookings.html:3997:  overflow: hidden;-webkit-mask-image: -webkit-radial-gradient(white, black);clip-path: none;-webkit-clip-path: none;\nsource/bookings.html:4022:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p style=\"text-align:center;white-space:pre-wrap;\" class=\"\">Business or pleasure - delight your guests with the casual sophistication of Rich &amp; Rare. From an exclusive 10-seater private room, to command of the whole venue, our spaces can work to your needs.</p></div>\nsource/bookings.html:4117:      href=\"/contact\" \nsource/bookings.html:4138:      href=\"/contact\" \nsource/bookings.html:4212:  data-section-theme=\"\"\nsource/bookings.html:4392:<img data-src=\"https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/e9c2b80c-f97e-4dff-81a4-2e7aef6e23c6/Rich+%26+Rare+-+Markus+Ravik+-+054.jpg\" data-image=\"https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/e9c2b80c-f97e-4dff-81a4-2e7aef6e23c6/Rich+%26+Rare+-+Markus+Ravik+-+054.jpg\" data-image-dimensions=\"2048x1366\" data-image-focal-point=\"0.49,0.67\" alt=\"Glass of red wine and a plate of sliced cured ham with herbs on a black outdoor table.\" data-load=\"false\" elementtiming=\"nbf-gallery-fullscreen-slideshow\" src=\"https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/e9c2b80c-f97e-4dff-81a4-2e7aef6e23c6/Rich+%26+Rare+-+Markus+Ravik+-+054.jpg\" width=\"2048\" height=\"1366\" alt=\"\" sizes=\"max(100vw, 149.9267935578331vh)\" style=\"display:block;object-position: 49% 67%; object-fit:cover; width: 100%; height: 100%;display: none;\" srcset=\"https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/e9c2b80c-f97e-4dff-81a4-2e7aef6e23c6/Rich+%26+Rare+-+Markus+Ravik+-+054.jpg?format=100w 100w, https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/e9c2b80c-f97e-4dff-81a4-2e7aef6e23c6/Rich+%26+Rare+-+Markus+Ravik+-+054.jpg?format=300w 300w, https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/e9c2b80c-f97e-4dff-81a4-2e7aef6e23c6/Rich+%26+Rare+-+Markus+Ravik+-+054.jpg?fo