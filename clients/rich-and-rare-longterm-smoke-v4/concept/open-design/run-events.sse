data: {"type":"tool_result","toolUseId":"item_6","content":"# Source brief\n\nThese source captures were prepared before the run. Use them as the primary redesign reference.\n\n- home: https://www.richandrare.com.au/ -> source/home.html\n- menu: https://www.richandrare.com.au/lunch-dinner -> source/menu.html\n- functions: https://www.richandrare.com.au/functions -> source/functions.html\n- contact: https://www.richandrare.com.au/contact -> source/contact.html\n- bookings: https://www.richandrare.com.au/bookings -> source/bookings.html\n","isError":false}

