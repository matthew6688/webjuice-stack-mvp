tml:1699:                      <a class=\"icon icon--lg icon--fill  header-icon header-icon-border-shape-circle header-icon-border-style-outline\"  style=\"box-shadow: 0px 0px 0px 1px inset\" href=\"http://facebook.com/richandrare.bne\" target=\"_blank\" aria-label=\"Facebook\">\nsource/menu.html:1701:                          <use xlink:href=\"#facebook-unauth-icon\" width=\"110\" height=\"110\"></use>\nsource/menu.html:1714:                href=\"https://www.sevenrooms.com/explore/richandrarerestaurant/reservations/create/search?venues=richandrarerestaurant,pompetteau,darkshepherd,yamasgreekdrink,stilts,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant\"\nsource/menu.html:1757:  data-section-theme=\"dark\"\nsource/menu.html:2040:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><h1 style=\"text-align:center;white-space:pre-wrap;\">LUNCH &amp; DINNER</h1></div>\nsource/menu.html:2124:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p style=\"text-align:center;white-space:pre-wrap;\" class=\"\">From the bountiful oceans and farms of Queensland to the acclaimed cattle paddocks of Japan, our Chefs have rounded up the finest produce to create this exceptional menu. For the perfect accompaniments, please don’t hesitate to ask your waiter for recommendations of wines, whiskeys, and cocktails.</p></div>\nsource/menu.html:2234:  data-section-theme=\"light-bold\"\nsource/menu.html:3351:              <div class=\"menu-item-description\">Mozzarella cheese, Calabrian chilli and Brazilian spices. Served with black garlic purée, paprika aioli and chimichurri</div>\nsource/menu.html:3375:              <div class=\"menu-item-description\">Pink peppercorn oil, black flake salt</div>\nsource/menu.html:3427:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><h2 style=\"text-align:center;white-space:pre-wrap;\">SNACKS</h2></div>\nsource/menu.html:3511:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><h2 style=\"text-align:center;white-space:pre-wrap;\">OYSTERS</h2></div>\nsource/menu.html:3711:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><h2 style=\"text-align:center;white-space:pre-wrap;\">COLD SEAFOOD</h2></div>\nsource/menu.html:3911:              <div class=\"menu-item-description\">Goat curd, hummus, black garlic purée</div>\nsource/menu.html:4203:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><h2 style=\"text-align:center;white-space:pre-wrap;\">ENTRÈE</h2></div>\nsource/menu.html:4287:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><h2 style=\"text-align:center;white-space:pre-wrap;\">LARGE PLATES</h2></div>\nsource/menu.html:5577:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><h2 style=\"text-align:center;white-space:pre-wrap;\">STONE AXE BOARD</h2></div>\nsource/menu.html:5661:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><h2 style=\"text-align:center;white-space:pre-wrap;\">CLASSIC SIDES</h2></div>\nsource/menu.html:5877:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><h2 style=\"text-align:center;white-space:pre-wrap;\">R&amp;R SIDES</h2></div>\nsource/menu.html:6201:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><h2 style=\"text-align: center; ; white-space:pre-wrap;\" data-rte-preserve-empty=\"true\">Sauces</h2></div>\nsource/menu.html:6285:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><h2 style=\"text-align:center;white-space:pre-wrap;\">EXTRAS</h2></div>\nsource/menu.html:6527:  data-section-theme=\"dark\"\nsource/menu.html:6938:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><h2 style=\"text-align:center;white-space:pre-wrap;\">BANQUETS</h2></div>\nsource/menu.html:7022:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p style=\"text-align:center;white-space:pre-wrap;\" class=\"sqsrte-small\"><em>Whole table only, minimum two people</em></p></div>\nsource/menu.html:7106:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><h4 style=\"text-align: center; ; white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>DrOVer’s delight - 88pp</strong></h4><p style=\"white-space:pre-wrap;\" class=\"sqsrte-small\" data-rte-preserve-empty=\"true\"><strong>Artisan Sourdough Ciabatta</strong><br><em>Bone marrow butter</em></p><p style=\"white-space:pre-wrap;\" class=\"sqsrte-small\" data-rte-preserve-empty=\"true\"><strong>Jamón Ibérico</strong><br><em>EVOO</em></p><p style=\"white-space:pre-wrap;\" class=\"sqsrte-small\" data-rte-preserve-empty=\"true\"><strong>Raw Salmon</strong><br><em>Ceviche, crispy sweet potato, salmon roe, green oil</em></p><p style=\"white-space:pre-wrap;\" class=\"sqsrte-small\" data-rte-preserve-empty=\"true\"><strong>Wagyu Bites &amp; Kiss Pepper Jam</strong><br><em>MB9+ Chuck Eye Roll, panko crumbed</em></p><p style=\"white-space:pre-wrap;\" class=\"sqsrte-small\" data-rte-preserve-empty=\"true\"><strong>400g Black Angus Sirloin MB4+</strong><br><em>270+ days grain fed, Portoro Black Angus, British and Euro Bred Black Angus, Riverina Region, Southern NSW • Chimichurri</em></p><p style=\"white-space:pre-wrap;\" class=\"sqsrte-small\" data-rte-preserve-empty=\"true\"><strong>Iceberg Lettuce</strong><br><em>Lemon, shaved parmesan&nbsp;</em></p><p style=\"white-space:pre-wrap;\" class=\"sqsrte-small\" data-rte-preserve-empty=\"true\"><strong>Shoestring Fries</strong><br><em>Rosemary salt, aioli</em></p><p style=\"white-space:pre-wrap;\" class=\"sqsrte-small\" data-rte-preserve-empty=\"true\"><strong>Coconut Panna Cotta</strong><br><em>Dried edible flowers, strawberry, silky mango sauce</em></p></div>\nsource/menu.html:7190:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><h4 style=\"text-align: center; ; white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>Wave &amp; Wagyu - 132pp</strong></h4><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>Artisan Sourdough Ciabatta<br></strong><em>Bone marrow butter</em></p><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>Jamón Ibérico</strong><br><em>EVOO</em></p><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>Westholme Wagyu Tartare - MB4-5 Petit Tender</strong><br><em>Yolk, fresh horseradish, homemade potato crisps</em></p><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>King Prawns</strong><br><em>Corn purée, homemade sweet chilli jam&nbsp;</em></p><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>Market Fish</strong><br><em>Ask your waiter about our market fish</em></p><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>Tajima Wagyu Striploin MB6-7</strong><br><em>400+ day grain fed Wagyu from Tajima bloodline cattle of Hyogo Prefecture in Japan, crossbred with Angus/Holstein, F1-F4, and raised in Australia, Riverina Region, NSW • Chimichurri</em></p><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>Wagyu Fat Potatoes</strong><br><em>Gremolata, wagyu fat</em></p><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>GreenBeans</strong><br><em>Goat curd, chilli</em></p><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>Chocolate</strong><br><em>Cocoa crumble, macadamia ice cream, meringue crackers, black flake salt&nbsp;</em></p></div>\nsource/menu.html:7357:  alt=\"Empty white background.\"\nsource/menu.html:7405:  overflow: hidden;-webkit-mask-image: -webkit-radial-gradient(white, black);clip-path: none;-webkit-clip-path: none;\nsource/menu.html:7430:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><h4 style=\"text-align: center; ; white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>R&amp;R EXPERIENCE - 220pp</strong></h4><p class=\"sqsrte-small\" style=\"text-align: center; ; white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>Artisan Sourdough Ciabatta<br></strong><em>Bone marrow butter</em></p><p class=\"sqsrte-small\" style=\"text-align: center; ; white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>Wagyu Tataki - MB8-9<br></strong><em>Rump, ponzu, wakame</em></p><p class=\"sqsrte-small\" style=\"text-align: center; ; white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>King Prawns<br></strong><em>Corn purée, homemade sweet chilli jam</em></p><p class=\"sqsrte-small\" style=\"text-align: center; ; white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>Westholme Wagyu Tartare MB4-5 Petit Tender<br></strong><em>Yolk, fresh horseradish, homemade potato crisps</em></p><p class=\"sqsrte-small\" style=\"text-align: center; ; white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>Scotch Fillet<br></strong><em>150+ days grain fed, Riverina, full blood Black Angus, <br> Glen Innes, New England Tablelands, NSW</em></p><p class=\"sqsrte-small\" style=\"text-align: center; ; white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>Tajima Wagyu Striploin MB6-7<br></strong><em>300+ day grain fed Wagyu from Tajima bloodline cattle of Hyogo Prefecture in Japan, crossbred with Angus/Holstein, F1-F4, and raised in Australia, Riverina Region, NSW</em></p><p class=\"sqsrte-small\" style=\"text-align: center; ; white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>Striploin A5 Japanese Wagyu MB12+<br></strong><em>650+ days grain fed, 100% full blood A5 Japanese Black Wagyu, Kagoshima Japan</em></p><p class=\"sqsrte-small\" style=\"text-align: center; ; white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>R&amp;R Red Wine Jus</strong></p><p class=\"sqsrte-small\" style=\"text-align: center; ; white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>Bone Marrow Mash&nbsp;</strong></p><p class=\"sqsrte-small\" style=\"text-align: center; ; white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>Green Beans&nbsp;</strong></p><p class=\"sqsrte-small\" style=\"text-align: center; ; white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>Shoestring Fries&nbsp;</strong></p><p class=\"sqsrte-small\" style=\"text-align: center; ; white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>Mixed Leaf Salad</strong></p><p class=\"sqsrte-small\" style=\"text-align: center; ; white-space:pre-wrap;\" data-rte-preserve-empty=\"true\"><strong>R&amp;R Cheesecake</strong></p></div>\nsource/menu.html:7525:                                                                                                                                          \"sitePaletteColor\": {\nsource/menu.html:7526:                                                                                                                                            \"colorName\": \"white\",\nsource/menu.html:7537:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p style=\"text-align:center;white-space:pre-wrap;\" class=\"sqsrte-small\"><span class=\"sqsrte-text-highlight\" data-text-attribute-id=\"0df74c89-af29-4e22-8841-53056b0eda66\"><strong>ADD ONS</strong></span></p><p style=\"text-align:center;white-space:pre-wrap;\" class=\"sqsrte-small\">Fried Egg <strong>5 </strong>Foie Gras <strong>40</strong> King Prawn <strong>12 </strong>Whole Live Lobster <strong>240 </strong>Blue Cheese <strong>10</strong></p></div>\nsource/menu.html:7647:  data-section-theme=\"\"\nsource/menu.html:7857:              <div class=\"menu-item-description\">Cocoa crumble, macadamia ice cream, meringue crackers, black flake salt</div>\nsource/menu.html:8047:  data-section-theme=\"white\"\nsource/menu.html:8068:    white'\nsource/menu.html:8082:                                                                                                                                        &quot;sectionTheme&quot;: &quot;white&quot;,\nsource/menu.html:8229:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p style=\"text-align:center;white-space:pre-wrap;\" class=\"sqsrte-small\"><span class=\"sqsrte-text-color--darkAccent\"><em>Kids menu available upon request.</em></span></p><p style=\"text-align:center;white-space:pre-wrap;\" class=\"sqsrte-small\"><em>10% Weekend surcharge (20% on public holidays). Card payment surcharge applies.</em></p><p style=\"text-align:center;white-space:pre-wrap;\" class=\"sqsrte-small\"><span class=\"sqsrte-text-color--darkAccent\"><em>Please advise wait staff of any dietary requirements or allergies. Needs are catered for to the best of our ability, but the decision to consume a meal is the responsibility of the diner. Nuts, seafood, shellfish, sesame seeds, wheat, flour, eggs, fungi &amp; dairy products are all handled on these premises.</em></span></p></div>\nsource/menu.html:8358:  data-section-theme=\"dark-bold\"\nsource/menu.html:8898:  overflow: hidden;-webkit-mask-image: -webkit-radial-gradient(white, black);clip-path: none;-webkit-clip-path: none;\nsource/menu.html:8925:  <div class=\"sqs-svg-icon--outer social-icon-alignment-center social-icons-color-black social-icons-size-medium social-icons-style-regular \">\nsource/menu.html:8938:            href=\"https://www.instagram.com/richandrare_brisbane/\"\nsource/menu.html:8945:                <use class=\"sqs-use--icon\" xlink:href=\"/universal/svg/social-accounts.svg#instagram-unauth-icon\"></use>\nsource/menu.html:8946:                <use class=\"sqs-use--mask\" xlink:href=\"/universal/svg/social-accounts.svg#instagram-unauth-mask\"></use>\nsource/menu.html:8954:            href=\"http://facebook.com/richandrare.bne\"\nsource/menu.html:8961:                <use class=\"sqs-use--icon\" xlink:href=\"/universal/svg/social-accounts.svg#facebook-unauth-icon\"></use>\nsource/menu.html:8962:                <use class=\"sqs-use--mask\" xlink:href=\"/universal/svg/social-accounts.svg#facebook-unauth-mask\"></use>\nsource/menu.html:8973:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\"><strong>OPEN 7 DAYS</strong><br>All Day Dining: 11:00am-late</p></div>\nsource/menu.html:9057:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\">10% Weekend surcharge (20% on Public Holidays). Card payment surcharge applies.</p></div>\nsource/menu.html:9141:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\">FIND US<br>West Village Garden Pavilion<br>97 Boundary Street,<br>West End, Q 4101</p><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\">CAREERS<br><a href=\"/careers\">Employment</a></p><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\"><br>BUSINESS OPPORTUNITIES<br><a href=\"https://www.tassisgroup.com.au/business-opportunities\" target=\"_blank\">Business Opportunities</a></p></div>\nsource/menu.html:9276:      <div class=\"newsletter-form-header-description\"><p class=\"\" style=\"white-space:pre-wrap;\">Sign up to receive news and updates.</p></div>\nsource/menu.html:9314:    <div class=\"newsletter-form-footnote\"><p class=\"\" data-rte-preserve-empty=\"true\" style=\"white-space:pre-wrap;\"></p></div>\nsource/menu.html:9321:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p style=\"text-align:center;white-space:pre-wrap;\" class=\"sqsrte-small\"><a href=\"/privacy-policy\">Privacy Policy</a> • Branding and design by <a href=\"https://www.allocreative.com.au\">Allo Creative</a></p></div>\n","isError":false}

