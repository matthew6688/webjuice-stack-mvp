shape-circle header-icon-border-style-outline\"  style=\"box-shadow: 0px 0px 0px 1px inset\" href=\"https://www.instagram.com/richandrare_brisbane/\" target=\"_blank\" aria-label=\"Instagram\">\nsource/functions.html:1688:                          <use xlink:href=\"#instagram-unauth-icon\" width=\"110\" height=\"110\"></use>\nsource/functions.html:1694:                      <a class=\"icon icon--lg icon--fill  header-icon header-icon-border-shape-circle header-icon-border-style-outline\"  style=\"box-shadow: 0px 0px 0px 1px inset\" href=\"http://facebook.com/richandrare.bne\" target=\"_blank\" aria-label=\"Facebook\">\nsource/functions.html:1696:                          <use xlink:href=\"#facebook-unauth-icon\" width=\"110\" height=\"110\"></use>\nsource/functions.html:1709:                href=\"https://www.sevenrooms.com/explore/richandrarerestaurant/reservations/create/search?venues=richandrarerestaurant,pompetteau,darkshepherd,yamasgreekdrink,stilts,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant\"\nsource/functions.html:1752:  data-section-theme=\"dark\"\nsource/functions.html:2227:  alt=\"Black background with large white stylized letters 'RR' centered.\"\nsource/functions.html:2275:  overflow: hidden;-webkit-mask-image: -webkit-radial-gradient(white, black);clip-path: none;-webkit-clip-path: none;\nsource/functions.html:2300:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p style=\"text-align:center;white-space:pre-wrap;\" class=\"sqsrte-small\">A new kind of elegance in vibrant West End, Rich and Rare offers a variety of spaces perfect for relaxed revelry.</p></div>\nsource/functions.html:2384:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><div class=\"sqsrte-scaled-text-container\"><span class=\"sqsrte-scaled-text\"><p style=\"text-align:center;white-space:pre-wrap;\" class=\"sqsrte-large\">A Rich &amp; Rare way to celebrate</p></span></div></div>\nsource/functions.html:2479:      href=\"/s/RAR22_RR_Functions_Pack_MAR26-h6pn.pdf\" \nsource/functions.html:2500:      href=\"/s/RAR22_RR_Functions_Pack_MAR26-h6pn.pdf\" \nsource/functions.html:2559:      href=\"/functions/#functions-enquiry\" \nsource/functions.html:2580:      href=\"/functions/#functions-enquiry\" \nsource/functions.html:2654:  data-section-theme=\"dark\"\nsource/functions.html:2877:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><h3 style=\"white-space:pre-wrap;\">Private dining</h3><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\"><em>10 pax seated or 16 pax Canapé.<br><br></em>Here’s where deals are done, memories made and relationships forged. Timber, leather, fine china and tinkling glasses complement a menu of modern classics in a room as welcoming as it is intimate. </p></div>\nsource/functions.html:3044:  alt=\"Elegant dining room with a long table set with white plates, glasses, and napkins, surrounded by beige chairs. Modern hanging pendant lights, white paneled wall, marble backsplash, and a portrait of a woman blowing bubblegum.\"\nsource/functions.html:3092:  overflow: hidden;-webkit-mask-image: -webkit-radial-gradient(white, black);clip-path: none;-webkit-clip-path: none;\nsource/functions.html:3143:  data-section-theme=\"white\"\nsource/functions.html:3164:    white'\nsource/functions.html:3178:    &quot;sectionTheme&quot;: &quot;white&quot;,\nsource/functions.html:3362:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><h2 style=\"white-space:pre-wrap;\">Full venue</h2><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\"><em>130 pax seated or 155 pax Canapé.<br><br></em>Celebrate elegantly with West End energy. An impressive entryway showcasing dry-aged beef and exceptional wine sets the scene for an unforgettable experience. Talk to our team about a bespoke menu bringing together the best of paddock, sea and vineyard to create an event your guests won’t want to end. </p></div>\nsource/functions.html:3577:  overflow: hidden;-webkit-mask-image: -webkit-radial-gradient(white, black);clip-path: none;-webkit-clip-path: none;\nsource/functions.html:3628:  data-section-theme=\"white\"\nsource/functions.html:3647:    white'\nsource/functions.html:3658:    &quot;sectionTheme&quot;: &quot;white&quot;,\nsource/functions.html:3764:      <p class=\"\" style=\"white-space:pre-wrap;\">our Spaces</p>\nsource/functions.html:3845:      &quot;description&quot;: &quot;&lt;p class=\\&quot;\\&quot; style=\\&quot;white-space:pre-wrap;\\&quot;&gt;65-70 pax seated or 80 pax canapé.&lt;\\/p&gt;&quot;,\nsource/functions.html:3847:        &quot;buttonText&quot;: &quot;Make It&quot;\nsource/functions.html:3894:      &quot;description&quot;: &quot;&lt;p class=\\&quot;\\&quot; style=\\&quot;white-space:pre-wrap;\\&quot;&gt;60 pax seated or 75 pax canapé.&lt;\\/p&gt;&quot;,\nsource/functions.html:3896:        &quot;buttonText&quot;: &quot;Click Here&quot;,\nsource/functions.html:3944:      &quot;description&quot;: &quot;&lt;p class=\\&quot;\\&quot; style=\\&quot;white-space:pre-wrap;\\&quot;&gt;15-20 pax seated or 35 pax canapé.&lt;\\/p&gt;&quot;,\nsource/functions.html:3946:        &quot;buttonText&quot;: &quot;Make It&quot;\nsource/functions.html:3993:      &quot;description&quot;: &quot;&lt;p class=\\&quot;\\&quot; style=\\&quot;white-space:pre-wrap;\\&quot;&gt;10 pax seated or 16 pax canapé.&lt;\\/p&gt;&quot;,\nsource/functions.html:3995:        &quot;buttonText&quot;: &quot;Make It&quot;,\nsource/functions.html:4048:      &quot;sectionTheme&quot;: &quot;white&quot;,\nsource/functions.html:4151:    &quot;sectionTitle&quot;: &quot;&lt;p class=\\&quot;\\&quot; style=\\&quot;white-space:pre-wrap;\\&quot;&gt;our Spaces&lt;\\/p&gt;&quot;,\nsource/functions.html:4159:      &quot;buttonText&quot;: &quot;DOWNLOAD FUNCTION PACK&quot;,\nsource/functions.html:4243:          <p class=\"\" style=\"white-space:pre-wrap;\">65-70 pax seated or 80 pax canapé.</p>\nsource/functions.html:4311:          <p class=\"\" style=\"white-space:pre-wrap;\">60 pax seated or 75 pax canapé.</p>\nsource/functions.html:4379:          <p class=\"\" style=\"white-space:pre-wrap;\">15-20 pax seated or 35 pax canapé.</p>\nsource/functions.html:4447:          <p class=\"\" style=\"white-space:pre-wrap;\">10 pax seated or 16 pax canapé.</p>\nsource/functions.html:4485:        href=\"/s/RAR22_RR_Functions_Pack_MAR26-h6pn.pdf\"\nsource/functions.html:4525:  data-section-theme=\"light\"\nsource/functions.html:4806:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p class=\"\" style=\"white-space:pre-wrap;\">Please complete the enquiry form and our functions manager will respond within one business day.</p></div>\nsource/functions.html:4909:    {\"address\":{\"address1\":\"Address 1\",\"address2\":\"Address 2\",\"city\":\"City\",\"country\":\"Country\",\"stateProvince\":\"State/Province\",\"zipPostalCode\":\"Zip/Postal Code\"},\"cannotSubmitDemoForm\":\"This is a demo form and cannot be submitted.\",\"date\":{\"day\":\"Day\",\"dd\":\"DD\",\"mm\":\"MM\",\"month\":\"Month\",\"year\":\"Year\",\"yyyy\":\"YYYY\"},\"email\":{\"required\":\"(required)\",\"signUp\":\"Sign up for news and updates\"},\"formBlock\":{\"learnMore\":\"Learn more\",\"title\":\"Form Block\"},\"invalidData\":\"Invalid form data.\",\"lightbox\":{\"openForm\":\"Open Form\"},\"likert\":{\"agree\":\"Agree\",\"disagree\":\"Disagree\",\"neutral\":\"Neutral\",\"stronglyAgree\":\"Strongly Agree\",\"stronglyDisagree\":\"Strongly Disagree\"},\"name\":{\"firstName\":\"First Name\",\"lastName\":\"Last Name\"},\"noStorageConnectedMessage\":\"This form needs a storage option. Double-click here to edit this form, and tell us where to save form submissions in the <strong>Storage<\\/strong> tab.\",\"notFound\":\"Form not found.\",\"phone\":{\"areaCode\":\"Area Code\",\"country\":\"Country\",\"line\":\"Line\",\"number\":\"Number\",\"prefix\":\"Prefix\"},\"required\":\"(required)\",\"submit\":\"Submit\",\"submitError\":\"Unable to submit form. Please 