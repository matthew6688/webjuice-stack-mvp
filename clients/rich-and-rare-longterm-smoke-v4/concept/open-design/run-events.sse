"/>\n398:    <path d=\"M2 7.24091C5.85455 8.40454 8.81818 10.9318 11 13.8591C13.1818 10.8591 16.1455 8.33181 20 7.24091\"  fill=\"none\" />\n402:    <path d=\"M11.05 7.1591C7.04096 5.60456 1.05005 4.95001 1.05005 4.95001C6.20459 7.89547 9.41368 10.4318 11.05 16.4864C12.6864 10.35 15.8955 7.81365 21.05 4.95001C21.05 4.95001 15.0591 5.60456 11.05 7.1591Z\" />\n810:                    href=\"https://www.sevenrooms.com/explore/richandrarerestaurant/reservations/create/search?venues=richandrarerestaurant,pompetteau,darkshepherd,yamasgreekdrink,stilts,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant\"\n813:                    BOOKINGS\n1175:                    href=\"https://www.sevenrooms.com/explore/richandrarerestaurant/reservations/create/search?venues=richandrarerestaurant,pompetteau,darkshepherd,yamasgreekdrink,stilts,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant\"\n1178:                    BOOKINGS\n1234:                                                                                                                          &quot;href&quot;: &quot;https://www.sevenrooms.com/explore/richandrarerestaurant/reservations/create/search?venues=richandrarerestaurant,pompetteau,darkshepherd,yamasgreekdrink,stilts,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant&quot;,\n1235:                                                                                                                          &quot;buttonText&quot;: &quot;BOOKINGS&quot;,\n1702:                href=\"https://www.sevenrooms.com/explore/richandrarerestaurant/reservations/create/search?venues=richandrarerestaurant,pompetteau,darkshepherd,yamasgreekdrink,stilts,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant\"\n1705:                BOOKINGS\n2650:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p style=\"text-align:center;white-space:pre-wrap;\" class=\"\">Rich flavours. Rare cuts. Real service.</p></div>\n2667:  #block-yui_3_17_2_1_1693374865215_10316 .sqs-html-content {\n2710:          #block-yui_3_17_2_1_1693374865215_10316 .sqs-html-content {\n2734:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><div class=\"sqsrte-scaled-text-container\"><span class=\"sqsrte-scaled-text\"><h1 style=\"text-align:center;white-space:pre-wrap;\">STEAK AND SEAFOOD RESTAURANT, WEST VILLAGE</h1></span></div></div>\n2751:  #block-8d73f0dcd4923bd73292 .sqs-html-content {\n2794:          #block-8d73f0dcd4923bd73292 .sqs-html-content {\n2829:      href=\"https://www.sevenrooms.com/explore/richandrarerestaurant/reservations/create/search?venues=richandrarerestaurant,pompetteau,darkshepherd,yamasgreekdrink,stilts,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant\" \n2850:      href=\"https://www.sevenrooms.com/explore/richandrarerestaurant/reservations/create/search?venues=richandrarerestaurant,pompetteau,darkshepherd,yamasgreekdrink,stilts,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant\" \n3390:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p style=\"text-align:center;white-space:pre-wrap;\" class=\"\">Rich &amp; Rare offers premium fare without pretension. Open your collar, order a whisky and settle in to enjoy succulent, dry-aged steak and freshly caught seafood, nestled in the heart of Brisbane’s vibrant West Village precinct.</p></div>\n3407:  #block-yui_3_17_2_1_1692841050029_8545 .sqs-html-content {\n3450:          #block-yui_3_17_2_1_1692841050029_8545 .sqs-html-content {\n4022:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p style=\"text-align:center;white-space:pre-wrap;\" class=\"\">Business or pleasure - delight your guests with the casual sophistication of Rich &amp; Rare. From an exclusive 10-seater private room, to command of the whole venue, our spaces can work to your needs.</p></div>\n4039:  #block-80427496a470d0f6206a .sqs-html-content {\n4082:          #block-80427496a470d0f6206a .sqs-html-content {\n4529:              <polyline fill=\"none\" stroke-miterlimit=\"10\" points=\"7.3,14.7 2.5,8 7.3,1.2 \"/>\n4538:              <polyline fill=\"none\" stroke-miterlimit=\"10\" points=\"1.6,1.2 6.5,7.9 1.6,14.7 \"/>\n4592:        <path d=\"M4.3,35.7L35.7,4.3\"/>\n4593:        <path d=\"M4.3,4.3l31.4,31.4\"/>\n4796:          <polyline fill=\"none\" stroke-miterlimit=\"10\" points=\"7.3,14.7 2.5,8 7.3,1.2 \"/>\n4805:          <polyline fill=\"none\" stroke-miterlimit=\"10\" points=\"1.6,1.2 6.5,7.9 1.6,14.7 \"/>\n5487:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\"><strong>OPEN 7 DAYS</strong><br>All Day Dining: 11:00am-late</p></div>\n5504:  #block-yui_3_17_2_1_1722823170214_2896 .sqs-html-content {\n5547:          #block-yui_3_17_2_1_1722823170214_2896 .sqs-html-content {\n5571:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\">10% Weekend surcharge (20% on Public Holidays). Card payment surcharge applies.</p></div>\n5588:  #block-c41f2ae0d7d3d617dc63 .sqs-html-content {\n5631:          #block-c41f2ae0d7d3d617dc63 .sqs-html-content {\n5655:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\">FIND US<br>West Village Garden Pavilion<br>97 Boundary Street,<br>West End, Q 4101</p><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\">CAREERS<br><a href=\"/careers\">Employment</a></p><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\"><br>BUSINESS OPPORTUNITIES<br><a href=\"https://www.tassisgroup.com.au/business-opportunities\" target=\"_blank\">Business Opportunities</a></p></div>\n5672:  #block-yui_3_17_2_1_1683680118894_8960 .sqs-html-content {\n5715:          #block-yui_3_17_2_1_1683680118894_896