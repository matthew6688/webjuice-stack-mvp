bne\" target=\"_blank\" aria-label=\"Facebook\">\n1152:                            <use xlink:href=\"#facebook-unauth-icon\" width=\"110\" height=\"110\"></use>\n1528:                href=\"/functions\"\n1534:                  Functions\n1567:                    <a href=\"https://giftcards.nowbookit.com/cards/card-selection?accent=0,0,0&accountid=4843949d-9776-494d-8655-478ef32b5105&theme=light&venueid=10347%C2%A0\" >R&amp;R Gift Voucher</a>\n1574:                    <a href=\"https://giftcards.nowbookit.com/cards/card-selection?accountid=4843949d-9776-494d-8655-478ef32b5105&venueid=14196&theme=light&accent=157,157,157\"  target=\"_blank\" >Tassis Group Gift Voucher</a>\n1694:                      <a class=\"icon icon--lg icon--fill  header-icon header-icon-border-shape-circle header-icon-border-style-outline\"  style=\"box-shadow: 0px 0px 0px 1px inset\" href=\"http://facebook.com/richandrare.bne\" target=\"_blank\" aria-label=\"Facebook\">\n1696:                          <use xlink:href=\"#facebook-unauth-icon\" width=\"110\" height=\"110\"></use>\n2300:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p style=\"text-align:center;white-space:pre-wrap;\" class=\"sqsrte-small\">A new kind of elegance in vibrant West End, Rich and Rare offers a variety of spaces perfect for relaxed revelry.</p></div>\n2317:  #block-yui_3_17_2_1_1696824135934_18523 .sqs-html-content {\n2360:          #block-yui_3_17_2_1_1696824135934_18523 .sqs-html-content {\n2384:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><div class=\"sqsrte-scaled-text-container\"><span class=\"sqsrte-scaled-text\"><p style=\"text-align:center;white-space:pre-wrap;\" class=\"sqsrte-large\">A Rich &amp; Rare way to celebrate</p></span></div></div>\n2401:  #block-022b4fe16584a2d68988 .sqs-html-content {\n2444:          #block-022b4fe16584a2d68988 .sqs-html-content {\n2479:      href=\"/s/RAR22_RR_Functions_Pack_MAR26-h6pn.pdf\" \n2500:      href=\"/s/RAR22_RR_Functions_Pack_MAR26-h6pn.pdf\" \n2559:      href=\"/functions/#functions-enquiry\" \n2580:      href=\"/functions/#functions-enquiry\" \n2877:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><h3 style=\"white-space:pre-wrap;\">Private dining</h3><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\"><em>10 pax seated or 16 pax Canapé.<br><br></em>Here’s where deals are done, memories made and relationships forged. Timber, leather, fine china and tinkling glasses complement a menu of modern classics in a room as welcoming as it is intimate. </p></div>\n2894:  #block-4ed4fe8869be84a953c5 .sqs-html-content {\n2937:          #block-4ed4fe8869be84a953c5 .sqs-html-content {\n3362:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><h2 style=\"white-space:pre-wrap;\">Full venue</h2><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\"><em>130 pax seated or 155 pax Canapé.<br><br></em>Celebrate elegantly with West End energy. An impressive entryway showcasing dry-aged beef and exceptional wine sets the scene for an unforgettable experience. Talk to our team about a bespoke menu bringing together the best of paddock, sea and vineyard to create an event your guests won’t want to end. </p></div>\n3379:  #block-007f67eb1c35f052117a .sqs-html-content {\n3422:          #block-007f67eb1c35f052117a .sqs-html-content {\n3764:      <p class=\"\" style=\"white-space:pre-wrap;\">our Spaces</p>\n3992:      &quot;title&quot;: &quot;Private Dining&quot;,\n4160:      &quot;buttonLink&quot;: &quot;/s/RAR22_RR_Functions_Pack_MAR26-h6pn.pdf&quot;,\n4228:        <h2\n4243:          <p class=\"\" style=\"white-space:pre-wrap;\">65-70 pax seated or 80 pax canapé.</p>\n4296:        <h2\n4311:          <p class=\"\" style=\"white-space:pre-wrap;\">60 pax seated or 75 pax canapé.</p>\n4364:        <h2\n4379:          <p class=\"\" style=\"white-space:pre-wrap;\">15-20 pax seated or 35 pax canapé.</p>\n4432:        <h2\n4435:        >Private Dining</h2>\n4447:          <p class=\"\" style=\"white-space:pre-wrap;\">10 pax seated or 16 pax canapé.</p>\n4485:        href=\"/s/RAR22_RR_Functions_Pack_MAR26-h6pn.pdf\"\n4801:    <h2 id=\"functions-enquiry\">Functions Enquiry</h2>\n4806:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p class=\"\" style=\"white-space:pre-wrap;\">Please complete the enquiry form and our functions manager will respond within one business day.</p></div>\n4823:  #block-yui_3_17_2_1_1713246143314_3142 .sqs-html-content {\n4866:          #block-yui_3_17_2_1_1713246143314_3142 .sqs-html-content {\n4902:    {\"secureUrl\":\"https://guppy-turkey-esm7.squarespace.com\",\"collectionId\":\"64e6e86022513e4b25dca1a3\",\"formFieldFormats\":{\"initialNameOrder\":\"GIVEN_FIRST\",\"initialAddressFormat\":{\"id\":0,\"type\":\"ADDRESS\",\"country\":\"AU\",\"labelLocale\":\"en\",\"fields\":[{\"type\":\"FIELD\",\"label\":\"Address Line 1\",\"identifier\":\"Line1\",\"length\":0,\"required\":true,\"metadata\":{\"autocomplete\":\"address-line1\"}},{\"type\":\"SEPARATOR\",\"label\":\"\\n\",\"identifier\":\"Newline\",\"length\":0,\"required\":false,\"metadata\":{}},{\"type\":\"FIELD\",\"label\":\"Address Line 2\",\"identifier\":\"Line2\",\"length\":0,\"required\":false,\"metadata\":{\"autocomplete\":\"address-line2\"}},{\"type\":\"SEPARATOR\",\"label\":\"\\n\",\"identifier\":\"Newline\",\"length\":0,\"required\":false,\"metadata\":{}},{\"type\":\"FIELD\",\"label\":\"Suburb\",\"identifier\":\"City\",\"length\":0,\"required\":true,\"metadata\":{\"autocomplete\":\"address-level2\"}},{\"type\":\"SEPARATOR\",\"label\":\" \",\"identifier\":\"Space\",\"length\":0,\"required\":false,\"metadata\":{}},{\"type\":\"FIELD\",\"label\":\"State\",\"identifier\":\"State\",\"length\":0,\"required\":true,\"metadata\":{\"autocomplete\":\"address-level1\"}},{\"type\":\"SEPARATOR\",\"label\":\" \",\"identifier\":\"Space\",\"length\":0,\"required\":false,\"metadata\":{}},{\"type\":\"FIELD\",\"label\":\"Postcode\",\"identifier\":\"Zip\",\"length\":0,\"required