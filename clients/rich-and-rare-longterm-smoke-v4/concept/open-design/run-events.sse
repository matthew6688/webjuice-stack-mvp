x-shadow: 0px 0px 0px 1px inset\" href=\"http://facebook.com/richandrare.bne\" target=\"_blank\" aria-label=\"Facebook\">\nsource/home.html:1689:                          <use xlink:href=\"#facebook-unauth-icon\" width=\"110\" height=\"110\"></use>\nsource/home.html:1699:            <div class=\"header-menu-cta\">\nsource/home.html:1702:                href=\"https://www.sevenrooms.com/explore/richandrarerestaurant/reservations/create/search?venues=richandrarerestaurant,pompetteau,darkshepherd,yamasgreekdrink,stilts,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant\"\nsource/home.html:2650:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p style=\"text-align:center;white-space:pre-wrap;\" class=\"\">Rich flavours. Rare cuts. Real service.</p></div>\nsource/home.html:2667:  #block-yui_3_17_2_1_1693374865215_10316 .sqs-html-content {\nsource/home.html:2710:          #block-yui_3_17_2_1_1693374865215_10316 .sqs-html-content {\nsource/home.html:2734:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><div class=\"sqsrte-scaled-text-container\"><span class=\"sqsrte-scaled-text\"><h1 style=\"text-align:center;white-space:pre-wrap;\">STEAK AND SEAFOOD RESTAURANT, WEST VILLAGE</h1></span></div></div>\nsource/home.html:2751:  #block-8d73f0dcd4923bd73292 .sqs-html-content {\nsource/home.html:2794:          #block-8d73f0dcd4923bd73292 .sqs-html-content {\nsource/home.html:2829:      href=\"https://www.sevenrooms.com/explore/richandrarerestaurant/reservations/create/search?venues=richandrarerestaurant,pompetteau,darkshepherd,yamasgreekdrink,stilts,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant\" \nsource/home.html:2850:      href=\"https://www.sevenrooms.com/explore/richandrarerestaurant/reservations/create/search?venues=richandrarerestaurant,pompetteau,darkshepherd,yamasgreekdrink,stilts,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant\" \nsource/home.html:3390:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p style=\"text-align:center;white-space:pre-wrap;\" class=\"\">Rich &amp; Rare offers premium fare without pretension. Open your collar, order a whisky and settle in to enjoy succulent, dry-aged steak and freshly caught seafood, nestled in the heart of Brisbane’s vibrant West Village precinct.</p></div>\nsource/home.html:3407:  #block-yui_3_17_2_1_1692841050029_8545 .sqs-html-content {\nsource/home.html:3450:          #block-yui_3_17_2_1_1692841050029_8545 .sqs-html-content {\nsource/home.html:3485:      href=\"/menus\" \nsource/home.html:3506:      href=\"/menus\" \nsource/home.html:4022:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p style=\"text-align:center;white-space:pre-wrap;\" class=\"\">Business or pleasure - delight your guests with the casual sophistication of Rich &amp; Rare. From an exclusive 10-seater private room, to command of the whole venue, our spaces can work to your needs.</p></div>\nsource/home.html:4039:  #block-80427496a470d0f6206a .sqs-html-content {\nsource/home.html:4082:          #block-80427496a470d0f6206a .sqs-html-content {\nsource/home.html:5452:            href=\"https://www.instagram.com/richandrare_brisbane/\"\nsource/home.html:5454:            class=\"sqs-svg-icon--wrapper instagram-unauth\"\nsource/home.html:5459:                <use class=\"sqs-use--icon\" xlink:href=\"/universal/svg/social-accounts.svg#instagram-unauth-icon\"></use>\nsource/home.html:5460:                <use class=\"sqs-use--mask\" xlink:href=\"/universal/svg/social-accounts.svg#instagram-unauth-mask\"></use>\nsource/home.html:5468:            href=\"http://facebook.com/richandrare.bne\"\nsource/home.html:5470:            class=\"sqs-svg-icon--wrapper facebook-unauth\"\nsource/home.html:5475:                <use class=\"sqs-use--icon\" xlink:href=\"/universal/svg/social-accounts.svg#facebook-unauth-icon\"></use>\nsource/home.html:5476:                <use class=\"sqs-use--mask\" xlink:href=\"/universal/svg/social-accounts.svg#facebook-unauth-mask\"></use>\nsource/home.html:5487:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\"><strong>OPEN 7 DAYS</strong><br>All Day Dining: 11:00am-late</p></div>\nsource/home.html:5504:  #block-yui_3_17_2_1_1722823170214_2896 .sqs-html-content {\nsource/home.html:5547:          #block-yui_3_17_2_1_1722823170214_2896 .sqs-html-content {\nsource/home.html:5571:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\">10% Weekend surcharge (20% on Public Holidays). Card payment surcharge applies.</p></div>\nsource/home.html:5588:  #block-c41f2ae0d7d3d617dc63 .sqs-html-content {\nsource/home.html:5631:          #block-c41f2ae0d7d3d617dc63 .sqs-html-content {\nsource/home.html:5655:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\">FIND US<br>West Village Garden Pavilion<br>97 Boundary Street,<br>West End, Q 4101</p><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\">CAREERS<br><a href=\"/careers\">Employment</a></p><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\"><br>BUSINESS OPPORTUNITIES<br><a href=\"https://www.tassisgroup.com.au/business-opportunities\" target=\"_blank\">Business Opportunities</a></p></div>\nsource/home.html:5672:  #block-yui_3_17_2_1_1683680118894_8960 .sqs-html-content {\nsource/home.html:5715:          #block-yui_3_17_2_1_1683680118894_8960 .sqs-html-content {\nsource/home.html:5789:      <h2 class=\"newsletter-form-header-title\">Subscribe</h2>\nsource/home.html:5790:      <div class=\"newsletter-form-header-description\"><p class=\"\" style=\"white-space:pre-wrap;\">Sign up to receive news and updates.</p></div>\nsource/home.html:5828:    <div class=\"newsletter-form-footnote\"><p class=\"\" data-rte-preserve-empty=\"true\" st