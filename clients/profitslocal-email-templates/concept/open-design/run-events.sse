data: {"type":"text_delta","delta":"Got it — high-fidelity ProfitsLocal transactional email template system. Tell me the remaining constraints:  \n<question-form id=\"discovery\" title=\"Quick brief — 30 seconds\">\n{\n  \"description\": \"I'll lock these in before building. Skip what doesn't apply — I'll fill defaults.\",\n  \"questions\": [\n    {\n      \"id\": \"platform\",\n      \"label\": \"Primary surface\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Desktop email clients\",\n        \"Mobile email clients\",\n        \"Responsive email — all sizes\",\n        \"Fixed preview canvas\"\n      ]\n    },\n    {\n      \"id\": \"audience\",\n      \"label\": \"Who receives these emails?\",\n      \"type\": \"text\",\n      \"placeholder\": \"e.g. local business owners, agency internal team, both\"\n    },\n    {\n      \"id\": \"email_examples\",\n      \"label\": \"Which states should be mocked first?\",\n      \"type\": \"checkbox\",\n      \"maxSelections\": 4,\n      \"options\": [\n        \"Payment received\",\n        \"Dev preview ready\",\n        \"Approval / revision / domain links\",\n        \"Domain setup status\",\n        \"Internal lead notification\",\n        \"Asset upload notification\"\n      ]\n    },\n    {\n      \"id\": \"brand\",\n      \"label\": \"Brand context\",\n      \"type\": \"radio\",\n      \"required\": true,\n      \"options\": [\n        \"Match a reference site / screenshot\",\n        \"I have a brand spec — I'll share it\",\n        \"Pick a direction for me\"\n      ]\n    },\n    {\n      \"id\": \"scale\",\n      \"label\": \"How much should the system include?\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"3 examples + component handoff\",\n        \"5 examples + component handoff\",\n        \"All listed email examples + component handoff\"\n      ]\n    },\n    {\n      \"id\": \"constraints\",\n      \"label\": \"Anything else I should know?\",\n      \"type\": \"textarea\",\n      \"placeholder\": \"Exact sender names, footer legal text, Resend/React Email preferences, copy to preserve…\"\n    }\n  ]\n}\n</question-form>"}

