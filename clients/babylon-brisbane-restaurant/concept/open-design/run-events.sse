data: {"type":"tool_result","toolUseId":"item_38","content":"387:        <a class=\"nav-cta\" href=\"https://www.sevenrooms.com/explore/babylonbrisbane/reservations/create/search?tracking=babylon-brisbane-widget&amp;venues=babylonbrisbane%2Cfridaysbrisbane%2Cregattahotel%2Ctheboatshed%2Cdeathandcobris%2Ctheboundaryhotelaus%2Cportoffice%2Cjimmysonthemall%2Cpignwhistleriverside%2Criverlandbrisbane\">Book a table</a>\n402:              <a class=\"btn btn-primary\" href=\"https://www.sevenrooms.com/explore/babylonbrisbane/reservations/create/search?tracking=babylon-brisbane-widget&amp;venues=babylonbrisbane%2Cfridaysbrisbane%2Cregattahotel%2Ctheboatshed%2Cdeathandcobris%2Ctheboundaryhotelaus%2Cportoffice%2Cjimmysonthemall%2Cpignwhistleriverside%2Criverlandbrisbane\">Book a table</a>\n418:          <a class=\"choice\" href=\"https://www.sevenrooms.com/explore/babylonbrisbane/reservations/create/search?tracking=babylon-brisbane-widget&amp;venues=babylonbrisbane%2Cfridaysbrisbane%2Cregattahotel%2Ctheboatshed%2Cdeathandcobris%2Ctheboundaryhotelaus%2Cportoffice%2Cjimmysonthemall%2Cpignwhistleriverside%2Criverlandbrisbane\">\n430:          <a class=\"choice\" href=\"https://my.matterport.com/show/?m=1rxMmuuhByW\">\n434:          <a class=\"choice\" href=\"https://thepassapp.com.au/the-pass-gift-cards/\">\n551:            <a class=\"btn btn-primary\" href=\"https://babylonbrisbane.com.au/functions/\">Function enquiry</a>\n582:            <a class=\"btn btn-primary\" href=\"tel:+61731866655\">(07) 3186 6655</a>\n583:            <a class=\"btn btn-secondary\" href=\"mailto:info@babylonbrisbane.com.au\">Email us</a>\n604:        <a class=\"btn btn-primary\" href=\"https://links.thepassapp.com.au/mwsQzm6WL2b\">Download the app</a>\n619:        <a href=\"https://thepassapp.com.au/the-pass-gift-cards/\">Gift Vouchers</a>\n","isError":false}

