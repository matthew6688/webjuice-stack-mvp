data: {"type":"tool_result","toolUseId":"item_29","content":"61:<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\n102:                Win big this May with a prize valued up to $7k - <a href=\"https://links.thepassapp.com.au/mwsQzm6WL2b\" target=\"_blank\">Download the app</a>                <span class=\"c-notification-close-icon\" data-close></span>\n118:<li class=\"c-navigation__item c-navigation__item--type-post_type c-navigation__item--object-page functions\"><a href=\"https://babylonbrisbane.com.au/functions/\"role=\"link\"class=\"c-navigation__link\" tabindex=\"0\">Functions</a></li>\n132:<li class=\"c-navigation__item c-navigation__item--type-post_type c-navigation__item--object-page functions\"><a href=\"https://babylonbrisbane.com.au/functions/\"role=\"link\"class=\"c-navigation__link\" tabindex=\"0\">Functions</a></li>\n139:                <a class=\"c-button c-button--outline-light\" href=\"#function\" data-modal-open>\n166:<li class=\"c-navigation__item c-navigation__item--type-post_type c-navigation__item--object-page functions\"><a href=\"https://babylonbrisbane.com.au/functions/\"role=\"link\"class=\"c-navigation__link\" tabindex=\"0\">Functions</a></li>\n181:<li class=\"c-navigation__item c-navigation__item--type-post_type c-navigation__item--object-page functions\"><a href=\"https://babylonbrisbane.com.au/functions/\"role=\"link\"class=\"c-navigation__link\" tabindex=\"0\">Functions</a></li>\n188:                <a class=\"c-button c-button--outline-light\" href=\"#function\" data-modal-open>\n240:<li class=\"c-navigation__item c-navigation__item--type-post_type c-navigation__item--object-page functions\"><a href=\"https://babylonbrisbane.com.au/functions/\"role=\"link\"class=\"c-navigation__link\" tabindex=\"0\">Functions</a></li>\n266:<li class=\"c-navigation__item c-navigation__item--type-custom c-navigation__item--object-custom giftvouchers\"><a href=\"https://thepassapp.com.au/the-pass-gift-cards/\"role=\"link\"class=\"c-navigation__link\" tabindex=\"0\">Gift Vouchers</a></li>\n267:<li class=\"c-navigation__item c-navigation__item--type-custom c-navigation__item--object-custom loyaltyprogram\"><a href=\"https://thepassapp.com.au/sign-up/?utm_source=venue-site&#038;utm_medium=referral&#038;utm_content=footer\"role=\"link\"class=\"c-navigation__link\" tabindex=\"0\">Loyalty Program</a></li>\n379:                View the menu                            <span class=\"c-link--icon-image__arrow\"><svg width=\"16\" height=\"15\" viewBox=\"0 0 16 15\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\" focusable=\"false\">\n388:                                <a class=\"c-link--icon-image c-link--icon-image\" href=\"https://babylonbrisbane.com.au/functions/\" >\n394:                Host a function                            <span class=\"c-link--icon-image__arrow\"><svg width=\"16\" height=\"15\" viewBox=\"0 0 16 15\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\" focusable=\"false\">\n403:                                <a class=\"c-link--icon-image c-link--icon-image external\" href=\"https://my.matterport.com/show/?m=1rxMmuuhByW\" target='_blank'>\n411:                Take a 3D tour                    <span class=\"c-link--icon-image__external\">\n425:                                <a class=\"c-link--icon-image c-link--icon-image external\" href=\"https://thepassapp.com.au/the-pass-gift-cards/\" target='_blank'>\n431:                Purchase a gift voucher                    <span class=\"c-link--icon-image__external\">\n536:                                        <a href=\"https://babylonbrisbane.com.au/events/corporate-taste-menu/\" class=\"c-carousel-event-card__link\">Corporate Taste Menu</a>\n596:                    <div class=\"c-block-text-image__description\"><p>Inspired by the rich culinary heritage of the Levant, our menu celebrates bold spices, wood-fired meats and generous shared plates. From land and sea, each dish is thoughtfully prepared over charcoal grills and open flames, delivering depth and flavour in every bite. Indulge in slow-cooked lamb, wood-roasted vegetables, fire-kissed seafood and house-made baklava — all served with genuine warmth and care.</p>\n630:                    <div class=\"c-block-text-image__description\"><p>Discover a lush, two-tiered bar and terrace offering panoramic views and a relaxed, alfresco atmosphere. With space for up to 500 guests, this outdoor terrace is ideal for sun-drenched cocktails, late-night gatherings, and spontaneous celebrations. The menu features Middle Eastern and East Mediterranean-inspired bites, best enjoyed with a curated wine list, signature cocktails, and a breeze off the Brisbane River.</p>\n664:                    <div class=\"c-block-text-image__description\"><p>Whether you&#8217;re planning a corporate event, milestone celebration or an intimate gathering, Babylon Brisbane offers versatile function spaces designed to impress.</p>\n670:                                            <p class=\"mt-5\">    <a class=\" c-button\" href=\"https://babylonbrisbane.com.au/functions/\" >\n948:<li class=\"c-navigation__item c-navigation__item--type-custom c-navigation__item--object-custom giftvouchers\"><a href=\"https://thepassapp.com.au/the-pass-gift-cards/\"role=\"link\"class=\"c-navigation__link\" tabindex=\"0\">Gift Vouchers</a></li>\n949:<li class=\"c-navigation__item c-navigation__item--type-custom c-navigation__item--object-custom loyaltyprogram\"><a href=\"https://thepassapp.com.au/sign-up/?utm_source=venue-site&#038;utm_medium=referral&#038;utm_content=footer\"role=\"link\"class=\"c-navigation__link\" tabindex=\"0\">Loyalty Program</a></li>\n1081:<div id=\"function\" class=\"c-modal-hider\">\n1082:            <div id=\"mgl-function\" data-modal-form-id=\"mf691cffa270b22\">\n1105:        function handleFormLoadError() {\n1116:        function handleFormLoadError() {\n1123:    <div class=\"c-modal-form c-modal-form--function\" data-mgl-ap