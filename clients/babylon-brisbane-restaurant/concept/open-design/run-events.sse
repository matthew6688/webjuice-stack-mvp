data: {"type":"tool_result","toolUseId":"item_9","content":"10:            <link rel=\"icon\" type=\"image/png\" sizes=\"96x96\" href=\"https://babylonbrisbane.com.au/wp-content/themes/frank-child/dist/images/favicons/favicon-96x96.png\">\n11:        <link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"https://babylonbrisbane.com.au/wp-content/themes/frank-child/dist/images/favicons/apple-touch-icon.png\">\n12:        <link rel=\"icon\" type=\"image/svg+xml\" href=\"https://babylonbrisbane.com.au/wp-content/themes/frank-child/dist/images/favicons/favicon.svg\" />\n13:        <link rel=\"shortcut icon\" href=\"https://babylonbrisbane.com.au/wp-content/themes/frank-child/dist/images/favicons/favicon.ico\" />\n14:        <link rel=\"manifest\" href=\"https://babylonbrisbane.com.au/wp-content/themes/frank-child/dist/images/favicons/site.webmanifest\">\n15:        <meta name=\"theme-color\" content=\"#ffffff\">\n31:\t<script type=\"application/ld+json\" class=\"yoast-schema-graph\">{\"@context\":\"https:\\/\\/schema.org\",\"@graph\":[{\"@type\":\"WebPage\",\"@id\":\"https:\\/\\/babylonbrisbane.com.au\\/\",\"url\":\"https:\\/\\/babylonbrisbane.com.au\\/\",\"name\":\"Babylon Brisbane | Middle Eastern Restaurant & Riverside Bar\",\"isPartOf\":{\"@id\":\"https:\\/\\/babylonbrisbane.com.au\\/#website\"},\"about\":{\"@id\":\"https:\\/\\/babylonbrisbane.com.au\\/#organization\"},\"datePublished\":\"2020-01-21T22:11:37+00:00\",\"dateModified\":\"2026-02-23T00:35:49+00:00\",\"description\":\"Experience Middle Eastern dining at Babylon Brisbane. Share plates, riverside cocktails and terrace dining in a vibrant CBD setting.\",\"breadcrumb\":{\"@id\":\"https:\\/\\/babylonbrisbane.com.au\\/#breadcrumb\"},\"inLanguage\":\"en-AU\",\"potentialAction\":[{\"@type\":\"ReadAction\",\"target\":[\"https:\\/\\/babylonbrisbane.com.au\\/\"]}]},{\"@type\":\"BreadcrumbList\",\"@id\":\"https:\\/\\/babylonbrisbane.com.au\\/#breadcrumb\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,