data: {"type":"tool_result","toolUseId":"item_11","content":"\r  0     0    0     0    0     0      0      0 --:--:-- --:--:-- --:--:--     0\r100  198k    0  198k    0     0   194k      0 --:--:--  0:00:01 --:--:--  194k\n2:<html xmlns:og=\"http://opengraphprotocol.org/schema/\" xmlns:fb=\"http://www.facebook.com/2008/fbml\" lang=\"en-AU\"  >\n9:<title>Main Menu &mdash; Dark Shepherd Restaurant</title>\n12:<meta property=\"og:site_name\" content=\"Dark Shepherd Restaurant\"/>\n13:<meta property=\"og:title\" content=\"Main Menu &mdash; Dark Shepherd Restaurant\"/>\n16:<meta property=\"og:description\" content=\"Delve into Dark Shepherd’s main menu at The Star Brisbane. Enjoy Mediterranean-inspired dishes with premium lamb, fresh seafood, and woodfired creations that celebrate bold flavours and expert craftsmanship.\"/>\n17:<meta itemprop=\"name\" content=\"Main Menu — Dark Shepherd Restaurant\"/>\n19:<meta itemprop=\"description\" content=\"Delve into Dark Shepherd’s main menu at The Star Brisbane. Enjoy Mediterranean-inspired dishes with premium lamb, fresh seafood, and woodfired creations that celebrate bold flavours and expert craftsmanship.\"/>\n20:<meta name=\"twitter:title\" content=\"Main Menu — Dark Shepherd Restaurant\"/>\n23:<meta name=\"twitter:description\" content=\"Delve into Dark Shepherd’s main menu at The Star Brisbane. Enjoy Mediterranean-inspired dishes with premium lamb, fresh seafood, and woodfired creations that celebrate bold flavours and expert craftsmanship.\"/>\n24:<meta name=\"description\" content=\"Delve into Dark Shepherd’s main menu at The Star Brisbane. Enjoy Mediterranean-inspired dishes with premium lamb, fresh seafood, and woodfired creations that celebrate bold flavours and expert craftsmanship.\" />\n34:<script data-name=\"static-context\">Static = window.Static || {}; Static.SQUARESPACE_CONTEXT = {\"betaFeatureFlags\":[\"campaigns_thumbnail_layout\",\"output_template_css_assets\",\"campaigns_import_discounts\",\"campaigns_merch_