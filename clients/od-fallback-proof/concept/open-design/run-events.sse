data: {"type":"tool_result","toolUseId":"item_40","content":"<!doctype html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Dark Shepherd · Mediterranean Restaurant at The Star Brisbane</title>\n  <style>\n    :root {\n      --bg:      oklch(15% 0.004 260);\n      --surface: oklch(20% 0.004 260);\n      --fg:      oklch(95% 0.008 80);\n      --muted:   oklch(72% 0.015 80);\n      --border:  oklch(34% 0.006 260);\n      --accent:  oklch(63% 0.19 31);\n\n      --accent-soft: color-mix(in oklch, var(--accent) 15%, transparent);\n      --fg-soft:     color-mix(in oklch, var(--fg) 7%, transparent);\n\n      --font-display: 'Iowan Old Style', 'Times New Roman', Georgia, serif;\n      --font-body:    -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;\n      --font-mono:    ui-monospace, 'JetBrains Mono', 'SF Mono', Menlo, monospace;\n\n      --fs-h1: clamp(52px, 8vw, 116px);\n      --fs-h2: clamp(34px, 5vw, 64px);\n      --fs-h3: 22px;\n      --fs-lead: 19px;\n      --fs-body: 16px;\n      --fs-meta: 12px;\n\n      --gap-xs: 8px;\n      --gap-sm: 12px;\n      --gap-md: 20px;\n      --gap-lg: 32px;\n      --gap-xl: 56px;\n      --gap-2xl: 96px;\n      --container: 1180px;\n      --gutter: 32px;\n      --radius: 2px;\n      --radius-lg: 2px;\n    }\n\n    *, *::before, *::after { box-sizing: border-box; }\n    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }\n    body {\n      margin: 0;\n      background: var(--bg);\n      color: var(--fg);\n      font-family: var(--font-body);\n      font-size: var(--fs-body);\n      line-height: 1.55;\n      text-rendering: optimizeLegibility;\n      -webkit-font-smoothing: antialiased;\n    }\n    img, svg { display: block; max-width: 100%; }\n    a { color: inherit; text-decoration: none; }\n    button { font: inherit; cursor: pointer; }\n    p { text-wrap: pretty; }\n    h1, h2, h3, h4 { text-wrap: balance; text-transform: uppercase; }\n\n    .container { max-width: var(--container); margin-inline: auto; padding-inline: var(--gutter); }\n    .section { padding-block: clamp(58px, 8vw, var(--gap-2xl)); }\n    .section + .section { border-top: 1px solid var(--border); }\n    .stack { display: flex; flex-direction: column; }\n    .stack > * + * { margin-top: var(--gap-md); }\n    .row { display: flex; align-items: center; gap: var(--gap-md); }\n    .row-between { display: flex; align-items: center; justify-content: space-between; gap: var(--gap-md); }\n    .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--gap-lg); }\n    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap-lg); }\n    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--gap-md); }\n    .grid-2-1 { display: grid; grid-template-columns: 2fr 1fr; gap: var(--gap-xl); align-items: start; }\n    .grid-1-2 { display: grid; grid-template-columns: 1fr 2fr; gap: var(--gap-xl); align-items: start; }\n    @media (max-width: 920px) {\n      .grid-2, .grid-3, .grid-4, .grid-2-1, .grid-1-2 { grid-template-columns: 1fr; }\n      .topnav nav { display: none; }\n      .hero-split { min-height: auto; }\n    }\n\n    .h1, h1 { font-family: var(--font-display); font-size: var(--fs-h1); line-height: 0.9; letter-spacing: 0; margin: 0; }\n    .h2, h2 { font-family: var(--font-display); font-size: var(--fs-h2); line-height: 0.98; letter-spacing: 0; margin: 0; }\n    .h3, h3 { font-family: var(--font-display); font-size: var(--fs-h3); font-weight: 600; line-height: 1.15; letter-spacing: 0; margin: 0; }\n    .lead { font-size: var(--fs-lead); line-height: 1.55; color: var(--muted); max-width: 58ch; margin: 0; }\n    .eyebrow {\n      font-family: var(--font-mono);\n      font-size: 12px;\n      letter-spacing: 0.08em;\n      text-transform: uppercase;\n      color: var(--muted);\n      margin: 0 0 var(--gap-md);\n    }\n    .meta { font-family: var(--font-mono); font-size: var(--fs-meta); color: var(--muted); letter-spacing: 0.04em; text-transform: uppercase; }\n    .num { font-family: var(--font-mono); font-variant-numeric: tabular-nums; }\n\n    .topnav {\n      position: sticky;\n      top: 0;\n      z-index: 10;\n      background: color-mix(in oklch, var(--bg) 88%, transparent);\n      backdrop-filter: blur(14px);\n      border-bottom: 1px solid var(--border);\n    }\n    .topnav-inner { display: flex; align-items: center; justify-content: space-between; padding-block: 16px; }\n    .topnav .logo img { width: 178px; height: auto; }\n    .topnav nav { gap: 24px; }\n    .topnav nav a { font-size: 12px; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; }\n    .topnav nav a:hover { color: var(--fg); }\n    .pagefoot { padding-block: var(--gap-xl); color: var(--muted); font-size: 13px; border-top: 1px solid var(--border); }\n    .pagefoot .row-between { flex-wrap: wrap; gap: var(--gap-md); }\n\n    .btn {\n      display: inline-flex; align-items: center; justify-content: center; gap: 8px;\n      min-height: 44px;\n      padding: 12px 22px;\n      border-radius: var(--radius);\n      border: 1px solid transparent;\n      font-size: 12px;\n      font-weight: 650;\n      letter-spacing: 0.1em;\n      text-transform: uppercase;\n      transition: transform 0.05s ease, background 0.15s ease, border-color 0.15s ease, color 0.15s ease;\n    }\n    .btn:active { transform: translateY(1px); }\n    .btn-primary { background: var(--accent); color: var(--fg); border-color: var(--accent); }\n    .btn-primary:hover { background: color-mix(in oklch, var(--accent) 88%, var(--fg)); color: var(--bg); }\n    .btn-secondary { background: transparent; color: var(--fg); border-color: var(--border); }\n    .btn-secondary:hover { border-color: var(--fg); }\n    .btn-ghost { background: transparent; color: var(--fg); border-color: transparent; padding-inline: 8px; }\n    .btn-ghost:hover { color: var(--muted); }\n    .btn-arrow::after { content: '>'; transition: transform 0.15s ease; }\n    .btn-arrow:hover::after { transform: translateX(2px); }\n\n    .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 28px; }\n    .card-flat { background: transparent; border: 0; padding: 0; }\n    .card-rule { background: transparent; border: 0; border-top: 1px solid var(--fg); padding: 24px 0 0; border-radius: 0; }\n    .feature .feature-mark {\n      width: 36px; height: 36px; display: grid; place-items: center;\n      border: 1px solid var(--border); border-radius: var(--radius); color: var(--muted); margin-bottom: var(--gap-md);\n    }\n    .feature .feature-mark svg { width: 18px; height: 18px; }\n    .feature h3 { margin-bottom: 8px; }\n    .feature p { margin: 0; color: var(--muted); font-size: 15px; }\n    .stat .stat-num {\n      font-family: var(--font-display);\n      font-size: clamp(56px, 8vw, 96px);\n      line-height: 0.95;\n      letter-spacing: 0;\n      color: var(--fg);\n      font-weight: 600;\n    }\n    .stat .stat-label { color: var(--muted); font-size: 14px; margin-top: 8px; max-width: 24ch; }\n    .quote { font-family: var(--font-display); font-size: clamp(24px, 2.8vw, 38px); line-height: 1.22; max-width: 31ch; text-transform: uppercase; }\n    .quote-author { color: var(--muted); font-size: 14px; margin-top: var(--gap-md); }\n    .quote-mark { font-family: var(--font-display); font-size: 128px; line-height: 0.7; color: var(--fg); opacity: 0.12; margin-bottom: -20px; }\n    .pill {\n      display: inline-flex; align-items: center; gap: 6px;\n      padding: 5px 11px;\n      background: var(--accent-soft);\n      color: var(--fg);\n      border-radius: 999px;\n      font-family: var(--font-mono);\n      font-size: 11px;\n      letter-spacing: 0.04em;\n      text-transform: uppercase;\n    }\n    .tag {\n      display: inline-flex; align-items: center;\n      padding: 5px 10px;\n      background: transparent;\n      color: var(--muted);\n      border: 1px solid var(--border);\n      border-radius: 999px;\n      font-size: 12px;\n    }\n    .field { display: flex; flex-direction: column; gap: 6px; }\n    .field label { font-size: 13px; color: var(--muted); }\n    .input, .textarea {\n      width: 100%; padding: 12px 14px; border: 1px solid var(--border); border-radius: var(--radius);\n      background: transparent; color: var(--fg); font: inherit; font-size: 15px;\n    }\n    .input:focus, .textarea:focus { outline: 2px solid var(--accent-soft); border-color: var(--accent); }\n    .textarea { min-height: 96px; resize: vertical; line-height: 1.55; }\n    .ds-table { width: 100%; border-collapse: collapse; font-size: 14px; }\n    .ds-table th, .ds-table td { padding: 13px 0; text-align: left; border-bottom: 1px solid var(--border); }\n    .ds-table th { color: var(--muted); font-weight: 500; font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.04em; text-transform: uppercase; }\n    .ds-table tbody tr:hover { background: var(--fg-soft); }\n    .ds-table .num-col { font-family: var(--font-mono); font-variant-numeric: tabular-nums; text-align: right; }\n    .ph-img {\n      background:\n        linear-gradient(135deg, var(--accent-soft), var(--fg-soft)),\n        var(--surface);\n      border: 1px solid var(--border);\n      min-height: 260px;\n      display: grid;\n      place-items: center;\n      color: var(--muted);\n      font-family: var(--font-mono);\n      font-size: 12px;\n      text-transform: uppercase;\n      letter-spacing: 0.08em;\n    }\n    .square { aspect-ratio: 1 / 1; }\n    .portrait { aspect-ratio: 4 / 5; }\n    .wide { aspect-ratio: 16 / 9; }\n    .rule { border-top: 1px solid var(--border); padding-top: var(--gap-md); }\n    .rule-strong { border-top: 1px solid var(--fg); padding-top: var(--gap-md); }\n    .hero { min-height: calc(100svh - 78px); display: grid; align-items: center; }\n    .hero-center { text-align: center; display: grid; justify-items: center; }\n    .hero-split { display: grid; grid-template-columns: minmax(0, 0.85fr) minmax(360px, 1.15fr); gap: var(--gap-xl); align-items: center; min-height: calc(100svh - 78px); }\n    .hero-cta { display: flex; gap: var(--gap-sm); flex-wrap: wrap; align-items: center; }\n    .log-row {\n      display: grid;\n      grid-template-columns: 140px 1fr 120px;\n      gap: var(--gap-lg);\n      padding: 22px 0;\n      border-top: 1px solid var(--border);\n      align-items: start;\n    }\n    .pull { justify-self: end; }\n    .media-card { position: relative; overflow: hidden; border: 1px solid var(--border); background: var(--surface); }\n    .media-card img { width: 100%; height: 100%; object-fit: cover; filter: saturate(0.88) contrast(1.04); }\n    .media-caption {\n      position: absolute;\n      inset: auto 18px 18px 18px;\n      border-top: 1px solid color-mix(in oklch, var(--fg) 42%, transparent);\n      padding-top: 12px;\n      color: var(--fg);\n      font-family: var(--font-mono);\n      font-size: 11px;\n      letter-spacing: 0.07em;\n      text-transform: uppercase;\n    }\n    .brand-mark { width: clamp(120px, 14vw, 190px); opacity: 0.9; margin-bottom: 28px; }\n    .hero-lockup { max-width: 780px; }\n    .hero-lockup h1 { margin-top: 4px; }\n    .hero-note { margin-top: 26px; color: var(--muted); max-width: 49ch; }\n    .menu-card { border-top: 1px solid var(--fg); padding-top: 18px; }\n    .menu-card h3 { margin-bottom: 12px; }\n    .menu-card ul { margin: 0; padding: 0; list-style: none; color: var(--muted); }\n    .menu-card li { padding: 8px 0; border-bottom: 1px solid var(--border); }\n    .visit-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: var(--gap-lg); }\n    @media (max-width: 920px) {\n      .hero-split { grid-template-columns: 1fr; }\n      .log-row { grid-template-columns: 1fr; gap: 8px; }\n      .pull { justify-self: start; }\n      .visit-grid { grid-template-columns: 1fr; }\n      .brand-mark { width: 120px; }\n    }\n  </style>\n</head>\n<body>\n  <header class=\"topnav\">\n    <div class=\"container topnav-inner\">\n      <a class=\"logo\" href=\"#home\" aria-label=\"Dark Shepherd home\">\n        <img src=\"assets/dark-shepherd-logo.webp\" alt=\"Dark Shepherd\" />\n      </a>\n      <nav class=\"row\" aria-label=\"Primary\">\n        <a href=\"menu.html\">Menus</a>\n        <a href=\"#banquets\">Banquets</a>\n        <a href=\"#drinks\">Drinks</a>\n        <a href=\"functions.html\">Functions</a>\n        <a href=\"#visit\">Contact</a>\n      </nav>\n      <a class=\"btn btn-primary\" href=\"https://www.sevenrooms.com/explore/darkshepherd/reservations/create/search?venues=darkshepherd,pompetteau,yamasgreekdrink,stilts,richandrarerestaurant,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant\">Bookings</a>\n    </div>\n  </header>\n\n  <main id=\"content\">\n    <section class=\"section hero\" id=\"home\" data-od-id=\"hero\">\n      <div class=\"container hero-split\">\n        <div class=\"hero-lockup\">\n          <img class=\"brand-mark\" src=\"assets/dark-shepherd-submark.webp\" alt=\"\" />\n          <p class=\"eyebrow\">Mediterranean restaurant · The Star Brisbane</p>\n          <h1>Born of fire. Bound by flavour.</h1>\n          <p class=\"lead hero-note\">White Pyrenees lamb, live seafood, woodfired heat and a dining room built for late lunches that become darker things.</p>\n          <div class=\"hero-cta\" style=\"margin-top: 30px;\">\n            <a class=\"btn btn-primary\" href=\"https://www.sevenrooms.com/explore/darkshepherd/reservations/create/search?venues=darkshepherd,pompetteau,yamasgreekdrink,stilts,richandrarerestaurant,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant\">Reserve a table</a>\n            <a class=\"btn btn-secondary\" href=\"menu.html\">View main menu</a>\n          </div>\n        </div>\n        <figure class=\"media-card wide\" style=\"margin: 0;\">\n          <img src=\"assets/dining-room.webp\" alt=\"Dark Shepherd dining room\" />\n          <figcaption class=\"media-caption\">The flock gathers · 7 days · 11am-late</figcaption>\n        </figure>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"menus\" data-od-id=\"menus\">\n      <div class=\"container stack\" style=\"gap: 56px;\">\n        <div class=\"row-between\">\n          <div style=\"max-width: 42ch;\">\n            <p class=\"eyebrow\">Menu paths</p>\n            <h2>Fire, flavour, and flair.</h2>\n          </div>\n          <a class=\"btn btn-ghost btn-arrow\" href=\"menu.html\">Open full menu</a>\n        </div>\n        <div class=\"grid-4\">\n          <article class=\"menu-card\">\n            <h3>Main Menu</h3>\n            <ul>\n              <li>Woodfired pillow bread</li>\n              <li>Oysters on ice</li>\n              <li>Wagyu souvlaki</li>\n            </ul>\n          </article>\n          <article class=\"menu-card\" id=\"banquets\">\n            <h3>Banquets</h3>\n            <ul>\n              <li>Baa Baa · 88pp</li>\n              <li>Shear Delight · 115pp</li>\n              <li>The Dark Shepherd · 169pp</li>\n            </ul>\n          </article>\n          <article class=\"menu-card\" id=\"drinks\">\n            <h3>Beverages</h3>\n            <ul>\n              <li>Signature cocktails</li>\n              <li>140-bottle wine list</li>\n              <li>Premium spirits</li>\n            </ul>\n          </article>\n          <article class=\"menu-card\">\n            <h3>Lunch</h3>\n            <ul>\n              <li>Daylight Banquet · 57pp</li>\n              <li>Martini & Souvlaki · 38pp</li>\n              <li>Craggy Range Weekends · 88pp</li>\n            </ul>\n          </article>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" data-od-id=\"signature\">\n      <div class=\"container grid-1-2\">\n        <div class=\"stack\">\n          <p class=\"eyebrow\">Shepherd menu · White Pyrenees</p>\n          <h2>Lamb meets fire's embrace.</h2>\n          <p class=\"lead\">Raised on lush pasture and crushed grains, the lamb is dry-aged, slow-cooked, charred, carved and served with the restraint of a serious steakhouse.</p>\n          <div class=\"grid-2\" style=\"gap: 18px; margin-top: 18px;\">\n            <div class=\"stat\">\n              <div class=\"stat-num num\">21</div>\n              <p class=\"stat-label\">days aged before the premium lamb cutlets reach the grill.</p>\n            </div>\n            <div class=\"stat\">\n              <div class=\"stat-num num\">120</div>\n              <p class=\"stat-label\">seat dining room, with a private 10-seater for quieter revels.</p>\n            </div>\n          </div>\n        </div>\n        <figure class=\"media-card portrait\" style=\"margin: 0;\">\n          <img src=\"assets/slow-cooked-lamb.webp\" alt=\"Slow cooked lamb at Dark Shepherd\" />\n          <figcaption class=\"media-caption\">Slow cooked lamb · woodfired peppers · roasted potatoes</figcaption>\n        </figure>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"functions\" data-od-id=\"functions\">\n      <div class=\"container grid-2\">\n        <figure class=\"media-card portrait\" style=\"margin: 0;\">\n          <img src=\"assets/service-room.webp\" alt=\"Dark Shepherd hospitality and dining service\" />\n          <figcaption class=\"media-caption\">Host boldly · dine brilliantly</figcaption>\n        </figure>\n        <div class=\"stack\" style=\"align-self: center;\">\n          <p class=\"eyebrow\">Functions & events</p>\n          <h2>A rite of passage, not a room hire.</h2>\n          <p class=\"lead\">Elect the 120-seat dining room for your revel, or retreat into the private 10-seater for a shadow of secrecy. Menus draw from Mediterranean fire, cocktails and a curated cellar.</p>\n          <div class=\"hero-cta\" style=\"margin-top: 14px;\">\n            <a class=\"btn btn-secondary\" href=\"functions.html\">Plan a function</a>\n            <a class=\"btn btn-ghost btn-arrow\" href=\"https://www.darkshepherd.com.au/banquets\">See banquets</a>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" data-od-id=\"quote\">\n      <div class=\"container\" style=\"max-width: 840px;\">\n        <div class=\"quote-mark\">\"</div>\n        <blockquote class=\"quote\">By night, the embers smoulder. By day, the sun lends its warmth.</blockquote>\n        <p class=\"quote-author\">— Dark Shepherd house copy</p>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"visit\" data-od-id=\"visit\">\n      <div class=\"container stack\" style=\"gap: 44px;\">\n        <div class=\"row-between\">\n          <div>\n            <p class=\"eyebrow\">When the embers glow</p>\n            <h2>Find us at The Terrace.</h2>\n          </div>\n          <a class=\"btn btn-primary\" href=\"https://www.sevenrooms.com/explore/darkshepherd/reservations/create/search?venues=darkshepherd,pompetteau,yamasgreekdrink,stilts,richandrarerestaurant,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant\">Book now</a>\n        </div>\n        <div class=\"visit-grid\">\n          <article class=\"card-rule\">\n            <p class=\"meta\">All day dining</p>\n            <h3>7 days · 11am-late</h3>\n            <p style=\"color: var(--muted); margin-bottom: 0;\">Open every day except Christmas Day.</p>\n          </article>\n          <article class=\"card-rule\">\n            <p class=\"meta\">Find us</p>\n            <h3>The Terrace, Level 4</h3>\n            <p style=\"color: var(--muted); margin-bottom: 0;\">The Star Brisbane<br />Ph. (07) 2111 6869</p>\n          </article>\n          <article class=\"card-rule\">\n            <p class=\"meta\">Guest notes</p>\n            <h3>Validated parking</h3>\n            <p style=\"color: var(--muted); margin-bottom: 0;\">Weekend and public holiday surcharges apply. Card payment surcharge applies.</p>\n          </article>\n        </div>\n      </div>\n    </section>\n  </main>\n\n  <footer class=\"pagefoot\">\n    <div class=\"container row-between\">\n      <span>Dark Shepherd · Mediterranean restaurant at The Star Brisbane</span>\n      <div class=\"row\" style=\"flex-wrap: wrap;\">\n        <a href=\"https://www.instagram.com/darkshepherd_bne/\">Instagram</a>\n        <a href=\"https://www.facebook.com/darkshepherd.brisbane\">Facebook</a>\n        <a href=\"https://giftcards.nowbookit.com/cards?accountid=4843949d-9776-494d-8655-478ef32b5105&venueid=12275&theme=dark&accent=157,157,157%C2%A0\">Gift voucher</a>\n        <a href=\"https://www.darkshepherd.com.au/contact\">Contact</a>\n      </div>\n    </div>\n  </footer>\n</body>\n</html>\n","isError":false}

