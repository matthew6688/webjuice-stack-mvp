data: {"type":"tool_result","toolUseId":"item_4","content":"functions.html:14:      <nav class=\"nav-right\"><a href=\"https://giftcards.nowbookit.com/cards?accountid=4843949d-9776-494d-8655-478ef32b5105&venueid=12275&theme=dark&accent=157,157,157\">Gift Vouchers</a><a href=\"https://www.sevenrooms.com/explore/darkshepherd/reservations/create/search?venues=darkshepherd,pompetteau,yamasgreekdrink,stilts,richandrarerestaurant,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant\">Bookings</a></nav>\nfunctions.html:18:    <section class=\"section\" data-od-id=\"functions-hero\">\nfunctions.html:27:        <div class=\"card-rule\"><p class=\"eyebrow\">Private room</p><h2 class=\"num\">10</h2><p class=\"lead\">A private 10-seater for groups seeking a shadow of secrecy.</p></div>\nmenu.html:14:      <nav class=\"nav-right\"><a href=\"https://giftcards.nowbookit.com/cards?accountid=4843949d-9776-494d-8655-478ef32b5105&venueid=12275&theme=dark&accent=157,157,157\">Gift Vouchers</a><a href=\"https://www.sevenrooms.com/explore/darkshepherd/reservations/create/search?venues=darkshepherd,pompetteau,yamasgreekdrink,stilts,richandrarerestaurant,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant\">Bookings</a></nav>\nmenu.html:18:    <section class=\"section hero-photo menu-hero\" data-od-id=\"menu-hero\">\nmenu.html:19:      <div class=\"container hero-panel\">\nmenu.html:27:        <div class=\"row-between\" style=\"margin-bottom: 32px;\"><h2>Explore the offerings</h2><a class=\"btn btn-primary\" href=\"https://www.sevenrooms.com/explore/darkshepherd/reservations/create/search?venues=darkshepherd,pompetteau,yamasgreekdrink,stilts,richandrarerestaurant,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant\">Book before dining</a></div>\nmenu.html:38:  <footer class=\"pagefoot\"><div class=\"container row-between\"><span>All day dining · 7 days · 11am-late</span><span>The Terrace, Level 4, The Star Brisbane · (07) 2111 6869</span></div></footer>\ncontact.html:14:      <nav class=\"nav-right\"><a href=\"https://giftcards.nowbookit.com/cards?accountid=4843949d-9776-494d-8655-478ef32b5105&venueid=12275&theme=dark&accent=157,157,157\">Gift Vouchers</a><a href=\"https://www.sevenrooms.com/explore/darkshepherd/reservations/create/search?venues=darkshepherd,pompetteau,yamasgreekdrink,stilts,richandrarerestaurant,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant\">Bookings</a></nav>\ncontact.html:18:    <section class=\"section\" data-od-id=\"contact-hero\">\ncontact.html:19:      <div class=\"container hero-center\" style=\"text-align: center; max-width: 780px;\">\ncontact.html:22:        <p class=\"lead\" style=\"margin: 18px auto 0;\">All day dining, seven days from 11am-late. Open every day except Christmas Day.</p>\ncontact.html:23:        <div class=\"hero-cta\" style=\"justify-content: center;\"><a class=\"btn btn-primary\" href=\"tel:+61721116869\">Call (07) 2111 6869</a><a class=\"btn btn-secondary\" href=\"https://www.sevenrooms.com/explore/darkshepherd/reservations/create/search?venues=darkshepherd,pompetteau,yamasgreekdrink,stilts,richandrarerestaurant,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant\">Book online</a></div>\ncontact.html:28:        <div class=\"card-rule\"><p class=\"eyebrow\">Hours</p><h3>When the embers glow</h3><p class=\"lead\">All Day Dining. 7 days, 11am-late. Open every day except Christmas Day.</p></div>\ncontact.html:30:        <div class=\"card-rule\"><p class=\"eyebrow\">Social</p><h3>Join the flock</h3><p class=\"lead\"><a href=\"https://www.instagram.com/darkshepherd_bne/\">Instagram</a> and <a href=\"https://www.facebook.com/darkshepherd.brisbane\">Facebook</a>. Careers and business opportunities remain linked from the original footer.</p></div>\nindex.html:13:    .hero{min-height:86vh;display:grid;grid-template-columns:1.1fr .9fr;gap:32px;align-items:end;max-width:1200px;margin:0 auto;padding:40px 24px 64px}\nindex.html:14:    .hero-copy small{display:block;letter-spacing:.24em;text-transform:uppercase;color:var(--accent);margin-bottom:18px}\nindex.html:15:    .hero-copy h1{font-size:clamp(56px,8vw,110px);line-height:.92;margin:0 0 18px;max-width:8ch}\nindex.html:16:    .hero-copy p{max-width:58ch;color:var(--muted);font-size:18px;line-height:1.7}\nindex.html:17:    .hero-actions{display:flex;gap:14px;margin-top:28px}.hero-actions a{padding:14px 18px;border:1px solid var(--line)}.hero-actions a.primary{background:var(--paper);color:#15110f}\nindex.html:18:    .hero-media{display:grid;grid-template-columns:1fr 1fr;gap:16px}.hero-media img{width:100%;height:100%;object-fit:cover;display:block;min-height:260px}\nindex.html:20:    .stats{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}.stats div{padding:24px;border:1px solid var(--line);background:var(--panel)}\nindex.html:23:    .menu-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:32px}.menu-block{background:var(--panel);border:1px solid var(--line);padding:22px}.section-head{color:var(--accent);text-transform:uppercase;letter-spacing:.2em;font-size:12px;margin-bottom:16px}.menu-row{display:flex;justify-content:space-between;gap:14px;padding:14px 0;border-top:1px solid var(--line)}.menu-row:first-of-type{border-top:none;padding-top:0}.menu-row h4{margin:0 0 6px;font-size:18px}.menu-row p{margin:0;color:var(--muted);font-size:14px;line-height:1.5}.menu-row strong{white-space:nowrap}\nindex.html:24:    .split{display:grid;grid-template-columns:1fr 1fr;gap:28px;align-items:start}.card{padding:28px;background:var(--panel);border:1px solid var(--line)}\nindex.html:27:    @media (max-width: 900px){.hero,.split,.menu-grid,.stats{grid-template-columns:1fr}.hero{min-height:auto;padding-top:24px}.hero-media{grid-template-columns:1fr}.hero-copy h1{font-size:54px}}\nindex.html:37:  <section class=\"hero\" id=\"home\">\nindex.html:38:    <div class=\"hero-copy\">\nindex.html:42:      <div class=\"hero-actions\">\nindex.html:47:    <div class=\"hero-media\">\nindex.html:48:      <img src=\"assets/dark-shepherd-hero.jpg\" alt=\"Dark Shepherd dining\" />\nindex.html:56:        <div><small class=\"section-kicker\">Phone</small><strong>(07) 2111 6869</strong><p>Tap-to-call preserved</p></div>\nindex.html:57:        <div><small class=\"section-kicker\">Booking</small><strong>Official</strong><p>Official reservation path retained</p></div>\nindex.html:64:      <p class=\"section-copy\">This concept keeps Dark Shepherd’s real menu source and preserves prices, section structure, and booking intent before anything becomes production UI.</p>\nindex.html:84:          <p class=\"section-copy\">The concept keeps the site’s function and private-dining intent visible, instead of flattening everything into a one-page brochure.</p>\nindex.html:87:          <h3>What stays preserved</h3>\nindex.html:104:        <div class=\"hero-actions\">\n","isError":false}

