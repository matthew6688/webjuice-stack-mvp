7%C2%A0\"  target=\"_blank\" >Dark Shepherd Gift Voucher</a>\n/tmp/darkshepherd-functions.html:1661:                    <a href=\"https://giftcards.nowbookit.com/cards/card-selection?accountid=4843949d-9776-494d-8655-478ef32b5105&venueid=14196&theme=light&accent=157,157,157\"  target=\"_blank\" >Tassis Group Gift Voucher</a>\n/tmp/darkshepherd-functions.html:1762:                          <use xlink:href=\"#facebook-unauth-icon\" width=\"110\" height=\"110\"></use>\n/tmp/darkshepherd-functions.html:1775:                href=\"https://www.sevenrooms.com/explore/darkshepherd/reservations/create/search?venues=darkshepherd,pompetteau,yamasgreekdrink,stilts,richandrarerestaurant,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant\"\n/tmp/darkshepherd-functions.html:2079:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><div class=\"sqsrte-scaled-text-container\"><span class=\"sqsrte-scaled-text\"><h1 style=\"text-align:center;white-space:pre-wrap;\">Functions &amp; <strong>Events</strong></h1></span></div></div>\n/tmp/darkshepherd-functions.html:2096:  #block-93bf1150de2474952614 .sqs-html-content {\n/tmp/darkshepherd-functions.html:2139:          #block-93bf1150de2474952614 .sqs-html-content {\n/tmp/darkshepherd-functions.html:2618:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><h2 style=\"white-space:pre-wrap;\">Enquire today</h2></div>\n/tmp/darkshepherd-functions.html:2635:  #block-yui_3_17_2_1_1733192257499_2522 .sqs-html-content {\n/tmp/darkshepherd-functions.html:2678:          #block-yui_3_17_2_1_1733192257499_2522 .sqs-html-content {\n/tmp/darkshepherd-functions.html:2702:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p class=\"\" style=\"white-space:pre-wrap;\">Enter the realm of Dark Shepherd and prepare for an event where decadence and desire intertwine. Whether seeking a grand celebration or a secretive, intimate gathering, our spaces are designed to mesmerise. The 120-seat venue hums with elegant energy, while the semi-private 10-seater curtained private dining room, veiled in shadow and secrecy, beckons for more intimate encounters.</p><p class=\"\" style=\"white-space:pre-wrap;\">Our menu, a reflection of Mediterranean mastery, elevates every gathering, complemented by cocktails that enrapture the senses and a curated selection of 140 distinguished wines. Carve moments into memories.</p><p class=\"\" style=\"white-space:pre-wrap;\"><strong>Gather your flock. Enquire now.</strong></p></div>\n/tmp/darkshepherd-functions.html:2719:  #block-4f833f469a8dad445b62 .sqs-html-content {\n/tmp/darkshepherd-functions.html:2762:          #block-4f833f469a8dad445b62 .sqs-html-content {\n/tmp/darkshepherd-functions.html:2798:    {\"secureUrl\":\"https://darkshepherd.squarespace.com\",\"collectionId\":\"672af1c5954a255029cca559\",\"formFieldFormats\":{\"initialPhoneFormat\":{\"id\":0,\"type\":\"PHONE_NUMBER\",\"country\":\"AU\",\"labelLocale\":\"en-US\",\"fields\":[{\"type\":\"FIELD\",\"label\":\"1\",\"identifier\":\"1\",\"length\":1,\"required\":false,\"metadata\":{}},{\"type\":\"SEPARATOR\",\"label\":\" \",\"identifier\":\"Space\",\"length\":0,\"required\":false,\"metadata\":{}},{\"type\":\"FIELD\",\"label\":\"2\",\"identifier\":\"2\",\"length\":4,\"required\":false,\"metadata\":{}},{\"type\":\"SEPARATOR\",\"label\":\" \",\"identifier\":\"Space\",\"length\":0,\"required\":false,\"metadata\":{}},{\"type\":\"FIELD\",\"label\":\"3\",\"identifier\":\"3\",\"length\":15,\"required\":false,\"metadata\":{}}]},\"initialNameOrder\":\"GIVEN_FIRST\",\"initialAddressFormat\":{\"id\":0,\"type\":\"ADDRESS\",\"country\":\"AU\",\"labelLocale\":\"en\",\"fields\":[{\"type\":\"FIELD\",\"label\":\"Address Line 1\",\"identifier\":\"Line1\",\"length\":0,\"required\":true,\"metadata\":{\"autocomplete\":\"address-line1\"}},{\"type\":\"SEPARATOR\",\"label\":\"\\n\",\"identifier\":\"Newline\",\"length\":0,\"required\":false,\"metadata\":{}},{\"type\":\"FIELD\",\"label\"