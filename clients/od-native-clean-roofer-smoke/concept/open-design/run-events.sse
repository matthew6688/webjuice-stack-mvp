data: {"type":"tool_result","toolUseId":"item_11","content":"327:      <a class=\"logo\" href=\"#top\" aria-label=\"Precision Roof Restore home\">Precision Roof Restore</a>\n329:        <a href=\"#services\">Services</a>\n330:        <a href=\"#areas\">Service area</a>\n331:        <a href=\"#enquiry\">Enquiry</a>\n333:      <a class=\"btn btn-primary\" href=\"tel:0424371622\">Call now · 0424 371 622</a>\n345:            <a class=\"btn btn-primary\" href=\"tel:0424371622\">Call now · 0424 371 622</a>\n346:            <a class=\"btn btn-secondary\" href=\"#enquiry\">Send an enquiry</a>\n348:          <p class=\"meta\" style=\"margin-top: 18px;\">Demo pre-sale mockup · form routes to hi@profitslocal.com</p>\n358:              <strong style=\"font-size: 24px;\">0424 371 622</strong>\n479:            <a class=\"btn btn-primary\" href=\"tel:0424371622\">Call now · 0424 371 622</a>\n482:        <form class=\"contact-card\" action=\"/api/contact/resend\" method=\"post\" data-resend-to=\"hi@profitslocal.com\">\n483:          <input type=\"hidden\" name=\"to\" value=\"hi@profitslocal.com\" />\n515:          <button class=\"btn btn-primary\" type=\"submit\" style=\"width: 100%; margin-top: 20px;\">Request a call · 0424 371 622</button>\n516:          <p class=\"form-status\" role=\"status\">Enquiries route through the existing Resend transactional email flow to hi@profitslocal.com.</p>\n525:      <span class=\"meta\">Call 0424 371 622 · Brisbane roof restoration enquiries</span>\n536:          status.textContent = 'Sending enquiry to hi@profitslocal.com...';\n","isError":false}

