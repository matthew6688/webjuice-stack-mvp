"M21 49C23.2091 49 25 47.2091 25 45C25 42.7909 23.2091 41 21 41C18.7909 41 17 42.7909 17 45C17 47.2091 18.7909 49 21 49Z\" />\n  <path d=\"M45 49C47.2091 49 49 47.2091 49 45C49 42.7909 47.2091 41 45 41C42.7909 41 41 42.7909 41 45C41 47.2091 42.7909 49 45 49Z\" />\n</svg>\n\n              <div class=\"legacy-cart icon-cart-quantity\">\n                <span class=\"sqs-cart-quantity\">0</span>\n              </div>\n            </span>\n          </a>\n        </div>\n      \n\n      \n\n\n\n\n\n\n\n\n\n\n\n\n  <header\n    data-test=\"header\"\n    id=\"header\"\n    \n    class=\"\n      \n        \n          black\n        \n      \n      header theme-col--primary\n    \"\n    data-section-theme=\"black\"\n    data-controller=\"Header\"\n    data-current-styles=\"{\n&quot;layout&quot;: &quot;navRight&quot;,\n&quot;action&quot;: {\n&quot;href&quot;: &quot;https://www.sevenrooms.com/explore/richandrarerestaurant/reservations/create/search?venues=richandrarerestaurant,pompetteau,darkshepherd,yamasgreekdrink,stilts,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant&quot;,\n&quot;buttonText&quot;: &quot;BOOKINGS&quot;,\n&quot;newWindow&quot;: false\n},\n&quot;showSocial&quot;: true,\n&quot;socialOptions&quot;: {\n&quot;socialBorderShape&quot;: &quot;circle&quot;,\n&quot;socialBorderStyle&quot;: &quot;outline&quot;,\n&quot;socialBorderThickness&quot;: {\n&quot;unit&quot;: &quot;px&quot;,\n&quot;value&quot;: 1.0\n}\n},\n&quot;menuOverlayAnimation&quot;: &quot;fade&quot;,\n&quot;cartStyle&quot;: &quot;cart&quot;,\n&quot;cartText&quot;: &quot;Cart&quot;,\n&quot;showEmptyCartState&quot;: true,\n&quot;cartOptions&quot;: {\n&quot;iconType&quot;: &quot;solid-7&quot;,\n&quot;cartBorderShape&quot;: &quot;none&quot;,\n&quot;cartBorderStyle&quot;: &quot;outline&quot;,\n&quot;cartBorderThickness&quot;: {\n&quot;unit&quot;: &quot;px&quot;,\n&quot;value&quot;: 1.0\n}\n},\n&quot;showButton&quot;: true,\n&quot;showCart&quot;: false,\n&quot;sho