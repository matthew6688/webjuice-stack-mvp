data: {"type":"tool_result","toolUseId":"item_9","content":"\r  0     0    0     0    0     0      0      0 --:--:-- --:--:-- --:--:--     0\r100 14739    0 14739    0     0  15169      0 --:--:-- --:--:-- --:--:-- 15163\n<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n<urlset xmlns=\"http://www.sitemaps.org/schemas/sitemap/0.9\" xmlns:image=\"http://www.google.com/schemas/sitemap-image/1.1\" xmlns:xhtml=\"http://www.w3.org/1999/xhtml\" xmlns:video=\"http://www.google.com/schemas/sitemap-video/1.1\">\r\n  <url>\r\n    <loc>https://www.richandrare.com.au/home</loc>\r\n    <changefreq>daily</changefreq>\r\n    <priority>1.0</priority>\r\n    <lastmod>2025-10-29</lastmod>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/27373d68-0489-45bd-acdd-e5d434fce859/Rich+%26+Rare+-+Markus+Ravik+-+170.jpg</image:loc>\r\n      <image:title>Home</image:title>\r\n      <image:caption>A formal dining table set with wine glasses, water glasses, plates, napkins, forks, knives, and spoons in front of a dark wood paneled wall with two circular light fixtures.</image:caption>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/e9c2b80c-f97e-4dff-81a4-2e7aef6e23c6/Rich+%26+Rare+-+Markus+Ravik+-+054.jpg</image:loc>\r\n      <image:title>Home</image:title>\r\n      <image:caption>Glass of red wine and a plate of sliced cured ham with herbs on a black outdoor table.</image:caption>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/375aaf5d-f714-4593-8953-493fe215c42d/Rich+%26+Rare+-+Markus+Ravik+-+138.jpg</image:loc>\r\n      <image:title>Home</image:title>\r\n      <image:caption>Five small white bowls with different gourmet dishes are arranged on a white marble dining table.</image:caption>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/e8e9f3c1-6b39-4a46-9bd7-840c1d488039/Rich+%26+Rare+-+Markus+Ravik+-+145.jpg</image:loc>\r\n      <image:title>Home</image:title>\r\n      <image:caption>Black pasta with fried toppings on a white plate beside a glass of white wine on a dark table.</image:caption>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/6d1c5350-0fb5-4b3c-83d1-c1363f13efd5/Rich+%26+Rare+-+Markus+Ravik+-+105.jpg</image:loc>\r\n      <image:title>Home</image:title>\r\n      <image:caption>A plate of seared scallops with broccoli and crunchy topping on a black plate, a glass of white wine, and a set of fork, knife, and napkin on a white marble table.</image:caption>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/46477aef-c229-4e4a-b028-41364c7234f3/Rich+%26+Rare+-+Markus+Ravik+-+106.jpg</image:loc>\r\n      <image:title>Home</image:title>\r\n      <image:caption>Fine dining plate with crab legs, purple edible flowers, a yellow sauce, and lemon, with a glass of white wine and a set of silverware on a marble table.</image:caption>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/d51f7460-32c1-4175-891d-deedd299a317/Rich+and+Rare_RR+Logo_RGB_White.png</image:loc>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/19f3cb37-cf2c-46fe-bcc7-e309fcf78111/R%26R_Winner.png</image:loc>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/43db72df-198f-49ae-9f24-bbaa214cfe7b/bronze-award.png</image:loc>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/44aafd22-89c7-4aaf-a014-2ab3118bf0d8/Rich+%26+Rare+-+Markus+Ravik+-+110.jpg</image:loc>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/c0f8bdcb-ef49-4410-a672-b2de1a3e09d0/Rich+%26+Rare+-+Markus+Ravik+-+132.jpg</image:loc>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/f46729bb-c405-4c20-8895-1a8f616256fa/Rich+%26+Rare+-+Markus+Ravik+-+077.jpg</image:loc>\r\n    </image:image>\r\n  </url>\r\n  <url>\r\n    <loc>https://www.richandrare.com.au/contact</loc>\r\n    <changefreq>daily</changefreq>\r\n    <priority>0.75</priority>\r\n    <lastmod>2026-03-03</lastmod>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/08e3020c-9b98-40b7-9703-7cc0917dec6b/Rich+And+Rare+West+End</image:loc>\r\n    </image:image>\r\n  </url>\r\n  <url>\r\n    <loc>https://www.richandrare.com.au/privacy-policy</loc>\r\n    <changefreq>daily</changefreq>\r\n    <priority>0.75</priority>\r\n    <lastmod>2026-01-05</lastmod>\r\n  </url>\r\n  <url>\r\n    <loc>https://www.richandrare.com.au/gallery</loc>\r\n    <changefreq>daily</changefreq>\r\n    <priority>0.75</priority>\r\n    <lastmod>2025-09-11</lastmod>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/022b4c91-9827-4771-a5ea-29e3325a9ee9/Rich+%26+Rare+-+Markus+Ravik+-+089.jpg</image:loc>\r\n      <image:title>Gallery</image:title>\r\n      <image:caption>Interior of a modern restaurant with a long dining table set with glassware, a waiter cleaning chairs, and two seated customers near the window.</image:caption>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/1f7c3e4d-38e2-40a8-8f04-cbb76a4d2aaa/Rich+%26+Rare+-+Markus+Ravik+-+090.jpg</image:loc>\r\n      <image:title>Gallery</image:title>\r\n      <image:caption>The Private Dining Room</image:caption>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/8cf882e4-0ade-4825-998b-99b0ba708e0d/Rich+%26+Rare+-+Markus+Ravik+-+092.jpg</image:loc>\r\n      <image:title>Gallery</image:title>\r\n      <image:caption>A dining table set with glassware, plates, and utensils in a dimly lit restaurant with dark wall decor and modern lighting fixtures.</image:caption>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/3a152f9a-b1ff-49ca-ae67-edaa2ca25478/Rich+%26+Rare+-+Markus+Ravik+-+131.jpg</image:loc>\r\n      <image:title>Gallery</image:title>\r\n      <image:caption>Bar seating</image:caption>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/f960a0ed-0dbe-4bda-a7d2-8c0e9f598a49/Rich+%26+Rare+-+Markus+Ravik+-+194.jpg</image:loc>\r\n      <image:title>Gallery</image:title>\r\n      <image:caption>Group of five people sitting around a restaurant table with drinks, in conversation, one woman looking at the camera.</image:caption>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/c5acba88-167a-4f65-bab1-88db977549a6/Rich+%26+Rare+-+Markus+Ravik+-+093.jpg</image:loc>\r\n      <image:title>Gallery</image:title>\r\n      <image:caption>A restaurant table set with glasses, plates, silverware, and napkins in a warmly lit dining space with large windows.</image:caption>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/da3aa2a0-68dc-423e-9053-83d4402d0a8f/Rich+%26+Rare+-+Markus+Ravik+-+195.jpg</image:loc>\r\n      <image:title>Gallery</image:title>\r\n      <image:caption>Outdoor Dining</image:caption>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/16107022-10f8-491c-97c7-b8eebc55c7a6/Rich+%26+Rare+-+Markus+Ravik+-+095.jpg</image:loc>\r\n      <image:title>Gallery</image:title>\r\n      <image:caption>A glass display case shows various cuts of meat in a restaurant or butcher shop. In the background, a man is working on a computer at a counter.</image:caption>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/1f2a07de-419c-4a2c-8217-b2ae84c2017f/Rich+%26+Rare+-+Markus+Ravik+-+211.jpg</image:loc>\r\n      <image:title>Gallery</image:title>\r\n      <image:caption>The Dining Room</image:caption>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/1778bb7d-95f9-42bb-93f7-379c06a02a2c/Rich+%26+Rare+-+Markus+Ravik+-+214.jpg</image:loc>\r\n      <image:title>Gallery</image:title>\r\n      <image:caption>People dining at a restaurant table with a waiter standing nearby, smiling and holding a glass.</image:caption>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/de24a5e0-229a-4261-905c-1a2e56eba781/Rich+%26+Rare+-+Markus+Ravik+-+213.jpg</image:loc>\r\n      <image:title>Gallery</image:title>\r\n      <image:caption>The Entrance</image:caption>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/d623eab8-71f3-46c6-a748-8454a27f0ef2/Rich+%26+Rare+-+Markus+Ravik+-+091.jpg</image:loc>\r\n      <image:title>Gallery</image:title>\r\n      <image:caption>The Private Dining Room</image:caption>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/1b380452-1a89-4428-8b16-2920bd173529/Rich+%26+Rare+-+Markus+Ravik+-+197.jpg</image:loc>\r\n      <image:title>Gallery</image:title>\r\n      <image:caption>A restaurant scene with a waiter serving dinner to a group of adults and children seated at a long table inside. The restaurant has warm lighting, wooden walls, and large windows with string lights outside.</image:caption>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/0fbde2a6-d7ad-4bc7-bc14-acac686e93c3/Rich+%26+Rare+-+Markus+Ravik+-+039.jpg</image:loc>\r\n      <image:title>Gallery</image:title>\r\n      <image:caption>Hand holding a glass of whiskey in front of a mural of a woman smoking a cigarette.</image:caption>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/28471c4b-a2f8-408c-a9dc-9ae99b20a3c3/Rich+%26+Rare+-+Markus+Ravik+-+212.jpg</image:loc>\r\n      <image:title>Gallery</image:title>\r\n      <image:caption>A woman with dark hair sitting at an outdoor restaurant table, reading a menu during evening. Other diners are visible in the background with string lights overhead.</image:caption>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/1fc2619b-a049-49a8-aa7c-167554f7044c/Rich+%26+Rare+-+Markus+Ravik+-+198.jpg</image:loc>\r\n      <image:title>Gallery</image:title>\r\n      <image:caption>Group of people dining at a restaurant table during evening, with large windows and outdoor greenery visible.</image:caption>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/c71541b3-206e-45a8-84fb-caf59053bc5f/Rich+%26+Rare+-+Markus+Ravik+-+199.jpg</image:loc>\r\n      <image:title>Gallery</image:title>\r\n      <image:caption>Two men looking at meat cuts in a glass refrigerated display case in a restaurant or butcher shop.</image:caption>\r\n    </image:image>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/e3df6d07-7ba4-4a32-a10b-87ca8e144179/Rich+%26+Rare+-+Markus+Ravik+-+208.jpg</image:loc>\r\n      <image:title>Gallery</image:title>\r\n      <image:caption>People dining at a restaurant, some looking at menus, some engaged in conversation, with a waiter attending to customers, indoor and outdoor seating areas visible.</image:caption>\r\n    </image:image>\r\n  </url>\r\n  <url>\r\n    <loc>https://www.richandrare.com.au/lunch-dinner</loc>\r\n    <changefreq>daily</changefreq>\r\n    <priority>0.75</priority>\r\n    <lastmod>2026-03-14</lastmod>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/63dc8452-3dec-4d78-b3ee-33439cd1168c/RAR45_M+Cup+Tile_V2.png</image:loc>\r\n    </image:image>\r\n  </url>\r\n  <url>\r\n    <loc>https://www.richandrare.com.au/lunch-specials</loc>\r\n    <changefreq>daily</changefreq>\r\n    <priority>0.75</priority>\r\n    <lastmod>2026-03-14</lastmod>\r\n  </url>\r\n  <url>\r\n    <loc>https://www.richandrare.com.au/power-banquet</loc>\r\n    <changefreq>daily</changefreq>\r\n    <priority>0.75</priority>\r\n    <lastmod>2026-03-14</lastmod>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/9d68f281-a89f-480d-9ee6-0d8e39fefb8f/RAR92_Hero+image.jpg</image:loc>\r\n    </image:image>\r\n  </url>\r\n  <url>\r\n    <loc>https://www.richandrare.com.au/the-experience</loc>\r\n    <changefreq>daily</changefreq>\r\n    <priority>0.75</priority>\r\n    <lastmod>2026-03-14</lastmod>\r\n    <image:image>\r\n      <image:loc>https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/1708054198737-GHC5EN35RMGYPFGEL3JC/Rich+%26+Rare+-+Markus+Ravik+-+183.jpg</image:loc>\r\n      <image:title>The R&amp;R Experience</image:title>\r\n    </image:image>\r\n","is