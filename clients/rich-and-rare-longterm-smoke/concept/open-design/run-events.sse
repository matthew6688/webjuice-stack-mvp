id: 104
event: agent
data: {"type":"tool_result","toolUseId":"item_16","content":"16:<meta property=\"og:description\" content=\"Stunning steak and seafood restaurant in Brisbane's West Village precinct, in West End. Join us for an array of gourmet steak, fresh seafood, an extensive wine list and cocktails.\"/>\n22:<meta itemprop=\"description\" content=\"Stunning steak and seafood restaurant in Brisbane's West Village precinct, in West End. Join us for an array of gourmet steak, fresh seafood, an extensive wine list and cocktails.\"/>\n30:<meta name=\"twitter:description\" content=\"Stunning steak and seafood restaurant in Brisbane's West Village precinct, in West End. Join us for an array of gourmet steak, fresh seafood, an extensive wine list and cocktails.\"/>\n31:<meta name=\"description\" content=\"Stunning steak and seafood restaurant in Brisbane's West Village precinct, in West End. Join us for an array of gourmet steak, fresh seafood, an extensive wine list and cocktails.\" />\n2650:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p style=\"text-align:center;white-space:pre-wrap;\" class=\"\">Rich flavours. Rare cuts. Real service.</p></div>\n2834:      BOOK NOW\n2855:      BOOK NOW\n3390:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p style=\"text-align:center;white-space:pre-wrap;\" class=\"\">Rich &amp; Rare offers premium fare without pretension. Open your collar, order a whisky and settle in to enjoy succulent, dry-aged steak and freshly caught seafood, nestled in the heart of Brisbane’s vibrant West Village precinct.</p></div>\n3490:      VIEW MENU\n3511:      VIEW MENU\n4122:      CONTACT US\n4143:      CONTACT US\n5487:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\"><strong>OPEN 7 DAYS</strong><br>All Day Dining: 11:00am-late</p></div>\n5655:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\">FIND US<br>West Village Garden Pavilion<br>97 Boundary Street,<br>West End, Q 4101</p><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\">CAREERS<br><a href=\"/careers\">Employment</a></p><p class=\"sqsrte-small\" style=\"white-space:pre-wrap;\"><br>BUSINESS OPPORTUNITIES<br><a href=\"https://www.tassisgroup.com.au/business-opportunities\" target=\"_blank\">Business Opportunities</a></p></div>\n","isError":false}

