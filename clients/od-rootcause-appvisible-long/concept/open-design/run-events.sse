data: {"type":"tool_result","toolUseId":"item_21","content":"14:      --accent:  oklch(64% 0.13 45);\n16:      --accent-soft: color-mix(in oklch, var(--accent) 15%, transparent);\n78:    .h1, h1 { font-family: var(--font-display); font-size: var(--fs-h1); line-height: 0.94; letter-spacing: -0.02em; margin: 0; }\n79:    .h2, h2 { font-family: var(--font-display); font-size: var(--fs-h2); line-height: 1.03; letter-spacing: -0.015em; margin: 0; }\n80:    .h3, h3 { font-family: var(--font-display); font-size: var(--fs-h3); font-weight: 600; line-height: 1.3; letter-spacing: 0; margin: 0; }\n87:      color: var(--accent);\n120:    .btn-primary { background: var(--accent); color: var(--bg); border-color: var(--accent); }\n121:    .btn-primary:hover { background: color-mix(in oklch, var(--accent) 84%, var(--fg)); }\n125:    .btn-ghost:hover { color: var(--accent); }\n141:      font-family: var(--font-display);\n145:      color: var(--accent);\n150:    .quote { font-family: var(--font-display); font-size: clamp(26px, 3vw, 40px); line-height: 1.25; letter-spacing: -0.01em; max-width: 30ch; }\n152:    .quote-mark { font-family: var(--font-display); font-size: 140px; line-height: 0.7; color: var(--accent); opacity: 0.18; margin-bottom: -28px; }\n155:      background: var(--accent-soft); color: var(--accent); border-radius: 999px;\n169:    .input:focus, .textarea:focus { outline: 2px solid var(--accent-soft); border-color: var(--accent); }\n178:      background: linear-gradient(135deg, var(--accent-soft), var(--fg-soft)), var(--surface);\n221:        linear-gradient(to top, color-mix(in oklch, var(--bg) 96%, transparent), color-mix(in oklch, var(--bg) 42%, transparent) 52%, color-mix(in oklch, var(--bg) 76%, transparent)),\n244:    .menu-strip strong { color: var(--fg); font-family: var(--font-display); font-size: 22px; }\n250:        radial-gradient(circle at 18% 0, var(--accent-soft), transparent 38%),\n293:    <section class=\"section hero\" id=\"home\" data-od-id=\"home-hero\">\n298:          <h1>Born of fire. Bound by flavour.</h1>\n308:    <section class=\"section\" data-od-id=\"quick-links\">\n319:    <section class=\"section\" id=\"story\" data-od-id=\"story\">\n323:          <h2>Fire, flavour, and flair.</h2>\n334:    <section class=\"section\" id=\"menus\" data-od-id=\"menus\">\n339:            <h2>White Pyrenees lamb leads the flock.</h2>\n345:            <article class=\"dish-row\"><span class=\"num\">$14</span><div><h3>Woodfired Pillow Bread</h3><p>Thyme and olive oil, or feta, olives, capers, spicy sausage, or sand crab.</p></div></article>\n346:            <article class=\"dish-row\"><span class=\"num\">$7ea</span><div><h3>Oysters</h3><p>Natural on ice, red wine vinegar, or sea brine with orange and mustard.</p></div></article>\n347:            <article class=\"dish-row\"><span class=\"num\">$38</span><div><h3>Woodfired Octopus</h3><p>Olive oil and fava, grilled over fire.</p></div></article>\n348:            <article class=\"dish-row\"><span class=\"num\">$60 / $120</span><div><h3>Lamb Shoulder</h3><p>21 days aged, bone in, served with tzatziki.</p></div></article>\n349:            <article class=\"dish-row\"><span class=\"num\">$180 / $360</span><div><h3>Live Lobster</h3><p>Orzo pasta with tomato and herbs, or grilled with tirokafteri butter.</p></div></article>\n359:    <section class=\"section\" id=\"banquets\" data-od-id=\"banquets\">\n363:          <h2>Shared tables, serious appetite.</h2>\n368:            <h3 style=\"font-size: 30px; margin-top: 12px;\">57pp</h3>\n374:            <h3 style=\"font-size: 30px; margin-top: 12px;\">169pp</h3>\n382:    <section class=\"section\" id=\"functions\" data-od-id=\"functions\">\n386:          <h2>Host boldly, dine brilliantly.</h2>\n397:    <section class=\"section\" id=\"drinks\" data-od-id=\"drinks\">\n405:    <section class=\"section\" id=\"contact\" data-od-id=\"contact\">\n409:          <h2>All Day Dining. 7 Days. 11am-Late.</h2>\n418:          <h3 style=\"font-size: 28px; margin: 10px 0 18px;\">Find us</h3>\n436:      <span class=\"row\"><a href=\"https://www.instagram.com/darkshepherd_bne/\" target=\"_blank\" rel=\"noreferrer\">Instagram</a><a href=\"https://www.facebook.com/darkshepherd.brisbane\" target=\"_blank\" rel=\"noreferrer\">Facebook</a><a href=\"https://giftcards.nowbookit.com/cards?accountid=4843949d-9776-494d-8655-478ef32b5105&venueid=12275&theme=dark&accent=157,157,157%C2%A0\" target=\"_blank\" rel=\"noreferrer\">Gift vouchers</a></span>\n","isError":false}

