data: {"type":"text_delta","delta":"Got it — high-fidelity local-business website prototype for M&B Roofing, using the restoration lead-capture template. Tell me the remaining direction choices:\n\n<question-form id=\"discovery\" title=\"Quick brief — 30 seconds\">\n{\n  \"description\": \"I'll lock these in before building. Skip what doesn't apply — I'll fill defaults from the handoff.\",\n  \"questions\": [\n    {\n      \"id\": \"platform\",\n      \"label\": \"Primary surface\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Responsive — all sizes\",\n        \"Mobile-first\",\n        \"Desktop web\",\n        \"Fixed canvas (1920×1080)\"\n      ]\n    },\n    {\n      \"id\": \"audience\",\n      \"label\": \"Who is this for?\",\n      \"type\": \"text\",\n      \"placeholder\": \"e.g. homeowners in Jamison Town and Greater Western Sydney\"\n    },\n    {\n      \"id\": \"tone\",\n      \"label\": \"Visual tone\",\n      \"type\": \"checkbox\",\n      \"maxSelections\": 2,\n      \"options\": [\n        \"Trustworthy local trade\",\n        \"Clean and professional\",\n        \"Warm and approachable\",\n        \"Urgent repair response\",\n        \"Premium restoration\",\n        \"Practical and no-nonsense\"\n      ]\n    },\n    {\n      \"id\": \"brand\",\n      \"label\": \"Brand context\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Pick a direction for me\",\n        \"I have a brand spec — I'll share it\",\n        \"Match a reference site / screenshot — I'll attach it\"\n      ]\n    },\n    {\n      \"id\": \"scale\",\n      \"label\": \"Page scope\",\n      \"type\": \"radio\",\n      \"options\": [\n        \"Single-page lead capture site\",\n        \"Homepage plus service-section anchors\",\n        \"Homepage plus separate service mockups\"\n      ]\n    },\n    {\n      \"id\": \"constraints\",\n      \"label\": \"Anything else I should know?\",\n      \"type\": \"textarea\",\n      \"placeholder\": \"Assets to use, colours to avoid, preferred image style, deadline…\"\n    }\n  ]\n}\n</question-form>"}

