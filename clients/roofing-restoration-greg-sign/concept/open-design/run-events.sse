skills/web-prototype/SKILL.md\n/Users/matthew/Developer/open-design/.od/projects/template-roofing-lead-capture-restoration/.od-skills/web-prototype/assets/template.html\n/Users/matthew/Developer/open-design/.od/projects/template-roofing-lead-capture-restoration/.od-skills/web-prototype/example.html\n/Users/matthew/Developer/open-design/.od/projects/template-roofing-lead-capture-restoration/.od-skills/web-prototype/references/checklist.md\n/Users/matthew/Developer/open-design/.od/projects/template-roofing-lead-capture-restoration/.od-skills/web-prototype/references/layouts.md\n/Users/matthew/Developer/open-design/.od/projects/template-roofing-lead-capture-restoration/assets/gutter-detail.svg\n/Users/matthew/Developer/open-design/.od/projects/template-roofing-lead-capture-restoration/assets/roof-before-after.svg\n/Users/matthew/Developer/open-design/.od/projects/template-roofing-lead-capture-restoration/assets/roof-restoration-scene.svg\n/Users/matthew/Developer/open-design/.od/projects/template-roofing-lead-capture-restoration/assets/roof-service-card.svg\n/Users/matthew/Developer/open-design/.od/projects/template-roofing-lead-capture-restoration/compact-one-page.html\n/Users/matthew/Developer/open-design/.od/projects/template-roofing-lead-capture-restoration/index.html\n/Users/matthew/Developer/open-design/.od/projects/template-roofing-lead-capture-restoration/style-guide.md\n","isError":false}

