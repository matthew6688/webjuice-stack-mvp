data: {"type":"tool_result","toolUseId":"item_4","content":"<!doctype html>\n<html xmlns:og=\"http://opengraphprotocol.org/schema/\" xmlns:fb=\"http://www.facebook.com/2008/fbml\" lang=\"en-AU\"  >\n  <head>\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge,chrome=1\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <!-- This is Squarespace. --><!-- guppy-turkey-esm7 -->\n<base href=\"\">\n<meta charset=\"utf-8\" />\n<title>Rich &amp; Rare Restaurant Brisbane</title>\n<meta http-equiv=\"Accept-CH\" content=\"Sec-CH-UA-Platform-Version, Sec-CH-UA-Model\" /><link rel=\"icon\" type=\"image/x-icon\" href=\"https://images.squarespace-cdn.com/content/v1/645aeb6e5e03ca278fcc244b/629177b2-75d2-4bd1-8de2-0ebafaf97f79/favicon.ico?format=100w\"/>\n<link rel=\"canonical\" href=\"https://www.richandrare.com.au\"/>\n<meta property=\"og:site_name\" content=\"Rich &amp; Rare Restaurant Brisbane\"/>\n<meta property=\"og:title\" content=\"Rich &amp; Rare Restaurant Brisbane\"/>\n<meta property=\"og:url\" content=\"https://www.richandrare.com.au\"/>\n<meta property=\"og:type\" content=\"website\"/>\n<meta property=\"og:description\" content=\"Stunning steak and seafood restaurant in Brisbane's West Village precinct, in West End. Join us for an array of gourmet steak, fresh seafood, an extensive wine list and cocktails.\"/>\n<meta property=\"og:image\" content=\"http://static1.squarespace.com/static/645aeb6e5e03ca278fcc244b/t/6678c0d2407be66f5c957acc/1719189714919/Rich+%26+Rare+-+Markus+Ravik+106.jpg?format=1500w\"/>\n<meta property=\"og:image:width\" content=\"1500\"/>\n<meta property=\"og:image:height\" content=\"1000\"/>\n<meta itemprop=\"name\" content=\"Rich &amp; Rare Restaurant Brisbane\"/>\n<meta itemprop=\"url\" content=\"https://www.richandrare.com.au\"/>\n<meta itemprop=\"description\" content=\"Stunning steak and seafood restaurant in Brisbane's West Village precinct, in West End. Join us for an array of gourmet steak, fresh seafood, an extensive wine list and cocktails.\"/>\n<meta itemprop=\"thumbnailUrl\" content=\"http://static1.squarespace.com/static/645aeb6e5e03ca278fcc244b/t/6678c0d2407be66f5c957acc/1719189714919/Rich+%26+Rare+-+Markus+Ravik+106.jpg?format=1500w\"/>\n<link rel=\"image_src\" href=\"http://static1.squarespace.com/static/645aeb6e5e03ca278fcc244b/t/6678c0d2407be66f5c957acc/1719189714919/Rich+%26+Rare+-+Markus+Ravik+106.jpg?format=1500w\" />\n<meta itemprop=\"image\" content=\"http://static1.squarespace.com/static/645aeb6e5e03ca278fcc244b/t/6678c0d2407be66f5c957acc/1719189714919/Rich+%26+Rare+-+Markus+Ravik+106.jpg?format=1500w\"/>\n<meta name=\"twitter:title\" content=\"Rich &amp; Rare Restaurant Brisbane\"/>\n<meta name=\"twitter:image\" content=\"http://static1.squarespace.com/static/645aeb6e5e03ca278fcc244b/t/6678c0d2407be66f5c957acc/1719189714919/Rich+%26+Rare+-+Markus+Ravik+106.jpg?format=1500w\"/>\n<meta name=\"twitter:url\" content=\"https://www.richandrare.com.au\"/>\n<meta name=\"twitter:card\" content=\"summary\"/>\n<meta name=\"twitter:description\" content=\"Stunning steak and seafood restaurant in Brisbane's West Village precinct, in West End. Join us for an array of gourmet steak, fresh seafood, an extensive wine list and cocktails.\"/>\n<meta name=\"description\" content=\"Stunning steak and seafood restaurant in Brisbane's West Village precinct, in West End. Join us for an array of gourmet steak, fresh seafood, an extensive wine list and cocktails.\" />\n<link rel=\"preconnect\" href=\"https://images.squarespace-cdn.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,400;0,700;1,400;1,700\"><script type=\"text/javascript\" crossorigin=\"anonymous\" defer=\"true\" nomodule=\"nomodule\" src=\"//assets.squarespace.com/@sqs/polyfiller/1.6/legacy.js\"></script>\n<script type=\"text/javascript\" crossorigin=\"anonymous\" defer=\"true\" sr