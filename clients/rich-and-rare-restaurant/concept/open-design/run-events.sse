data: {"type":"tool_result","toolUseId":"item_46","content":"134:    .feature .feature-mark {\n142:    .feature .feature-mark svg { width: 18px; height: 18px; }\n334:            <div class=\"feature-mark\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\"><path d=\"M4 18h16M6 18V8m12 10V8M8 8h8l-4-4-4 4Z\"/></svg></div>\n339:            <div class=\"feature-mark\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\"><path d=\"M7 3v18M17 3v18M4 8h16M4 16h16\"/></svg></div>\n344:            <div class=\"feature-mark\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\"><circle cx=\"12\" cy=\"12\" r=\"7\"/><path d=\"M12 7v5l3 3\"/></svg></div>\n349:            <div class=\"feature-mark\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\"><path d=\"M12 21s7-5.2 7-11a7 7 0 0 0-14 0c0 5.8 7 11 7 11Z\"/><circle cx=\"12\" cy=\"10\" r=\"2\"/></svg></div>\n<!doctype html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Rich &amp; Rare Brisbane · Website Concept</title>\n  <style>\n    :root {\n      --bg:      oklch(14% 0.018 60);\n      --surface: oklch(19% 0.018 60);\n      --fg:      oklch(96% 0.008 75);\n      --muted:   oklch(72% 0.018 75);\n      --border:  oklch(32% 0.022 65);\n      --accent:  oklch(67% 0.105 72);\n\n      --accent-soft: color-mix(in oklch, var(--accent) 14%, transparent);\n      --fg-soft:     color-mix(in oklch, var(--fg) 7%, transparent);\n      --shadow:      color-mix(in oklch, black 42%, transparent);\n\n      --font-display: 'Charter', 'Iowan Old Style', Georgia, serif;\n      --font-body:    'Montserrat', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;\n      --font-mono:    ui-monospace, 'SFMono-Regular', Menlo, Consolas, monospace;\n\n      --fs-h1: clamp(46px, 7vw, 94px);\n      --fs-h2: clamp(31px, 4vw, 54px);\n      --fs-h3: 22px;\n      --fs-lead: 19px;\n      --fs-body: 16px;\n      --fs-meta: 12px;\n\n      --gap-xs: 8px;\n      --gap-sm: 12px;\n      --gap-md: 20px;\n      --gap-lg: 32px;\n      --gap-xl: 56px;\n      --gap-2xl: 96px;\n      --container: 1180px;\n      --gutter: 32px;\n\n      --radius: 4px;\n      --radius-lg: 6px;\n    }\n\n    *, *::before, *::after { box-sizing: border-box; }\n    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }\n    body {\n      margin: 0;\n      background: var(--bg);\n      color: var(--fg);\n      font-family: var(--font-body);\n      font-size: var(--fs-body);\n      line-height: 1.55;\n      text-rendering: optimizeLegibility;\n      -webkit-font-smoothing: antialiased;\n    }\n    img, svg { display: block; max-width: 100%; }\n    a { color: inherit; text-decoration: none; }\n    button { font: inherit; cursor: pointer; }\n    p { text-wrap: pretty; }\n    h1, h2, h3, h4 { text-wrap: balance; }\n\n    .container { max-width: var(--container); margin-inline: auto; padding-inline: var(--gutter); }\n    .section { padding-block: clamp(58px, 8vw, var(--gap-2xl)); }\n    .section + .section { border-top: 1px solid var(--border); }\n    .stack { display: flex; flex-direction: column; }\n    .stack > * + * { margin-top: var(--gap-md); }\n    .row { display: flex; align-items: center; gap: var(--gap-md); }\n    .row-between { display: flex; align-items: center; justify-content: space-between; gap: var(--gap-md); }\n    .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--gap-lg); }\n    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap-lg); }\n    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--gap-md); }\n    .grid-2-1 { display: grid; grid-template-columns: 2fr 1fr; gap: var(--gap-xl); align-items: start; }\n    .grid-1-2 { display: grid; grid-template-columns: 1fr 2fr; gap: var(--gap-xl); align-items: start; }\n    @media (max-width: 920px) {\n      .grid-2, .grid-3, .grid-4, .grid-2-1, .grid-1-2 { grid-template-columns: 1fr; }\n    }\n\n    .h1, h1 { font-family: var(--font-display); font-size: var(--fs-h1); line-height: 0.98; letter-spacing: 0; margin: 0; font-weight: 700; }\n    .h2, h2 { font-family: var(--font-display); font-size: var(--fs-h2); line-height: 1.05; letter-spacing: 0; margin: 0; font-weight: 700; }\n    .h3, h3 { font-family: var(--font-display); font-size: var(--fs-h3); font-weight: 700; line-height: 1.25; letter-spacing: 0; margin: 0; }\n    .lead { font-size: var(--fs-lead); line-height: 1.55; color: var(--muted); max-width: 60ch; margin: 0; }\n    .eyebrow {\n      font-family: var(--font-mono);\n      font-size: 12px;\n      letter-spacing: 0.08em;\n      text-transform: uppercase;\n      color: var(--muted);\n      margin: 0 0 var(--gap-md);\n    }\n    .meta { font-family: var(--font-mono); font-size: var(--fs-meta); color: var(--muted); letter-spacing: 0.03em; text-transform: uppercase; }\n    .num { font-family: var(--font-mono); font-variant-numeric: tabular-nums; }\n\n    .topnav {\n      position: sticky; top: 0; z-index: 10;\n      background: color-mix(in oklch, var(--bg) 90%, transparent);\n      backdrop-filter: blur(14px);\n      border-bottom: 1px solid var(--border);\n    }\n    .topnav-inner { display: flex; align-items: center; justify-content: space-between; padding-block: 14px; }\n    .topnav .logo { display: inline-flex; align-items: center; min-width: 156px; }\n    .topnav .logo img { height: 32px; width: auto; }\n    .topnav nav { display: flex; gap: var(--gap-lg); }\n    .topnav nav a { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; }\n    .topnav nav a:hover { color: var(--fg); }\n    .pagefoot { padding-block: var(--gap-xl); color: var(--muted); font-size: 13px; border-top: 1px solid var(--border); }\n    .pagefoot .row-between { flex-wrap: wrap; gap: var(--gap-md); }\n\n    .btn {\n      display: inline-flex; align-items: center; justify-content: center; gap: 8px;\n      min-height: 44px;\n      padding: 11px 20px;\n      border-radius: var(--radius);\n      border: 1px solid transparent;\n      font-size: 13px;\n      font-weight: 700;\n      letter-spacing: 0.08em;\n      text-transform: uppercase;\n      transition: transform 0.05s ease, background 0.15s ease, border-color 0.15s ease;\n    }\n    .btn:active { transform: translateY(1px); }\n    .btn-primary { background: var(--accent); color: var(--bg); border-color: var(--accent); }\n    .btn-primary:hover { background: color-mix(in oklch, var(--accent) 86%, white); }\n    .btn-secondary { background: transparent; color: var(--fg); border-color: var(--border); }\n    .btn-secondary:hover { border-color: var(--fg); }\n    .btn-ghost { background: transparent; color: var(--fg); border-color: transparent; padding-inline: 8px; }\n    .btn-ghost:hover { color: var(--accent); }\n    .btn-arrow::after { content: '>'; transition: transform 0.15s ease; }\n    .btn-arrow:hover::after { transform: translateX(2px); }\n\n    .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 28px; }\n    .card-flat { background: transparent; border: 0; padding: 0; }\n    .card-rule { background: transparent; border: 0; border-top: 1px solid var(--fg); padding: 24px 0 0; border-radius: 0; }\n\n    .feature .feature-mark {\n      width: 36px; height: 36px;\n      display: grid; place-items: center;\n      border: 1px solid var(--border);\n      border-radius: var(--radius);\n      color: var(--muted);\n      margin-bottom: var(--gap-md);\n    }\n    .feature .feature-mark svg { width: 18px; height: 18px; }\n    .feature h3 { margin-bottom: 6px; }\n    .feature p { margin: 0; color: var(--muted); font-size: 15px; }\n\n    .stat .stat-num {\n      font-family: var(--font-display);\n      font-size: clamp(48px, 7vw, 84px);\n      line-height: 0.95;\n      letter-spacing: 0;\n      color: var(--fg);\n      font-weight: 700;\n    }\n    .stat .stat-label { color: var(--muted); font-size: 14px; margin-top: 8px; max-width: 24ch; }\n    .stat .stat-unit { font-size: 0.42em; opacity: 0.75; margin-left: 2px; }\n\n    .quote {\n      font-family: var(--font-display);\n      font-size: clamp(25px, 2.8vw, 34px);\n      line-height: 1.28;\n      letter-spacing: 0;\n      max-width: 28ch;\n      text-transform: uppercase;\n      margin: 0;\n    }\n    .quote-author { color: var(--muted); font-size: 14px; margin-top: var(--gap-md); }\n    .quote-mark { font-family: var(--font-display); font-size: 130px; line-height: 0.7; color: var(--accent); opacity: 0.18; margin-bottom: -28px; }\n\n    .pill {\n      display: inline-flex; align-items: center; gap: 6px;\n      padding: 4px 10px;\n      background: var(--accent-soft);\n      color: var(--accent);\n      border-radius: 999px;\n      font-family: var(--font-mono);\n      font-size: 11px;\n      letter-spacing: 0.04em;\n      text-transform: uppercase;\n    }\n    .tag { display: inline-flex; align-items: center; padding: 4px 10px; background: transparent; color: var(--muted); border: 1px solid var(--border); border-radius: 999px; font-size: 12px; }\n    .field { display: flex; flex-direction: column; gap: 6px; }\n    .field label { font-size: 13px; color: var(--muted); }\n    .input, .textarea { width: 100%; padding: 11px 14px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--surface); color: var(--fg); font: inherit; font-size: 15px; }\n    .input:focus, .textarea:focus { outline: 2px solid var(--accent-soft); border-color: var(--accent); }\n    .textarea { min-height: 96px; resize: vertical; line-height: 1.55; }\n    .ds-table { width: 100%; border-collapse: collapse; font-size: 14px; }\n    .ds-table th, .ds-table td { padding: 14px 14px; text-align: left; border-bottom: 1px solid var(--border); vertical-align: top; }\n    .ds-table th { color: var(--muted); font-weight: 700; font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.04em; text-transform: uppercase; }\n    .ds-table tbody tr:hover { background: var(--fg-soft); }\n    .ds-table .num-col { font-family: var(--font-mono); font-variant-numeric: tabular-nums; text-align: right; white-space: nowrap; }\n\n    .ph-img {\n      position: relative;\n      overflow: hidden;\n      background: var(--surface);\n      border: 1px solid var(--border);\n      border-radius: var(--radius-lg);\n      aspect-ratio: 16 / 10;\n      display: grid;\n      place-items: center;\n      color: var(--muted);\n      font-family: var(--font-mono);\n      font-size: 12px;\n      letter-spacing: 0.04em;\n    }\n    .ph-img img { width: 100%; height: 100%; object-fit: cover; }\n    .ph-img::after { content: ''; position: absolute; inset: 0; background: color-mix(in oklch, var(--bg) 18%, transparent); pointer-events: none; }\n    .ph-img.square { aspect-ratio: 1 / 1; }\n    .ph-img.portrait { aspect-ratio: 3 / 4; }\n    .ph-img.wide { aspect-ratio: 16 / 9; }\n    .rule { border: 0; border-top: 1px solid var(--border); margin: 0; }\n    .rule-strong { border: 0; border-top: 1px solid var(--fg); margin: 0; }\n\n    .hero { padding-block: clamp(84px, 12vw, 168px); }\n    .hero-center { text-align: center; max-width: 32ch; margin-inline: auto; }\n    .hero h1 { margin-bottom: var(--gap-md); }\n    .hero .lead { margin-bottom: var(--gap-lg); }\n    .hero-cta { display: inline-flex; gap: var(--gap-sm); flex-wrap: wrap; }\n    .hero-center .hero-cta { justify-content: center; }\n    .hero-split { display: grid; grid-template-columns: 1fr 1fr; gap: var(--gap-2xl); align-items: center; }\n    @media (max-width: 920px) { .hero-split { grid-template-columns: 1fr; } }\n\n    .log-row { display: grid; grid-template-columns: 120px 1fr 120px; gap: var(--gap-lg); padding: 22px 0; border-top: 1px solid var(--border); align-items: baseline; }\n    .log-row .meta { color: var(--muted); }\n    .log-row h3 { font-size: 19px; }\n    .log-row .pull { text-align: right; }\n\n    .hero-photo {\n      min-height: calc(100svh - 72px);\n      display: grid;\n      align-items: end;\n      position: relative;\n      overflow: hidden;\n      border-bottom: 1px solid var(--border);\n    }\n    .hero-photo::before {\n      content: '';\n      position: absolute;\n      inset: 0;\n      background-image:\n        linear-gradient(to bottom, color-mix(in oklch, var(--bg) 18%, transparent), var(--bg)),\n        url('assets/dining-room.webp');\n      background-size: cover;\n      background-position: center;\n      transform: scale(1.02);\n    }\n    .hero-photo .container { position: relative; padding-block: clamp(96px, 14vw, 168px) 72px; }\n    .hero-lockup { max-width: 790px; }\n    .hero-lockup h1 { font-size: clamp(52px, 9vw, 124px); }\n    .hero-bar {\n      margin-top: var(--gap-xl);\n      display: grid;\n      grid-template-columns: 1.35fr 1fr 1fr;\n      border-top: 1px solid var(--border);\n      border-bottom: 1px solid var(--border);\n      background: color-mix(in oklch, var(--bg) 74%, transparent);\n      backdrop-filter: blur(10px);\n    }\n    .hero-bar > div { padding: 18px 20px; border-right: 1px solid var(--border); }\n    .hero-bar > div:last-child { border-right: 0; }\n    .hero-bar strong { display: block; font-size: 13px; text-transform: uppercase; letter-spacing: 0.08em; }\n    .hero-bar span { color: var(--muted); font-size: 14px; }\n\n    .page-strip { display: grid; grid-template-columns: 220px 1fr; gap: var(--gap-xl); align-items: start; }\n    .page-label { position: sticky; top: 96px; }\n    .menu-list { display: grid; grid-template-columns: 1fr 1fr; gap: var(--gap-lg); }\n    .menu-card { border-top: 1px solid var(--border); padding-top: 24px; }\n    .menu-card .price { color: var(--fg); }\n    .gallery-band { display: grid; grid-template-columns: 1fr 1.2fr 0.8fr; gap: var(--gap-md); align-items: end; }\n    .booking-panel { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border: 1px solid var(--border); background: var(--surface); }\n    .booking-panel > div { padding: clamp(24px, 4vw, 44px); }\n    .booking-panel > div + div { border-left: 1px solid var(--border); }\n    .footer-links { display: flex; flex-wrap: wrap; gap: var(--gap-md); }\n    .mobile-only { display: none; }\n\n    @media (max-width: 920px) {\n      :root { --gutter: 22px; }\n      .topnav nav { display: none; }\n      .topnav .btn { display: none; }\n      .mobile-only { display: inline-flex; }\n      .hero-photo { min-height: auto; }\n      .hero-lockup h1 { font-size: clamp(42px, 14vw, 76px); }\n      .hero-bar, .page-strip, .menu-list, .gallery-band, .booking-panel { grid-template-columns: 1fr; }\n      .hero-bar > div, .booking-panel > div + div { border-right: 0; border-left: 0; border-top: 1px solid var(--border); }\n      .hero-bar > div:first-child { border-top: 0; }\n      .page-label { position: static; }\n      .log-row { grid-template-columns: 1fr; gap: 8px; }\n      .log-row .pull { text-align: left; }\n    }\n  </style>\n</head>\n<body>\n  <header class=\"topnav\" data-od-id=\"topnav\">\n    <div class=\"container topnav-inner\">\n      <a class=\"logo\" href=\"#home\" aria-label=\"Rich and Rare home\"><img src=\"assets/rich-rare-logo.webp\" alt=\"Rich &amp; Rare\"></a>\n      <nav aria-label=\"Concept navigation\">\n        <a href=\"#menus\">Menus</a>\n        <a href=\"#experience\">Experience</a>\n        <a href=\"#functions\">Functions</a>\n        <a href=\"#contact\">Contact</a>\n      </nav>\n      <a class=\"btn btn-primary\" href=\"#contact\">Book a table</a>\n    </div>\n  </header>\n\n  <main id=\"content\">\n    <section class=\"hero-photo\" id=\"home\" data-od-id=\"home-hero\">\n      <div class=\"container\">\n        <div class=\"hero-lockup\">\n          <p class=\"eyebrow\">West Village · West End · Brisbane</p>\n          <h1>Steak, seafood and a darker kind of occasion.</h1>\n          <p class=\"lead\" style=\"margin-top: 22px;\">A refined concept for Rich &amp; Rare that keeps the current brand, sharpens the booking path, and lets the dining room, wine, steak and seafood lead the story.</p>\n          <div class=\"hero-cta\" style=\"margin-top: 30px;\">\n            <a class=\"btn btn-primary\" href=\"#contact\">Reserve now</a>\n            <a class=\"btn btn-secondary\" href=\"#menus\">View menus</a>\n          </div>\n        </div>\n        <div class=\"hero-bar\" aria-label=\"Key restaurant details\">\n          <div><strong>Restaurant</strong><span>Gourmet steak, fresh seafood, wine and cocktails.</span></div>\n          <div><strong>Address</strong><span>West Village, 97 Boundary Street, West End.</span></div>\n          <div><strong>Contact</strong><span class=\"num\">(07) 3638 8888</span></div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" data-od-id=\"concept-pages\">\n      <div class=\"container page-strip\">\n        <div class=\"page-label\">\n          <p class=\"eyebrow\">Concept map</p>\n          <h2>Four key pages, one clear booking path.</h2>\n        </div>\n        <div class=\"grid-4\">\n          <div class=\"feature card-flat\">\n            <div class=\"feature-mark\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\"><path d=\"M4 18h16M6 18V8m12 10V8M8 8h8l-4-4-4 4Z\"/></svg></div>\n            <h3>Home</h3>\n            <p>Photographic first impression, concise positioning, direct routes to booking and menus.</p>\n          </div>\n          <div class=\"feature card-flat\">\n            <div class=\"feature-mark\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\"><path d=\"M7 3v18M17 3v18M4 8h16M4 16h16\"/></svg></div>\n            <h3>Menus</h3>\n            <p>Lunch &amp; Dinner, Lunch Specials, Banquets, Power Banquet and The R&amp;R Experience.</p>\n          </div>\n          <div class=\"feature card-flat\">\n            <div class=\"feature-mark\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\"><circle cx=\"12\" cy=\"12\" r=\"7\"/><path d=\"M12 7v5l3 3\"/></svg></div>\n            <h3>Experience</h3>\n            <p>Dining-room atmosphere, private dining, functions and gift voucher intent grouped together.</p>\n          </div>\n          <div class=\"feature card-flat\">\n            <div class=\"feature-mark\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\"><path d=\"M12 21s7-5.2 7-11a7 7 0 0 0-14 0c0 5.8 7 11 7 11Z\"/><circle cx=\"12\" cy=\"10\" r=\"2\"/></svg></div>\n            <h3>Contact</h3>\n            <p>Phone, location, booking form intent, parking and careers links kept visible without clutter.</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"menus\" data-od-id=\"menus\">\n      <div class=\"container page-strip\">\n        <div class=\"page-label\">\n          <p class=\"eyebrow\">Menus</p>\n          <h2>Make the menu feel premium before the PDF opens.</h2>\n          <p class=\"lead\" style=\"margin-top: 18px;\">The current menu depth becomes a browsable decision layer: lunch, dinner, banquets and signature experiences are visible at once.</p>\n        </div>\n        <div class=\"stack\">\n          <div class=\"grid-2\">\n            <div class=\"ph-img wide\"><img src=\"assets/seafood-plate.webp\" alt=\"Rich &amp; Rare seafood plate with wine\"></div>\n            <div class=\"card\">\n              <p class=\"meta\">Featured banquet</p>\n              <h3 style=\"margin-top: 10px;\">Wave &amp; Wagyu</h3>\n              <p class=\"lead\" style=\"font-size: 16px; margin-top: 14px;\">Artisan sourdough, Jamon Iberico, Westholme Wagyu tartare, king prawns, market fish, Tajima Wagyu striploin and dessert.</p>\n              <p class=\"meta price\" style=\"margin-top: 22px;\"><span class=\"num\">132pp</span></p>\n            </div>\n          </div>\n          <div class=\"menu-list\">\n            <article class=\"menu-card\">\n              <p class=\"meta\">Lunch &amp; Dinner</p>\n              <h3>Steak and seafood core</h3>\n              <p style=\"color: var(--muted);\">Seafood platter, Westholme Wagyu tartare, Wagyu steak tartare, market fish and premium beef cuts.</p>\n            </article>\n            <article class=\"menu-card\">\n              <p class=\"meta\">Lunch Specials</p>\n              <h3>Quick-service intent</h3>\n              <p style=\"color: var(--muted);\">A separate pathway for lunch guests who need the current lunch specials quickly.</p>\n            </article>\n            <article class=\"menu-card\">\n              <p class=\"meta\">Power Banquet</p>\n              <h3><span class=\"num\">$57</span> early dining</h3>\n              <p style=\"color: var(--muted);\">Lunch and early dinner built around a nine-course feed, kept prominent for conversion.</p>\n            </article>\n            <article class=\"menu-card\">\n              <p class=\"meta\">R&amp;R Experience</p>\n              <h3><span class=\"num\">220pp</span> signature menu</h3>\n              <p style=\"color: var(--muted);\">Wagyu tataki, king prawns, Westholme tartare, multiple premium steaks, sides and cheesecake.</p>\n            </article>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"experience\" data-od-id=\"experience\">\n      <div class=\"container gallery-band\">\n        <div>\n          <p class=\"eyebrow\">The R&amp;R Experience</p>\n          <h2>Dining room first, menu second, booking always close.</h2>\n        </div>\n        <div class=\"ph-img wide\"><img src=\"assets/dining-room-service.webp\" alt=\"Rich &amp; Rare dining room service\"></div>\n        <div class=\"card-rule\">\n          <blockquote class=\"quote\">A formal dining room that still feels unmistakably West End.</blockquote>\n          <p class=\"quote-author\">Concept copy, based on the current gallery and official location.</p>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"functions\" data-od-id=\"functions\">\n      <div class=\"container grid-1-2\">\n        <div>\n          <p class=\"eyebrow\">Functions &amp; occasions</p>\n          <h2>Private dining, vouchers and group intent stay in the main path.</h2>\n        </div>\n        <div>\n          <div class=\"log-row\">\n            <span class=\"meta\">Private</span>\n            <div>\n              <h3>The Private Dining Room</h3>\n              <p style=\"margin: 4px 0 0; color: var(--muted); font-size: 14px;\">A dedicated route for hosted dinners, celebrations and business occasions.</p>\n            </div>\n            <span class=\"pull meta\">Functions</span>\n          </div>\n          <div class=\"log-row\">\n            <span class=\"meta\">Voucher</span>\n            <div>\n              <h3>R&amp;R Gift Voucher</h3>\n              <p style=\"margin: 4px 0 0; color: var(--muted); font-size: 14px;\">Preserves the existing voucher intent without making it compete with bookings.</p>\n            </div>\n            <span class=\"pull meta\">Gifting</span>\n          </div>\n          <div class=\"log-row\">\n            <span class=\"meta\">Gallery</span>\n            <div>\n              <h3>Dining room, bar and outdoor seating</h3>\n              <p style=\"margin: 4px 0 0; color: var(--muted); font-size: 14px;\">The official photography becomes the proof layer for atmosphere and occasion fit.</p>\n            </div>\n            <span class=\"pull meta\">Photos</span>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" id=\"contact\" data-od-id=\"contact\">\n      <div class=\"container\">\n        <div class=\"booking-panel\">\n          <div>\n            <p class=\"eyebrow\">Bookings &amp; contact</p>\n            <h2>Reserve at Rich &amp; Rare.</h2>\n            <p class=\"lead\" style=\"margin-top: 18px;\">Contact the team for bookings, events and inquiries at West Village, West End.</p>\n            <div class=\"hero-cta\" style=\"margin-top: 30px;\">\n              <a class=\"btn btn-primary\" href=\"tel:+61736388888\">Call (07) 3638 8888</a>\n              <a class=\"btn btn-secondary\" href=\"#menus\">Check menus</a>\n            </div>\n          </div>\n          <div class=\"stack\">\n            <div class=\"ph-img wide\"><img src=\"assets/location.webp\" alt=\"Rich &amp; Rare West End location\"></div>\n            <table class=\"ds-table\" aria-label=\"Rich and Rare contact facts\">\n              <tbody>\n                <tr><td>Phone</td><td class=\"num-col\">(07) 3638 8888</td></tr>\n                <tr><td>Precinct</td><td class=\"num-col\">West Village</td></tr>\n                <tr><td>Address</td><td class=\"num-col\">97 Boundary Street, West End, 4101</td></tr>\n                <tr><td>Social</td><td class=\"num-col\">@richandrare_brisbane</td></tr>\n              </tbody>\n            </table>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" data-od-id=\"cta-strip\" style=\"text-align: center;\">\n      <div class=\"container\" style=\"max-width: 640px;\">\n        <h2>Keep the brand. Make the path sharper.</h2>\n        <p class=\"lead\" style=\"margin: 16px auto 32px;\">This concept preserves the existing Rich &amp; Rare sitemap intent while giving guests a cleaner route from appetite to booking.</p>\n        <a class=\"btn btn-primary\" href=\"#home\">Back to top</a>\n      </div>\n    </section>\n  </main>\n\n  <footer class=\"pagefoot\" data-od-id=\"footer\">\n    <div class=\"container row-between\">\n      <span>Rich &amp; Rare Restaurant Brisbane · Concept only</span>\n      <span class=\"footer-links meta\">\n        <a href=\"#menus\">Menus</a>\n        <a href=\"#functions\">Functions</a>\n        <a href=\"#contact\">Contact</a>\n        <a href=\"#contact\">Bookings</a>\n      </span>\n    </div>\n  </footer>\n</body>\n</html>\n","isError":false}

