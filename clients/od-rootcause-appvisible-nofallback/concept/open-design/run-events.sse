                 <use xlink:href=\"#instagram-unauth-icon\" width=\"110\" height=\"110\"></use>\n1769:                      <a class=\"icon icon--lg icon--fill  header-icon header-icon-border-shape-none header-icon-border-style-outline\"  href=\"https://www.facebook.com/darkshepherd.brisbane\" target=\"_blank\" aria-label=\"Facebook\">\n1771:                          <use xlink:href=\"#facebook-unauth-icon\" width=\"110\" height=\"110\"></use>\n1784:                href=\"https://www.sevenrooms.com/explore/darkshepherd/reservations/create/search?venues=darkshepherd,pompetteau,yamasgreekdrink,stilts,richandrarerestaurant,fatcowrestaurant,longwangchopstickhouse,opabarmezze,massimorestaurantandbar,foshbarrestaurant\"\n1787:                BOOKINGS\n2493:              <div class=\"menu-item-title\">Woodfired Pillow Bread</div>\n2517:              <div class=\"menu-item-title\">Woodfired Pillow Bread</div>\n2541:              <div class=\"menu-item-title\">Woodfired Pillow Bread</div>\n2565:              <div class=\"menu-item-title\">Woodfired Pillow Bread</div>\n2665:              <div class=\"menu-item-title\">Woodfired Scallop</div>\n2780:              <div class=\"menu-item-title\">Woodfired Eggplant</div>\n2915:              <div class=\"menu-item-title\">Woodfired Sprouts</div>\n3122:              <div class=\"menu-item-title\">Woodfired Octopus</div>\n3233:              <div class=\"menu-item-title\">Woodfired Cabbage</div>\n3462:              <div class=\"menu-item-description\">Woodfired, lemony sauce. Includes 1 complimentary side of your choice</div>\n3615:          <div class=\"menu-section-description\">White Pyrenees Lamb, known as the \"Wagyu of lamb,\" is a premium, tender meat sourced from Victoria’s Pyrenees Ranges. <br> Raised on lush pasture and crushed grains, it is finely marbled and MSA graded for top quality. <br><br> Slow-cooked in a woodfired oven, served with woodfired peppers and roasted potatoes.<br><br></div>\n3860:              <div class=\"menu-item-title\">Woodfired Shepherd Cheesecake</div>\n4904:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p style=\"text-align:center;white-space:pre-wrap;\" class=\"\"><strong>WHEN THE EMBERS GLOW</strong></p><p style=\"text-align:center;white-space:pre-wrap;\" class=\"\"><strong>All Day Dining </strong></p><p style=\"text-align:center;white-space:pre-wrap;\" class=\"\"><strong>7 Days • 11am-Late<br></strong>Open every day except Christmas Day</p></div>\n4988:  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p style=\"text-align:center;white-space:pre-wrap;\" class=\"\"><strong>FIND US</strong></p><p style=\"text-align:center;white-space:pre-wrap;\" class=\"\"><strong>The Terrace, Level 4</strong> <br>The Star Brisbane<br><span class=\"sqsrte-text-color--white\">Ph. </span><a href=\"tel:+61721116869\" target=\"_blank\"><span class=\"sqsrte-text-color--white\">(07) 2111 6869</span></a></p><p style=\"text-align:center;white-space:pre-wrap;\" class=\"\"><a href=\"/careers\"><strong>Careers</strong></a><strong><br></strong><a href=\"https://www.tassisgroup.com.au/business-opportunities\" target=\"_blank\"><strong>Business Opportunities</strong></a></p></div>\n5171:            href=\"https://www.instagram.com/darkshepherd_bne/\"\n5173:            class=\"sqs-svg-icon--wrapper instagram-unauth\"\n5178:                <use class=\"sqs-use--icon\" xlink:href=\"/universal/svg/social-accounts.svg#instagram-unauth-icon\"></use>\n5179:                <use class=\"sqs-use--mask\" xlink:href=\"/universal/svg/social-accounts.svg#instagram-unauth-mask\"></use>\n5187:            href=\"https://www.facebook.com/darkshepherd.brisbane\"\n5189:            class=\"sqs-svg-icon--wrapper facebook-unauth\"\n5194:                <use class=\"sqs-use--icon\" xlink:href=\"/universal/svg/social-accounts.svg#facebook-unauth-icon\"></use>\n5195:                <use class=\"sqs-use--mask\" xlink:href=\"/universal/svg/social-accounts.svg#facebook-unauth-mask\"></u